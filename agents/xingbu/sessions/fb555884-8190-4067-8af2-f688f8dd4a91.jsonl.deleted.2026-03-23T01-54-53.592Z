u.Auth/Security/SecurityValidator.cs\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Auth/Controllers/AuthController.cs\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Auth/Controllers/UserController.cs\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Auth/Controllers/PermissionController.cs\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Auth/Controllers/RoleController.cs","cwd":"/root/clawd-xingbu"},"isError":false,"timestamp":1774227323921}}
