{"type":"message","id":"2ea2428e","parentId":"7e3085e3","timestamp":"2026-03-24T16:22:45.016Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，认证路由已创建。现在需要创建用户管理、角色管理和权限管理的路由。继续创建剩余的API接口。","thinkingSignature":"reasoning_content"},{"type":"text","text":"### 📝 创建用户、角色、权限管理API"},{"type":"toolCall","id":"call_3270184af25944e6b9552ae5","name":"write","arguments":{"path":"/root/.openclaw/workspace-shangshu/backend/routes/users.js","content":"const express = require('express');\nconst db = require('../database');\nconst { authenticate, checkPermission } = require('../middleware/auth');\n\nconst router = express.Router();\n\n// 获取所有用户（需要权限）\nrouter.get('/', authenticate, checkPermission('users', 'read'), (req, res) => {\n  const query = `\n    SELECT \n      u.id, u.username, u.email, u.created_at, u.updated_at,\n      GROUP_CONCAT(DISTINCT r.name) as roles\n    FROM users u\n    LEFT JOIN user_roles ur ON u.id = ur.user_id\n    LEFT JOIN roles r ON ur.role_id = r.id\n    GROUP BY u.id\n    ORDER BY u.created_at DESC\n  `;\n\n  db.all(query, [], (err, users) => {\n    if (err) {\n      return res.status(500).json({ error: '查询用户列表失败' });\n    }\n\n    res.json({\n      users: users.map(u => ({\n        ...u,\n        roles: u.roles ? u.roles.split(',') : []\n      }))\n    });\n  });\n});\n\n// 获取单个用户\nrouter.get('/:id', authenticate, checkPermission('users', 'read'), (req, res) => {\n  const query = `\n    SELECT \n      u.id, u.username, u.email, u.created_at, u.updated_at,\n      GROUP_CONCAT(DISTINCT r.name) as roles,\n      GROUP_CONCAT(DISTINCT p.name) as permissions\n    FROM users u\n    LEFT JOIN user_roles ur ON u.id = ur.user_id\n    LEFT JOIN roles r ON ur.role_id = r.id\n    LEFT JOIN role_permissions rp ON r.id = rp.role_id\n    LEFT JOIN permissions p ON rp.permission_id = p.id\n    WHERE u.id = ?\n    GROUP BY u.id\n  `;\n\n  db.get(query, [req.params.id], (err, user) => {\n    if (err) {\n      return res.status(500).json({ error: '查询用户失败' });\n    }\n\n    if (!user) {\n      return res.status(404).json({ error: '用户不存在' });\n    }\n\n    res.json({\n      user: {\n        ...user,\n        roles: user.roles ? user.roles.split(',') : [],\n        permissions: user.permissions ? user.permissions.split(',') : []\n      }\n    });\n  });\n});\n\n// 更新用户（需要权限）\nrouter.put('/:id', authenticate, checkPermission('users', 'write'), (req, res) => {\n  const { username, email } = req.body;\n\n  if (!username && !email) {\n    return res.status(400).json({ error: '至少需要提供一个更新字段' });\n  }\n\n  const updates = [];\n  const values = [];\n\n  if (username) {\n    updates.push('username = ?');\n    values.push(username);\n  }\n\n  if (email) {\n    updates.push('email = ?');\n    values.push(email);\n  }\n\n  updates.push('updated_at = CURRENT_TIMESTAMP');\n  values.push(req.params.id);\n\n  const query = `UPDATE users SET ${updates.join(', ')} WHERE id = ?`;\n\n  db.run(query, values, function(err) {\n    if (err) {\n      if (err.message.includes('UNIQUE constraint failed')) {\n        return res.status(409).json({ error: '用户名或邮箱已被使用' });\n      }\n      return res.status(500).json({ error: '更新用户失败' });\n    }\n\n    if (this.changes === 0) {\n      return res.status(404).json({ error: '用户不存在' });\n    }\n\n    res.json({ message: '用户更新成功', changes: this.changes });\n  });\n});\n\n// 删除用户（需要权限）\nrouter.delete('/:id', authenticate, checkPermission('users', 'delete'), (req, res) => {\n  db.run('DELETE FROM users WHERE id = ?', [req.params.id], function(err) {\n    if (err) {\n      return res.status(500).json({ error: '删除用户失败' });\n    }\n\n    if (this.changes === 0) {\n      return res.status(404).json({ error: '用户不存在' });\n    }\n\n    res.json({ message: '用户删除成功' });\n  });\n});\n\n// 为用户分配角色\nrouter.post('/:id/roles', authenticate, checkPermission('users', 'write'), (req, res) => {\n  const { roleId } = req.body;\n\n  if (!roleId) {\n    return res.status(400).json({ error: '角色ID为必填项' });\n  }\n\n  db.run(\n    'INSERT OR IGNORE INTO user_roles (user_id, role_id) VALUES (?, ?)',\n    [req.params.id, roleId],\n    function(err) {\n      if (err) {\n        return res.status(500).json({ error: '分配角色失败' });\n      }\n\n      res.json({ message: '角色分配成功', changes: this.changes });\n    }\n  );\n});\n\n// 移除用户角色\nrouter.delete('/:id/roles"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1774369337533,"errorMessage":"Request was aborted"}}
