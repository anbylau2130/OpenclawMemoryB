nents/FormDesigner/ComponentToolbox.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/FormDesigner/PropertyPanel.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/FormDesigner/FormCanvas.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/FormDesigner/FormPreview.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/FormDesigner/ComponentPreview.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/WorkflowDesigner.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/PendingTasks.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/TaskHandler.razor\n/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/wwwroot/js/bpmn-designer.js","cwd":"/root/clawd-libu"},"isError":false,"timestamp":1774227311096}}
{"type":"message","id":"4663b758","parentId":"57da6006","timestamp":"2026-03-23T00:55:11.106Z","message":{"role":"toolResult","toolCallId":"call_20ea5d4443e44a3f99b5c2f7","toolName":"exec","content":[{"type":"text","text":"total 0\ndrwxr-xr-x 1 root root   22 Mar 22 23:00 .\ndrwxr-xr-x 1 root root 2336 Mar 23 08:21 ..\ndrwxr-xr-x 1 root root   92 Mar 23 08:03 Tianyou.Web"}],"details":{"status":"completed","exitCode":0,"durationMs":19,"aggregated":"total 0\ndrwxr-xr-x 1 root root   22 Mar 22 23:00 .\ndrwxr-xr-x 1 root root 2336 Mar 23 08:21 ..\ndrwxr-xr-x 1 root root   92 Mar 23 08:03 Tianyou.Web","cwd":"/root/clawd-libu"},"isError":false,"timestamp":1774227311102}}
{"type":"message","id":"2a95935d","parentId":"4663b758","timestamp":"2026-03-23T00:55:11.148Z","message":{"role":"toolResult","toolCallId":"call_2a1efa78c62c413eb7854493","toolName":"read","content":[{"type":"text","text":"# 云天佑 (Tianyou) - 金蝶云苍穹标准重构计划\n\n> **重构目标**: 完全符合金蝶云苍穹开发规范\n> **参考文档**: 云苍穹知识库 76篇\n> **启动时间**: 2026-03-23 08:20\n> **开发模式**: 完全参照云苍穹标准\n\n---\n\n## 📋 金蝶云苍穹核心功能清单\n\n### 1. 核心开发能力\n- ✅ **单据建模** - 单据模型设计\n- ✅ **基础资料建模** - 基础资料设计\n- ✅ **单据转换** - 单据转换配置\n- ✅ **工作流开发** - 审批流程\n- ✅ **报表开发** - 报表设计器\n- ✅ **数据集成** - API集成\n\n### 2. 插件体系（6种插件）\n1. **表单插件** (FormPlugin)\n   - OnLoad - 表单加载\n   - OnBillModelInitialize - 模型初始化\n   - BeforeDoOperation - 操作前\n   - AfterDoOperation - 操作后\n   - BeforeSave - 保存前\n   - AfterSave - 保存后\n   - DataChanged - 数据变更\n   - BarItemClick - 工具栏点击\n   - EntryBarItemClick - 分录工具栏点击\n\n2. **列表插件** (ListPlugin)\n   - OnInitialize - 初始化\n   - BeforeDoOperation - 操作前\n   - AfterDoOperation - 操作后\n   - CreateListColumns - 创建列\n   - PrepareFilterParameter - 准备过滤\n   - FormatRowCondition - 行格式化\n\n3. **操作插件** (OperationPlugin)\n   - OnPrepareOperationService - 准备服务\n   - OnPreparePropertys - 准备属性\n   - BeginOperationTransaction - 开始事务\n   - EndOperationTransaction - 结束事务\n   - OnDoOperation - 执行操作\n\n4. **工作流插件** (WorkflowPlugin)\n   - OnWorkflowStatusChanged - 状态变更\n   - OnApproveResult - 审批结果\n   - OnAddApprover - 添加审批人\n   - OnGetRejectOption - 获取驳回选项\n\n5. **转换插件** (ConvertPlugin)\n   - BeforeConvert - 转换前\n   - AfterConvert - 转换后\n   - OnFieldConvert - 字段转换\n\n6. **报表插件** (ReportPlugin)\n   - BeforeQuery - 查询前\n   - AfterQuery - 查询后\n   - OnFormatCellValue - 格式化单元格\n\n### 3. 低代码引擎\n- ✅ 可视化表单设计器\n- ✅ 组件库（30+组件）\n- ✅ 属性配置面板\n- ✅ 代码自动生成\n- ✅ KingScript脚本\n\n### 4. 数据服务\n- ✅ 元数据管理\n- ✅ 动态查询API\n- ✅ 批量操作API\n- ✅ 数据权限\n- ✅ 审计日志\n\n### 5. 前端开发\n- ✅ React/Vue组件\n- ✅ 移动端适配\n- ✅ 离线功能\n- ✅ 响应式布局\n\n### 6. 移动端\n- ✅ 移动表单\n- ✅ 移动列表\n- ✅ 离线存储\n- ✅ 推送通知\n\n### 7. AI能力\n- ✅ 智能预测\n- ✅ 智能推荐\n- ✅ 智能分析\n- ✅ 自然语言\n\n### 8. 系统管理\n- ✅ 用户管理\n- ✅ 角色权限\n- ✅ 组织架构\n- ✅ 系统配置\n\n---\n\n## 🏗️ 重构架构\n\n### 1. 插件系统（完全符合云苍穹）\n\n```\nsrc/Tianyou.Plugin.Abstractions/\n├── IPlugin.cs                    # 插件基类\n├── PluginMetadataAttribute.cs    # 插件元数据\n├── Events/\n│   ├── FormEvents.cs            # 表单事件\n│   ├── ListEvents.cs            # 列表事件\n│   ├── OperationEvents.cs       # 操作事件\n│   ├── WorkflowEvents.cs        # 工作流事件\n│   ├── ConvertEvents.cs         # 转换事件\n│   └── ReportEvents.cs          # 报表事件\n├── Interfaces/\n│   ├── IFormPlugin.cs           # 表单插件接口\n│   ├── IListPlugin.cs           # 列表插件接口\n│   ├── IOperationPlugin.cs      # 操作插件接口\n│   ├── IWorkflowPlugin.cs       # 工作流插件接口\n│   ├── IConvertPlugin.cs        # 转换插件接口\n│   └── IReportPlugin.cs         # 报表插件接口\n└── Models/\n    ├── PluginContext.cs         # 插件上下文\n    ├── OperationResult.cs       # 操作结果\n    └── BusinessService.cs       # 业务服务\n```\n\n### 2. 低代码引擎\n\n```\nsrc/Tianyou.LowCode.Engine/\n├── Designer/\n│   ├── FormDesigner.cs          # 表单设计器\n│   ├── ComponentPalette.cs      # 组件面板\n│   └── PropertyPanel.cs         # 属性面板\n├── Components/\n│   ├── BaseComponent.cs         # 组件基类\n│   ├── InputComponent.cs        # 输入组件\n│   ├── DateComponent.cs         # 日期组件\n│   ├── SelectComponent.cs       # 下拉组件\n│   ├── TableComponent.cs        # 表格组件\n│   └── ... (30+组件)\n├── Generator/\n│   ├── CodeGenerator.cs         # 代码生成器\n│   ├── ModelGenerator.cs        # 模型生成\n│   └── ApiGenerator.cs          # API生成\n└── Script/\n    ├── KingScriptEngine.cs      # 脚本引擎\n    └── ScriptExecutor.cs        # 脚本执行器\n```\n\n### 3. 元数据服务\n\n```\nsrc/Tianyou.Metadata/\n├── Models/\n│   ├── FormMetadata.cs          # 表单元数据\n│   ├── FieldMetadata.cs         # 字段元数据\n│   ├── EntityMetadata.cs        # 实体元数据\n│   └── OperationMetadata.cs     # 操作元数据\n├── Services/\n│   ├── IMetadataService.cs      # 元数据服务接口\n│   ├── MetadataService.cs       # 元数据服务实现\n│   └── MetadataCache.cs         # 元数据缓存\n└── Repositories/\n    ├── IMetadataRepository.cs   # 元数据仓储\n    └── MetadataRepository.cs    # 仓储实现\n```\n\n### 4. 通用数据服务（参考云苍穹API）\n\n```\nsrc/Tianyou.Data.Services/\n├── GenericDataService.cs        # 通用数据服务\n├── QueryBuilder.cs              # 查询构建器\n├── FilterParser.cs              # 过滤解析器\n└── DataServiceExtensions.cs     # 服务扩展\n```\n\n---\n\n## 📊 开发计划\n\n### Week 1 (Day 1-7): 核心引擎\n- ✅ Day 1: 插件系统（6种插件）\n- Day 2: 元数据服务\n- Day 3: 低代码引擎核心\n- Day 4: 组件库（30+组件）\n- Day 5: 代码生成器\n- Day 6: KingScript引擎\n- Day 7: 集成测试\n\n### Week 2 (Day 8-14): 业务模块\n- Day 8-9: 单据建模\n- Day 10-11: 基础资料建模\n- Day 12: 单据转换\n- Day 13: 工作流引擎\n- Day 14: 报表引擎\n\n### Week 3 (Day 15-21): 高级功能\n- Day 15-16: 移动端适配\n- Day 17-18: AI功能\n- Day 19: 数据集成\n- Day 20: DevOps\n- Day 21: 系统管理\n\n---\n\n## 🎯 开发规范\n\n### 1. 命名规范（遵循云苍穹）\n- 类名: PascalCase\n- 方法名: PascalCase\n- 参数名: camelCase\n- 常量: UPPER_CASE\n- 插件ID: kdev_{module}_{function}\n\n### 2. 代码规范\n- 所有函数不超过50行\n- 完整的XML注释\n- 异步操作使用async/await\n- 依赖注入\n\n### 3. API规范（参考云苍穹）\n```\nGET    /api/metadata/{type}              # 获取元数据\nPOST   /api/metadata/{type}              # 创建元数据\nGET    /api/data/{entity}                # 查询数据\nPOST   /api/data/{entity}                # 新增数据\nPUT    /api/data/{entity}/{id}           # 更新数据\nDELETE /api/data/{entity}/{id}           # 删除数据\nPOST   /api/data/{entity}/query          # 高级查询\nPOST   /api/data/{entity}/batch          # 批量操作\nPOST   /api/operation/{name}             # 执行操作\nPOST   /api/workflow/start               # 启动流程\nPOST   /api/workflow/approve             # 审批操作\n```\n\n---\n\n## 🚀 立即开始\n\n我将按照这个计划，完全参照金蝶云苍穹的开发规范进行重构。\n\n**开始执行！**\n"}],"isError":false,"timestamp":1774227311143}}
{"type":"message","id":"93cfa820","parentId":"2a95935d","timestamp":"2026-03-23T00:55:16.100Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，我看到了：\n\n1. 项目已经有一些基础结构\n2. 有一个重构计划\n3. Web项目已经有一些组件\n\n现在我需要快速检查现有的低代码引擎和前端组件，然后开始补充和完善。让我先查看现有的组件：","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_15b9215de55142aeb2107cb6","name":"read","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Pages/FormDesigner.razor"}},{"type":"toolCall","id":"call_b6ccc939c8c04d199d6dfd11","name":"read","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Models/FormComponents.cs"}},{"type":"toolCall","id":"call_9d16a6c71aad4a57ae62931e","name":"exec","arguments":{"command":"find /root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.LowCode.Engine -type f -name \"*.cs\""}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":2791,"output":166,"cacheRead":20032,"cacheWrite":0,"totalTokens":22989,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227311149}}
{"type":"message","id":"803eae9d","parentId":"93cfa820","timestamp":"2026-03-23T00:55:16.951Z","message":{"role":"toolResult","toolCallId":"call_15b9215de55142aeb2107cb6","toolName":"read","content":[{"type":"text","text":"@inject IJSRuntime JSRuntime\n@inject NavigationManager NavigationManager\n\n<MudContainer MaxWidth=\"MaxWidth.ExtraLarge\" Class=\"mt-4\">\n    <MudGrid>\n        <!-- 顶部工具栏 -->\n        <MudItem xs=\"12\">\n            <MudPaper Elevation=\"2\" Class=\"pa-2\">\n                <MudStack Row=\"true\" Spacing=\"2\" Justify=\"Justify.SpaceBetween\">\n                    <MudText Typo=\"Typo.h5\">表单设计器</MudText>\n                    <MudStack Row=\"true\" Spacing=\"2\">\n                        <MudButton Variant=\"Variant.Outlined\" OnClick=\"PreviewForm\">\n                            <MudIcon Icon=\"@Icons.Material.Filled.Preview\" Class=\"mr-2\" />\n                            预览\n                        </MudButton>\n                        <MudButton Variant=\"Variant.Outlined\" OnClick=\"SaveForm\">\n                            <MudIcon Icon=\"@Icons.Material.Filled.Save\" Class=\"mr-2\" />\n                            保存\n                        </MudButton>\n                        <MudButton Variant=\"Variant.Filled\" Color=\"Color.Primary\" OnClick=\"PublishForm\">\n                            <MudIcon Icon=\"@Icons.Material.Filled.Publish\" Class=\"mr-2\" />\n                            发布\n                        </MudButton>\n                    </MudStack>\n                </MudStack>\n            </MudPaper>\n        </MudItem>\n\n        <!-- 主内容区 -->\n        <MudItem xs=\"12\" Class=\"mt-2\">\n            <MudGrid Spacing=\"2\">\n                <!-- 左侧：组件工具箱 -->\n                <MudItem xs=\"2\">\n                    <ComponentToolbox OnComponentAdd=\"@AddComponent\" />\n                </MudItem>\n\n                <!-- 中间：表单设计区域 -->\n                <MudItem xs=\"7\">\n                    <FormCanvas Components=\"@formComponents\"\n                                SelectedComponent=\"@selectedComponent\"\n                                OnComponentSelect=\"@SelectComponent\"\n                                OnComponentMove=\"@MoveComponent\"\n                                OnComponentDelete=\"@DeleteComponent\" />\n                </MudItem>\n\n                <!-- 右侧：属性面板 -->\n                <MudItem xs=\"3\">\n                    <PropertyPanel Component=\"@selectedComponent\"\n                                   OnPropertyChange=\"@UpdateComponentProperty\" />\n                </MudItem>\n            </MudGrid>\n        </MudItem>\n    </MudGrid>\n</MudContainer>\n\n<!-- 预览对话框 -->\n<MudDialog @bind-IsOpen=\"@previewOpen\" MaxWidth=\"MaxWidth.Medium\" FullWidth=\"true\">\n    <TitleContent>\n        <MudText Typo=\"Typo.h6\">表单预览</MudText>\n    </TitleContent>\n    <DialogContent>\n        <FormPreview Components=\"@formComponents\" />\n    </DialogContent>\n    <DialogActions>\n        <MudButton OnClick=\"() => previewOpen = false\">关闭</MudButton>\n    </DialogActions>\n</MudDialog>\n\n@code {\n    private List<FormComponentBase> formComponents = new();\n    private FormComponentBase? selectedComponent;\n    private bool previewOpen = false;\n\n    /// <summary>\n    /// 添加组件\n    /// </summary>\n    private void AddComponent(string componentType)\n    {\n        var component = CreateComponent(componentType);\n        if (component != null)\n        {\n            formComponents.Add(component);\n            selectedComponent = component;\n        }\n    }\n\n    /// <summary>\n    /// 创建组件实例\n    /// </summary>\n    private FormComponentBase? CreateComponent(string type)\n    {\n        return type switch\n        {\n            \"TextField\" => new TextFieldComponent\n            {\n                Id = Guid.NewGuid(),\n                Code = $\"field_{formComponents.Count + 1}\",\n                Name = $\"文本字段{formComponents.Count + 1}\",\n                Placeholder = \"请输入\"\n            },\n            \"NumberField\" => new NumberFieldComponent\n            {\n                Id = Guid.NewGuid(),\n                Code = $\"field_{formComponents.Count + 1}\",\n                Name = $\"数字字段{formComponents.Count + 1}\"\n            },\n            \"DateField\" => new DateFieldComponent\n            {\n                Id = Guid.NewGuid(),\n                Code = $\"field_{formComponents.Count + 1}\",\n                Name = $\"日期字段{formComponents.Count + 1}\"\n            },\n            \"SelectField\" => new SelectFieldComponent\n            {\n                Id = Guid.NewGuid(),\n                Code = $\"field_{formComponents.Count + 1}\",\n                Name = $\"下拉字段{formComponents.Count + 1}\"\n            },\n            _ => null\n        };\n    }\n\n    /// <summary>\n    /// 选择组件\n    /// </summary>\n    private void SelectComponent(FormComponentBase component)\n    {\n        selectedComponent = component;\n        StateHasChanged();\n    }\n\n    /// <summary>\n    /// 移动组件\n    /// </summary>\n    private void MoveComponent(int oldIndex, int newIndex)\n    {\n        if (oldIndex >= 0 && oldIndex < formComponents.Count &&\n            newIndex >= 0 && newIndex < formComponents.Count)\n        {\n            var item = formComponents[oldIndex];\n            formComponents.RemoveAt(oldIndex);\n            formComponents.Insert(newIndex, item);\n        }\n    }\n\n    /// <summary>\n    /// 删除组件\n    /// </summary>\n    private void DeleteComponent(FormComponentBase component)\n    {\n        formComponents.Remove(component);\n        if (selectedComponent == component)\n        {\n            selectedComponent = null;\n        }\n        StateHasChanged();\n    }\n\n    /// <summary>\n    /// 更新组件属性\n    /// </summary>\n    private void UpdateComponentProperty(string propertyName, object? value)\n    {\n        if (selectedComponent == null) return;\n\n        var property = selectedComponent.GetType().GetProperty(propertyName);\n        if (property != null && property.CanWrite)\n        {\n            property.SetValue(selectedComponent, value);\n            StateHasChanged();\n        }\n    }\n\n    /// <summary>\n    /// 预览表单\n    /// </summary>\n    private void PreviewForm()\n    {\n        previewOpen = true;\n    }\n\n    /// <summary>\n    /// 保存表单\n    /// </summary>\n    private async Task SaveForm()\n    {\n        // TODO: 保存到数据库\n        await Task.CompletedTask;\n    }\n\n    /// <summary>\n    /// 发布表单\n    /// </summary>\n    private async Task PublishForm()\n    {\n        // TODO: 发布表单\n        await Task.CompletedTask;\n    }\n}\n"}],"isError":false,"timestamp":1774227316854}}
{"type":"message","id":"d261259a","parentId":"803eae9d","timestamp":"2026-03-23T00:55:16.994Z","message":{"role":"toolResult","toolCallId":"call_b6ccc939c8c04d199d6dfd11","toolName":"read","content":[{"type":"text","text":"using System;\nusing System.Collections.Generic;\nusing System.Linq;\n\nnamespace Tianyou.Web.Models;\n\n/// <summary>\n/// 表单组件基类\n/// </summary>\npublic abstract class FormComponentBase\n{\n    public Guid Id { get; set; }\n    public string Code { get; set; } = string.Empty;\n    public string Name { get; set; } = string.Empty;\n    public abstract string ComponentType { get; }\n    public bool IsRequired { get; set; } = false;\n    public bool IsReadOnly { get; set; } = false;\n    public bool IsVisible { get; set; } = true;\n    public int Width { get; set; } = 6;\n    public int SortOrder { get; set; } = 0;\n    public object? DefaultValue { get; set; }\n    public string? HelpText { get; set; }\n    public List<ValidationRule> ValidationRules { get; set; } = new();\n    public abstract Dictionary<string, object> ToJsonSchema();\n}\n\n/// <summary>\n/// 文本字段\n/// </summary>\npublic class TextFieldComponent : FormComponentBase\n{\n    public override string ComponentType => \"TextField\";\n    public string Placeholder { get; set; } = string.Empty;\n    public int? MaxLength { get; set; }\n    public string? ValidationRegex { get; set; }\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        var schema = new Dictionary<string, object>\n        {\n            [\"type\"] = \"string\",\n            [\"title\"] = Name,\n            [\"maxLength\"] = MaxLength ?? 0\n        };\n        if (!string.IsNullOrEmpty(ValidationRegex))\n            schema[\"pattern\"] = ValidationRegex;\n        return schema;\n    }\n}\n\n/// <summary>\n/// 数字字段\n/// </summary>\npublic class NumberFieldComponent : FormComponentBase\n{\n    public override string ComponentType => \"NumberField\";\n    public decimal? MinValue { get; set; }\n    public decimal? MaxValue { get; set; }\n    public int DecimalPlaces { get; set; } = 2;\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        var schema = new Dictionary<string, object>\n        {\n            [\"type\"] = \"number\",\n            [\"title\"] = Name\n        };\n        if (MinValue.HasValue) schema[\"minimum\"] = MinValue.Value;\n        if (MaxValue.HasValue) schema[\"maximum\"] = MaxValue.Value;\n        return schema;\n    }\n}\n\n/// <summary>\n/// 日期字段\n/// </summary>\npublic class DateFieldComponent : FormComponentBase\n{\n    public override string ComponentType => \"DateField\";\n    public string Format { get; set; } = \"yyyy-MM-dd\";\n    public DateTime? MinDate { get; set; }\n    public DateTime? MaxDate { get; set; }\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"string\",\n            [\"format\"] = \"date\",\n            [\"title\"] = Name\n        };\n    }\n}\n\n/// <summary>\n/// 下拉选择字段\n/// </summary>\npublic class SelectFieldComponent : FormComponentBase\n{\n    public override string ComponentType => \"SelectField\";\n    public List<SelectOption> Options { get; set; } = new();\n    public bool IsMultiple { get; set; } = false;\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = IsMultiple ? \"array\" : \"string\",\n            [\"title\"] = Name,\n            [\"enum\"] = Options.Select(o => o.Value).ToList()\n        };\n    }\n}\n\n/// <summary>\n/// 复选框字段\n/// </summary>\npublic class CheckBoxFieldComponent : FormComponentBase\n{\n    public override string ComponentType => \"CheckBox\";\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"boolean\",\n            [\"title\"] = Name\n        };\n    }\n}\n\n/// <summary>\n/// 单选框字段\n/// </summary>\npublic class RadioFieldComponent : FormComponentBase\n{\n    public override string ComponentType => \"Radio\";\n    public List<SelectOption> Options { get; set; } = new();\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"string\",\n            [\"title\"] = Name,\n            [\"enum\"] = Options.Select(o => o.Value).ToList()\n        };\n    }\n}\n\n/// <summary>\n/// 表格字段\n/// </summary>\npublic class TableFieldComponent : FormComponentBase\n{\n    public override string ComponentType => \"Table\";\n    public List<TableColumn> Columns { get; set; } = new();\n    public bool AllowAdd { get; set; } = true;\n    public bool AllowDelete { get; set; } = true;\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"array\",\n            [\"title\"] = Name,\n            [\"items\"] = new Dictionary<string, object>()\n        };\n    }\n}\n\n/// <summary>\n/// 文件上传字段\n/// </summary>\npublic class FileUploadComponent : FormComponentBase\n{\n    public override string ComponentType => \"FileUpload\";\n    public List<string> AllowedExtensions { get; set; } = new() { \".pdf\", \".doc\", \".docx\", \".xls\", \".xlsx\" };\n    public long MaxFileSize { get; set; } = 10 * 1024 * 1024; // 10MB\n    public bool AllowMultiple { get; set; } = false;\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"string\",\n            [\"format\"] = \"uri\",\n            [\"title\"] = Name\n        };\n    }\n}\n\n/// <summary>\n/// 图片上传字段\n/// </summary>\npublic class ImageUploadComponent : FormComponentBase\n{\n    public override string ComponentType => \"ImageUpload\";\n    public long MaxFileSize { get; set; } = 5 * 1024 * 1024; // 5MB\n    public bool AllowMultiple { get; set; } = false;\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"string\",\n            [\"format\"] = \"uri\",\n            [\"title\"] = Name\n        };\n    }\n}\n\n/// <summary>\n/// 人员选择字段\n/// </summary>\npublic class UserPickerComponent : FormComponentBase\n{\n    public override string ComponentType => \"UserPicker\";\n    public bool AllowMultiple { get; set; } = false;\n    public Guid? DeptId { get; set; }\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"string\",\n            [\"format\"] = \"user\",\n            [\"title\"] = Name\n        };\n    }\n}\n\n/// <summary>\n/// 部门选择字段\n/// </summary>\npublic class DeptPickerComponent : FormComponentBase\n{\n    public override string ComponentType => \"DeptPicker\";\n    public bool AllowMultiple { get; set; } = false;\n    public override Dictionary<string, object> ToJsonSchema()\n    {\n        return new Dictionary<string, object>\n        {\n            [\"type\"] = \"string\",\n            [\"format\"] = \"department\",\n            [\"title\"] = Name\n        };\n    }\n}\n\n/// <summary>\n/// 选择项\n/// </summary>\npublic class SelectOption\n{\n    public string Label { get; set; } = string.Empty;\n    public string Value { get; set; } = string.Empty;\n    public bool IsDefault { get; set; } = false;\n}\n\n/// <summary>\n/// 表格列\n/// </summary>\npublic class TableColumn\n{\n    public string Code { get; set; } = string.Empty;\n    public string Name { get; set; } = string.Empty;\n    public string DataType { get; set; } = \"string\";\n    public int Width { get; set; } = 150;\n}\n\n/// <summary>\n/// 验证规则\n/// </summary>\npublic class ValidationRule\n{\n    public string RuleType { get; set; } = string.Empty;\n    public string? ErrorMessage { get; set; }\n    public object? RuleValue { get; set; }\n}\n"}],"isError":false,"timestamp":1774227316982}}
