{"type":"message","id":"82b84d89","parentId":"d014cb1b","timestamp":"2026-03-22T23:56:21.283Z","message":{"role":"toolResult","toolCallId":"call_5e4bbf80b0934f889c09aa7a","toolName":"read","content":[{"type":"text","text":"namespace Tianyou.Core.Abstractions;\n\n/// <summary>\n/// 元数据基类\n/// </summary>\npublic abstract class MetadataBase\n{\n    /// <summary>\n    /// 唯一标识\n    /// </summary>\n    public string Id { get; set; } = Guid.NewGuid().ToString();\n    \n    /// <summary>\n    /// 编码\n    /// </summary>\n    public string Code { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 名称\n    /// </summary>\n    public string Name { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 描述\n    /// </summary>\n    public string? Description { get; set; }\n    \n    /// <summary>\n    /// 创建时间\n    /// </summary>\n    public DateTime CreateTime { get; set; } = DateTime.UtcNow;\n    \n    /// <summary>\n    /// 修改时间\n    /// </summary>\n    public DateTime ModifyTime { get; set; } = DateTime.UtcNow;\n    \n    /// <summary>\n    /// 版本号\n    /// </summary>\n    public int Version { get; set; } = 1;\n    \n    /// <summary>\n    /// 扩展属性\n    /// </summary>\n    public Dictionary<string, object> ExtendedProperties { get; set; } = new();\n}\n\n/// <summary>\n/// 表单元数据\n/// </summary>\npublic class FormMetadata : MetadataBase\n{\n    /// <summary>\n    /// 表单类型\n    /// </summary>\n    public FormType FormType { get; set; }\n    \n    /// <summary>\n    /// 所属应用\n    /// </summary>\n    public string AppId { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 字段列表\n    /// </summary>\n    public List<FieldMetadata> Fields { get; set; } = new();\n    \n    /// <summary>\n    /// 分录列表\n    /// </summary>\n    public List<EntryMetadata> Entries { get; set; } = new();\n    \n    /// <summary>\n    /// 表单规则\n    /// </summary>\n    public List<FormRule> Rules { get; set; } = new();\n    \n    /// <summary>\n    /// 表单布局\n    /// </summary>\n    public FormLayout Layout { get; set; } = new();\n    \n    /// <summary>\n    /// 关联插件\n    /// </summary>\n    public List<PluginReference> Plugins { get; set; } = new();\n}\n\n/// <summary>\n/// 字段元数据\n/// </summary>\npublic class FieldMetadata : MetadataBase\n{\n    /// <summary>\n    /// 字段类型\n    /// </summary>\n    public FieldType FieldType { get; set; }\n    \n    /// <summary>\n    /// 数据类型\n    /// </summary>\n    public DataType DataType { get; set; }\n    \n    /// <summary>\n    /// 是否必填\n    /// </summary>\n    public bool Required { get; set; }\n    \n    /// <summary>\n    /// 是否只读\n    /// </summary>\n    public bool ReadOnly { get; set; }\n    \n    /// <summary>\n    /// 默认值\n    /// </summary>\n    public object? DefaultValue { get; set; }\n    \n    /// <summary>\n    /// 验证规则\n    /// </summary>\n    public List<ValidationRule> ValidationRules { get; set; } = new();\n    \n    /// <summary>\n    /// 值更新规则\n    /// </summary>\n    public List<ValueUpdateRule> ValueUpdateRules { get; set; } = new();\n    \n    /// <summary>\n    /// 控件配置\n    /// </summary>\n    public ControlConfig ControlConfig { get; set; } = new();\n}\n\n/// <summary>\n/// 分录元数据\n/// </summary>\npublic class EntryMetadata : MetadataBase\n{\n    /// <summary>\n    /// 字段列表\n    /// </summary>\n    public List<FieldMetadata> Fields { get; set; } = new();\n}\n\n/// <summary>\n/// 表单类型\n/// </summary>\npublic enum FormType\n{\n    /// <summary>\n    /// 单据\n    /// </summary>\n    Bill,\n    \n    /// <summary>\n    /// 基础资料\n    /// </summary>\n    BaseData,\n    \n    /// <summary>\n    /// 动态表单\n    /// </summary>\n    DynamicForm,\n    \n    /// <summary>\n    /// 报表\n    /// </summary>\n    Report\n}\n\n/// <summary>\n/// 字段类型\n/// </summary>\npublic enum FieldType\n{\n    Text,\n    Number,\n    Date,\n    DateTime,\n    Select,\n    MultiSelect,\n    Radio,\n    Checkbox,\n    File,\n    Image,\n    RichText,\n    Reference,\n    EntryTable\n}\n\n/// <summary>\n/// 数据类型\n/// </summary>\npublic enum DataType\n{\n    String,\n    Integer,\n    Decimal,\n    Boolean,\n    DateTime,\n    Binary,\n    Json,\n    Reference\n}\n\n/// <summary>\n/// 表单规则\n/// </summary>\npublic class FormRule\n{\n    public string Name { get; set; } = string.Empty;\n    public RuleType Type { get; set; }\n    public string Condition { get; set; } = string.Empty;\n    public string Action { get; set; } = string.Empty;\n    public int Priority { get; set; }\n}\n\n/// <summary>\n/// 规则类型\n/// </summary>\npublic enum RuleType\n{\n    Visibility,\n    ReadOnly,\n    Required,\n    ValueUpdate,\n    Validation\n}\n\n/// <summary>\n/// 验证规则\n/// </summary>\npublic class ValidationRule\n{\n    public string Name { get; set; } = string.Empty;\n    public ValidationType Type { get; set; }\n    public string Value { get; set; } = string.Empty;\n    public string Message { get; set; } = string.Empty;\n}\n\n/// <summary>\n/// 验证类型\n/// </summary>\npublic enum ValidationType\n{\n    Required,\n    MinLength,\n    MaxLength,\n    Range,\n    Pattern,\n    Custom\n}\n\n/// <summary>\n/// 值更新规则\n/// </summary>\npublic class ValueUpdateRule\n{\n    public string TargetField { get; set; } = string.Empty;\n    public string Expression { get; set; } = string.Empty;\n    public string TriggerField { get; set; } = string.Empty;\n}\n\n/// <summary>\n/// 表单布局\n/// </summary>\npublic class FormLayout\n{\n    public LayoutType Type { get; set; } = LayoutType.Tabs;\n    public List<LayoutSection> Sections { get; set; } = new();\n    public int Columns { get; set; } = 2;\n}\n\n/// <summary>\n/// 布局类型\n/// </summary>\npublic enum LayoutType\n{\n    Tabs,\n    Accordion,\n    Steps,\n    Grid\n}\n\n/// <summary>\n/// 布局区块\n/// </summary>\npublic class LayoutSection\n{\n    public string Title { get; set; } = string.Empty;\n    public List<string> Fields { get; set; } = new();\n    public int Columns { get; set; } = 2;\n}\n\n/// <summary>\n/// 控件配置\n/// </summary>\npublic class ControlConfig\n{\n    public string Placeholder { get; set; } = string.Empty;\n    public int? Width { get; set; }\n    public int? Height { get; set; }\n    public bool Visible { get; set; } = true;\n    public bool Enabled { get; set; } = true;\n    public Dictionary<string, object> ExtendedProps { get; set; } = new();\n}\n\n/// <summary>\n/// 插件引用\n/// </summary>\npublic class PluginReference\n{\n    public string PluginId { get; set; } = string.Empty;\n    public string PluginType { get; set; } = string.Empty;\n    public Dictionary<string, object> Config { get; set; } = new();\n    public int Order { get; set; }\n}\n"}],"isError":false,"timestamp":1774223781160}}
{"type":"message","id":"ddebeb1e","parentId":"82b84d89","timestamp":"2026-03-22T23:56:55.987Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我看到了现有的元数据定义，但没有看到Workflow相关的接口和实体。现在我需要：\n\n1. 创建Workflow相关的实体和接口\n2. 添加Elsa Workflows集成\n3. 实现流程设计器的前端\n4. 实现任务管理和审批功能\n5. 集成Hangfire\n\n让我开始创建必要的文件。首先，我需要创建工作流相关的实体和接口定义。","thinkingSignature":"reasoning_content"},{"type":"text","text":"## 第二步：创建工作流实体和接口定义"},{"type":"toolCall","id":"call_fa1d8450297f4e41bfa8b38e","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Workflow/WorkflowEntities.cs","content":"namespace Tianyou.Core.Abstractions.Workflow;\n\n/// <summary>\n/// 工作流定义\n/// </summary>\npublic class WorkflowDefinition : MetadataBase\n{\n    /// <summary>\n    /// BPMN XML定义\n    /// </summary>\n    public string BpmnXml { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 流程分类\n    /// </summary>\n    public string Category { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 流程状态\n    /// </summary>\n    public WorkflowStatus Status { get; set; } = WorkflowStatus.Draft;\n    \n    /// <summary>\n    /// 发布版本\n    /// </summary>\n    public int PublishedVersion { get; set; }\n    \n    /// <summary>\n    /// 表单ID\n    /// </summary>\n    public string? FormId { get; set; }\n    \n    /// <summary>\n    /// 审批节点配置\n    /// </summary>\n    public List<ApprovalNode> ApprovalNodes { get; set; } = new();\n    \n    /// <summary>\n    /// 流程变量\n    /// </summary>\n    public Dictionary<string, object> Variables { get; set; } = new();\n}\n\n/// <summary>\n/// 工作流实例\n/// </summary>\npublic class WorkflowInstance : MetadataBase\n{\n    /// <summary>\n    /// 流程定义ID\n    /// </summary>\n    public string DefinitionId { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 流程定义版本\n    /// </summary>\n    public int DefinitionVersion { get; set; }\n    \n    /// <summary>\n    /// 实例状态\n    /// </summary>\n    public WorkflowInstanceState State { get; set; } = WorkflowInstanceState.Running;\n    \n    /// <summary>\n    /// 发起人ID\n    /// </summary>\n    public string InitiatorId { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 发起人名称\n    /// </summary>\n    public string InitiatorName { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 业务数据\n    /// </summary>\n    public Dictionary<string, object> BusinessData { get; set; } = new();\n    \n    /// <summary>\n    /// 当前节点\n    /// </summary>\n    public string? CurrentNode { get; set; }\n    \n    /// <summary>\n    /// 开始时间\n    /// </summary>\n    public DateTime StartTime { get; set; } = DateTime.UtcNow;\n    \n    /// <summary>\n    /// 结束时间\n    /// </summary>\n    public DateTime? EndTime { get; set; }\n    \n    /// <summary>\n    /// 优先级\n    /// </summary>\n    public int Priority { get; set; }\n}\n\n/// <summary>\n/// 工作流任务\n/// </summary>\npublic class WorkflowTask : MetadataBase\n{\n    /// <summary>\n    /// 流程实例ID\n    /// </summary>\n    public string InstanceId { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 任务名称\n    /// </summary>\n    public string TaskName { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 任务类型\n    /// </summary>\n    public TaskType TaskType { get; set; } = TaskType.UserTask;\n    \n    /// <summary>\n    /// 任务状态\n    /// </summary>\n    public TaskState State { get; set; } = TaskState.Pending;\n    \n    /// <summary>\n    /// 分配给用户ID\n    /// </summary>\n    public string? AssignedUserId { get; set; }\n    \n    /// <summary>\n    /// 分配给用户名\n    /// </summary>\n    public string? AssignedUserName { get; set; }\n    \n    /// <summary>\n    /// 分配给角色ID列表\n    /// </summary>\n    public List<string> AssignedRoleIds { get; set; } = new();\n    \n    /// <summary>\n    /// 到期时间\n    /// </summary>\n    public DateTime? DueDate { get; set; }\n    \n    /// <summary>\n    /// 完成时间\n    /// </summary>\n    public DateTime? CompletedTime { get; set; }\n    \n    /// <summary>\n    /// 审批意见\n    /// </summary>\n    public string? Comment { get; set; }\n    \n    /// <summary>\n    /// 审批结果\n    /// </summary>\n    public ApprovalResult? ApprovalResult { get; set; }\n    \n    /// <summary>\n    /// 节点ID\n    /// </summary>\n    public string NodeId { get; set; } = string.Empty;\n}\n\n/// <summary>\n/// 审批节点\n/// </summary>\npublic class ApprovalNode\n{\n    public string NodeId { get; set; } = string.Empty;\n    public string NodeName { get; set; } = string.Empty;\n    public ApprovalType ApprovalType { get; set; }\n    public List<string> ApproverIds { get; set; } = new();\n    public List<string> ApproverRoleIds { get; set; } = new();\n    public int TimeoutHours { get; set; } = 72;\n    public bool AllowTransfer { get; set; } = true;\n    public bool AllowDelegate { get; set; } = true;\n}\n\n/// <summary>\n/// 审批记录\n/// </summary>\npublic class ApprovalRecord\n{\n    public string Id { get; set; } = Guid.NewGuid().ToString();\n    public string InstanceId { get; set; } = string.Empty;\n    public string TaskId { get; set; } = string.Empty;\n    public string NodeId { get; set; } = string.Empty;\n    public string OperatorId { get; set; } = string.Empty;\n    public string OperatorName { get; set; } = string.Empty;\n    public ApprovalAction Action { get; set; }\n    public string? Comment { get; set; }\n    public DateTime OperationTime { get; set; } = DateTime.UtcNow;\n    public string? TransferToUserId { get; set; }\n}\n\n/// <summary>\n/// 工作流状态\n/// </summary>\npublic enum WorkflowStatus\n{\n    Draft,\n    Published,\n    Deprecated,\n    Archived\n}\n\n/// <summary>\n/// 工作流实例状态\n/// </summary>\npublic enum WorkflowInstanceState\n{\n    Running,\n    Suspended,\n    Completed,\n    Cancelled,\n    Faulted\n}\n\n/// <summary>\n/// 任务类型\n/// </summary>\npublic enum TaskType\n{\n    UserTask,\n    ServiceTask,\n    ScriptTask,\n    ApprovalTask\n}\n\n/// <summary>\n/// 任务状态\n/// </summary>\npublic enum TaskState\n{\n    Pending,\n    InProgress,\n    Completed,\n    Cancelled,\n    Error\n}\n\n/// <summary>\n/// 审批类型\n/// </summary>\npublic enum ApprovalType\n{\n    OrSign,\n    AndSign,\n    Sequential\n}\n\n/// <summary>\n/// 审批动作\n/// </summary>\npublic enum ApprovalAction\n{\n    Approve,\n    Reject,\n    Transfer,\n    Delegate,\n    Withdraw,\n    Cancel\n}\n\n/// <summary>\n/// 审批结果\n/// </summary>\npublic enum ApprovalResult\n{\n    Approved,\n    Rejected,\n    Transferred,\n    Delegated\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1767,"output":1701,"cacheRead":15808,"cacheWrite":0,"totalTokens":19276,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774223781284}}
