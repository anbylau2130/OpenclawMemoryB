{"type":"message","id":"5bcf2106","parentId":"ee0381c4","timestamp":"2026-03-23T00:00:08.660Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建增强的WorkflowController，包含所有需要的API端点。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_d96d49e77ab44ecca96fdadf","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/Controllers/WorkflowController.cs","content":"using Microsoft.AspNetCore.Mvc;\nusing Tianyou.Core.Abstractions.Workflow;\n\nnamespace Tianyou.WorkflowService.Controllers;\n\n/// <summary>\n/// 工作流API控制器\n/// </summary>\n[ApiController]\n[Route(\"api/[controller]\")]\npublic class WorkflowController : ControllerBase\n{\n    private readonly IWorkflowService _workflowService;\n    private readonly ILogger<WorkflowController> _logger;\n\n    public WorkflowController(\n        IWorkflowService workflowService, \n        ILogger<WorkflowController> logger)\n    {\n        _workflowService = workflowService;\n        _logger = logger;\n    }\n\n    #region 流程定义管理\n\n    /// <summary>\n    /// 获取流程定义\n    /// </summary>\n    [HttpGet(\"{id}\")]\n    public async Task<IActionResult> GetWorkflow(string id)\n    {\n        try\n        {\n            var workflow = await _workflowService.GetWorkflowAsync(id);\n            if (workflow == null)\n                return NotFound(new { message = \"流程定义不存在\" });\n            \n            return Ok(workflow);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取流程定义失败: {Id}\", id);\n            return StatusCode(500, new { message = \"获取流程定义失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 获取流程定义列表\n    /// </summary>\n    [HttpGet]\n    public async Task<IActionResult> GetWorkflows(\n        [FromQuery] int page = 1, \n        [FromQuery] int pageSize = 20,\n        [FromQuery] string? category = null,\n        [FromQuery] WorkflowStatus? status = null)\n    {\n        try\n        {\n            var result = await _workflowService.GetWorkflowsAsync(page, pageSize, category, status);\n            return Ok(result);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取流程列表失败\");\n            return StatusCode(500, new { message = \"获取流程列表失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 创建流程定义\n    /// </summary>\n    [HttpPost]\n    public async Task<IActionResult> CreateWorkflow([FromBody] WorkflowDefinition workflow)\n    {\n        try\n        {\n            var id = await _workflowService.CreateWorkflowAsync(workflow);\n            return CreatedAtAction(nameof(GetWorkflow), new { id }, new { id });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"创建流程失败\");\n            return StatusCode(500, new { message = \"创建流程失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 更新流程定义\n    /// </summary>\n    [HttpPut(\"{id}\")]\n    public async Task<IActionResult> UpdateWorkflow(string id, [FromBody] WorkflowDefinition workflow)\n    {\n        try\n        {\n            workflow.Id = id;\n            await _workflowService.UpdateWorkflowAsync(workflow);\n            return NoContent();\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"更新流程失败: {Id}\", id);\n            return StatusCode(500, new { message = \"更新流程失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 删除流程定义\n    /// </summary>\n    [HttpDelete(\"{id}\")]\n    public async Task<IActionResult> DeleteWorkflow(string id)\n    {\n        try\n        {\n            await _workflowService.DeleteWorkflowAsync(id);\n            return NoContent();\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"删除流程失败: {Id}\", id);\n            return StatusCode(500, new { message = \"删除流程失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 发布流程定义\n    /// </summary>\n    [HttpPost(\"{id}/publish\")]\n    public async Task<IActionResult> PublishWorkflow(string id)\n    {\n        try\n        {\n            await _workflowService.PublishWorkflowAsync(id);\n            return Ok(new { message = \"流程发布成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"发布流程失败: {Id}\", id);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 验证流程定义\n    /// </summary>\n    [HttpPost(\"validate\")]\n    public async Task<IActionResult> ValidateWorkflow([FromBody] ValidateRequest request)\n    {\n        try\n        {\n            var result = await _workflowService.ValidateWorkflowAsync(request.BpmnXml);\n            return Ok(result);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"验证流程失败\");\n            return StatusCode(500, new { message = \"验证流程失败\" });\n        }\n    }\n\n    #endregion\n\n    #region 流程实例管理\n\n    /// <summary>\n    /// 启动流程实例\n    /// </summary>\n    [HttpPost(\"{id}/start\")]\n    public async Task<IActionResult> StartWorkflow(\n        string id, \n        [FromBody] StartWorkflowRequest request)\n    {\n        try\n        {\n            var instanceId = await _workflowService.StartWorkflowAsync(\n                id, \n                request.Data, \n                request.InitiatorId);\n            \n            return Ok(new { instanceId });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"启动流程失败: {Id}\", id);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 获取流程实例\n    /// </summary>\n    [HttpGet(\"instances/{instanceId}\")]\n    public async Task<IActionResult> GetWorkflowInstance(string instanceId)\n    {\n        try\n        {\n            var instance = await _workflowService.GetWorkflowInstanceAsync(instanceId);\n            if (instance == null)\n                return NotFound(new { message = \"流程实例不存在\" });\n            \n            return Ok(instance);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取流程实例失败: {InstanceId}\", instanceId);\n            return StatusCode(500, new { message = \"获取流程实例失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 获取流程实例列表\n    /// </summary>\n    [HttpGet(\"instances\")]\n    public async Task<IActionResult> GetWorkflowInstances(\n        [FromQuery] int page = 1,\n        [FromQuery] int pageSize = 20,\n        [FromQuery] string? definitionId = null,\n        [FromQuery] WorkflowInstanceState? state = null,\n        [FromQuery] string? initiatorId = null)\n    {\n        try\n        {\n            var result = await _workflowService.GetWorkflowInstancesAsync(\n                page, pageSize, definitionId, state, initiatorId);\n            return Ok(result);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取流程实例列表失败\");\n            return StatusCode(500, new { message = \"获取流程实例列表失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 挂起流程实例\n    /// </summary>\n    [HttpPost(\"instances/{instanceId}/suspend\")]\n    public async Task<IActionResult> SuspendWorkflowInstance(string instanceId)\n    {\n        try\n        {\n            await _workflowService.SuspendWorkflowInstanceAsync(instanceId);\n            return Ok(new { message = \"流程已挂起\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"挂起流程失败: {InstanceId}\", instanceId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 恢复流程实例\n    /// </summary>\n    [HttpPost(\"instances/{instanceId}/resume\")]\n    public async Task<IActionResult> ResumeWorkflowInstance(string instanceId)\n    {\n        try\n        {\n            await _workflowService.ResumeWorkflowInstanceAsync(instanceId);\n            return Ok(new { message = \"流程已恢复\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"恢复流程失败: {InstanceId}\", instanceId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 取消流程实例\n    /// </summary>\n    [HttpPost(\"instances/{instanceId}/cancel\")]\n    public async Task<IActionResult> CancelWorkflowInstance(\n        string instanceId, \n        [FromBody] CancelRequest request)\n    {\n        try\n        {\n            await _workflowService.CancelWorkflowInstanceAsync(instanceId, request.Reason);\n            return Ok(new { message = \"流程已取消\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"取消流程失败: {InstanceId}\", instanceId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    #endregion\n\n    #region 任务管理\n\n    /// <summary>\n    /// 获取待办任务\n    /// </summary>\n    [HttpGet(\"tasks/pending/{userId}\")]\n    public async Task<IActionResult> GetPendingTasks(\n        string userId,\n        [FromQuery] int page = 1,\n        [FromQuery] int pageSize = 20)\n    {\n        try\n        {\n            var result = await _workflowService.GetPendingTasksAsync(userId, page, pageSize);\n            return Ok(result);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取待办任务失败: {UserId}\", userId);\n            return StatusCode(500, new { message = \"获取待办任务失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 获取已办任务\n    /// </summary>\n    [HttpGet(\"tasks/completed/{userId}\")]\n    public async Task<IActionResult> GetCompletedTasks(\n        string userId,\n        [FromQuery] int page = 1,\n        [FromQuery] int pageSize = 20)\n    {\n        try\n        {\n            var result = await _workflowService.GetCompletedTasksAsync(userId, page, pageSize);\n            return Ok(result);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取已办任务失败: {UserId}\", userId);\n            return StatusCode(500, new { message = \"获取已办任务失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 获取任务详情\n    /// </summary>\n    [HttpGet(\"tasks/{taskId}\")]\n    public async Task<IActionResult> GetTask(string taskId)\n    {\n        try\n        {\n            var task = await _workflowService.GetTaskAsync(taskId);\n            if (task == null)\n                return NotFound(new { message = \"任务不存在\" });\n            \n            return Ok(task);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取任务失败: {TaskId}\", taskId);\n            return StatusCode(500, new { message = \"获取任务失败\" });\n        }\n    }\n\n    /// <summary>\n    /// 认领任务\n    /// </summary>\n    [HttpPost(\"tasks/{taskId}/claim\")]\n    public async Task<IActionResult> ClaimTask(string taskId, [FromBody] ClaimRequest request)\n    {\n        try\n        {\n            await _workflowService.ClaimTaskAsync(taskId, request.UserId);\n            return Ok(new { message = \"任务认领成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"认领任务失败: {TaskId}\", taskId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    #endregion\n\n    #region 审批操作\n\n    /// <summary>\n    /// 同意审批\n    /// </summary>\n    [HttpPost(\"tasks/{taskId}/approve\")]\n    public async Task<IActionResult> ApproveTask(\n        string taskId, \n        [FromBody] ApprovalRequest request)\n    {\n        try\n        {\n            await _workflowService.ApproveTaskAsync(taskId, request.UserId, request.Comment);\n            return Ok(new { message = \"审批通过\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"审批失败: {TaskId}\", taskId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 拒绝审批\n    /// </summary>\n    [HttpPost(\"tasks/{taskId}/reject\")]\n    public async Task<IActionResult> RejectTask(\n        string taskId, \n        [FromBody] ApprovalRequest request)\n    {\n        try\n        {\n            await _workflowService.RejectTaskAsync(taskId, request.UserId, request.Comment);\n            return Ok(new { message = \"审批拒绝\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"拒绝审批失败: {TaskId}\", taskId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 转办任务\n    /// </summary>\n    [HttpPost(\"tasks/{taskId}/transfer\")]\n    public async Task<IActionResult> TransferTask(\n        string taskId, \n        [FromBody] TransferRequest request)\n    {\n        try\n        {\n            await _workflowService.TransferTaskAsync(\n                taskId, \n                request.FromUserId, \n                request.ToUserId, \n                request.Comment);\n            \n            return Ok(new { message = \"转办成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"转办失败: {TaskId}\", taskId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 委派任务\n    /// </summary>\n    [HttpPost(\"tasks/{taskId}/delegate\")]\n    public async Task<IActionResult> DelegateTask(\n        string taskId, \n        [FromBody] TransferRequest request)\n    {\n        try\n        {\n            await _workflowService.DelegateTaskAsync(\n                taskId, \n                request.FromUserId, \n                request.ToUserId, \n                request.Comment);\n            \n            return Ok(new { message = \"委派成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"委派失败: {TaskId}\", taskId);\n            return StatusCode(500, new { message = ex.Message });\n        }\n    }\n\n    /// <summary>\n    /// 获取审批记录\n    /// </summary>\n    [HttpGet(\"instances/{instanceId}/approval-records\")]\n    public async Task<IActionResult> GetApprovalRecords(string instanceId)\n    {\n        try\n        {\n            var records = await _workflowService.GetApprovalRecordsAsync(instanceId);\n            return Ok(records);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取审批记录失败: {InstanceId}\", instanceId);\n            return StatusCode(500, new { message = \"获取审批记录失败\" });\n        }\n    }\n\n    #endregion\n}\n\n#region 请求模型\n\npublic class ValidateRequest\n{\n    public string BpmnXml { get; set; } = string.Empty;\n}\n\npublic class StartWorkflowRequest\n{\n    public Dictionary<string, object> Data { get; set; } = new();\n    public string? InitiatorId { get; set; }\n}\n\npublic class CancelRequest\n{\n    public string Reason { get; set; } = string.Empty;\n}\n\npublic class ClaimRequest\n{\n    public string UserId { get; set; } = string.Empty;\n}\n\npublic class ApprovalRequest\n{\n    public string UserId { get; set; } = string.Empty;\n    public string? Comment { get; set; }\n}\n\npublic class TransferRequest\n{\n    public string FromUserId { get; set; } = string.Empty;\n    public string ToUserId { get; set; } = string.Empty;\n    public string? Comment { get; set; }\n}\n\n#endregion\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":691,"output":3277,"cacheRead":25344,"cacheWrite":0,"totalTokens":29312,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774223944067}}
