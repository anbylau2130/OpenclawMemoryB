{"type":"message","id":"c5eb3e82","parentId":"e9a81b0d","timestamp":"2026-03-22T23:57:14.548Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，现在创建工作流服务接口。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_27c04e7967d4405f97190a0d","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Workflow/IWorkflowService.cs","content":"namespace Tianyou.Core.Abstractions.Workflow;\n\n/// <summary>\n/// 工作流服务接口\n/// </summary>\npublic interface IWorkflowService\n{\n    #region 流程定义管理\n    \n    /// <summary>\n    /// 获取流程定义\n    /// </summary>\n    Task<WorkflowDefinition?> GetWorkflowAsync(string id);\n    \n    /// <summary>\n    /// 获取流程定义列表\n    /// </summary>\n    Task<PagedResult<WorkflowDefinition>> GetWorkflowsAsync(\n        int page = 1, int pageSize = 20, \n        string? category = null, \n        WorkflowStatus? status = null);\n    \n    /// <summary>\n    /// 创建流程定义\n    /// </summary>\n    Task<string> CreateWorkflowAsync(WorkflowDefinition workflow);\n    \n    /// <summary>\n    /// 更新流程定义\n    /// </summary>\n    Task UpdateWorkflowAsync(WorkflowDefinition workflow);\n    \n    /// <summary>\n    /// 删除流程定义\n    /// </summary>\n    Task DeleteWorkflowAsync(string id);\n    \n    /// <summary>\n    /// 发布流程定义\n    /// </summary>\n    Task PublishWorkflowAsync(string id);\n    \n    /// <summary>\n    /// 验证流程定义\n    /// </summary>\n    Task<ValidationResult> ValidateWorkflowAsync(string bpmnXml);\n    \n    #endregion\n    \n    #region 流程实例管理\n    \n    /// <summary>\n    /// 启动流程实例\n    /// </summary>\n    Task<string> StartWorkflowAsync(\n        string definitionId, \n        Dictionary<string, object> data,\n        string? initiatorId = null);\n    \n    /// <summary>\n    /// 获取流程实例\n    /// </summary>\n    Task<WorkflowInstance?> GetWorkflowInstanceAsync(string instanceId);\n    \n    /// <summary>\n    /// 获取流程实例列表\n    /// </summary>\n    Task<PagedResult<WorkflowInstance>> GetWorkflowInstancesAsync(\n        int page = 1, int pageSize = 20,\n        string? definitionId = null,\n        WorkflowInstanceState? state = null,\n        string? initiatorId = null);\n    \n    /// <summary>\n    /// 挂起流程实例\n    /// </summary>\n    Task SuspendWorkflowInstanceAsync(string instanceId);\n    \n    /// <summary>\n    /// 恢复流程实例\n    /// </summary>\n    Task ResumeWorkflowInstanceAsync(string instanceId);\n    \n    /// <summary>\n    /// 取消流程实例\n    /// </summary>\n    Task CancelWorkflowInstanceAsync(string instanceId, string reason);\n    \n    #endregion\n    \n    #region 任务管理\n    \n    /// <summary>\n    /// 获取待办任务\n    /// </summary>\n    Task<PagedResult<WorkflowTask>> GetPendingTasksAsync(\n        string userId,\n        int page = 1,\n        int pageSize = 20);\n    \n    /// <summary>\n    /// 获取已办任务\n    /// </summary>\n    Task<PagedResult<WorkflowTask>> GetCompletedTasksAsync(\n        string userId,\n        int page = 1,\n        int pageSize = 20);\n    \n    /// <summary>\n    /// 获取任务详情\n    /// </summary>\n    Task<WorkflowTask?> GetTaskAsync(string taskId);\n    \n    /// <summary>\n    /// 认领任务\n    /// </summary>\n    Task ClaimTaskAsync(string taskId, string userId);\n    \n    /// <summary>\n    /// 完成任务\n    /// </summary>\n    Task CompleteTaskAsync(string taskId, string userId, string? comment = null);\n    \n    #endregion\n    \n    #region 审批操作\n    \n    /// <summary>\n    /// 同意审批\n    /// </summary>\n    Task ApproveTaskAsync(\n        string taskId, \n        string userId, \n        string? comment = null);\n    \n    /// <summary>\n    /// 拒绝审批\n    /// </summary>\n    Task RejectTaskAsync(\n        string taskId, \n        string userId, \n        string? comment = null);\n    \n    /// <summary>\n    /// 转办任务\n    /// </summary>\n    Task TransferTaskAsync(\n        string taskId, \n        string fromUserId, \n        string toUserId,\n        string? comment = null);\n    \n    /// <summary>\n    /// 委派任务\n    /// </summary>\n    Task DelegateTaskAsync(\n        string taskId, \n        string fromUserId, \n        string toUserId,\n        string? comment = null);\n    \n    /// <summary>\n    /// 获取审批记录\n    /// </summary>\n    Task<List<ApprovalRecord>> GetApprovalRecordsAsync(string instanceId);\n    \n    #endregion\n}\n\n/// <summary>\n/// 分页结果\n/// </summary>\npublic class PagedResult<T>\n{\n    public List<T> Items { get; set; } = new();\n    public int TotalCount { get; set; }\n    public int Page { get; set; }\n    public int PageSize { get; set; }\n    public int TotalPages => (int)Math.Ceiling((double)TotalCount / PageSize);\n}\n\n/// <summary>\n/// 验证结果\n/// </summary>\npublic class ValidationResult\n{\n    public bool IsValid { get; set; }\n    public List<string> Errors { get; set; } = new();\n    public List<string> Warnings { get; set; } = new();\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1781,"output":1165,"cacheRead":17536,"cacheWrite":0,"totalTokens":20482,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774223816071}}
