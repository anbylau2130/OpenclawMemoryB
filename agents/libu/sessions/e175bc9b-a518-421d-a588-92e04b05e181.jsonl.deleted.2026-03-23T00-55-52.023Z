{"type":"message","id":"a413ef6e","parentId":"0af7bcc4","timestamp":"2026-03-23T00:02:43.667Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建Hangfire定时任务服务来处理超时和通知。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_f45d3f8f2f534551886ec987","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/Jobs/WorkflowJobs.cs","content":"using Hangfire;\nusing Microsoft.EntityFrameworkCore;\nusing Tianyou.WorkflowService.Data;\n\nnamespace Tianyou.WorkflowService.Jobs;\n\n/// <summary>\n/// 工作流定时任务\n/// </summary>\npublic class WorkflowJobs\n{\n    private readonly WorkflowDbContext _context;\n    private readonly ILogger<WorkflowJobs> _logger;\n    \n    public WorkflowJobs(WorkflowDbContext context, ILogger<WorkflowJobs> logger)\n    {\n        _context = context;\n        _logger = logger;\n    }\n    \n    /// <summary>\n    /// 检查任务超时\n    /// </summary>\n    [AutomaticRetry(Attempts = 3)]\n    public async Task CheckTaskTimeoutAsync()\n    {\n        _logger.LogInformation(\"开始检查任务超时...\");\n        \n        var overdueTasks = await _context.WorkflowTasks\n            .Where(t => t.State == TaskState.Pending)\n            .Where(t => t.DueDate.HasValue && t.DueDate.Value < DateTime.UtcNow)\n            .ToListAsync();\n        \n        foreach (var task in overdueTasks)\n        {\n            await HandleOverdueTaskAsync(task);\n        }\n        \n        _logger.LogInformation(\"检查完成，发现 {Count} 个超时任务\", overdueTasks.Count);\n    }\n    \n    private async Task HandleOverdueTaskAsync(WorkflowTask task)\n    {\n        // 发送超时通知\n        _logger.LogWarning(\"任务超时: {TaskId}, {TaskName}\", task.Id, task.TaskName);\n        \n        // TODO: 发送邮件或短信通知\n        // TODO: 可以自动转办给上级\n        \n        task.ExtendedProperties[\"Overdue\"] = true;\n        await _context.SaveChangesAsync();\n    }\n    \n    /// <summary>\n    /// 发送任务提醒\n    /// </summary>\n    [AutomaticRetry(Attempts = 3)]\n    public async Task SendTaskRemindersAsync()\n    {\n        _logger.LogInformation(\"发送任务提醒...\");\n        \n        var soonDueTasks = await _context.WorkflowTasks\n            .Where(t => t.State == TaskState.Pending)\n            .Where(t => t.DueDate.HasValue)\n            .Where(t => t.DueDate.Value <= DateTime.UtcNow.AddHours(4))\n            .Where(t => t.DueDate.Value > DateTime.UtcNow)\n            .ToListAsync();\n        \n        foreach (var task in soonDueTasks)\n        {\n            await SendReminderAsync(task);\n        }\n        \n        _logger.LogInformation(\"已发送 {Count} 条提醒\", soonDueTasks.Count);\n    }\n    \n    private async Task SendReminderAsync(WorkflowTask task)\n    {\n        // TODO: 实现实际的提醒逻辑\n        // 邮件、短信、站内信等\n        \n        _logger.LogInformation(\"发送提醒: {TaskId}, 用户: {UserId}\", \n            task.Id, task.AssignedUserId);\n    }\n    \n    /// <summary>\n    /// 清理已完成的历史数据\n    /// </summary>\n    [AutomaticRetry(Attempts = 3)]\n    public async Task CleanupHistoryAsync()\n    {\n        _logger.LogInformation(\"清理历史数据...\");\n        \n        var cutoffDate = DateTime.UtcNow.AddMonths(-6);\n        \n        // 删除6个月前的已完成任务\n        var oldTasks = await _context.WorkflowTasks\n            .Where(t => t.State == TaskState.Completed)\n            .Where(t => t.CompletedTime.HasValue && t.CompletedTime.Value < cutoffDate)\n            .ToListAsync();\n        \n        _context.WorkflowTasks.RemoveRange(oldTasks);\n        \n        // 删除6个月前的已完成流程实例\n        var oldInstances = await _context.WorkflowInstances\n            .Where(i => i.State == WorkflowInstanceState.Completed || \n                        i.State == WorkflowInstanceState.Cancelled)\n            .Where(i => i.EndTime.HasValue && i.EndTime.Value < cutoffDate)\n            .ToListAsync();\n        \n        _context.WorkflowInstances.RemoveRange(oldInstances);\n        \n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"清理完成，删除 {TaskCount} 个任务，{InstanceCount} 个实例\", \n            oldTasks.Count, oldInstances.Count);\n    }\n    \n    /// <summary>\n    /// 生成统计报表\n    /// </summary>\n    [AutomaticRetry(Attempts = 3)]\n    public async Task GenerateStatisticsAsync()\n    {\n        _logger.LogInformation(\"生成统计报表...\");\n        \n        var stats = new\n        {\n            TotalDefinitions = await _context.WorkflowDefinitions.CountAsync(),\n            ActiveInstances = await _context.WorkflowInstances\n                .CountAsync(i => i.State == WorkflowInstanceState.Running),\n            PendingTasks = await _context.WorkflowTasks\n                .CountAsync(t => t.State == TaskState.Pending),\n            CompletedToday = await _context.WorkflowTasks\n                .CountAsync(t => t.State == TaskState.Completed && \n                                t.CompletedTime.HasValue &&\n                                t.CompletedTime.Value.Date == DateTime.UtcNow.Date)\n        };\n        \n        _logger.LogInformation(\n            \"统计: 总流程定义 {TotalDefs}, 运行中实例 {ActiveInstances}, \" +\n            \"待办任务 {PendingTasks}, 今日完成 {CompletedToday}\",\n            stats.TotalDefinitions, stats.ActiveInstances, \n            stats.PendingTasks, stats.CompletedToday);\n        \n        // TODO: 保存统计数据到数据库\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":2103,"output":1124,"cacheRead":33984,"cacheWrite":0,"totalTokens":37211,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774224136222}}
