{"type":"message","id":"382a796a","parentId":"e51e0753","timestamp":"2026-03-23T00:05:08.207Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"创建快速测试脚本。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_6dffd26fcdc0429e94af4b49","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/quick-test.sh","content":"#!/bin/bash\n\n# 工作流服务快速测试脚本\n\nBASE_URL=\"http://localhost:5005/api/workflow\"\n\necho \"================================\"\necho \"工作流服务API测试\"\necho \"================================\"\n\n# 测试健康检查\necho \"\"\necho \"1️⃣ 测试健康检查...\"\ncurl -s http://localhost:5005/health | jq .\n\n# 创建流程定义\necho \"\"\necho \"2️⃣ 创建流程定义...\"\nWORKFLOW_ID=$(curl -s -X POST \"$BASE_URL\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"请假审批流程\",\n    \"code\": \"LEAVE_APPROVAL\",\n    \"category\": \"人事审批\",\n    \"description\": \"员工请假审批流程\",\n    \"bpmnXml\": \"<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?><bpmn:definitions xmlns:bpmn=\\\"http://www.omg.org/spec/BPMN/20100524/MODEL\\\"><bpmn:process id=\\\"Process1\\\"><bpmn:startEvent id=\\\"Start\\\"/></bpmn:process></bpmn:definitions>\",\n    \"approvalNodes\": [\n      {\n        \"nodeId\": \"Node_Manager\",\n        \"nodeName\": \"部门经理审批\",\n        \"approvalType\": 0,\n        \"approverRoleIds\": [\"manager\"],\n        \"timeoutHours\": 24\n      }\n    ]\n  }' | jq -r '.id')\n\necho \"流程ID: $WORKFLOW_ID\"\n\n# 发布流程\necho \"\"\necho \"3️⃣ 发布流程...\"\ncurl -s -X POST \"$BASE_URL/$WORKFLOW_ID/publish\" | jq .\n\n# 启动流程实例\necho \"\"\necho \"4️⃣ 启动流程实例...\"\nINSTANCE_ID=$(curl -s -X POST \"$BASE_URL/$WORKFLOW_ID/start\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"initiatorId\": \"user001\",\n    \"data\": {\n      \"leaveType\": \"事假\",\n      \"days\": 3,\n      \"reason\": \"个人事务\"\n    }\n  }' | jq -r '.instanceId')\n\necho \"实例ID: $INSTANCE_ID\"\n\n# 获取待办任务\necho \"\"\necho \"5️⃣ 获取待办任务...\"\ncurl -s \"$BASE_URL/tasks/pending/user001?page=1&pageSize=10\" | jq .\n\n# 获取任务列表\nTASK_ID=$(curl -s \"$BASE_URL/tasks/pending/user001?page=1&pageSize=10\" | jq -r '.items[0].id')\n\nif [ \"$TASK_ID\" != \"null\" ]; then\n  # 审批任务\n  echo \"\"\n  echo \"6️⃣ 审批任务...\"\n  curl -s -X POST \"$BASE_URL/tasks/$TASK_ID/approve\" \\\n    -H \"Content-Type: application/json\" \\\n    -d '{\n      \"userId\": \"user001\",\n      \"comment\": \"同意，情况属实\"\n    }' | jq .\nfi\n\n# 获取审批记录\necho \"\"\necho \"7️⃣ 获取审批记录...\"\ncurl -s \"$BASE_URL/instances/$INSTANCE_ID/approval-records\" | jq .\n\n# 获取流程实例\necho \"\"\necho \"8️⃣ 获取流程实例...\"\ncurl -s \"$BASE_URL/instances/$INSTANCE_ID\" | jq .\n\necho \"\"\necho \"✅ 测试完成\"\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":429,"output":786,"cacheRead":42752,"cacheWrite":0,"totalTokens":43967,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774224291653}}
