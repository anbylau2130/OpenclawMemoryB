{"type":"message","id":"00b8e3d2","parentId":"c201d359","timestamp":"2026-03-23T00:02:16.118Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建任务处理组件。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_0abdb23651f844829562599e","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/web/Tianyou.Web/Components/TaskHandler.razor","content":"@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject ISnackbar Snackbar\n\n<MudCard Elevation=\"2\">\n    <MudCardHeader>\n        <CardHeaderContent>\n            <MudText Typo=\"Typo.h5\">@task?.TaskName</MudText>\n            <MudText Typo=\"Typo.body2\" Color=\"Color.Secondary\">\n                流程: @instance?.Name | 发起人: @instance?.InitiatorName\n            </MudText>\n        </CardHeaderContent>\n    </MudCardHeader>\n    \n    <MudCardContent>\n        <MudGrid>\n            <MudItem xs=\"12\" md=\"8\">\n                <MudPaper Elevation=\"1\" Class=\"pa-4\">\n                    <MudText Typo=\"Typo.h6\" Class=\"mb-3\">表单数据</MudText>\n                    \n                    @if (instance?.BusinessData != null)\n                    {\n                        @foreach (var item in instance.BusinessData)\n                        {\n                            <MudTextField @bind-Value=\"@instance.BusinessData[item.Key]\"\n                                          Label=\"@item.Key\"\n                                          Variant=\"Variant.Outlined\"\n                                          ReadOnly=\"true\"\n                                          Margin=\"Margin.Dense\"\n                                          Class=\"mb-2\" />\n                        }\n                    }\n                </MudPaper>\n            </MudItem>\n            \n            <MudItem xs=\"12\" md=\"4\">\n                <MudPaper Elevation=\"1\" Class=\"pa-4\">\n                    <MudText Typo=\"Typo.h6\" Class=\"mb-3\">审批操作</MudText>\n                    \n                    <MudTextArea @bind-Value=\"comment\"\n                                 Label=\"审批意见\"\n                                 Variant=\"Variant.Outlined\"\n                                 Rows=\"4\"\n                                 Class=\"mb-3\" />\n                    \n                    <MudDivider Class=\"my-3\" />\n                    \n                    <MudButtonGroup Vertical=\"true\" FullWidth=\"true\">\n                        <MudButton Variant=\"Variant.Filled\" \n                                   Color=\"Color.Success\"\n                                   Size=\"Size.Large\"\n                                   OnClick=\"Approve\">\n                            <MudIcon Icon=\"@Icons.Material.Filled.Check\" Class=\"mr-2\" />\n                            同意\n                        </MudButton>\n                        \n                        <MudButton Variant=\"Variant.Filled\" \n                                   Color=\"Color.Error\"\n                                   Size=\"Size.Large\"\n                                   OnClick=\"Reject\">\n                            <MudIcon Icon=\"@Icons.Material.Filled.Close\" Class=\"mr-2\" />\n                            拒绝\n                        </MudButton>\n                        \n                        @if (currentNode?.AllowTransfer == true)\n                        {\n                            <MudButton Variant=\"Variant.Outlined\" \n                                       Color=\"Color.Warning\"\n                                       Size=\"Size.Large\"\n                                       OnClick=\"Transfer\">\n                                <MudIcon Icon=\"@Icons.Material.Filled.Forward\" Class=\"mr-2\" />\n                                转办\n                            </MudButton>\n                        }\n                        \n                        @if (currentNode?.AllowDelegate == true)\n                        {\n                            <MudButton Variant=\"Variant.Outlined\" \n                                       Size=\"Size.Large\"\n                                       OnClick=\"Delegate\">\n                                <MudIcon Icon=\"@Icons.Material.Filled.People\" Class=\"mr-2\" />\n                                委派\n                            </MudButton>\n                        }\n                    </MudButtonGroup>\n                </MudPaper>\n                \n                <MudPaper Elevation=\"1\" Class=\"pa-4 mt-4\">\n                    <MudText Typo=\"Typo.h6\" Class=\"mb-3\">流程信息</MudText>\n                    \n                    <MudList TData=\"string\" Dense=\"true\">\n                        <MudListItem>\n                            <MudText><b>流程ID:</b> @instance?.Id</MudText>\n                        </MudListItem>\n                        <MudListItem>\n                            <MudText><b>发起时间:</b> @instance?.StartTime.ToString(\"yyyy-MM-dd HH:mm\")</MudText>\n                        </MudListItem>\n                        <MudListItem>\n                            <MudText><b>当前节点:</b> @task?.TaskName</MudText>\n                        </MudListItem>\n                        @if (task?.DueDate != null)\n                        {\n                            <MudListItem>\n                                <MudText><b>到期时间:</b> @task.DueDate.Value.ToString(\"yyyy-MM-dd HH:mm\")</MudText>\n                            </MudListItem>\n                        }\n                    </MudList>\n                </MudPaper>\n            </MudItem>\n            \n            <MudItem xs=\"12\">\n                <MudPaper Elevation=\"1\" Class=\"pa-4\">\n                    <MudText Typo=\"Typo.h6\" Class=\"mb-3\">审批记录</MudText>\n                    \n                    @if (approvalRecords != null && approvalRecords.Count > 0)\n                    {\n                        <MudTimeline>\n                            @foreach (var record in approvalRecords)\n                            {\n                                <MudTimelineItem Elevation=\"0\" Size=\"Size.Small\">\n                                    <ItemContent>\n                                        <MudCard Elevation=\"0\" Style=\"background: transparent;\">\n                                            <MudCardContent Class=\"pa-0\">\n                                                <MudText Typo=\"Typo.body2\">\n                                                    <b>@record.OperatorName</b>\n                                                    @GetActionText(record.Action)\n                                                </MudText>\n                                                @if (!string.IsNullOrEmpty(record.Comment))\n                                                {\n                                                    <MudText Typo=\"Typo.caption\" Color=\"Color.Secondary\">\n                                                        @record.Comment\n                                                    </MudText>\n                                                }\n                                                <MudText Typo=\"Typo.caption\" Color=\"Color.Secondary\">\n                                                    @record.OperationTime.ToString(\"yyyy-MM-dd HH:mm:ss\")\n                                                </MudText>\n                                            </MudCardContent>\n                                        </MudCard>\n                                    </ItemContent>\n                                </MudTimelineItem>\n                            }\n                        </MudTimeline>\n                    }\n                    else\n                    {\n                        <MudAlert Severity=\"Severity.Info\">暂无审批记录</MudAlert>\n                    }\n                </MudPaper>\n            </MudItem>\n        </MudGrid>\n    </MudCardContent>\n</MudCard>\n\n@code {\n    [Parameter]\n    public string TaskId { get; set; } = \"\";\n    \n    [Parameter]\n    public string UserId { get; set; } = \"current-user\";\n    \n    private WorkflowTask? task;\n    private WorkflowInstance? instance;\n    private ApprovalNode? currentNode;\n    private List<ApprovalRecord>? approvalRecords;\n    private string comment = \"\";\n    \n    protected override async Task OnInitializedAsync()\n    {\n        await LoadTask();\n    }\n    \n    private async Task LoadTask()\n    {\n        try\n        {\n            task = await Http.GetFromJsonAsync<WorkflowTask>(\n                $\"http://localhost:5005/api/workflow/tasks/{TaskId}\");\n            \n            if (task != null)\n            {\n                instance = await Http.GetFromJsonAsync<WorkflowInstance>(\n                    $\"http://localhost:5005/api/workflow/instances/{task.InstanceId}\");\n                \n                approvalRecords = await Http.GetFromJsonAsync<List<ApprovalRecord>>(\n                    $\"http://localhost:5005/api/workflow/instances/{task.InstanceId}/approval-records\");\n                \n                // 获取当前节点配置\n                if (instance != null)\n                {\n                    var definition = await Http.GetFromJsonAsync<WorkflowDefinition>(\n                        $\"http://localhost:5005/api/workflow/{instance.DefinitionId}\");\n                    \n                    currentNode = definition?.ApprovalNodes\n                        .FirstOrDefault(n => n.NodeId == task.NodeId);\n                }\n            }\n        }\n        catch (Exception ex)\n        {\n            Snackbar.Add($\"加载任务失败: {ex.Message}\", Severity.Error);\n        }\n    }\n    \n    private async Task Approve()\n    {\n        try\n        {\n            var response = await Http.PostAsJsonAsync(\n                $\"http://localhost:5005/api/workflow/tasks/{TaskId}/approve\",\n                new { UserId, Comment = comment });\n            \n            if (response.IsSuccessStatusCode)\n            {\n                Snackbar.Add(\"审批成功\", Severity.Success);\n                NavigationManager.NavigateTo(\"/workflow/tasks/pending\");\n            }\n        }\n        catch (Exception ex)\n        {\n            Snackbar.Add($\"审批失败: {ex.Message}\", Severity.Error);\n        }\n    }\n    \n    private async Task Reject()\n    {\n        try\n        {\n            var response = await Http.PostAsJsonAsync(\n                $\"http://localhost:5005/api/workflow/tasks/{TaskId}/reject\",\n                new { UserId, Comment = comment });\n            \n            if (response.IsSuccessStatusCode)\n            {\n                Snackbar.Add(\"已拒绝\", Severity.Warning);\n                NavigationManager.NavigateTo(\"/workflow/tasks/pending\");\n            }\n        }\n        catch (Exception ex)\n        {\n            Snackbar.Add($\"拒绝失败: {ex.Message}\", Severity.Error);\n        }\n    }\n    \n    private void Transfer()\n    {\n        NavigationManager.NavigateTo($\"/workflow/task/{TaskId}/transfer\");\n    }\n    \n    private void Delegate()\n    {\n        NavigationManager.NavigateTo($\"/workflow/task/{TaskId}/delegate\");\n    }\n    \n    private string GetActionText(ApprovalAction action)\n    {\n        return action switch\n        {\n            ApprovalAction.Approve => \"同意\",\n            ApprovalAction.Reject => \"拒绝\",\n            ApprovalAction.Transfer => \"转办\",\n            ApprovalAction.Delegate => \"委派\",\n            ApprovalAction.Withdraw => \"撤回\",\n            ApprovalAction.Cancel => \"取消\",\n            _ => action.ToString()\n        };\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1635,"output":2027,"cacheRead":32384,"cacheWrite":0,"totalTokens":36046,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774224097702}}
