{"type":"message","id":"fe8e783d","parentId":"721c322c","timestamp":"2026-03-22T23:59:04.038Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在更新Program.cs以配置所有服务。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_735a367a2fd44e518dfac888","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/Program.cs","content":"using Microsoft.EntityFrameworkCore;\nusing Microsoft.OpenApi.Models;\nusing Serilog;\nusing Hangfire;\nusing Hangfire.Dashboard;\nusing Hangfire.MemoryStorage;\nusing Tianyou.WorkflowService.Data;\nusing Tianyou.WorkflowService.Services;\nusing Tianyou.Core.Abstractions.Workflow;\n\nvar builder = WebApplication.CreateBuilder(args);\n\n// 配置Serilog\nLog.Logger = new LoggerConfiguration()\n    .WriteTo.Console()\n    .WriteTo.File(\"logs/workflow-.log\", rollingInterval: RollingInterval.Day)\n    .CreateLogger();\n\nbuilder.Host.UseSerilog();\n\n// 配置数据库\nvar connectionString = builder.Configuration.GetConnectionString(\"DefaultConnection\")\n    ?? \"Server=localhost;Database=TianyouWorkflow;Trusted_Connection=true;MultipleActiveResultSets=true;TrustServerCertificate=true\";\n\nbuilder.Services.AddDbContext<WorkflowDbContext>(options =>\n    options.UseSqlServer(connectionString));\n\n// 配置Hangfire\nbuilder.Services.AddHangfire(config => config\n    .UseSimpleAssemblyNameTypeSerializer()\n    .UseRecommendedSerializerSettings()\n    .UseMemoryStorage());\n\nbuilder.Services.AddHangfireServer();\n\n// 注册服务\nbuilder.Services.AddScoped<IWorkflowService, WorkflowServiceImpl>();\n\nbuilder.Services.AddControllers();\nbuilder.Services.AddCors(options =>\n{\n    options.AddPolicy(\"AllowAll\", policy =>\n    {\n        policy.AllowAnyOrigin()\n              .AllowAnyMethod()\n              .AllowAnyHeader();\n    });\n});\n\nbuilder.Services.AddEndpointsApiExplorer();\nbuilder.Services.AddSwaggerGen(c =>\n{\n    c.SwaggerDoc(\"v1\", new OpenApiInfo\n    {\n        Title = \"天佑工作流服务 API\",\n        Version = \"v1\",\n        Description = \"基于Elsa Workflows 3.x的工作流引擎\"\n    });\n});\n\nvar app = builder.Build();\n\n// 自动迁移数据库\nusing (var scope = app.Services.CreateScope())\n{\n    var context = scope.ServiceProvider.GetRequiredService<WorkflowDbContext>();\n    context.Database.EnsureCreated();\n}\n\napp.UseCors(\"AllowAll\");\napp.MapControllers();\n\napp.UseSwagger();\napp.UseSwaggerUI(c =>\n{\n    c.SwaggerEndpoint(\"/swagger/v1/swagger.json\", \"Workflow API V1\");\n});\n\n// Hangfire Dashboard\napp.UseHangfireDashboard(\"/hangfire\", new DashboardOptions\n{\n    Authorization = new[] { new AllowAllDashboardAuthorizationFilter() }\n});\n\napp.MapGet(\"/health\", () => Results.Ok(new\n{\n    service = \"Tianyou Workflow Service\",\n    status = \"healthy\",\n    time = DateTime.UtcNow\n}));\n\nLog.Information(\"工作流服务启动中...\");\nLog.Information(\"Swagger UI: http://localhost:5005/swagger\");\nLog.Information(\"Hangfire Dashboard: http://localhost:5005/hangfire\");\n\napp.Run();\n\n/// <summary>\n/// 允许所有访问的Hangfire授权过滤器（仅用于开发环境）\n/// </summary>\npublic class AllowAllDashboardAuthorizationFilter : IDashboardAuthorizationFilter\n{\n    public bool Authorize(DashboardContext context) => true;\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":645,"output":647,"cacheRead":24704,"cacheWrite":0,"totalTokens":25996,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774223928414}}
