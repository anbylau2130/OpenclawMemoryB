{"type":"message","id":"36042d6e","parentId":"540ec015","timestamp":"2026-03-22T23:58:34.421Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建WorkflowService的实现。由于要求所有函数不超过50行，我会将服务拆分成多个小方法。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_72ee079c583046cc91e6ab0a","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/Services/WorkflowServiceImpl.cs","content":"using Microsoft.EntityFrameworkCore;\nusing Tianyou.Core.Abstractions.Workflow;\nusing Tianyou.Data;\n\nnamespace Tianyou.WorkflowService.Services;\n\n/// <summary>\n/// 工作流服务实现\n/// </summary>\npublic class WorkflowServiceImpl : IWorkflowService\n{\n    private readonly WorkflowDbContext _context;\n    private readonly ILogger<WorkflowServiceImpl> _logger;\n    \n    public WorkflowServiceImpl(WorkflowDbContext context, ILogger<WorkflowServiceImpl> logger)\n    {\n        _context = context;\n        _logger = logger;\n    }\n    \n    #region 流程定义管理\n    \n    public async Task<WorkflowDefinition?> GetWorkflowAsync(string id)\n    {\n        return await _context.WorkflowDefinitions\n            .Include(w => w.ApprovalNodes)\n            .FirstOrDefaultAsync(w => w.Id == id);\n    }\n    \n    public async Task<PagedResult<WorkflowDefinition>> GetWorkflowsAsync(\n        int page = 1, int pageSize = 20, \n        string? category = null, \n        WorkflowStatus? status = null)\n    {\n        var query = _context.WorkflowDefinitions.AsQueryable();\n        \n        if (!string.IsNullOrEmpty(category))\n            query = query.Where(w => w.Category == category);\n        \n        if (status.HasValue)\n            query = query.Where(w => w.Status == status.Value);\n        \n        var totalCount = await query.CountAsync();\n        var items = await query\n            .OrderByDescending(w => w.ModifyTime)\n            .Skip((page - 1) * pageSize)\n            .Take(pageSize)\n            .ToListAsync();\n        \n        return new PagedResult<WorkflowDefinition>\n        {\n            Items = items,\n            TotalCount = totalCount,\n            Page = page,\n            PageSize = pageSize\n        };\n    }\n    \n    public async Task<string> CreateWorkflowAsync(WorkflowDefinition workflow)\n    {\n        workflow.Id = Guid.NewGuid().ToString();\n        workflow.CreateTime = DateTime.UtcNow;\n        workflow.ModifyTime = DateTime.UtcNow;\n        \n        _context.WorkflowDefinitions.Add(workflow);\n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"创建工作流定义: {WorkflowId}, {WorkflowName}\", \n            workflow.Id, workflow.Name);\n        \n        return workflow.Id;\n    }\n    \n    public async Task UpdateWorkflowAsync(WorkflowDefinition workflow)\n    {\n        workflow.ModifyTime = DateTime.UtcNow;\n        workflow.Version++;\n        \n        _context.WorkflowDefinitions.Update(workflow);\n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"更新工作流定义: {WorkflowId}, Version: {Version}\", \n            workflow.Id, workflow.Version);\n    }\n    \n    public async Task DeleteWorkflowAsync(string id)\n    {\n        var workflow = await GetWorkflowAsync(id);\n        if (workflow == null)\n            throw new InvalidOperationException($\"工作流定义不存在: {id}\");\n        \n        _context.WorkflowDefinitions.Remove(workflow);\n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"删除工作流定义: {WorkflowId}\", id);\n    }\n    \n    public async Task PublishWorkflowAsync(string id)\n    {\n        var workflow = await GetWorkflowAsync(id);\n        if (workflow == null)\n            throw new InvalidOperationException($\"工作流定义不存在: {id}\");\n        \n        workflow.Status = WorkflowStatus.Published;\n        workflow.PublishedVersion = workflow.Version;\n        workflow.ModifyTime = DateTime.UtcNow;\n        \n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"发布工作流定义: {WorkflowId}, Version: {Version}\", \n            workflow.Id, workflow.PublishedVersion);\n    }\n    \n    public async Task<ValidationResult> ValidateWorkflowAsync(string bpmnXml)\n    {\n        var result = new ValidationResult { IsValid = true };\n        \n        if (string.IsNullOrWhiteSpace(bpmnXml))\n        {\n            result.IsValid = false;\n            result.Errors.Add(\"BPMN XML不能为空\");\n            return result;\n        }\n        \n        // TODO: 集成bpmn-js验证逻辑\n        // 这里可以调用BPMN验证库或API\n        \n        return await Task.FromResult(result);\n    }\n    \n    #endregion\n    \n    #region 流程实例管理\n    \n    public async Task<string> StartWorkflowAsync(\n        string definitionId, \n        Dictionary<string, object> data,\n        string? initiatorId = null)\n    {\n        var definition = await GetWorkflowAsync(definitionId);\n        if (definition == null)\n            throw new InvalidOperationException($\"工作流定义不存在: {definitionId}\");\n        \n        if (definition.Status != WorkflowStatus.Published)\n            throw new InvalidOperationException(\"只能启动已发布的流程\");\n        \n        var instance = new WorkflowInstance\n        {\n            Id = Guid.NewGuid().ToString(),\n            DefinitionId = definitionId,\n            DefinitionVersion = definition.PublishedVersion,\n            InitiatorId = initiatorId ?? \"system\",\n            BusinessData = data,\n            StartTime = DateTime.UtcNow\n        };\n        \n        _context.WorkflowInstances.Add(instance);\n        await _context.SaveChangesAsync();\n        \n        // 创建第一个任务\n        await CreateInitialTaskAsync(instance, definition);\n        \n        _logger.LogInformation(\"启动工作流实例: {InstanceId}\", instance.Id);\n        \n        return instance.Id;\n    }\n    \n    private async Task CreateInitialTaskAsync(WorkflowInstance instance, WorkflowDefinition definition)\n    {\n        if (definition.ApprovalNodes.Count == 0)\n            return;\n        \n        var firstNode = definition.ApprovalNodes.First();\n        var task = new WorkflowTask\n        {\n            Id = Guid.NewGuid().ToString(),\n            InstanceId = instance.Id,\n            TaskName = firstNode.NodeName,\n            NodeId = firstNode.NodeId,\n            TaskType = TaskType.ApprovalTask,\n            AssignedRoleIds = firstNode.ApproverRoleIds,\n            DueDate = DateTime.UtcNow.AddHours(firstNode.TimeoutHours)\n        };\n        \n        _context.WorkflowTasks.Add(task);\n        await _context.SaveChangesAsync();\n    }\n    \n    public async Task<WorkflowInstance?> GetWorkflowInstanceAsync(string instanceId)\n    {\n        return await _context.WorkflowInstances\n            .FirstOrDefaultAsync(i => i.Id == instanceId);\n    }\n    \n    public async Task<PagedResult<WorkflowInstance>> GetWorkflowInstancesAsync(\n        int page = 1, int pageSize = 20,\n        string? definitionId = null,\n        WorkflowInstanceState? state = null,\n        string? initiatorId = null)\n    {\n        var query = _context.WorkflowInstances.AsQueryable();\n        \n        if (!string.IsNullOrEmpty(definitionId))\n            query = query.Where(i => i.DefinitionId == definitionId);\n        \n        if (state.HasValue)\n            query = query.Where(i => i.State == state.Value);\n        \n        if (!string.IsNullOrEmpty(initiatorId))\n            query = query.Where(i => i.InitiatorId == initiatorId);\n        \n        var totalCount = await query.CountAsync();\n        var items = await query\n            .OrderByDescending(i => i.StartTime)\n            .Skip((page - 1) * pageSize)\n            .Take(pageSize)\n            .ToListAsync();\n        \n        return new PagedResult<WorkflowInstance>\n        {\n            Items = items,\n            TotalCount = totalCount,\n            Page = page,\n            PageSize = pageSize\n        };\n    }\n    \n    public async Task SuspendWorkflowInstanceAsync(string instanceId)\n    {\n        var instance = await GetWorkflowInstanceAsync(instanceId);\n        if (instance == null)\n            throw new InvalidOperationException($\"流程实例不存在: {instanceId}\");\n        \n        instance.State = WorkflowInstanceState.Suspended;\n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"挂起流程实例: {InstanceId}\", instanceId);\n    }\n    \n    public async Task ResumeWorkflowInstanceAsync(string instanceId)\n    {\n        var instance = await GetWorkflowInstanceAsync(instanceId);\n        if (instance == null)\n            throw new InvalidOperationException($\"流程实例不存在: {instanceId}\");\n        \n        instance.State = WorkflowInstanceState.Running;\n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"恢复流程实例: {InstanceId}\", instanceId);\n    }\n    \n    public async Task CancelWorkflowInstanceAsync(string instanceId, string reason)\n    {\n        var instance = await GetWorkflowInstanceAsync(instanceId);\n        if (instance == null)\n            throw new InvalidOperationException($\"流程实例不存在: {instanceId}\");\n        \n        instance.State = WorkflowInstanceState.Cancelled;\n        instance.EndTime = DateTime.UtcNow;\n        \n        // 取消所有待办任务\n        var pendingTasks = await _context.WorkflowTasks\n            .Where(t => t.InstanceId == instanceId && t.State == TaskState.Pending)\n            .ToListAsync();\n        \n        foreach (var task in pendingTasks)\n        {\n            task.State = TaskState.Cancelled;\n        }\n        \n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"取消流程实例: {InstanceId}, 原因: {Reason}\", instanceId, reason);\n    }\n    \n    #endregion\n    \n    #region 任务管理\n    \n    public async Task<PagedResult<WorkflowTask>> GetPendingTasksAsync(\n        string userId, int page = 1, int pageSize = 20)\n    {\n        var query = _context.WorkflowTasks\n            .Where(t => t.State == TaskState.Pending)\n            .Where(t => t.AssignedUserId == userId);\n        \n        var totalCount = await query.CountAsync();\n        var items = await query\n            .OrderByDescending(t => t.CreateTime)\n            .Skip((page - 1) * pageSize)\n            .Take(pageSize)\n            .ToListAsync();\n        \n        return new PagedResult<WorkflowTask>\n        {\n            Items = items,\n            TotalCount = totalCount,\n            Page = page,\n            PageSize = pageSize\n        };\n    }\n    \n    public async Task<PagedResult<WorkflowTask>> GetCompletedTasksAsync(\n        string userId, int page = 1, int pageSize = 20)\n    {\n        var query = _context.WorkflowTasks\n            .Where(t => t.State == TaskState.Completed)\n            .Where(t => t.AssignedUserId == userId);\n        \n        var totalCount = await query.CountAsync();\n        var items = await query\n            .OrderByDescending(t => t.CompletedTime)\n            .Skip((page - 1) * pageSize)\n            .Take(pageSize)\n            .ToListAsync();\n        \n        return new PagedResult<WorkflowTask>\n        {\n            Items = items,\n            TotalCount = totalCount,\n            Page = page,\n            PageSize = pageSize\n        };\n    }\n    \n    public async Task<WorkflowTask?> GetTaskAsync(string taskId)\n    {\n        return await _context.WorkflowTasks\n            .FirstOrDefaultAsync(t => t.Id == taskId);\n    }\n    \n    public async Task ClaimTaskAsync(string taskId, string userId)\n    {\n        var task = await GetTaskAsync(taskId);\n        if (task == null)\n            throw new InvalidOperationException($\"任务不存在: {taskId}\");\n        \n        if (task.State != TaskState.Pending)\n            throw new InvalidOperationException(\"只能认领待办任务\");\n        \n        task.AssignedUserId = userId;\n        task.State = TaskState.InProgress;\n        \n        await _context.SaveChangesAsync();\n        \n        _logger.LogInformation(\"认领任务: {TaskId}, 用户: {UserId}\", taskId, userId);\n    }\n    \n    public async Task CompleteTaskAsync(string taskId, string userId, string? comment = null)\n    {\n        var task = await GetTaskAsync(taskId);\n        if (task == null)\n            throw new InvalidOperationException($\"任务不存在: {taskId}\");\n        \n        task.State = TaskState.Completed;\n        task.CompletedTime = DateTime.UtcNow;\n        task.Comment = comment;\n        \n        await _context.SaveChangesAsync();\n        \n        // 推进流程\n        await MoveToNextNodeAsync(task);\n        \n        _logger.LogInformation(\"完成任务: {TaskId}, 用户: {UserId}\", taskId, userId);\n    }\n    \n    private async Task MoveToNextNodeAsync(WorkflowTask task)\n    {\n        var instance = await GetWorkflowInstanceAsync(task.InstanceId);\n        if (instance == null) return;\n        \n        var definition = await GetWorkflowAsync(instance.DefinitionId);\n        if (definition == null) return;\n        \n        var currentNodeIndex = definition.ApprovalNodes\n            .FindIndex(n => n.NodeId == task.NodeId);\n        \n        if (currentNodeIndex < definition.ApprovalNodes.Count - 1)\n        {\n            // 还有下一个节点，创建下一个任务\n            var nextNode = definition.ApprovalNodes[currentNodeIndex + 1];\n            await CreateTaskForNodeAsync(instance, nextNode);\n        }\n        else\n        {\n            // 流程结束\n            instance.State = WorkflowInstanceState.Completed;\n            instance.EndTime = DateTime.UtcNow;\n            await _context.SaveChangesAsync();\n        }\n    }\n    \n    private async Task CreateTaskForNodeAsync(WorkflowInstance instance, ApprovalNode node)\n    {\n        var task = new WorkflowTask\n        {\n            Id = Guid.NewGuid().ToString(),\n            InstanceId = instance.Id,\n            TaskName = node.NodeName,\n            NodeId = node.NodeId,\n            TaskType = TaskType.ApprovalTask,\n            AssignedRoleIds = node.ApproverRoleIds,\n            DueDate = DateTime.UtcNow.AddHours(node.TimeoutHours)\n        };\n        \n        _context.WorkflowTasks.Add(task);\n        await _context.SaveChangesAsync();\n    }\n    \n    #endregion\n    \n    #region 审批操作\n    \n    public async Task ApproveTaskAsync(string taskId, string userId, string? comment = null)\n    {\n        var task = await GetTaskAsync(taskId);\n        if (task == null)\n            throw new InvalidOperationException($\"任务不存在: {taskId}\");\n        \n        task.ApprovalResult = ApprovalResult.Approved;\n        \n        await CompleteTaskAsync(taskId, userId, comment);\n        \n        // 记录审批历史\n        await RecordApprovalAsync(task, userId, ApprovalAction.Approve, comment);\n    }\n    \n    public async Task RejectTaskAsync(string taskId, string userId, string? comment = null)\n    {\n        var task = await GetTaskAsync(taskId);\n        if (task == null)\n            throw new InvalidOperationException($\"任务不存在: {taskId}\");\n        \n        task.ApprovalResult = ApprovalResult.Rejected;\n        task.State = TaskState.Completed;\n        task.CompletedTime = DateTime.UtcNow;\n        task.Comment = comment;\n        \n        await _context.SaveChangesAsync();\n        \n        // 拒绝时结束流程\n        var instance = await GetWorkflowInstanceAsync(task.InstanceId);\n        if (instance != null)\n        {\n            instance.State = WorkflowInstanceState.Cancelled;\n            instance.EndTime = DateTime.UtcNow;\n            await _context.SaveChangesAsync();\n        }\n        \n        await RecordApprovalAsync(task, userId, ApprovalAction.Reject, comment);\n    }\n    \n    public async Task TransferTaskAsync(\n        string taskId, string fromUserId, string toUserId, string? comment = null)\n    {\n        var task = await GetTaskAsync(taskId);\n        if (task == null)\n            throw new InvalidOperationException($\"任务不存在: {taskId}\");\n        \n        task.AssignedUserId = toUserId;\n        \n        await _context.SaveChangesAsync();\n        \n        await RecordApprovalAsync(task, fromUserId, ApprovalAction.Transfer, comment, toUserId);\n        \n        _logger.LogInformation(\"转办任务: {TaskId}, 从 {FromUser} 到 {ToUser}\", \n            taskId, fromUserId, toUserId);\n    }\n    \n    public async Task DelegateTaskAsync(\n        string taskId, string fromUserId, string toUserId, string? comment = null)\n    {\n        var task = await GetTaskAsync(taskId);\n        if (task == null)\n            throw new InvalidOperationException($\"任务不存在: {taskId}\");\n        \n        // 委派不同于转办，委派后任务会返回给原处理人\n        // 这里简化处理，实际应该记录委派关系\n        var originalUserId = task.AssignedUserId;\n        task.AssignedUserId = toUserId;\n        \n        await _context.SaveChangesAsync();\n        \n        await RecordApprovalAsync(task, fromUserId, ApprovalAction.Delegate, comment, toUserId);\n        \n        _logger.LogInformation(\"委派任务: {TaskId}, 从 {FromUser} 到 {ToUser}\", \n            taskId, fromUserId, toUserId);\n    }\n    \n    public async Task<List<ApprovalRecord>> GetApprovalRecordsAsync(string instanceId)\n    {\n        return await _context.ApprovalRecords\n            .Where(r => r.InstanceId == instanceId)\n            .OrderBy(r => r.OperationTime)\n            .ToListAsync();\n    }\n    \n    private async Task RecordApprovalAsync(\n        WorkflowTask task, \n        string userId, \n        ApprovalAction action, \n        string? comment,\n        string? transferToUserId = null)\n    {\n        var record = new ApprovalRecord\n        {\n            InstanceId = task.InstanceId,\n            TaskId = task.Id,\n            NodeId = task.NodeId,\n            OperatorId = userId,\n            Action = action,\n            Comment = comment,\n            TransferToUserId = transferToUserId\n        };\n        \n        _context.ApprovalRecords.Add(record);\n        await _context.SaveChangesAsync();\n    }\n    \n    #endregion\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":648,"output":3537,"cacheRead":20480,"cacheWrite":0,"totalTokens":24665,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774223847145}}
