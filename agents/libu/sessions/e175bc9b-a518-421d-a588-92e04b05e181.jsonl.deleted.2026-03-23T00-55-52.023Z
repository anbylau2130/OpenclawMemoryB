{"type":"message","id":"e91f5fad","parentId":"d29b65d3","timestamp":"2026-03-23T00:04:02.794Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建测试和示例数据初始化脚本。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_fd9353ab54c7466c80b4379c","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/Data/WorkflowDataSeeder.cs","content":"using Tianyou.Core.Abstractions.Workflow;\n\nnamespace Tianyou.WorkflowService.Data;\n\n/// <summary>\n/// 工作流示例数据初始化\n/// </summary>\npublic static class WorkflowDataSeeder\n{\n    /// <summary>\n    /// 初始化示例数据\n    /// </summary>\n    public static void Seed(WorkflowDbContext context)\n    {\n        if (context.WorkflowDefinitions.Any())\n            return;\n        \n        // 创建请假审批流程\n        var leaveWorkflow = new WorkflowDefinition\n        {\n            Id = Guid.NewGuid().ToString(),\n            Code = \"LEAVE_APPROVAL\",\n            Name = \"请假审批流程\",\n            Description = \"员工请假审批流程，支持事假、病假、年假等多种类型\",\n            Category = \"人事审批\",\n            Status = WorkflowStatus.Published,\n            PublishedVersion = 1,\n            BpmnXml = GetLeaveApprovalBpmn(),\n            ApprovalNodes = new List<ApprovalNode>\n            {\n                new ApprovalNode\n                {\n                    NodeId = \"Node_Manager\",\n                    NodeName = \"部门经理审批\",\n                    ApprovalType = ApprovalType.OrSign,\n                    ApproverRoleIds = new List<string> { \"manager\" },\n                    TimeoutHours = 24\n                },\n                new ApprovalNode\n                {\n                    NodeId = \"Node_HR\",\n                    NodeName = \"人事审批\",\n                    ApprovalType = ApprovalType.OrSign,\n                    ApproverRoleIds = new List<string> { \"hr\" },\n                    TimeoutHours = 48\n                }\n            }\n        };\n        \n        context.WorkflowDefinitions.Add(leaveWorkflow);\n        \n        // 创建报销审批流程\n        var expenseWorkflow = new WorkflowDefinition\n        {\n            Id = Guid.NewGuid().ToString(),\n            Code = \"EXPENSE_APPROVAL\",\n            Name = \"费用报销审批\",\n            Description = \"费用报销审批流程，根据金额自动路由\",\n            Category = \"财务审批\",\n            Status = WorkflowStatus.Published,\n            PublishedVersion = 1,\n            BpmnXml = GetExpenseApprovalBpmn(),\n            ApprovalNodes = new List<ApprovalNode>\n            {\n                new ApprovalNode\n                {\n                    NodeId = \"Node_Supervisor\",\n                    NodeName = \"直属领导审批\",\n                    ApprovalType = ApprovalType.OrSign,\n                    ApproverRoleIds = new List<string> { \"supervisor\" },\n                    TimeoutHours = 48\n                },\n                new ApprovalNode\n                {\n                    NodeId = \"Node_Finance\",\n                    NodeName = \"财务审批\",\n                    ApprovalType = ApprovalType.AndSign,\n                    ApproverRoleIds = new List<string> { \"finance\" },\n                    TimeoutHours = 72\n                }\n            }\n        };\n        \n        context.WorkflowDefinitions.Add(expenseWorkflow);\n        \n        // 创建采购审批流程\n        var purchaseWorkflow = new WorkflowDefinition\n        {\n            Id = Guid.NewGuid().ToString(),\n            Code = \"PURCHASE_APPROVAL\",\n            Name = \"采购审批流程\",\n            Description = \"采购申请审批流程\",\n            Category = \"财务审批\",\n            Status = WorkflowStatus.Published,\n            PublishedVersion = 1,\n            BpmnXml = GetPurchaseApprovalBpmn(),\n            ApprovalNodes = new List<ApprovalNode>\n            {\n                new ApprovalNode\n                {\n                    NodeId = \"Node_Department\",\n                    NodeName = \"部门负责人审批\",\n                    ApprovalType = ApprovalType.OrSign,\n                    ApproverRoleIds = new List<string> { \"dept_head\" },\n                    TimeoutHours = 48\n                },\n                new ApprovalNode\n                {\n                    NodeId = \"Node_Purchase\",\n                    NodeName = \"采购部审批\",\n                    ApprovalType = ApprovalType.OrSign,\n                    ApproverRoleIds = new List<string> { \"purchase\" },\n                    TimeoutHours = 72\n                },\n                new ApprovalNode\n                {\n                    NodeId = \"Node_CFO\",\n                    NodeName = \"财务总监审批\",\n                    ApprovalType = ApprovalType.OrSign,\n                    ApproverRoleIds = new List<string> { \"cfo\" },\n                    TimeoutHours = 96\n                }\n            }\n        };\n        \n        context.WorkflowDefinitions.Add(purchaseWorkflow);\n        \n        context.SaveChanges();\n    }\n    \n    private static string GetLeaveApprovalBpmn()\n    {\n        return @\"<?xml version=\"\"1.0\"\" encoding=\"\"UTF-8\"\"?>\n<bpmn:definitions xmlns:bpmn=\"\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\"\n                 xmlns:bpmndi=\"\"http://www.omg.org/spec/BPMN/20100524/DI\"\"\n                 xmlns:dc=\"\"http://www.omg.org/spec/DD/20100524/DC\"\"\n                 targetNamespace=\"\"http://tianyou.com/workflow\"\">\n  <bpmn:process id=\"\"LeaveApproval\"\" name=\"\"请假审批\"\">\n    <bpmn:startEvent id=\"\"Start\"\" name=\"\"开始\"\" />\n    <bpmn:userTask id=\"\"Node_Manager\"\" name=\"\"部门经理审批\"\" />\n    <bpmn:userTask id=\"\"Node_HR\"\" name=\"\"人事审批\"\" />\n    <bpmn:endEvent id=\"\"End\"\" name=\"\"结束\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Start\"\" targetRef=\"\"Node_Manager\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Node_Manager\"\" targetRef=\"\"Node_HR\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Node_HR\"\" targetRef=\"\"End\"\" />\n  </bpmn:process>\n</bpmn:definitions>\";\n    }\n    \n    private static string GetExpenseApprovalBpmn()\n    {\n        return @\"<?xml version=\"\"1.0\"\" encoding=\"\"UTF-8\"\"?>\n<bpmn:definitions xmlns:bpmn=\"\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\"\n                 xmlns:bpmndi=\"\"http://www.omg.org/spec/BPMN/20100524/DI\"\"\n                 xmlns:dc=\"\"http://www.omg.org/spec/DD/20100524/DC\"\"\n                 targetNamespace=\"\"http://tianyou.com/workflow\"\">\n  <bpmn:process id=\"\"ExpenseApproval\"\" name=\"\"费用报销审批\"\">\n    <bpmn:startEvent id=\"\"Start\"\" name=\"\"开始\"\" />\n    <bpmn:userTask id=\"\"Node_Supervisor\"\" name=\"\"直属领导审批\"\" />\n    <bpmn:userTask id=\"\"Node_Finance\"\" name=\"\"财务审批\"\" />\n    <bpmn:endEvent id=\"\"End\"\" name=\"\"结束\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Start\"\" targetRef=\"\"Node_Supervisor\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Node_Supervisor\"\" targetRef=\"\"Node_Finance\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Node_Finance\"\" targetRef=\"\"End\"\" />\n  </bpmn:process>\n</bpmn:definitions>\";\n    }\n    \n    private static string GetPurchaseApprovalBpmn()\n    {\n        return @\"<?xml version=\"\"1.0\"\" encoding=\"\"UTF-8\"\"?>\n<bpmn:definitions xmlns:bpmn=\"\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\"\n                 xmlns:bpmndi=\"\"http://www.omg.org/spec/BPMN/20100524/DI\"\"\n                 xmlns:dc=\"\"http://www.omg.org/spec/DD/20100524/DC\"\"\n                 targetNamespace=\"\"http://tianyou.com/workflow\"\">\n  <bpmn:process id=\"\"PurchaseApproval\"\" name=\"\"采购审批\"\">\n    <bpmn:startEvent id=\"\"Start\"\" name=\"\"开始\"\" />\n    <bpmn:userTask id=\"\"Node_Department\"\" name=\"\"部门负责人审批\"\" />\n    <bpmn:userTask id=\"\"Node_Purchase\"\" name=\"\"采购部审批\"\" />\n    <bpmn:userTask id=\"\"Node_CFO\"\" name=\"\"财务总监审批\"\" />\n    <bpmn:endEvent id=\"\"End\"\" name=\"\"结束\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Start\"\" targetRef=\"\"Node_Department\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Node_Department\"\" targetRef=\"\"Node_Purchase\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Node_Purchase\"\" targetRef=\"\"Node_CFO\"\" />\n    <bpmn:sequenceFlow sourceRef=\"\"Node_CFO\"\" targetRef=\"\"End\"\" />\n  </bpmn:process>\n</bpmn:definitions>\";\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1454,"output":1827,"cacheRead":37824,"cacheWrite":0,"totalTokens":41105,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774224211783}}
