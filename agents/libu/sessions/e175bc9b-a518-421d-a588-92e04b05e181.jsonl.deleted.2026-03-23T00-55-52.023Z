{"type":"message","id":"ba5477e0","parentId":"137d5152","timestamp":"2026-03-22T23:58:48.391Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建数据库上下文。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_3d3bd23472884f559b75f687","name":"write","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/Data/WorkflowDbContext.cs","content":"using Microsoft.EntityFrameworkCore;\nusing Tianyou.Core.Abstractions.Workflow;\n\nnamespace Tianyou.WorkflowService.Data;\n\n/// <summary>\n/// 工作流数据库上下文\n/// </summary>\npublic class WorkflowDbContext : DbContext\n{\n    public WorkflowDbContext(DbContextOptions<WorkflowDbContext> options)\n        : base(options)\n    {\n    }\n    \n    public DbSet<WorkflowDefinition> WorkflowDefinitions { get; set; }\n    public DbSet<WorkflowInstance> WorkflowInstances { get; set; }\n    public DbSet<WorkflowTask> WorkflowTasks { get; set; }\n    public DbSet<ApprovalRecord> ApprovalRecords { get; set; }\n    \n    protected override void OnModelCreating(ModelBuilder modelBuilder)\n    {\n        base.OnModelCreating(modelBuilder);\n        \n        // WorkflowDefinition\n        modelBuilder.Entity<WorkflowDefinition>(entity =>\n        {\n            entity.HasKey(e => e.Id);\n            entity.Property(e => e.Name).IsRequired().HasMaxLength(200);\n            entity.Property(e => e.Category).HasMaxLength(100);\n            entity.Property(e => e.BpmnXml).HasColumnType(\"nvarchar(max)\");\n            entity.Property(e => e.Variables).HasColumnType(\"nvarchar(max)\");\n            \n            entity.OwnsMany(e => e.ApprovalNodes, a =>\n            {\n                a.WithOwner().HasForeignKey(\"WorkflowDefinitionId\");\n                a.Property<Guid>(\"WorkflowDefinitionId\");\n                a.Property<string>(\"Id\").IsRequired();\n                a.HasKey(\"Id\");\n            });\n        });\n        \n        // WorkflowInstance\n        modelBuilder.Entity<WorkflowInstance>(entity =>\n        {\n            entity.HasKey(e => e.Id);\n            entity.Property(e => e.DefinitionId).IsRequired();\n            entity.Property(e => e.InitiatorId).IsRequired().HasMaxLength(100);\n            entity.Property(e => e.BusinessData).HasColumnType(\"nvarchar(max)\");\n            \n            entity.HasIndex(e => e.DefinitionId);\n            entity.HasIndex(e => e.InitiatorId);\n            entity.HasIndex(e => e.State);\n        });\n        \n        // WorkflowTask\n        modelBuilder.Entity<WorkflowTask>(entity =>\n        {\n            entity.HasKey(e => e.Id);\n            entity.Property(e => e.InstanceId).IsRequired();\n            entity.Property(e => e.NodeId).IsRequired().HasMaxLength(100);\n            entity.Property(e => e.AssignedUserId).HasMaxLength(100);\n            \n            entity.HasIndex(e => e.InstanceId);\n            entity.HasIndex(e => e.AssignedUserId);\n            entity.HasIndex(e => e.State);\n        });\n        \n        // ApprovalRecord\n        modelBuilder.Entity<ApprovalRecord>(entity =>\n        {\n            entity.HasKey(e => e.Id);\n            entity.Property(e => e.InstanceId).IsRequired();\n            entity.Property(e => e.OperatorId).IsRequired().HasMaxLength(100);\n            \n            entity.HasIndex(e => e.InstanceId);\n        });\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":3586,"output":602,"cacheRead":21120,"cacheWrite":0,"totalTokens":25308,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774223914476}}
