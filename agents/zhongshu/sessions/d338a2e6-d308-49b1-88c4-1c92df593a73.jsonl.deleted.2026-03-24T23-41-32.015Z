{"type":"message","id":"236032a9","parentId":"15784d8a","timestamp":"2026-03-24T22:44:51.392Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"很好！登录页面已创建。现在创建注册页面：","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_84675a82f55345eaaac355f2","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/Register.razor","content":"@page \"/register\"\n@inject Tianyou.Web.Services.AuthService AuthService\n@inject NavigationManager NavigationManager\n@inject ILogger<Register> Logger\n\n<div class=\"container mt-5\">\n    <div class=\"row justify-content-center\">\n        <div class=\"col-md-6 col-lg-4\">\n            <div class=\"card shadow\">\n                <div class=\"card-header bg-success text-white text-center\">\n                    <h4 class=\"mb-0\">✨ 用户注册</h4>\n                </div>\n                <div class=\"card-body\">\n                    @if (!string.IsNullOrEmpty(ErrorMessage))\n                    {\n                        <div class=\"alert alert-danger alert-dismissible fade show\" role=\"alert\">\n                            @ErrorMessage\n                            <button type=\"button\" class=\"btn-close\" @onclick=\"ClearError\"></button>\n                        </div>\n                    }\n                    \n                    @if (!string.IsNullOrEmpty(SuccessMessage))\n                    {\n                        <div class=\"alert alert-success alert-dismissible fade show\" role=\"alert\">\n                            @SuccessMessage\n                            <button type=\"button\" class=\"btn-close\" @onclick=\"ClearSuccess\"></button>\n                        </div>\n                    }\n                    \n                    <EditForm Model=\"@registerModel\" OnValidSubmit=\"@HandleRegister\" class=\"needs-validation\">\n                        <DataAnnotationsValidator />\n                        \n                        <div class=\"mb-3\">\n                            <label for=\"username\" class=\"form-label\">用户名 *</label>\n                            <InputText id=\"username\" @bind-Value=\"registerModel.Username\" class=\"form-control\" placeholder=\"请输入用户名\" required />\n                            <ValidationMessage For=\"@(() => registerModel.Username)\" class=\"text-danger\" />\n                        </div>\n                        \n                        <div class=\"mb-3\">\n                            <label for=\"email\" class=\"form-label\">邮箱 *</label>\n                            <InputText id=\"email\" type=\"email\" @bind-Value=\"registerModel.Email\" class=\"form-control\" placeholder=\"请输入邮箱\" required />\n                            <ValidationMessage For=\"@(() => registerModel.Email)\" class=\"text-danger\" />\n                        </div>\n                        \n                        <div class=\"mb-3\">\n                            <label for=\"fullName\" class=\"form-label\">姓名</label>\n                            <InputText id=\"fullName\" @bind-Value=\"registerModel.FullName\" class=\"form-control\" placeholder=\"请输入姓名（选填）\" />\n                            <ValidationMessage For=\"@(() => registerModel.FullName)\" class=\"text-danger\" />\n                        </div>\n                        \n                        <div class=\"mb-3\">\n                            <label for=\"password\" class=\"form-label\">密码 *</label>\n                            <InputText id=\"password\" type=\"password\" @bind-Value=\"registerModel.Password\" class=\"form-control\" placeholder=\"请输入密码（至少6位）\" required />\n                            <ValidationMessage For=\"@(() => registerModel.Password)\" class=\"text-danger\" />\n                        </div>\n                        \n                        <div class=\"mb-3\">\n                            <label for=\"confirmPassword\" class=\"form-label\">确认密码 *</label>\n                            <InputText id=\"confirmPassword\" type=\"password\" @bind-Value=\"registerModel.ConfirmPassword\" class=\"form-control\" placeholder=\"请再次输入密码\" required />\n                            <ValidationMessage For=\"@(() => registerModel.ConfirmPassword)\" class=\"text-danger\" />\n                        </div>\n                        \n                        <div class=\"d-grid gap-2\">\n                            <button type=\"submit\" class=\"btn btn-success\" disabled=\"@IsLoading\">\n                                @if (IsLoading)\n                                {\n                                    <span class=\"spinner-border spinner-border-sm me-2\" role=\"status\" aria-hidden=\"true\"></span>\n                                    <span>注册中...</span>\n                                }\n                                else\n                                {\n                                    <span>🎉 注册</span>\n                                }\n                            </button>\n                        </div>\n                    </EditForm>\n                    \n                    <hr class=\"my-4\" />\n                    \n                    <div class=\"text-center\">\n                        <p class=\"mb-0\">\n                            已有账号？\n                            <a href=\"/login\" class=\"text-decoration-none\">立即登录</a>\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n@code {\n    private RegisterModel registerModel = new RegisterModel();\n    private bool IsLoading = false;\n    private string? ErrorMessage;\n    private string? SuccessMessage;\n    \n    protected override async Task OnInitializedAsync()\n    {\n        // 检查是否已登录\n        var isAuthenticated = await AuthService.IsAuthenticatedAsync();\n        if (isAuthenticated)\n        {\n            NavigationManager.NavigateTo(\"/\");\n        }\n    }\n    \n    private async Task HandleRegister()\n    {\n        // 验证密码是否一致\n        if (registerModel.Password != registerModel.ConfirmPassword)\n        {\n            ErrorMessage = \"两次输入的密码不一致\";\n            return;\n        }\n        \n        IsLoading = true;\n        ErrorMessage = null;\n        SuccessMessage = null;\n        \n        try\n        {\n            var result = await AuthService.RegisterAsync(\n                registerModel.Username,\n                registerModel.Email,\n                registerModel.Password,\n                registerModel.FullName ?? string.Empty\n            );\n            \n            if (result.Success)\n            {\n                Logger.LogInformation(\"注册成功，自动登录并跳转到首页\");\n                SuccessMessage = \"注册成功！正在跳转...\";\n                \n                // 短暂延迟后跳转\n                await Task.Delay(1000);\n                NavigationManager.NavigateTo(\"/\");\n            }\n            else\n            {\n                ErrorMessage = result.Message ?? \"注册失败，请重试\";\n            }\n        }\n        catch (Exception ex)\n        {\n            Logger.LogError(ex, \"注册异常\");\n            ErrorMessage = $\"注册失败: {ex.Message}\";\n        }\n        finally\n        {\n            IsLoading = false;\n        }\n    }\n    \n    private void ClearError()\n    {\n        ErrorMessage = null;\n    }\n    \n    private void ClearSuccess()\n    {\n        SuccessMessage = null;\n    }\n    \n    public class RegisterModel\n    {\n        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = \"用户名不能为空\")]\n        [System.ComponentModel.DataAnnotations.StringLength(50, MinimumLength = 3, ErrorMessage = \"用户名长度3-50个字符\")]\n        public string Username { get; set; } = string.Empty;\n        \n        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = \"邮箱不能为空\")]\n        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = \"邮箱格式不正确\")]\n        public string Email { get; set; } = string.Empty;\n        \n        public string? FullName { get; set; }\n        \n        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = \"密码不能为空\")]\n        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 6, ErrorMessage = \"密码长度至少6个字符\")]\n        public string Password { get; set; } = string.Empty;\n        \n        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = \"请确认密码\")]\n        public string ConfirmPassword { get; set; } = string.Empty;\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":991,"output":1481,"cacheRead":25344,"cacheWrite":0,"totalTokens":27816,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774392258955}}
