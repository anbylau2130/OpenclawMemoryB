{"type":"message","id":"67c71f73","parentId":"3d4eb7fe","timestamp":"2026-03-24T22:45:20.976Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"很好！注册页面已创建。现在我需要修改Home页面来显示用户信息，并添加登出功能：","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_6ba8e4a14eed4ab9853efa0f","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/Home.razor","content":"@page \"/\"\n@inject Tianyou.Web.Services.AuthService AuthService\n@inject NavigationManager NavigationManager\n@inject ILogger<Home> Logger\n\n<div class=\"container mt-5\">\n    <div class=\"row justify-content-center\">\n        <div class=\"col-md-8 col-lg-6\">\n            @if (IsLoading)\n            {\n                <div class=\"text-center\">\n                    <div class=\"spinner-border text-primary\" role=\"status\">\n                        <span class=\"visually-hidden\">加载中...</span>\n                    </div>\n                    <p class=\"mt-2\">正在加载用户信息...</p>\n                </div>\n            }\n            else if (UserInfo == null)\n            {\n                <div class=\"alert alert-warning text-center\" role=\"alert\">\n                    <h4 class=\"alert-heading\">⚠️ 未登录</h4>\n                    <p>请先登录以访问系统功能</p>\n                    <hr>\n                    <div class=\"d-flex justify-content-center gap-2\">\n                        <a href=\"/login\" class=\"btn btn-primary\">🔐 立即登录</a>\n                        <a href=\"/register\" class=\"btn btn-success\">✨ 立即注册</a>\n                    </div>\n                </div>\n            }\n            else\n            {\n                <div class=\"card shadow\">\n                    <div class=\"card-header bg-primary text-white\">\n                        <h4 class=\"mb-0\">🏠 欢迎回来，@UserInfo.FullName！</h4>\n                    </div>\n                    <div class=\"card-body\">\n                        <div class=\"mb-4\">\n                            <h5 class=\"card-title\">📋 用户信息</h5>\n                            <hr>\n                            <div class=\"row mb-3\">\n                                <div class=\"col-sm-3\">\n                                    <strong>用户ID：</strong>\n                                </div>\n                                <div class=\"col-sm-9\">\n                                    <code>@UserInfo.UserId</code>\n                                </div>\n                            </div>\n                            <div class=\"row mb-3\">\n                                <div class=\"col-sm-3\">\n                                    <strong>用户名：</strong>\n                                </div>\n                                <div class=\"col-sm-9\">\n                                    @UserInfo.Username\n                                </div>\n                            </div>\n                            <div class=\"row mb-3\">\n                                <div class=\"col-sm-3\">\n                                    <strong>邮箱：</strong>\n                                </div>\n                                <div class=\"col-sm-9\">\n                                    <a href=\"mailto:@UserInfo.Email\">@UserInfo.Email</a>\n                                </div>\n                            </div>\n                            <div class=\"row mb-3\">\n                                <div class=\"col-sm-3\">\n                                    <strong>姓名：</strong>\n                                </div>\n                                <div class=\"col-sm-9\">\n                                    @UserInfo.FullName\n                                </div>\n                            </div>\n                            \n                            @if (UserInfo.Roles != null && UserInfo.Roles.Any())\n                            {\n                                <div class=\"row mb-3\">\n                                    <div class=\"col-sm-3\">\n                                        <strong>角色：</strong>\n                                    </div>\n                                    <div class=\"col-sm-9\">\n                                        @foreach (var role in UserInfo.Roles)\n                                        {\n                                            <span class=\"badge bg-info me-1\">@role</span>\n                                        }\n                                    </div>\n                                </div>\n                            }\n                            \n                            @if (UserInfo.Permissions != null && UserInfo.Permissions.Any())\n                            {\n                                <div class=\"row mb-3\">\n                                    <div class=\"col-sm-3\">\n                                        <strong>权限：</strong>\n                                    </div>\n                                    <div class=\"col-sm-9\">\n                                        @foreach (var permission in UserInfo.Permissions)\n                                        {\n                                            <span class=\"badge bg-secondary me-1\">@permission</span>\n                                        }\n                                    </div>\n                                </div>\n                            }\n                        </div>\n                        \n                        <div class=\"d-flex justify-content-end\">\n                            <button class=\"btn btn-danger\" @onclick=\"HandleLogout\">\n                                🚪 登出\n                            </button>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"card mt-4 shadow\">\n                    <div class=\"card-header bg-info text-white\">\n                        <h5 class=\"mb-0\">🎯 系统功能</h5>\n                    </div>\n                    <div class=\"card-body\">\n                        <div class=\"row\">\n                            <div class=\"col-md-6 mb-3\">\n                                <div class=\"card h-100 border-primary\">\n                                    <div class=\"card-body text-center\">\n                                        <h6 class=\"card-title\">📊 数据管理</h6>\n                                        <p class=\"card-text text-muted\">管理您的业务数据</p>\n                                        <button class=\"btn btn-outline-primary btn-sm\" disabled>即将上线</button>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"col-md-6 mb-3\">\n                                <div class=\"card h-100 border-success\">\n                                    <div class=\"card-body text-center\">\n                                        <h6 class=\"card-title\">⚙️ 系统设置</h6>\n                                        <p class=\"card-text text-muted\">配置系统参数</p>\n                                        <button class=\"btn btn-outline-success btn-sm\" disabled>即将上线</button>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            }\n        </div>\n    </div>\n</div>\n\n@code {\n    private Tianyou.Web.Services.UserInfo? UserInfo;\n    private bool IsLoading = true;\n    \n    protected override async Task OnInitializedAsync()\n    {\n        await LoadUserInfo();\n    }\n    \n    private async Task LoadUserInfo()\n    {\n        try\n        {\n            // 检查是否已登录\n            var isAuthenticated = await AuthService.IsAuthenticatedAsync();\n            \n            if (!isAuthenticated)\n            {\n                UserInfo = null;\n                IsLoading = false;\n                return;\n            }\n            \n            // 获取用户信息\n            UserInfo = await AuthService.GetCurrentUserAsync();\n            \n            if (UserInfo == null)\n            {\n                Logger.LogWarning(\"获取用户信息失败，可能Token已过期\");\n            }\n        }\n        catch (Exception ex)\n        {\n            Logger.LogError(ex, \"加载用户信息异常\");\n            UserInfo = null;\n        }\n        finally\n        {\n            IsLoading = false;\n        }\n    }\n    \n    private async Task HandleLogout()\n    {\n        try\n        {\n            await AuthService.LogoutAsync();\n            Logger.LogInformation(\"用户已登出\");\n            NavigationManager.NavigateTo(\"/login\");\n        }\n        catch (Exception ex)\n        {\n            Logger.LogError(ex, \"登出异常\");\n        }\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1551,"output":1442,"cacheRead":26304,"cacheWrite":0,"totalTokens":29297,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774392291432}}
