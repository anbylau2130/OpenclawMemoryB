{"type":"message","id":"90674807","parentId":"1f33beb3","timestamp":"2026-03-21T07:28:37.305Z","message":{"role":"toolResult","toolCallId":"call_1aaaf0d619544e0c8f3302c0","toolName":"exec","content":[{"type":"text","text":"# 启动 watchdog 监控\n    if [ -f /root/.openclaw/workspace/scripts/pm2-watchdog.sh ]; then\n        su - root -c \"nohup /root/.openclaw/workspace/scripts/pm2-watchdog.sh > /root/.openclaw/workspace/logs/pm2-watchdog.out 2>&1 &\"\n        echo \"Started PM2 watchdog\"\n    fi\n}\n\nstop() {\n    super $PM2 kill\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"# 启动 watchdog 监控\n    if [ -f /root/.openclaw/workspace/scripts/pm2-watchdog.sh ]; then\n        su - root -c \"nohup /root/.openclaw/workspace/scripts/pm2-watchdog.sh > /root/.openclaw/workspace/logs/pm2-watchdog.out 2>&1 &\"\n        echo \"Started PM2 watchdog\"\n    fi\n}\n\nstop() {\n    super $PM2 kill\n}","cwd":"/root/.openclaw/workspace"},"isError":false,"timestamp":1774078117279}}
