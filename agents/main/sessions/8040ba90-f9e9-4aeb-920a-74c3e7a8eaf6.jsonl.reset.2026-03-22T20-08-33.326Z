{"type":"message","id":"640c4787","parentId":"0fad9447","timestamp":"2026-03-22T03:56:59.355Z","message":{"role":"toolResult","toolCallId":"call_9fad2f5e6d5146949dfa6983","toolName":"exec","content":[{"type":"text","text":"#   bash install-lite.sh --no-gui     # 跳过 Dashboard Web UI\n#   bash install-lite.sh --with-gui   # 包含 Dashboard Web UI\n# ============================================\nset -e\n\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nCYAN='\\033[0;36m'\nNC='\\033[0m'\n\n--\nINSTALL_GUI=\"\"\nfor arg in \"$@\"; do\n    case \"$arg\" in\n        --no-gui)  INSTALL_GUI=\"no\" ;;\n        --with-gui) INSTALL_GUI=\"yes\" ;;\n    esac\ndone\n\necho \"\"\necho -e \"${BLUE}🏛️ AI 朝廷 — 精简配置${NC}\"\necho \"================================\"\necho -e \"适用于已安装 OpenClaw 的用户\"\necho \"\"\n\n# ---- 检查 OpenClaw 是否已安装 ----\n--\n# ---- 是否安装 Dashboard Web UI ----"}],"details":{"status":"completed","exitCode":0,"durationMs":22,"aggregated":"#   bash install-lite.sh --no-gui     # 跳过 Dashboard Web UI\n#   bash install-lite.sh --with-gui   # 包含 Dashboard Web UI\n# ============================================\nset -e\n\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nCYAN='\\033[0;36m'\nNC='\\033[0m'\n\n--\nINSTALL_GUI=\"\"\nfor arg in \"$@\"; do\n    case \"$arg\" in\n        --no-gui)  INSTALL_GUI=\"no\" ;;\n        --with-gui) INSTALL_GUI=\"yes\" ;;\n    esac\ndone\n\necho \"\"\necho -e \"${BLUE}🏛️ AI 朝廷 — 精简配置${NC}\"\necho \"================================\"\necho -e \"适用于已安装 OpenClaw 的用户\"\necho \"\"\n\n# ---- 检查 OpenClaw 是否已安装 ----\n--\n# ---- 是否安装 Dashboard Web UI ----","cwd":"/root/.openclaw/workspace"},"isError":false,"timestamp":1774151819317}}
