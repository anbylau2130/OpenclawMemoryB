{"type":"message","id":"70bba0b6","parentId":"59fabd7b","timestamp":"2026-03-24T23:50:26.134Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"工作流模块的3个页面已创建完成。现在继续创建系统管理模块的5个页面。","thinkingSignature":"reasoning_content"},{"type":"text","text":"工作流模块完成！继续创建系统管理模块："},{"type":"toolCall","id":"call_60c645c4ac2047e4a4bc3424","name":"write","arguments":{"content":"@page \"/admin/users\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>用户管理</h3>\n\n<div class=\"mb-3 d-flex justify-content-between\">\n    <div class=\"input-group\" style=\"max-width: 300px;\">\n        <input type=\"text\" class=\"form-control\" placeholder=\"搜索用户...\" @bind=\"searchKeyword\" />\n        <button class=\"btn btn-outline-secondary\" type=\"button\">🔍</button>\n    </div>\n    <button class=\"btn btn-primary\" data-bs-toggle=\"modal\" data-bs-target=\"#userModal\" @onclick=\"NewUser\">\n        ➕ 添加用户\n    </button>\n</div>\n\n@if (users == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse\n{\n    <div class=\"table-responsive\">\n        <table class=\"table table-hover\">\n            <thead>\n                <tr>\n                    <th>头像</th>\n                    <th>用户名</th>\n                    <th>邮箱</th>\n                    <th>姓名</th>\n                    <th>角色</th>\n                    <th>状态</th>\n                    <th>创建时间</th>\n                    <th>操作</th>\n                </tr>\n            </thead>\n            <tbody>\n                @foreach (var user in FilteredUsers)\n                {\n                    <tr>\n                        <td>\n                            <div class=\"avatar-circle bg-primary text-white\">\n                                @(user.FullName?.FirstOrDefault() ?? user.Username.FirstOrDefault())\n                            </div>\n                        </td>\n                        <td>@user.Username</td>\n                        <td>@user.Email</td>\n                        <td>@user.FullName</td>\n                        <td>\n                            @if (user.Roles != null)\n                            {\n                                @foreach (var role in user.Roles.Take(2))\n                                {\n                                    <span class=\"badge bg-info me-1\">@role</span>\n                                }\n                                @if (user.Roles.Count > 2)\n                                {\n                                    <span class=\"badge bg-secondary\">+@(user.Roles.Count - 2)</span>\n                                }\n                            }\n                        </td>\n                        <td>\n                            @if (user.IsActive)\n                            {\n                                <span class=\"badge bg-success\">激活</span>\n                            }\n                            else\n                            {\n                                <span class=\"badge bg-secondary\">停用</span>\n                            }\n                        </td>\n                        <td>@user.CreatedAt.ToString(\"yyyy-MM-dd\")</td>\n                        <td>\n                            <div class=\"btn-group btn-group-sm\">\n                                <button class=\"btn btn-outline-primary\" @onclick=\"() => EditUser(user)\" title=\"编辑\">\n                                    ✏️\n                                </button>\n                                <button class=\"btn btn-outline-warning\" @onclick=\"() => ResetPassword(user.UserId)\" title=\"重置密码\">\n                                    🔑\n                                </button>\n                                <button class=\"btn btn-outline-@(user.IsActive ? \"warning\" : \"success\")\" \n                                        @onclick=\"() => ToggleUserStatus(user.UserId, !user.IsActive)\" title=\"@(user.IsActive ? \"停用\" : \"激活\")\">\n                                    @(user.IsActive ? \"⏸️\" : \"▶️\")\n                                </button>\n                                <button class=\"btn btn-outline-danger\" @onclick=\"() => DeleteUser(user.UserId)\" title=\"删除\">\n                                    🗑️\n                                </button>\n                            </div>\n                        </td>\n                    </tr>\n                }\n            </tbody>\n        </table>\n    </div>\n\n    <div class=\"d-flex justify-content-between align-items-center\">\n        <small class=\"text-muted\">共 @FilteredUsers.Count() 个用户</small>\n    </div>\n}\n\n<!-- User Modal -->\n<div class=\"modal fade\" id=\"userModal\" tabindex=\"-1\">\n    <div class=\"modal-dialog\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h5 class=\"modal-title\">@(editingUserId.HasValue ? \"编辑用户\" : \"添加用户\")</h5>\n                <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"mb-3\">\n                    <label class=\"form-label\">用户名 <span class=\"text-danger\">*</span></label>\n                    <input type=\"text\" class=\"form-control\" @bind=\"userForm.Username\"\n                           placeholder=\"请输入用户名\" />\n                </div>\n                <div class=\"mb-3\">\n                    <label class=\"form-label\">邮箱 <span class=\"text-danger\">*</span></label>\n                    <input type=\"email\" class=\"form-control\" @bind=\"userForm.Email\"\n                           placeholder=\"请输入邮箱\" />\n                </div>\n                <div class=\"mb-3\">\n                    <label class=\"form-label\">姓名 <span class=\"text-danger\">*</span></label>\n                    <input type=\"text\" class=\"form-control\" @bind=\"userForm.FullName\"\n                           placeholder=\"请输入姓名\" />\n                </div>\n                @if (!editingUserId.HasValue)\n                {\n                    <div class=\"mb-3\">\n                        <label class=\"form-label\">密码 <span class=\"text-danger\">*</span></label>\n                        <input type=\"password\" class=\"form-control\" @bind=\"userForm.Password\"\n                               placeholder=\"请输入密码\" />\n                    </div>\n                }\n                <div class=\"mb-3\">\n                    <label class=\"form-label\">角色</label>\n                    <select class=\"form-select\" @bind=\"userForm.SelectedRole\">\n                        <option value=\"\">请选择角色</option>\n                        @foreach (var role in availableRoles)\n                        {\n                            <option value=\"@role\">@role</option>\n                        }\n                    </select>\n                </div>\n                <div class=\"mb-3 form-check\">\n                    <input type=\"checkbox\" class=\"form-check-input\" @bind=\"userForm.IsActive\" />\n                    <label class=\"form-check-label\">激活账户</label>\n                </div>\n            </div>\n            <div class=\"modal-footer\">\n                <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">取消</button>\n                <button type=\"button\" class=\"btn btn-primary\" @onclick=\"SaveUser\" disabled=\"@isSaving\">\n                    @if (isSaving)\n                    {\n                        <span class=\"spinner-border spinner-border-sm me-2\"></span>\n                    }\n                    保存\n                </button>\n            </div>\n        </div>\n    </div>\n</div>\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n<style>\n    .avatar-circle {\n        width: 40px;\n        height: 40px;\n        border-radius: 50%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-weight: bold;\n    }\n</style>\n\n@code {\n    private List<UserDto>? users;\n    private string searchKeyword = \"\";\n    private Guid? editingUserId;\n    private UserFormModel userForm = new();\n    private bool isSaving = false;\n    private string? errorMessage;\n    private string? successMessage;\n    private List<string> availableRoles = new() { \"Admin\", \"Manager\", \"User\", \"Guest\" };\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadUsers();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadUsers()\n    {\n        try\n        {\n            // Mock data for demo - in real app, call API\n            users = new List<UserDto>\n            {\n                new UserDto { UserId = Guid.NewGuid(), Username = \"admin\", Email = \"admin@example.com\", FullName = \"系统管理员\", Roles = new List<string> { \"Admin\" }, IsActive = true, CreatedAt = DateTime.Now.AddDays(-30) },\n                new UserDto { UserId = Guid.NewGuid(), Username = \"manager\", Email = \"manager@example.com\", FullName = \"部门经理\", Roles = new List<string> { \"Manager\" }, IsActive = true, CreatedAt = DateTime.Now.AddDays(-20) },\n                new UserDto { UserId = Guid.NewGuid(), Username = \"user1\", Email = \"user1@example.com\", FullName = \"张三\", Roles = new List<string> { \"User\" }, IsActive = true, CreatedAt = DateTime.Now.AddDays(-10) },\n                new UserDto { UserId = Guid.NewGuid(), Username = \"user2\", Email = \"user2@example.com\", FullName = \"李四\", Roles = new List<string> { \"User\" }, IsActive = false, CreatedAt = DateTime.Now.AddDays(-5) }\n            };\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private IEnumerable<UserDto> FilteredUsers => \n        users?.Where(u => string.IsNullOrEmpty(searchKeyword) || \n            u.Username.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase) ||\n            u.Email.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase) ||\n            (u.FullName?.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase) ?? false))\n        ?? Enumerable.Empty<UserDto>();\n\n    private void NewUser()\n    {\n        editingUserId = null;\n        userForm = new UserFormModel { IsActive = true };\n    }\n\n    private void EditUser(UserDto user)\n    {\n        editingUserId = user.UserId;\n        userForm = new UserFormModel\n        {\n            Username = user.Username,\n            Email = user.Email,\n            FullName = user.FullName ?? \"\",\n            IsActive = user.IsActive,\n            SelectedRole = user.Roles?.FirstOrDefault() ?? \"\"\n        };\n    }\n\n    private async Task SaveUser()\n    {\n        isSaving = true;\n        errorMessage = null;\n\n        try\n        {\n            // Mock save - in real app, call API\n            await Task.Delay(500);\n            successMessage = editingUserId.HasValue ? \"用户更新成功！\" : \"用户创建成功！\";\n            await LoadUsers();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"保存失败: {ex.Message}\";\n        }\n        finally\n        {\n            isSaving = false;\n        }\n    }\n\n    private async Task ResetPassword(Guid userId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要重置该用户的密码吗？\"))\n            return;\n\n        try\n        {\n            await Task.Delay(300);\n            successMessage = \"密码已重置为默认密码：123456\";\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"重置失败: {ex.Message}\";\n        }\n    }\n\n    private async Task ToggleUserStatus(Guid userId, bool activate)\n    {\n        var action = activate ? \"激活\" : \"停用\";\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", $\"确定要{action}该用户吗？\"))\n            return;\n\n        try\n        {\n            await Task.Delay(300);\n            successMessage = $\"用户已{action}！\";\n            await LoadUsers();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"{action}失败: {ex.Message}\";\n        }\n    }\n\n    private async Task DeleteUser(Guid userId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要删除该用户吗？此操作不可恢复！\"))\n            return;\n\n        try\n        {\n            await Task.Delay(300);\n            successMessage = \"用户已删除！\";\n            await LoadUsers();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"删除失败: {ex.Message}\";\n        }\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class UserDto\n    {\n        public Guid UserId { get; set; }\n        public string Username { get; set; } = \"\";\n        public string Email { get; set; } = \"\";\n        public string? FullName { get; set; }\n        public List<string>? Roles { get; set; }\n        public bool IsActive { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class UserFormModel\n    {\n        public string Username { get; set; } = \"\";\n        public string Email { get; set; } = \"\";\n        public string FullName { get; set; } = \"\";\n        public string Password { get; set; } = \"\";\n        public string SelectedRole { get; set; } = \"\";\n        public bool IsActive { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/UserManagement.razor"}},{"type":"toolCall","id":"call_502be8d1318843098e52f69e","name":"write","arguments":{"content":"@page \"/admin/roles\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>角色管理</h3>\n\n<div class=\"mb-3 d-flex justify-content-between\">\n    <div></div>\n    <button class=\"btn btn-primary\" data-bs-toggle=\"modal\" data-bs-target=\"#roleModal\" @onclick=\"NewRole\">\n        ➕ 添加角色\n    </button>\n</div>\n\n@if (roles == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var role in roles)\n        {\n            <div class=\"col-md-6 mb-3\">\n                <div class=\"card\">\n                    <div class=\"card-header d-flex justify-content-between align-items-center\">\n                        <h6 class=\"mb-0\">\n                            <span class=\"badge bg-primary me-2\">@role.RoleName</span>\n                            @if (role.IsSystem)\n                            {\n                                <span class=\"badge bg-secondary\">系统角色</span>\n                            }\n                        </h6>\n                        <div class=\"btn-group btn-group-sm\">\n                            <button class=\"btn btn-outline-primary\" @onclick=\"() => EditRole(role)\" title=\"编辑\">\n                                ✏️\n                            </button>\n                            @if (!role.IsSystem)\n                            {\n                                <button class=\"btn btn-outline-danger\" @onclick=\"() => DeleteRole(role.RoleId)\" title=\"删除\">\n                                    🗑️\n                                </button>\n                            }\n                        </div>\n                    </div>\n                    <div class=\"card-body\">\n                        <p class=\"card-text text-muted\">@(role.Description ?? \"暂无描述\")</p>\n                        <div class=\"mb-2\">\n                            <strong>权限列表:</strong>\n                        </div>\n                        <div class=\"permission-list\">\n                            @if (role.Permissions != null && role.Permissions.Any())\n                            {\n                                @foreach (var group in role.Permissions.GroupBy(p => p.Category))\n                                {\n                                    <div class=\"mb-2\">\n                                        <small class=\"text-muted\">@group.Key:</small>\n                                        <div class=\"ms-2\">\n                                            @foreach (var permission in group)\n                                            {\n                                                <span class=\"badge bg-light text-dark me-1 mb-1\">@permission.Name</span>\n                                            }\n                                        </div>\n                                    </div>\n                                }\n                            }\n                            else\n                            {\n                                <small class=\"text-muted\">暂无权限</small>\n                            }\n                        </div>\n                        <div class=\"mt-3\">\n                            <small class=\"text-muted\">用户数: @role.UserCount</small>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n<!-- Role Modal -->\n<div class=\"modal fade\" id=\"roleModal\" tabindex=\"-1\">\n    <div class=\"modal-dialog modal-lg\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h5 class=\"modal-title\">@(editingRoleId.HasValue ? \"编辑角色\" : \"添加角色\")</h5>\n                <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"row\">\n                    <div class=\"col-md-6\">\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">角色名称 <span class=\"text-danger\">*</span></label>\n                            <input type=\"text\" class=\"form-control\" @bind=\"roleForm.RoleName\"\n                                   placeholder=\"例如：Admin, Manager, User\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">角色描述</label>\n                            <textarea class=\"form-control\" rows=\"3\" @bind=\"roleForm.Description\"\n                                      placeholder=\"请输入角色描述...\"></textarea>\n                        </div>\n                    </div>\n                    <div class=\"col-md-6\">\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">权限配置</label>\n                            <div class=\"permission-tree\" style=\"max-height: 300px; overflow-y: auto;\">\n                                @foreach (var category in allPermissions.GroupBy(p => p.Category))\n                                {\n                                    <div class=\"card mb-2\">\n                                        <div class=\"card-header py-2\">\n                                            <div class=\"form-check\">\n                                                <input type=\"checkbox\" class=\"form-check-input\"\n                                                       @bind=\"GetCategoryChecked(category.Key)\" />\n                                                <label class=\"form-check-label fw-bold\">@category.Key</label>\n                                            </div>\n                                        </div>\n                                        <div class=\"card-body py-2\">\n                                            @foreach (var permission in category)\n                                            {\n                                                <div class=\"form-check\">\n                                                    <input type=\"checkbox\" class=\"form-check-input\"\n                                                           @bind=\"permission.IsSelected\" />\n                                                    <label class=\"form-check-label\">@permission.Name</label>\n                                                </div>\n                                            }\n                                        </div>\n                                    </div>\n                                }\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"modal-footer\">\n                <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">取消</button>\n                <button type=\"button\" class=\"btn btn-primary\" @onclick=\"SaveRole\" disabled=\"@isSaving\">\n                    @if (isSaving)\n                    {\n                        <span class=\"spinner-border spinner-border-sm me-2\"></span>\n                    }\n                    保存\n                </button>\n            </div>\n        </div>\n    </div>\n</div>\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n@code {\n    private List<RoleDto>? roles;\n    private Guid? editingRoleId;\n    private RoleFormModel roleForm = new();\n    private List<PermissionDto> allPermissions = new();\n    private bool isSaving = false;\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadRoles();\n        LoadAllPermissions();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadRoles()\n    {\n        try\n        {\n            // Mock data\n            roles = new List<RoleDto>\n            {\n                new RoleDto \n                { \n                    RoleId = Guid.NewGuid(), \n                    RoleName = \"Admin\", \n                    Description = \"系统管理员，拥有所有权限\",\n                    IsSystem = true,\n                    UserCount = 1,\n                    Permissions = new List<PermissionInfo>\n                    {\n                        new PermissionInfo { Category = \"系统管理\", Name = \"用户管理\" },\n                        new PermissionInfo { Category = \"系统管理\", Name = \"角色管理\" },\n                        new PermissionInfo { Category = \"系统管理\", Name = \"系统配置\" },\n                        new PermissionInfo { Category = \"数据管理\", Name = \"数据查看\" },\n                        new PermissionInfo { Category = \"数据管理\", Name = \"数据编辑\" },\n                        new PermissionInfo { Category = \"数据管理\", Name = \"数据删除\" }\n                    }\n                },\n                new RoleDto \n                { \n                    RoleId = Guid.NewGuid(), \n                    RoleName = \"Manager\", \n                    Description = \"部门经理，管理本部门数据\",\n                    IsSystem = true,\n                    UserCount = 3,\n                    Permissions = new List<PermissionInfo>\n                    {\n                        new PermissionInfo { Category = \"数据管理\", Name = \"数据查看\" },\n                        new PermissionInfo { Category = \"数据管理\", Name = \"数据编辑\" },\n                        new PermissionInfo { Category = \"工作流\", Name = \"审批\" }\n                    }\n                },\n                new RoleDto \n                { \n                    RoleId = Guid.NewGuid(), \n                    RoleName = \"User\", \n                    Description = \"普通用户\",\n                    IsSystem = true,\n                    UserCount = 10,\n                    Permissions = new List<PermissionInfo>\n                    {\n                        new PermissionInfo { Category = \"数据管理\", Name = \"数据查看\" }\n                    }\n                }\n            };\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private void LoadAllPermissions()\n    {\n        allPermissions = new List<PermissionDto>\n        {\n            new PermissionDto { Category = \"系统管理\", Name = \"用户管理\", Code = \"system:user\" },\n            new PermissionDto { Category = \"系统管理\", Name = \"角色管理\", Code = \"system:role\" },\n            new PermissionDto { Category = \"系统管理\", Name = \"系统配置\", Code = \"system:config\" },\n            new PermissionDto { Category = \"系统管理\", Name = \"日志查看\", Code = \"system:log\" },\n            new PermissionDto { Category = \"数据管理\", Name = \"数据查看\", Code = \"data:view\" },\n            new PermissionDto { Category = \"数据管理\", Name = \"数据编辑\", Code = \"data:edit\" },\n            new PermissionDto { Category = \"数据管理\", Name = \"数据删除\", Code = \"data:delete\" },\n            new PermissionDto { Category = \"数据管理\", Name = \"数据导出\", Code = \"data:export\" },\n            new PermissionDto { Category = \"工作流\", Name = \"流程设计\", Code = \"workflow:design\" },\n            new PermissionDto { Category = \"工作流\", Name = \"审批\", Code = \"workflow:approve\" },\n            new PermissionDto { Category = \"工作流\", Name = \"查看实例\", Code = \"workflow:view\" }\n        };\n    }\n\n    private bool GetCategoryChecked(string category)\n    {\n        var categoryPermissions = allPermissions.Where(p => p.Category == category);\n        return categoryPermissions.All(p => p.IsSelected);\n    }\n\n    private void NewRole()\n    {\n        editingRoleId = null;\n        roleForm = new RoleFormModel();\n        allPermissions.ForEach(p => p.IsSelected = false);\n    }\n\n    private void EditRole(RoleDto role)\n    {\n        editingRoleId = role.RoleId;\n        roleForm = new RoleFormModel\n        {\n            RoleName = role.RoleName,\n            Description = role.Description ?? \"\"\n        };\n\n        // Set selected permissions\n        foreach (var permission in allPermissions)\n        {\n            permission.IsSelected = role.Permissions?.Any(p => p.Name == permission.Name) ?? false;\n        }\n    }\n\n    private async Task SaveRole()\n    {\n        if (string.IsNullOrEmpty(roleForm.RoleName))\n        {\n            errorMessage = \"角色名称不能为空\";\n            return;\n        }\n\n        isSaving = true;\n        errorMessage = null;\n\n        try\n        {\n            await Task.Delay(500);\n            successMessage = editingRoleId.HasValue ? \"角色更新成功！\" : \"角色创建成功！\";\n            await LoadRoles();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"保存失败: {ex.Message}\";\n        }\n        finally\n        {\n            isSaving = false;\n        }\n    }\n\n    private async Task DeleteRole(Guid roleId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要删除该角色吗？\"))\n            return;\n\n        try\n        {\n            await Task.Delay(300);\n            successMessage = \"角色已删除！\";\n            await LoadRoles();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"删除失败: {ex.Message}\";\n        }\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class RoleDto\n    {\n        public Guid RoleId { get; set; }\n        public string RoleName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsSystem { get; set; }\n        public int UserCount { get; set; }\n        public List<PermissionInfo>? Permissions { get; set; }\n    }\n\n    public class PermissionInfo\n    {\n        public string Category { get; set; } = \"\";\n        public string Name { get; set; } = \"\";\n    }\n\n    public class PermissionDto\n    {\n        public string Category { get; set; } = \"\";\n        public string Name { get; set; } = \"\";\n        public string Code { get; set; } = \"\";\n        public bool IsSelected { get; set; }\n    }\n\n    public class RoleFormModel\n    {\n        public string RoleName { get; set; } = \"\";\n        public string Description { get; set; } = \"\";\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/RoleManagement.razor"}},{"type":"toolCall","id":"call_a8dae79f05a44a6298be20cf","name":"write","arguments":{"content":"@page \"/admin/plugins\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>插件管理</h3>\n\n<div class=\"mb-3 d-flex justify-content-between\">\n    <div>\n        <button class=\"btn btn-outline-primary\" @onclick=\"RefreshPlugins\">\n            🔄 刷新\n        </button>\n        <button class=\"btn btn-outline-info ms-2\" @onclick=\"CheckUpdates\">\n            📥 检查更新\n        </button>\n    </div>\n    <button class=\"btn btn-primary\" @onclick=\"InstallPlugin\">\n        ➕ 安装插件\n    </button>\n</div>\n\n@if (plugins == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var plugin in plugins)\n        {\n            <div class=\"col-md-6 mb-3\">\n                <div class=\"card\">\n                    <div class=\"card-header d-flex justify-content-between align-items-center\">\n                        <div>\n                            <h6 class=\"mb-0\">@plugin.PluginName</h6>\n                            <small class=\"text-muted\">v@plugin.Version</small>\n                        </div>\n                        @if (plugin.IsEnabled)\n                        {\n                            <span class=\"badge bg-success\">已启用</span>\n                        }\n                        else\n                        {\n                            <span class=\"badge bg-secondary\">已禁用</span>\n                        }\n                    </div>\n                    <div class=\"card-body\">\n                        <p class=\"card-text\">@(plugin.Description ?? \"暂无描述\")</p>\n                        <div class=\"mb-2\">\n                            <small class=\"text-muted\">\n                                <strong>作者:</strong> @plugin.Author<br/>\n                                <strong>类别:</strong> @plugin.Category<br/>\n                                <strong>安装时间:</strong> @plugin.InstalledAt.ToString(\"yyyy-MM-dd\")\n                            </small>\n                        </div>\n                        @if (plugin.Dependencies != null && plugin.Dependencies.Any())\n                        {\n                            <div class=\"mb-2\">\n                                <small><strong>依赖:</strong></small>\n                                @foreach (var dep in plugin.Dependencies)\n                                {\n                                    <span class=\"badge bg-light text-dark me-1\">@dep</span>\n                                }\n                            </div>\n                        }\n                    </div>\n                    <div class=\"card-footer\">\n                        <div class=\"btn-group btn-group-sm w-100\">\n                            @if (plugin.IsEnabled)\n                            {\n                                <button class=\"btn btn-outline-warning\" @onclick=\"() => TogglePlugin(plugin.PluginId, false)\">\n                                    ⏸️ 禁用\n                                </button>\n                            }\n                            else\n                            {\n                                <button class=\"btn btn-outline-success\" @onclick=\"() => TogglePlugin(plugin.PluginId, true)\">\n                                    ▶️ 启用\n                                </button>\n                            }\n                            <button class=\"btn btn-outline-info\" @onclick=\"() => ConfigurePlugin(plugin)\">\n                                ⚙️ 配置\n                            </button>\n                            <button class=\"btn btn-outline-primary\" @onclick=\"() => UpdatePlugin(plugin.PluginId)\">\n                                📥 更新\n                            </button>\n                            <button class=\"btn btn-outline-danger\" @onclick=\"() => UninstallPlugin(plugin.PluginId)\">\n                                🗑️ 卸载\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n\n    <div class=\"mt-3\">\n        <h5>插件市场</h5>\n        <hr />\n        <div class=\"row\">\n            @foreach (var availablePlugin in availablePlugins)\n            {\n                <div class=\"col-md-4 mb-3\">\n                    <div class=\"card h-100\">\n                        <div class=\"card-body\">\n                            <h6 class=\"card-title\">@availablePlugin.Name</h6>\n                            <p class=\"card-text small text-muted\">@availablePlugin.Description</p>\n                            <div class=\"d-flex justify-content-between align-items-center\">\n                                <small class=\"text-muted\">⭐ @availablePlugin.Rating</small>\n                                <button class=\"btn btn-primary btn-sm\" @onclick=\"() => InstallFromMarket(availablePlugin.Id)\">\n                                    📥 安装\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            }\n        </div>\n    </div>\n}\n\n<!-- Plugin Config Modal -->\n@if (configuringPlugin != null)\n{\n    <div class=\"modal fade show\" style=\"display: block; background: rgba(0,0,0,0.5);\">\n        <div class=\"modal-dialog\">\n            <div class=\"modal-content\">\n                <div class=\"modal-header\">\n                    <h5 class=\"modal-title\">配置 - @configuringPlugin.PluginName</h5>\n                    <button type=\"button\" class=\"btn-close\" @onclick=\"CloseConfigModal\"></button>\n                </div>\n                <div class=\"modal-body\">\n                    @if (configuringPlugin.ConfigItems != null)\n                    {\n                        @foreach (var item in configuringPlugin.ConfigItems)\n                        {\n                            <div class=\"mb-3\">\n                                <label class=\"form-label\">@item.Label</label>\n                                @switch (item.Type)\n                                {\n                                    case \"text\":\n                                        <input type=\"text\" class=\"form-control\" @bind=\"item.Value\" />\n                                        break;\n                                    case \"number\":\n                                        <input type=\"number\" class=\"form-control\" @bind=\"item.Value\" />\n                                        break;\n                                    case \"boolean\":\n                                        <div class=\"form-check\">\n                                            <input type=\"checkbox\" class=\"form-check-input\" @bind=\"item.Value\" />\n                                        </div>\n                                        break;\n                                    case \"select\":\n                                        <select class=\"form-select\" @bind=\"item.Value\">\n                                            @foreach (var option in item.Options ?? new List<string>())\n                                            {\n                                                <option value=\"@option\">@option</option>\n                                            }\n                                        </select>\n                                        break;\n                                }\n                                @if (!string.IsNullOrEmpty(item.Description))\n                                {\n                                    <small class=\"text-muted\">@item.Description</small>\n                                }\n                            </div>\n                        }\n                    }\n                    else\n                    {\n                        <p class=\"text-muted\">该插件无需配置</p>\n                    }\n                </div>\n                <div class=\"modal-footer\">\n                    <button type=\"button\" class=\"btn btn-secondary\" @onclick=\"CloseConfigModal\">取消</button>\n                    <button type=\"button\" class=\"btn btn-primary\" @onclick=\"SavePluginConfig\">保存</button>\n                </div>\n            </div>\n        </div>\n    </div>\n}\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n@code {\n    private List<PluginDto>? plugins;\n    private List<AvailablePluginDto> availablePlugins = new();\n    private PluginDto? configuringPlugin;\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadPlugins();\n        LoadAvailablePlugins();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadPlugins()\n    {\n        try\n        {\n            // Mock data\n            plugins = new List<PluginDto>\n            {\n                new PluginDto\n                {\n                    PluginId = Guid.NewGuid(),\n                    PluginName = \"数据导入导出\",\n                    Version = \"1.2.0\",\n                    Description = \"支持Excel、CSV格式的数据导入导出\",\n                    Author = \"Tianyou Team\",\n                    Category = \"数据工具\",\n                    IsEnabled = true,\n                    InstalledAt = DateTime.Now.AddDays(-30)\n                },\n                new PluginDto\n                {\n                    PluginId = Guid.NewGuid(),\n                    PluginName = \"消息推送\",\n                    Version = \"2.0.1\",\n                    Description = \"支持邮件、短信、钉钉等多种消息推送方式\",\n                    Author = \"Tianyou Team\",\n                    Category = \"通知服务\",\n                    IsEnabled = true,\n                    InstalledAt = DateTime.Now.AddDays(-20),\n                    Dependencies = new List<string> { \"消息队列\" }\n                },\n                new PluginDto\n                {\n                    PluginId = Guid.NewGuid(),\n                    PluginName = \"图表报表\",\n                    Version = \"1.5.0\",\n                    Description = \"提供丰富的图表组件和报表生成功能\",\n                    Author = \"Third Party\",\n                    Category = \"可视化\",\n                    IsEnabled = false,\n                    InstalledAt = DateTime.Now.AddDays(-10)\n                }\n            };\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private void LoadAvailablePlugins()\n    {\n        availablePlugins = new List<AvailablePluginDto>\n        {\n            new AvailablePluginDto { Id = \"plugin-1\", Name = \"工作日历\", Description = \"日历视图和任务管理\", Rating = 4.5 },\n            new AvailablePluginDto { Id = \"plugin-2\", Name = \"AI助手\", Description = \"集成AI对话和智能推荐\", Rating = 4.8 },\n            new AvailablePluginDto { Id = \"plugin-3\", Name = \"多语言支持\", Description = \"国际化多语言切换\", Rating = 4.2 }\n        };\n    }\n\n    private async Task RefreshPlugins()\n    {\n        await LoadPlugins();\n        successMessage = \"插件列表已刷新\";\n    }\n\n    private async Task CheckUpdates()\n    {\n        await Task.Delay(500);\n        successMessage = \"已检查更新，所有插件均为最新版本\";\n    }\n\n    private void InstallPlugin()\n    {\n        // Open file upload dialog or navigate to plugin market\n        successMessage = \"请从插件市场选择插件安装\";\n    }\n\n    private async Task InstallFromMarket(string pluginId)\n    {\n        try\n        {\n            await Task.Delay(500);\n            successMessage = \"插件安装成功！\";\n            await LoadPlugins();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"安装失败: {ex.Message}\";\n        }\n    }\n\n    private async Task TogglePlugin(Guid pluginId, bool enable)\n    {\n        var plugin = plugins?.FirstOrDefault(p => p.PluginId == pluginId);\n        if (plugin != null)\n        {\n            plugin.IsEnabled = enable;\n            successMessage = enable ? \"插件已启用\" : \"插件已禁用\";\n        }\n    }\n\n    private void ConfigurePlugin(PluginDto plugin)\n    {\n        configuringPlugin = plugin;\n        // Load plugin configuration\n        if (configuringPlugin.ConfigItems == null)\n        {\n            configuringPlugin.ConfigItems = new List<ConfigItemDto>\n            {\n                new ConfigItemDto { Label = \"启用调试模式\", Type = \"boolean\", Value = \"false\" },\n                new ConfigItemDto { Label = \"日志级别\", Type = \"select\", Options = new List<string> { \"Debug\", \"Info\", \"Warning\", \"Error\" }, Value = \"Info\" }\n            };\n        }\n    }\n\n    private void CloseConfigModal()\n    {\n        configuringPlugin = null;\n    }\n\n    private async Task SavePluginConfig()\n    {\n        await Task.Delay(300);\n        successMessage = \"配置已保存\";\n        CloseConfigModal();\n    }\n\n    private async Task UpdatePlugin(Guid pluginId)\n    {\n        try\n        {\n            await Task.Delay(500);\n            successMessage = \"插件更新成功！\";\n            await LoadPlugins();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"更新失败: {ex.Message}\";\n        }\n    }\n\n    private async Task UninstallPlugin(Guid pluginId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要卸载该插件吗？\"))\n            return;\n\n        try\n        {\n            await Task.Delay(300);\n            successMessage = \"插件已卸载\";\n            await LoadPlugins();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"卸载失败: {ex.Message}\";\n        }\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class PluginDto\n    {\n        public Guid PluginId { get; set; }\n        public string PluginName { get; set; } = \"\";\n        public string Version { get; set; } = \"\";\n        public string? Description { get; set; }\n        public string Author { get; set; } = \"\";\n        public string Category { get; set; } = \"\";\n        public bool IsEnabled { get; set; }\n        public DateTime InstalledAt { get; set; }\n        public List<string>? Dependencies { get; set; }\n        public List<ConfigItemDto>? ConfigItems { get; set; }\n    }\n\n    public class ConfigItemDto\n    {\n        public string Label { get; set; } = \"\";\n        public string Type { get; set; } = \"text\";\n        public string? Description { get; set; }\n        public string Value { get; set; } = \"\";\n        public List<string>? Options { get; set; }\n    }\n\n    public class AvailablePluginDto\n    {\n        public string Id { get; set; } = \"\";\n        public string Name { get; set; } = \"\";\n        public string Description { get; set; } = \"\";\n        public double Rating { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/PluginManagement.razor"}},{"type":"toolCall","id":"call_68ac329660214024be9355f6","name":"write","arguments":{"content":"@page \"/admin/tenants\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>租户管理</h3>\n\n<div class=\"mb-3 d-flex justify-content-between\">\n    <div class=\"input-group\" style=\"max-width: 300px;\">\n        <input type=\"text\" class=\"form-control\" placeholder=\"搜索租户...\" @bind=\"searchKeyword\" />\n        <button class=\"btn btn-outline-secondary\">🔍</button>\n    </div>\n    <button class=\"btn btn-primary\" data-bs-toggle=\"modal\" data-bs-target=\"#tenantModal\" @onclick=\"NewTenant\">\n        ➕ 添加租户\n    </button>\n</div>\n\n@if (tenants == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse\n{\n    <div class=\"table-responsive\">\n        <table class=\"table table-hover\">\n            <thead>\n                <tr>\n                    <th>租户名称</th>\n                    <th>租户代码</th>\n                    <th>套餐</th>\n                    <th>用户数</th>\n                    <th>状态</th>\n                    <th>到期时间</th>\n                    <th>创建时间</th>\n                    <th>操作</th>\n                </tr>\n            </thead>\n            <tbody>\n                @foreach (var tenant in FilteredTenants)\n                {\n                    <tr>\n                        <td>\n                            <strong>@tenant.TenantName</strong>\n                            @if (tenant.IsDefault)\n                            {\n                                <span class=\"badge bg-primary ms-1\">默认</span>\n                            }\n                        </td>\n                        <td><code>@tenant.TenantCode</code></td>\n                        <td>\n                            <span class=\"badge bg-@GetPlanBadgeColor(tenant.Plan)\">@tenant.Plan</span>\n                        </td>\n                        <td>\n                            <span class=\"badge bg-info\">@tenant.UserCount / @tenant.MaxUsers</span>\n                        </td>\n                        <td>\n                            @if (tenant.IsActive)\n                            {\n                                <span class=\"badge bg-success\">激活</span>\n                            }\n                            else\n                            {\n                                <span class=\"badge bg-secondary\">停用</span>\n                            }\n                        </td>\n                        <td>\n                            @if (tenant.ExpireDate.HasValue)\n                            {\n                                @if (tenant.ExpireDate.Value < DateTime.Now)\n                                {\n                                    <span class=\"text-danger\">@tenant.ExpireDate.Value.ToString(\"yyyy-MM-dd\") (已过期)</span>\n                                }\n                                else if (tenant.ExpireDate.Value < DateTime.Now.AddDays(7))\n                                {\n                                    <span class=\"text-warning\">@tenant.ExpireDate.Value.ToString(\"yyyy-MM-dd\") (即将到期)</span>\n                                }\n                                else\n                                {\n                                    @tenant.ExpireDate.Value.ToString(\"yyyy-MM-dd\")\n                                }\n                            }\n                            else\n                            {\n                                <span class=\"text-muted\">永久</span>\n                            }\n                        </td>\n                        <td>@tenant.CreatedAt.ToString(\"yyyy-MM-dd\")</td>\n                        <td>\n                            <div class=\"btn-group btn-group-sm\">\n                                <button class=\"btn btn-outline-primary\" @onclick=\"() => EditTenant(tenant)\" title=\"编辑\">\n                                    ✏️\n                                </button>\n                                <button class=\"btn btn-outline-info\" @onclick=\"() => ViewTenantDetail(tenant)\" title=\"详情\">\n                                    👁️\n                                </button>\n                                <button class=\"btn btn-outline-@(tenant.IsActive ? \"warning\" : \"success\")\" \n                                        @onclick=\"() => ToggleTenantStatus(tenant.TenantId, !tenant.IsActive)\">\n                                    @(tenant.IsActive ? \"⏸️\" : \"▶️\")\n                                </button>\n                                <button class=\"btn btn-outline-secondary\" @onclick=\"() => RenewTenant(tenant.TenantId)\" title=\"续费\">\n                                    💳\n                                </button>\n                                @if (!tenant.IsDefault)\n                                {\n                                    <button class=\"btn btn-outline-danger\" @onclick=\"() => DeleteTenant(tenant.TenantId)\" title=\"删除\">\n                                        🗑️\n                                    </button>\n                                }\n                            </div>\n                        </td>\n                    </tr>\n                }\n            </tbody>\n        </table>\n    </div>\n}\n\n<!-- Tenant Modal -->\n<div class=\"modal fade\" id=\"tenantModal\" tabindex=\"-1\">\n    <div class=\"modal-dialog modal-lg\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h5 class=\"modal-title\">@(editingTenantId.HasValue ? \"编辑租户\" : \"添加租户\")</h5>\n                <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"row\">\n                    <div class=\"col-md-6\">\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">租户名称 <span class=\"text-danger\">*</span></label>\n                            <input type=\"text\" class=\"form-control\" @bind=\"tenantForm.TenantName\"\n                                   placeholder=\"例如：XX公司\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">租户代码 <span class=\"text-danger\">*</span></label>\n                            <input type=\"text\" class=\"form-control\" @bind=\"tenantForm.TenantCode\"\n                                   placeholder=\"例如：company1\" />\n                            <small class=\"text-muted\">用于URL标识，只能包含字母、数字和连字符</small>\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">联系邮箱</label>\n                            <input type=\"email\" class=\"form-control\" @bind=\"tenantForm.ContactEmail\"\n                                   placeholder=\"admin@example.com\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">联系电话</label>\n                            <input type=\"tel\" class=\"form-control\" @bind=\"tenantForm.ContactPhone\" />\n                        </div>\n                    </div>\n                    <div class=\"col-md-6\">\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">套餐</label>\n                            <select class=\"form-select\" @bind=\"tenantForm.Plan\">\n                                <option value=\"Free\">免费版</option>\n                                <option value=\"Basic\">基础版</option>\n                                <option value=\"Pro\">专业版</option>\n                                <option value=\"Enterprise\">企业版</option>\n                            </select>\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">最大用户数</label>\n                            <input type=\"number\" class=\"form-control\" @bind=\"tenantForm.MaxUsers\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">到期时间</label>\n                            <input type=\"date\" class=\"form-control\" @bind=\"tenantForm.ExpireDate\" />\n                            <small class=\"text-muted\">留空表示永久有效</small>\n                        </div>\n                        <div class=\"mb-3 form-check\">\n                            <input type=\"checkbox\" class=\"form-check-input\" @bind=\"tenantForm.IsActive\" />\n                            <label class=\"form-check-label\">激活租户</label>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"modal-footer\">\n                <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">取消</button>\n                <button type=\"button\" class=\"btn btn-primary\" @onclick=\"SaveTenant\" disabled=\"@isSaving\">\n                    @if (isSaving)\n                    {\n                        <span class=\"spinner-border spinner-border-sm me-2\"></span>\n                    }\n                    保存\n                </button>\n            </div>\n        </div>\n    </div>\n</div>\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n@code {\n    private List<TenantDto>? tenants;\n    private string searchKeyword = \"\";\n    private Guid? editingTenantId;\n    private TenantFormModel tenantForm = new();\n    private bool isSaving = false;\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadTenants();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadTenants()\n    {\n        try\n        {\n            // Mock data\n            tenants = new List<TenantDto>\n            {\n                new TenantDto\n                {\n                    TenantId = Guid.NewGuid(),\n                    TenantName = \"默认租户\",\n                    TenantCode = \"default\",\n                    Plan = \"Enterprise\",\n                    UserCount = 15,\n                    MaxUsers = 100,\n                    IsActive = true,\n                    IsDefault = true,\n                    ContactEmail = \"admin@default.com\",\n                    CreatedAt = DateTime.Now.AddMonths(-6)\n                },\n                new TenantDto\n                {\n                    TenantId = Guid.NewGuid(),\n                    TenantName = \"示例公司\",\n                    TenantCode = \"demo\",\n                    Plan = \"Pro\",\n                    UserCount = 8,\n                    MaxUsers = 20,\n                    IsActive = true,\n                    IsDefault = false,\n                    ContactEmail = \"admin@demo.com\",\n                    ExpireDate = DateTime.Now.AddDays(30),\n                    CreatedAt = DateTime.Now.AddMonths(-3)\n                },\n                new TenantDto\n                {\n                    TenantId = Guid.NewGuid(),\n                    TenantName = \"测试企业\",\n                    TenantCode = \"test\",\n                    Plan = \"Basic\",\n                    UserCount = 3,\n                    MaxUsers = 10,\n                    IsActive = false,\n                    IsDefault = false,\n                    ContactEmail = \"admin@test.com\",\n                    ExpireDate = DateTime.Now.AddDays(-5),\n                    CreatedAt = DateTime.Now.AddMonths(-1)\n                }\n            };\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private IEnumerable<TenantDto> FilteredTenants =>\n        tenants?.Where(t => string.IsNullOrEmpty(searchKeyword) ||\n            t.TenantName.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase) ||\n            t.TenantCode.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase))\n        ?? Enumerable.Empty<TenantDto>();\n\n    private string GetPlanBadgeColor(string plan) => plan switch\n    {\n        \"Free\" => \"secondary\",\n        \"Basic\" => \"info\",\n        \"Pro\" => \"primary\",\n        \"Enterprise\" => \"success\",\n        _ => \"secondary\"\n    };\n\n    private void NewTenant()\n    {\n        editingTenantId = null;\n        tenantForm = new TenantFormModel { IsActive = true, Plan = \"Basic\", MaxUsers = 10 };\n    }\n\n    private void EditTenant(TenantDto tenant)\n    {\n        editingTenantId = tenant.TenantId;\n        tenantForm = new TenantFormModel\n        {\n            TenantName = tenant.TenantName,\n            TenantCode = tenant.TenantCode,\n            ContactEmail = tenant.ContactEmail ?? \"\",\n            ContactPhone = tenant.ContactPhone ?? \"\",\n            Plan = tenant.Plan,\n            MaxUsers = tenant.MaxUsers,\n            ExpireDate = tenant.ExpireDate?.ToString(\"yyyy-MM-dd\"),\n            IsActive = tenant.IsActive\n        };\n    }\n\n    private void ViewTenantDetail(TenantDto tenant)\n    {\n        NavigationManager.NavigateTo($\"/admin/tenants/{tenant.TenantId}\");\n    }\n\n    private async Task SaveTenant()\n    {\n        if (string.IsNullOrEmpty(tenantForm.TenantName) || string.IsNullOrEmpty(tenantForm.TenantCode))\n        {\n            errorMessage = \"租户名称和代码不能为空\";\n            return;\n        }\n\n        isSaving = true;\n        errorMessage = null;\n\n        try\n        {\n            await Task.Delay(500);\n            successMessage = editingTenantId.HasValue ? \"租户更新成功！\" : \"租户创建成功！\";\n            await LoadTenants();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"保存失败: {ex.Message}\";\n        }\n        finally\n        {\n            isSaving = false;\n        }\n    }\n\n    private async Task ToggleTenantStatus(Guid tenantId, bool activate)\n    {\n        var tenant = tenants?.FirstOrDefault(t => t.TenantId == tenantId);\n        if (tenant != null)\n        {\n            tenant.IsActive = activate;\n            successMessage = activate ? \"租户已激活\" : \"租户已停用\";\n        }\n    }\n\n    private async Task RenewTenant(Guid tenantId)\n    {\n        var tenant = tenants?.FirstOrDefault(t => t.TenantId == tenantId);\n        if (tenant != null)\n        {\n            tenant.ExpireDate = DateTime.Now.AddYears(1);\n            successMessage = \"租户续费成功，有效期延长1年\";\n        }\n    }\n\n    private async Task DeleteTenant(Guid tenantId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要删除该租户吗？此操作不可恢复！\"))\n            return;\n\n        try\n        {\n            await Task.Delay(300);\n            successMessage = \"租户已删除\";\n            await LoadTenants();\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"删除失败: {ex.Message}\";\n        }\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class TenantDto\n    {\n        public Guid TenantId { get; set; }\n        public string TenantName { get; set; } = \"\";\n        public string TenantCode { get; set; } = \"\";\n        public string Plan { get; set; } = \"\";\n        public int UserCount { get; set; }\n        public int MaxUsers { get; set; }\n        public bool IsActive { get; set; }\n        public bool IsDefault { get; set; }\n        public string? ContactEmail { get; set; }\n        public string? ContactPhone { get; set; }\n        public DateTime? ExpireDate { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class TenantFormModel\n    {\n        public string TenantName { get; set; } = \"\";\n        public string TenantCode { get; set; } = \"\";\n        public string ContactEmail { get; set; } = \"\";\n        public string ContactPhone { get; set; } = \"\";\n        public string Plan { get; set; } = \"Basic\";\n        public int MaxUsers { get; set; } = 10;\n        public string? ExpireDate { get; set; }\n        public bool IsActive { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/TenantManagement.razor"}},{"type":"toolCall","id":"call_5dd294953322462eac645ce7","name":"write","arguments":{"content":"@page \"/notifications\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>通知中心</h3>\n\n<div class=\"mb-3 d-flex justify-content-between align-items-center\">\n    <div class=\"btn-group\" role=\"group\">\n        <button type=\"button\" class=\"btn @(typeFilter == \"all\" ? \"btn-primary\" : \"btn-outline-primary\")\"\n                @onclick='() => SetTypeFilter(\"all\")'>全部</button>\n        <button type=\"button\" class=\"btn @(typeFilter == \"unread\" ? \"btn-primary\" : \"btn-outline-primary\")\"\n                @onclick='() => SetTypeFilter(\"unread\")'>未读</button>\n        <button type=\"button\" class=\"btn @(typeFilter == \"system\" ? \"btn-primary\" : \"btn-outline-primary\")\"\n                @onclick='() => SetTypeFilter(\"system\")'>系统</button>\n        <button type=\"button\" class=\"btn @(typeFilter == \"workflow\" ? \"btn-primary\" : \"btn-outline-primary\")\"\n                @onclick='() => SetTypeFilter(\"workflow\")'>工作流</button>\n    </div>\n    <div>\n        <button class=\"btn btn-outline-secondary btn-sm\" @onclick=\"MarkAllAsRead\">\n            ✅ 全部已读\n        </button>\n        <button class=\"btn btn-outline-danger btn-sm ms-2\" @onclick=\"ClearAllNotifications\">\n            🗑️ 清空通知\n        </button>\n    </div>\n</div>\n\n@if (notifications == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse if (!FilteredNotifications.Any())\n{\n    <div class=\"alert alert-info text-center\">\n        <h5>📭 暂无通知</h5>\n        <p>您的通知列表是空的。</p>\n    </div>\n}\nelse\n{\n    <div class=\"list-group\">\n        @foreach (var notification in FilteredNotifications.OrderByDescending(n => n.CreatedAt))\n        {\n            <div class=\"list-group-item list-group-item-action @(!notification.IsRead ? \"list-group-item-warning\" : \"\")\">\n                <div class=\"d-flex w-100 justify-content-between\">\n                    <h6 class=\"mb-1\">\n                        @GetNotificationIcon(notification.Type) @notification.Title\n                        @if (!notification.IsRead)\n                        {\n                            <span class=\"badge bg-danger ms-1\">新</span>\n                        }\n                    </h6>\n                    <small>@GetTimeAgo(notification.CreatedAt)</small>\n                </div>\n                <p class=\"mb-1\">@notification.Content</p>\n                <div class=\"d-flex justify-content-between align-items-center mt-2\">\n                    <div>\n                        <span class=\"badge bg-@GetNotificationBadgeColor(notification.Type)\">@notification.Type</span>\n                        @if (!string.IsNullOrEmpty(notification.Source))\n                        {\n                            <small class=\"text-muted ms-2\">来源: @notification.Source</small>\n                        }\n                    </div>\n                    <div>\n                        @if (!notification.IsRead)\n                        {\n                            <button class=\"btn btn-sm btn-outline-primary\" @onclick=\"() => MarkAsRead(notification.NotificationId)\">\n                                ✅ 标记已读\n                            </button>\n                        }\n                        @if (!string.IsNullOrEmpty(notification.ActionUrl))\n                        {\n                            <a href=\"@notification.ActionUrl\" class=\"btn btn-sm btn-outline-info ms-1\">\n                                👁️ 查看\n                            </a>\n                        }\n                        <button class=\"btn btn-sm btn-outline-danger ms-1\" @onclick=\"() => DeleteNotification(notification.NotificationId)\">\n                            🗑️\n                        </button>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n\n    <div class=\"mt-3 d-flex justify-content-between align-items-center\">\n        <small class=\"text-muted\">\n            共 @FilteredNotifications.Count() 条通知 |\n            未读: @FilteredNotifications.Count(n => !n.IsRead)\n        </small>\n    </div>\n}\n\n<!-- Notification Statistics -->\n<div class=\"row mt-4\">\n    <div class=\"col-md-3\">\n        <div class=\"card text-center\">\n            <div class=\"card-body\">\n                <h5 class=\"card-title\">@notificationStats.Total</h5>\n                <p class=\"card-text text-muted\">总通知数</p>\n            </div>\n        </div>\n    </div>\n    <div class=\"col-md-3\">\n        <div class=\"card text-center\">\n            <div class=\"card-body\">\n                <h5 class=\"card-title text-warning\">@notificationStats.Unread</h5>\n                <p class=\"card-text text-muted\">未读通知</p>\n            </div>\n        </div>\n    </div>\n    <div class=\"col-md-3\">\n        <div class=\"card text-center\">\n            <div class=\"card-body\">\n                <h5 class=\"card-title text-info\">@notificationStats.Today</h5>\n                <p class=\"card-text text-muted\">今日通知</p>\n            </div>\n        </div>\n    </div>\n    <div class=\"col-md-3\">\n        <div class=\"card text-center\">\n            <div class=\"card-body\">\n                <h5 class=\"card-title text-primary\">@notificationStats.ThisWeek</h5>\n                <p class=\"card-text text-muted\">本周通知</p>\n            </div>\n        </div>\n    </div>\n</div>\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n@code {\n    private List<NotificationDto>? notifications;\n    private string typeFilter = \"all\";\n    private NotificationStats notificationStats = new();\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadNotifications();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadNotifications()\n    {\n        try\n        {\n            // Mock data\n            notifications = new List<NotificationDto>\n            {\n                new NotificationDto\n                {\n                    NotificationId = Guid.NewGuid(),\n                    Type = \"Workflow\",\n                    Title = \"审批任务待处理\",\n                    Content = \"您有一个请假申请需要审批，申请人：张三，请假天数：3天\",\n                    Source = \"请假流程\",\n                    ActionUrl = \"/workflows/my-tasks\",\n                    IsRead = false,\n                    CreatedAt = DateTime.Now.AddMinutes(-10)\n                },\n                new NotificationDto\n                {\n                    NotificationId = Guid.NewGuid(),\n                    Type = \"System\",\n                    Title = \"系统维护通知\",\n                    Content = \"系统将于今晚22:00-23:00进行例行维护，届时服务将暂停访问\",\n                    Source = \"系统管理员\",\n                    IsRead = false,\n                    CreatedAt = DateTime.Now.AddHours(-2)\n                },\n                new NotificationDto\n                {\n                    NotificationId = Guid.NewGuid(),\n                    Type = \"Workflow\",\n                    Title = \"流程已通过\",\n                    Content = \"您的报销申请已通过审批，金额：￥1,234.00\",\n                    Source = \"报销流程\",\n                    ActionUrl = \"/workflows/instances\",\n                    IsRead = true,\n                    CreatedAt = DateTime.Now.AddDays(-1)\n                },\n                new NotificationDto\n                {\n                    NotificationId = Guid.NewGuid(),\n                    Type = \"Data\",\n                    Title = \"数据导入完成\",\n                    Content = \"批量导入客户数据已完成，成功：150条，失败：2条\",\n                    Source = \"数据导入\",\n                    IsRead = true,\n                    CreatedAt = DateTime.Now.AddDays(-2)\n                },\n                new NotificationDto\n                {\n                    NotificationId = Guid.NewGuid(),\n                    Type = \"System\",\n                    Title = \"密码即将过期\",\n                    Content = \"您的密码将在7天后过期，请及时修改\",\n                    Source = \"安全中心\",\n                    IsRead = true,\n                    CreatedAt = DateTime.Now.AddDays(-3)\n                }\n            };\n\n            // Calculate stats\n            notificationStats = new NotificationStats\n            {\n                Total = notifications.Count,\n                Unread = notifications.Count(n => !n.IsRead),\n                Today = notifications.Count(n => n.CreatedAt.Date == DateTime.Today),\n                ThisWeek = notifications.Count(n => n.CreatedAt >= DateTime.Today.AddDays(-7))\n            };\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private IEnumerable<NotificationDto> FilteredNotifications => typeFilter switch\n    {\n        \"unread\" => notifications?.Where(n => !n.IsRead) ?? Enumerable.Empty<NotificationDto>(),\n        \"system\" => notifications?.Where(n => n.Type == \"System\") ?? Enumerable.Empty<NotificationDto>(),\n        \"workflow\" => notifications?.Where(n => n.Type == \"Workflow\") ?? Enumerable.Empty<NotificationDto>(),\n        _ => notifications ?? Enumerable.Empty<NotificationDto>()\n    };\n\n    private void SetTypeFilter(string type)\n    {\n        typeFilter = type;\n    }\n\n    private string GetNotificationIcon(string type) => type switch\n    {\n        \"System\" => \"⚙️\",\n        \"Workflow\" => \"📋\",\n        \"Data\" => \"📊\",\n        \"Security\" => \"🔒\",\n        _ => \"🔔\"\n    };\n\n    private string GetNotificationBadgeColor(string type) => type switch\n    {\n        \"System\" => \"secondary\",\n        \"Workflow\" => \"primary\",\n        \"Data\" => \"info\",\n        \"Security\" => \"danger\",\n        _ => \"light\"\n    };\n\n    private string GetTimeAgo(DateTime time)\n    {\n        var span = DateTime.Now - time;\n        if (span.TotalMinutes < 1) return \"刚刚\";\n        if (span.TotalMinutes < 60) return $\"{(int)span.TotalMinutes}分钟前\";\n        if (span.TotalHours < 24) return $\"{(int)span.TotalHours}小时前\";\n        if (span.TotalDays < 7) return $\"{(int)span.TotalDays}天前\";\n        return time.ToString(\"MM-dd HH:mm\");\n    }\n\n    private async Task MarkAsRead(Guid notificationId)\n    {\n        var notification = notifications?.FirstOrDefault(n => n.NotificationId == notificationId);\n        if (notification != null)\n        {\n            notification.IsRead = true;\n            notificationStats.Unread = notifications?.Count(n => !n.IsRead) ?? 0;\n            successMessage = \"已标记为已读\";\n        }\n    }\n\n    private async Task MarkAllAsRead()\n    {\n        if (notifications != null)\n        {\n            foreach (var notification in notifications.Where(n => !n.IsRead))\n            {\n                notification.IsRead = true;\n            }\n            notificationStats.Unread = 0;\n            successMessage = \"已全部标记为已读\";\n        }\n    }\n\n    private async Task DeleteNotification(Guid notificationId)\n    {\n        if (notifications != null)\n        {\n            var notification = notifications.FirstOrDefault(n => n.NotificationId == notificationId);\n            if (notification != null)\n            {\n                notifications.Remove(notification);\n                if (!notification.IsRead)\n                {\n                    notificationStats.Unread--;\n                }\n                notificationStats.Total--;\n                successMessage = \"通知已删除\";\n            }\n        }\n    }\n\n    private async Task ClearAllNotifications()\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要清空所有通知吗？\"))\n            return;\n\n        notifications?.Clear();\n        notificationStats = new NotificationStats();\n        successMessage = \"通知已清空\";\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class NotificationDto\n    {\n        public Guid NotificationId { get; set; }\n        public string Type { get; set; } = \"\";\n        public string Title { get; set; } = \"\";\n        public string Content { get; set; } = \"\";\n        public string? Source { get; set; }\n        public string? ActionUrl { get; set; }\n        public bool IsRead { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class NotificationStats\n    {\n        public int Total { get; set; }\n        public int Unread { get; set; }\n        public int Today { get; set; }\n        public int ThisWeek { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/NotificationList.razor"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":7931,"output":14536,"cacheRead":40000,"cacheWrite":0,"totalTokens":62467,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774396007856}}
