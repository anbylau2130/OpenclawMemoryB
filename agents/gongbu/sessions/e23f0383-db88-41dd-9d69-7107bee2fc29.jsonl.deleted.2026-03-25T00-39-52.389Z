{"type":"message","id":"73207434","parentId":"a3f3d4e8","timestamp":"2026-03-24T23:46:47.758Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"表单设计器模块的3个页面已创建完成。现在继续创建工作流模块的3个页面。","thinkingSignature":"reasoning_content"},{"type":"text","text":"表单设计器模块完成！继续创建工作流模块："},{"type":"toolCall","id":"call_7447df3f4c024217a7e0fd45","name":"write","arguments":{"content":"@page \"/workflows\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>工作流管理</h3>\n\n<div class=\"mb-3 d-flex justify-content-between\">\n    <div>\n        <input type=\"text\" class=\"form-control\" placeholder=\"搜索工作流...\" @bind=\"searchKeyword\" />\n    </div>\n    <button class=\"btn btn-primary\" @onclick=\"CreateWorkflow\">➕ 创建工作流</button>\n</div>\n\n@if (workflows == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse if (!workflows.Any())\n{\n    <div class=\"alert alert-info\">\n        <h5>暂无工作流</h5>\n        <p>点击上方\"创建工作流\"按钮开始设计您的第一个工作流。</p>\n    </div>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var workflow in workflows.Where(w => string.IsNullOrEmpty(searchKeyword) || \n            w.WorkflowName.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase)))\n        {\n            <div class=\"col-md-4 mb-3\">\n                <div class=\"card h-100\">\n                    <div class=\"card-header d-flex justify-content-between align-items-center\">\n                        <h6 class=\"mb-0\">@workflow.WorkflowName</h6>\n                        @if (workflow.IsActive)\n                        {\n                            <span class=\"badge bg-success\">启用</span>\n                        }\n                        else\n                        {\n                            <span class=\"badge bg-secondary\">停用</span>\n                        }\n                    </div>\n                    <div class=\"card-body\">\n                        <p class=\"card-text text-muted\">@(workflow.Description ?? \"暂无描述\")</p>\n                        <p class=\"card-text\"><small>创建时间: @workflow.CreatedAt.ToString(\"yyyy-MM-dd HH:mm\")</small></p>\n                    </div>\n                    <div class=\"card-footer\">\n                        <div class=\"btn-group w-100\" role=\"group\">\n                            <button class=\"btn btn-outline-primary btn-sm\" @onclick=\"() => DesignWorkflow(workflow.WorkflowId)\">\n                                🎨 设计\n                            </button>\n                            <button class=\"btn btn-outline-success btn-sm\" @onclick=\"() => StartWorkflow(workflow.WorkflowId)\">\n                                ▶️ 启动\n                            </button>\n                            @if (workflow.IsActive)\n                            {\n                                <button class=\"btn btn-outline-warning btn-sm\" @onclick=\"() => ToggleStatus(workflow.WorkflowId, false)\">\n                                    ⏸️ 停用\n                                </button>\n                            }\n                            else\n                            {\n                                <button class=\"btn btn-outline-success btn-sm\" @onclick=\"() => ToggleStatus(workflow.WorkflowId, true)\">\n                                    ▶️ 启用\n                                </button>\n                            }\n                            <button class=\"btn btn-outline-danger btn-sm\" @onclick=\"() => DeleteWorkflow(workflow.WorkflowId)\">\n                                🗑️\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n<!-- Create Workflow Modal -->\n<div class=\"modal fade\" id=\"createWorkflowModal\" tabindex=\"-1\">\n    <div class=\"modal-dialog\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h5 class=\"modal-title\">创建工作流</h5>\n                <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"mb-3\">\n                    <label class=\"form-label\">工作流名称 <span class=\"text-danger\">*</span></label>\n                    <input type=\"text\" class=\"form-control\" @bind=\"newWorkflow.WorkflowName\" \n                           placeholder=\"例如：请假审批、报销流程\" />\n                </div>\n                <div class=\"mb-3\">\n                    <label class=\"form-label\">描述</label>\n                    <textarea class=\"form-control\" rows=\"3\" @bind=\"newWorkflow.Description\"\n                              placeholder=\"请输入工作流描述...\"></textarea>\n                </div>\n            </div>\n            <div class=\"modal-footer\">\n                <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">取消</button>\n                <button type=\"button\" class=\"btn btn-primary\" @onclick=\"SaveWorkflow\" disabled=\"@isSaving\">\n                    @if (isSaving)\n                    {\n                        <span class=\"spinner-border spinner-border-sm me-2\"></span>\n                    }\n                    创建\n                </button>\n            </div>\n        </div>\n    </div>\n</div>\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n@code {\n    private List<WorkflowListDto>? workflows;\n    private string searchKeyword = \"\";\n    private NewWorkflowModel newWorkflow = new();\n    private bool isSaving = false;\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadWorkflows();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadWorkflows()\n    {\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<List<WorkflowListDto>>>(\"api/workflows\");\n            if (response?.Success == true)\n            {\n                workflows = response.Data;\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private void CreateWorkflow()\n    {\n        newWorkflow = new NewWorkflowModel();\n        // Show modal via JS\n    }\n\n    private async Task SaveWorkflow()\n    {\n        if (string.IsNullOrEmpty(newWorkflow.WorkflowName))\n        {\n            errorMessage = \"工作流名称不能为空\";\n            return;\n        }\n\n        isSaving = true;\n        errorMessage = null;\n\n        try\n        {\n            var response = await Http.PostAsJsonAsync(\"api/workflows\", newWorkflow);\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"工作流创建成功！\";\n                await LoadWorkflows();\n                newWorkflow = new NewWorkflowModel();\n                // Hide modal via JS\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"创建失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"创建异常: {ex.Message}\";\n        }\n        finally\n        {\n            isSaving = false;\n        }\n    }\n\n    private void DesignWorkflow(Guid workflowId)\n    {\n        NavigationManager.NavigateTo($\"/workflows/{workflowId}/design\");\n    }\n\n    private async Task StartWorkflow(Guid workflowId)\n    {\n        try\n        {\n            var response = await Http.PostAsJsonAsync($\"api/workflows/{workflowId}/start\", new { });\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"工作流启动成功！\";\n                NavigationManager.NavigateTo(\"/workflows/my-tasks\");\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"启动失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"启动异常: {ex.Message}\";\n        }\n    }\n\n    private async Task ToggleStatus(Guid workflowId, bool activate)\n    {\n        // TODO: Implement toggle workflow status API\n        errorMessage = \"工作流状态切换功能待实现\";\n    }\n\n    private async Task DeleteWorkflow(Guid workflowId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要删除这个工作流吗？\"))\n            return;\n\n        // TODO: Implement delete workflow API\n        errorMessage = \"删除工作流功能待实现\";\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class WorkflowListDto\n    {\n        public Guid WorkflowId { get; set; }\n        public string WorkflowName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsActive { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class NewWorkflowModel\n    {\n        public string WorkflowName { get; set; } = \"\";\n        public string? Description { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/WorkflowList.razor"}},{"type":"toolCall","id":"call_d27f86a2edce4da68f588587","name":"write","arguments":{"content":"@page \"/workflows/{WorkflowId:guid}/design\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>工作流设计器</h3>\n\n@if (workflow == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse\n{\n    <div class=\"row\">\n        <!-- 左侧：节点工具箱 -->\n        <div class=\"col-md-2\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h6 class=\"mb-0\">📦 节点工具箱</h6>\n                </div>\n                <div class=\"card-body\">\n                    <div class=\"mb-3\">\n                        <h6 class=\"text-muted small\">开始/结束</h6>\n                        <div class=\"d-grid gap-2\">\n                            <button class=\"btn btn-outline-success btn-sm text-start\" \n                                    @onclick=\"() => AddNode(\"Start\")\">\n                                🟢 开始节点\n                            </button>\n                            <button class=\"btn btn-outline-danger btn-sm text-start\" \n                                    @onclick=\"() => AddNode(\"End\")\">\n                                🔴 结束节点\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"mb-3\">\n                        <h6 class=\"text-muted small\">任务节点</h6>\n                        <div class=\"d-grid gap-2\">\n                            <button class=\"btn btn-outline-primary btn-sm text-start\" \n                                    @onclick=\"() => AddNode(\"Approval\")\">\n                                ✅ 审批节点\n                            </button>\n                            <button class=\"btn btn-outline-primary btn-sm text-start\" \n                                    @onclick=\"() => AddNode(\"Task\")\">\n                                📋 任务节点\n                            </button>\n                            <button class=\"btn btn-outline-info btn-sm text-start\" \n                                    @onclick=\"() => AddNode(\"Notification\")\">\n                                📧 通知节点\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"mb-3\">\n                        <h6 class=\"text-muted small\">网关</h6>\n                        <div class=\"d-grid gap-2\">\n                            <button class=\"btn btn-outline-warning btn-sm text-start\" \n                                    @onclick=\"() => AddNode(\"ExclusiveGateway\")\">\n                                ◆ 排他网关\n                            </button>\n                            <button class=\"btn btn-outline-warning btn-sm text-start\" \n                                    @onclick=\"() => AddNode(\"ParallelGateway\")\">\n                                ⬜ 并行网关\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 中间：流程设计区 -->\n        <div class=\"col-md-7\">\n            <div class=\"card\">\n                <div class=\"card-header d-flex justify-content-between align-items-center\">\n                    <h6 class=\"mb-0\">@workflow.WorkflowName</h6>\n                    <span class=\"badge @(workflow.IsActive ? \"bg-success\" : \"bg-secondary\")\">\n                        @(workflow.IsActive ? \"启用\" : \"停用\")\n                    </span>\n                </div>\n                <div class=\"card-body\" style=\"min-height: 500px; background: #f8f9fa;\">\n                    @if (nodes == null || !nodes.Any())\n                    {\n                        <div class=\"text-center text-muted py-5\">\n                            <h5>从左侧拖拽节点到这里</h5>\n                            <p>或点击左侧节点类型添加</p>\n                        </div>\n                    }\n                    else\n                    {\n                        <div class=\"workflow-canvas\">\n                            @foreach (var node in nodes.OrderBy(n => n.SortOrder))\n                            {\n                                <div class=\"workflow-node card mb-3 @(selectedNodeId == node.NodeId ? \"border-primary\" : \"\")\"\n                                     @onclick=\"() => SelectNode(node.NodeId)\"\n                                     style=\"cursor: move;\">\n                                    <div class=\"card-header py-2 @GetNodeHeaderClass(node.NodeType)\">\n                                        <h6 class=\"mb-0 small\">\n                                            @GetNodeIcon(node.NodeType) @node.NodeName\n                                        </h6>\n                                    </div>\n                                    <div class=\"card-body py-2\">\n                                        <small class=\"text-muted\">@node.Description</small>\n                                        <div class=\"mt-2\">\n                                            @if (!string.IsNullOrEmpty(node.AssignedTo))\n                                            {\n                                                <span class=\"badge bg-info me-1\">👤 @node.AssignedTo</span>\n                                            }\n                                            @if (!string.IsNullOrEmpty(node.Role))\n                                            {\n                                                <span class=\"badge bg-secondary\">👥 @node.Role</span>\n                                            }\n                                        </div>\n                                    </div>\n                                    <div class=\"card-footer py-1 d-flex justify-content-end\">\n                                        <button class=\"btn btn-sm btn-outline-secondary me-1\"\n                                                @onclick=\"() => MoveNode(node.NodeId, -1)\">↑</button>\n                                        <button class=\"btn btn-sm btn-outline-secondary me-1\"\n                                                @onclick=\"() => MoveNode(node.NodeId, 1)\">↓</button>\n                                        <button class=\"btn btn-sm btn-outline-danger\"\n                                                @onclick=\"() => DeleteNode(node.NodeId)\">🗑️</button>\n                                    </div>\n                                </div>\n                            }\n                        </div>\n                    }\n                </div>\n                <div class=\"card-footer\">\n                    <button class=\"btn btn-secondary btn-sm\" @onclick=\"GoBack\">返回列表</button>\n                    <button class=\"btn btn-success btn-sm ms-2\" @onclick=\"SaveWorkflow\" disabled=\"@isSaving\">\n                        @if (isSaving)\n                        {\n                            <span class=\"spinner-border spinner-border-sm me-1\"></span>\n                        }\n                        💾 保存\n                    </button>\n                    <button class=\"btn btn-warning btn-sm ms-2\" @onclick=\"PublishWorkflow\">📢 发布</button>\n                </div>\n            </div>\n        </div>\n\n        <!-- 右侧：节点属性配置 -->\n        <div class=\"col-md-3\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h6 class=\"mb-0\">⚙️ 节点属性</h6>\n                </div>\n                <div class=\"card-body\">\n                    @if (selectedNode == null)\n                    {\n                        <p class=\"text-muted\">请选择一个节点进行编辑</p>\n                    }\n                    else\n                    {\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">节点名称</label>\n                            <input type=\"text\" class=\"form-control form-control-sm\" \n                                   @bind=\"selectedNode.NodeName\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">节点类型</label>\n                            <input type=\"text\" class=\"form-control form-control-sm\" \n                                   @bind=\"selectedNode.NodeType\" readonly />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">描述</label>\n                            <textarea class=\"form-control form-control-sm\" rows=\"2\"\n                                      @bind=\"selectedNode.Description\"></textarea>\n                        </div>\n                        @if (selectedNode.NodeType == \"Approval\" || selectedNode.NodeType == \"Task\")\n                        {\n                            <div class=\"mb-3\">\n                                <label class=\"form-label\">指派给（用户）</label>\n                                <input type=\"text\" class=\"form-control form-control-sm\" \n                                       @bind=\"selectedNode.AssignedTo\" \n                                       placeholder=\"用户ID或用户名\" />\n                            </div>\n                            <div class=\"mb-3\">\n                                <label class=\"form-label\">指派给（角色）</label>\n                                <input type=\"text\" class=\"form-control form-control-sm\" \n                                       @bind=\"selectedNode.Role\"\n                                       placeholder=\"角色名称\" />\n                            </div>\n                            <div class=\"mb-3\">\n                                <label class=\"form-label\">超时时间（小时）</label>\n                                <input type=\"number\" class=\"form-control form-control-sm\" \n                                       @bind=\"selectedNode.TimeoutHours\" />\n                            </div>\n                        }\n                        @if (selectedNode.NodeType == \"Notification\")\n                        {\n                            <div class=\"mb-3\">\n                                <label class=\"form-label\">通知模板</label>\n                                <textarea class=\"form-control form-control-sm\" rows=\"3\"\n                                          @bind=\"selectedNode.NotificationTemplate\"\n                                          placeholder=\"通知内容模板\"></textarea>\n                            </div>\n                        }\n                        <button class=\"btn btn-primary btn-sm w-100\" @onclick=\"UpdateNode\">\n                            ✅ 更新节点\n                        </button>\n                    }\n                </div>\n            </div>\n        </div>\n    </div>\n}\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3\">@successMessage</div>\n}\n\n@code {\n    [Parameter]\n    public Guid WorkflowId { get; set; }\n\n    private WorkflowDetailDto? workflow;\n    private List<NodeDto> nodes = new();\n    private Guid? selectedNodeId;\n    private NodeDto? selectedNode;\n    private bool isSaving = false;\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadWorkflow();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadWorkflow()\n    {\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<WorkflowDetailDto>>($\"api/workflows/{WorkflowId}\");\n            if (response?.Success == true)\n            {\n                workflow = response.Data;\n                // Load nodes from workflow config\n                if (!string.IsNullOrEmpty(workflow.StepsConfig))\n                {\n                    nodes = System.Text.Json.JsonSerializer.Deserialize<List<NodeDto>>(workflow.StepsConfig) ?? new();\n                }\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private void SelectNode(Guid nodeId)\n    {\n        selectedNodeId = nodeId;\n        selectedNode = nodes.FirstOrDefault(n => n.NodeId == nodeId);\n    }\n\n    private void AddNode(string nodeType)\n    {\n        var newNode = new NodeDto\n        {\n            NodeId = Guid.NewGuid(),\n            NodeName = GetDefaultNodeName(nodeType),\n            NodeType = nodeType,\n            SortOrder = nodes.Count\n        };\n        nodes.Add(newNode);\n        selectedNodeId = newNode.NodeId;\n        selectedNode = newNode;\n    }\n\n    private void UpdateNode()\n    {\n        if (selectedNode == null) return;\n        successMessage = \"节点属性已更新\";\n    }\n\n    private void DeleteNode(Guid nodeId)\n    {\n        nodes.RemoveAll(n => n.NodeId == nodeId);\n        if (selectedNodeId == nodeId)\n        {\n            selectedNodeId = null;\n            selectedNode = null;\n        }\n    }\n\n    private void MoveNode(Guid nodeId, int direction)\n    {\n        var node = nodes.FirstOrDefault(n => n.NodeId == nodeId);\n        if (node == null) return;\n\n        var currentIndex = nodes.IndexOf(node);\n        var newIndex = currentIndex + direction;\n\n        if (newIndex >= 0 && newIndex < nodes.Count)\n        {\n            nodes.RemoveAt(currentIndex);\n            nodes.Insert(newIndex, node);\n            \n            // Update sort order\n            for (int i = 0; i < nodes.Count; i++)\n            {\n                nodes[i].SortOrder = i;\n            }\n        }\n    }\n\n    private async Task SaveWorkflow()\n    {\n        isSaving = true;\n        errorMessage = null;\n\n        try\n        {\n            var config = System.Text.Json.JsonSerializer.Serialize(nodes);\n            var response = await Http.PutAsJsonAsync($\"api/workflows/{WorkflowId}\", new { StepsConfig = config });\n            \n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"工作流保存成功！\";\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"保存失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"保存异常: {ex.Message}\";\n        }\n        finally\n        {\n            isSaving = false;\n        }\n    }\n\n    private async Task PublishWorkflow()\n    {\n        await SaveWorkflow();\n        if (!string.IsNullOrEmpty(successMessage))\n        {\n            try\n            {\n                var response = await Http.PostAsync($\"api/workflows/{WorkflowId}/activate\", null);\n                if (response.IsSuccessStatusCode)\n                {\n                    successMessage = \"工作流发布成功！\";\n                    await LoadWorkflow();\n                }\n            }\n            catch (Exception ex)\n            {\n                errorMessage = $\"发布异常: {ex.Message}\";\n            }\n        }\n    }\n\n    private void GoBack()\n    {\n        NavigationManager.NavigateTo(\"/workflows\");\n    }\n\n    private string GetDefaultNodeName(string nodeType) => nodeType switch\n    {\n        \"Start\" => \"开始\",\n        \"End\" => \"结束\",\n        \"Approval\" => \"审批节点\",\n        \"Task\" => \"任务节点\",\n        \"Notification\" => \"通知节点\",\n        \"ExclusiveGateway\" => \"排他网关\",\n        \"ParallelGateway\" => \"并行网关\",\n        _ => \"节点\"\n    };\n\n    private string GetNodeIcon(string nodeType) => nodeType switch\n    {\n        \"Start\" => \"🟢\",\n        \"End\" => \"🔴\",\n        \"Approval\" => \"✅\",\n        \"Task\" => \"📋\",\n        \"Notification\" => \"📧\",\n        \"ExclusiveGateway\" => \"◆\",\n        \"ParallelGateway\" => \"⬜\",\n        _ => \"⭕\"\n    };\n\n    private string GetNodeHeaderClass(string nodeType) => nodeType switch\n    {\n        \"Start\" => \"bg-success text-white\",\n        \"End\" => \"bg-danger text-white\",\n        \"Approval\" => \"bg-primary text-white\",\n        \"Task\" => \"bg-primary text-white\",\n        \"Notification\" => \"bg-info text-white\",\n        \"ExclusiveGateway\" => \"bg-warning\",\n        \"ParallelGateway\" => \"bg-warning\",\n        _ => \"bg-secondary text-white\"\n    };\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class WorkflowDetailDto\n    {\n        public Guid WorkflowId { get; set; }\n        public string WorkflowName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsActive { get; set; }\n        public string? StepsConfig { get; set; }\n    }\n\n    public class NodeDto\n    {\n        public Guid NodeId { get; set; }\n        public string NodeName { get; set; } = \"\";\n        public string NodeType { get; set; } = \"\";\n        public string? Description { get; set; }\n        public string? AssignedTo { get; set; }\n        public string? Role { get; set; }\n        public int? TimeoutHours { get; set; }\n        public string? NotificationTemplate { get; set; }\n        public int SortOrder { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/WorkflowDesigner.razor"}},{"type":"toolCall","id":"call_9b95c60df3d9405b8d881113","name":"write","arguments":{"content":"@page \"/workflows/my-tasks\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>我的待办</h3>\n\n<div class=\"mb-3 d-flex justify-content-between align-items-center\">\n    <div class=\"btn-group\" role=\"group\">\n        <button type=\"button\" class=\"btn @(statusFilter == \"all\" ? \"btn-primary\" : \"btn-outline-primary\")\"\n                @onclick='() => SetFilter(\"all\")'>全部</button>\n        <button type=\"button\" class=\"btn @(statusFilter == \"pending\" ? \"btn-primary\" : \"btn-outline-primary\")\"\n                @onclick='() => SetFilter(\"pending\")'>待处理</button>\n        <button type=\"button\" class=\"btn @(statusFilter == \"completed\" ? \"btn-primary\" : \"btn-outline-primary\")\"\n                @onclick='() => SetFilter(\"completed\")'>已完成</button>\n    </div>\n    <button class=\"btn btn-outline-secondary btn-sm\" @onclick=\"LoadTasks\">\n        🔄 刷新\n    </button>\n</div>\n\n@if (tasks == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse if (!tasks.Any())\n{\n    <div class=\"alert alert-info\">\n        <h5>🎉 暂无待办任务</h5>\n        <p>您已经处理完所有任务，或者还没有分配到任务。</p>\n    </div>\n}\nelse\n{\n    <div class=\"list-group\">\n        @foreach (var task in FilteredTasks)\n        {\n            <div class=\"list-group-item list-group-item-action flex-column align-items-start\n                        @(task.Status == \"Completed\" ? \"list-group-item-success\" : \"\")\">\n                <div class=\"d-flex w-100 justify-content-between\">\n                    <h6 class=\"mb-1\">\n                        @GetTaskIcon(task.TaskType) @task.TaskName\n                        @if (task.Status == \"Pending\")\n                        {\n                            <span class=\"badge bg-warning ms-2\">待处理</span>\n                        }\n                        else if (task.Status == \"InProgress\")\n                        {\n                            <span class=\"badge bg-info ms-2\">进行中</span>\n                        }\n                        else if (task.Status == \"Completed\")\n                        {\n                            <span class=\"badge bg-success ms-2\">已完成</span>\n                        }\n                    </h6>\n                    <small>@task.CreatedAt.ToString(\"MM-dd HH:mm\")</small>\n                </div>\n                <p class=\"mb-1 text-muted\">\n                    <small>\n                        📋 工作流: @task.WorkflowName |\n                        📝 类型: @task.TaskType\n                    </small>\n                </p>\n                <div class=\"d-flex justify-content-between align-items-center mt-2\">\n                    <small class=\"text-muted\">\n                        @if (task.CompletedAt.HasValue)\n                        {\n                            <span>✅ 完成于: @task.CompletedAt.Value.ToString(\"MM-dd HH:mm\")</span>\n                        }\n                    </small>\n                    <div>\n                        @if (task.Status != \"Completed\")\n                        {\n                            <button class=\"btn btn-success btn-sm\" @onclick=\"() => CompleteTask(task.TaskId)\">\n                                ✅ 完成任务\n                            </button>\n                            <button class=\"btn btn-info btn-sm ms-1\" @onclick=\"() => ViewInstance(task.InstanceId)\">\n                                👁️ 查看详情\n                            </button>\n                        }\n                        else\n                        {\n                            <button class=\"btn btn-outline-secondary btn-sm\" @onclick=\"() => ViewInstance(task.InstanceId)\">\n                                👁️ 查看详情\n                            </button>\n                        }\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n\n    <div class=\"mt-3\">\n        <small class=\"text-muted\">\n            共 @FilteredTasks.Count() 条任务 |\n            待处理: @FilteredTasks.Count(t => t.Status != \"Completed\") |\n            已完成: @FilteredTasks.Count(t => t.Status == \"Completed\")\n        </small>\n    </div>\n}\n\n<!-- Task Detail Modal -->\n@if (selectedTask != null)\n{\n    <div class=\"modal fade show\" style=\"display: block; background: rgba(0,0,0,0.5);\">\n        <div class=\"modal-dialog\">\n            <div class=\"modal-content\">\n                <div class=\"modal-header\">\n                    <h5 class=\"modal-title\">@selectedTask.TaskName</h5>\n                    <button type=\"button\" class=\"btn-close\" @onclick=\"CloseModal\"></button>\n                </div>\n                <div class=\"modal-body\">\n                    <div class=\"mb-3\">\n                        <strong>任务类型:</strong> @selectedTask.TaskType\n                    </div>\n                    <div class=\"mb-3\">\n                        <strong>工作流:</strong> @selectedTask.WorkflowName\n                    </div>\n                    <div class=\"mb-3\">\n                        <strong>状态:</strong> \n                        @if (selectedTask.Status == \"Pending\")\n                        {\n                            <span class=\"badge bg-warning\">待处理</span>\n                        }\n                        else if (selectedTask.Status == \"InProgress\")\n                        {\n                            <span class=\"badge bg-info\">进行中</span>\n                        }\n                        else\n                        {\n                            <span class=\"badge bg-success\">已完成</span>\n                        }\n                    </div>\n                    <div class=\"mb-3\">\n                        <strong>创建时间:</strong> @selectedTask.CreatedAt.ToString(\"yyyy-MM-dd HH:mm:ss\")\n                    </div>\n                    @if (selectedTask.CompletedAt.HasValue)\n                    {\n                        <div class=\"mb-3\">\n                            <strong>完成时间:</strong> @selectedTask.CompletedAt.Value.ToString(\"yyyy-MM-dd HH:mm:ss\")\n                        </div>\n                    }\n                    @if (!string.IsNullOrEmpty(selectedTask.TaskData))\n                    {\n                        <div class=\"mb-3\">\n                            <strong>任务数据:</strong>\n                            <pre class=\"bg-light p-2 rounded small\">@selectedTask.TaskData</pre>\n                        </div>\n                    }\n                    <div class=\"mb-3\">\n                        <label class=\"form-label\"><strong>处理意见:</strong></label>\n                        <textarea class=\"form-control\" rows=\"3\" @bind=\"taskComment\"\n                                  placeholder=\"请输入处理意见...\"></textarea>\n                    </div>\n                </div>\n                <div class=\"modal-footer\">\n                    @if (selectedTask.Status != \"Completed\")\n                    {\n                        <button type=\"button\" class=\"btn btn-success\" @onclick=\"() => CompleteTask(selectedTask.TaskId)\">\n                            ✅ 完成任务\n                        </button>\n                        <button type=\"button\" class=\"btn btn-danger\" @onclick=\"() => RejectTask(selectedTask.TaskId)\">\n                            ❌ 驳回\n                        </button>\n                    }\n                    <button type=\"button\" class=\"btn btn-secondary\" @onclick=\"CloseModal\">关闭</button>\n                </div>\n            </div>\n        </div>\n    </div>\n}\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n@code {\n    private List<TaskDto>? tasks;\n    private string statusFilter = \"all\";\n    private TaskDto? selectedTask;\n    private string taskComment = \"\";\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadTasks();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadTasks()\n    {\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<List<TaskDto>>>(\"api/workflows/my-tasks\");\n            if (response?.Success == true)\n            {\n                tasks = response.Data;\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private IEnumerable<TaskDto> FilteredTasks => statusFilter switch\n    {\n        \"pending\" => tasks?.Where(t => t.Status != \"Completed\") ?? Enumerable.Empty<TaskDto>(),\n        \"completed\" => tasks?.Where(t => t.Status == \"Completed\") ?? Enumerable.Empty<TaskDto>(),\n        _ => tasks ?? Enumerable.Empty<TaskDto>()\n    };\n\n    private void SetFilter(string status)\n    {\n        statusFilter = status;\n    }\n\n    private async Task CompleteTask(Guid taskId)\n    {\n        try\n        {\n            var response = await Http.PostAsync($\"api/workflows/tasks/{taskId}/complete\", null);\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"任务完成！\";\n                await LoadTasks();\n                CloseModal();\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"操作失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"操作异常: {ex.Message}\";\n        }\n    }\n\n    private async Task RejectTask(Guid taskId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要驳回这个任务吗？\"))\n            return;\n\n        // TODO: Implement reject task API\n        errorMessage = \"驳回功能待实现\";\n    }\n\n    private void ViewInstance(Guid instanceId)\n    {\n        NavigationManager.NavigateTo($\"/workflows/instances/{instanceId}\");\n    }\n\n    private void CloseModal()\n    {\n        selectedTask = null;\n        taskComment = \"\";\n    }\n\n    private string GetTaskIcon(string taskType) => taskType switch\n    {\n        \"Approval\" => \"✅\",\n        \"Task\" => \"📋\",\n        \"Review\" => \"👁️\",\n        \"Notification\" => \"📧\",\n        _ => \"📝\"\n    };\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class TaskDto\n    {\n        public Guid TaskId { get; set; }\n        public string TaskName { get; set; } = \"\";\n        public string TaskType { get; set; } = \"\";\n        public string Status { get; set; } = \"\";\n        public string WorkflowName { get; set; } = \"\";\n        public Guid InstanceId { get; set; }\n        public DateTime CreatedAt { get; set; }\n        public DateTime? CompletedAt { get; set; }\n        public string? TaskData { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/WorkflowTasks.razor"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":7611,"output":7755,"cacheRead":32448,"cacheWrite":0,"totalTokens":47814,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774395850669}}
