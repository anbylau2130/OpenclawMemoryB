{"type":"message","id":"b5ee78e2","parentId":"2f022f11","timestamp":"2026-03-24T23:44:10.584Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，数据管理模块的3个页面已创建完成。现在继续创建表单设计器模块的3个页面。","thinkingSignature":"reasoning_content"},{"type":"text","text":"数据管理模块完成！继续创建表单设计器模块："},{"type":"toolCall","id":"call_beb6d9749e6640ffac45f004","name":"write","arguments":{"content":"@page \"/forms\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>表单管理</h3>\n\n<div class=\"mb-3 d-flex justify-content-between\">\n    <div>\n        <input type=\"text\" class=\"form-control\" placeholder=\"搜索表单...\" @bind=\"searchKeyword\" />\n    </div>\n    <button class=\"btn btn-primary\" @onclick=\"CreateForm\">➕ 创建表单</button>\n</div>\n\n@if (forms == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse if (!forms.Any())\n{\n    <div class=\"alert alert-info\">\n        <h5>暂无表单</h5>\n        <p>点击上方\"创建表单\"按钮开始设计您的第一个表单。</p>\n    </div>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var form in forms.Where(f => string.IsNullOrEmpty(searchKeyword) || \n            f.FormName.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase)))\n        {\n            <div class=\"col-md-4 mb-3\">\n                <div class=\"card h-100\">\n                    <div class=\"card-header d-flex justify-content-between align-items-center\">\n                        <h6 class=\"mb-0\">@form.FormName</h6>\n                        @if (form.IsPublished)\n                        {\n                            <span class=\"badge bg-success\">已发布</span>\n                        }\n                        else\n                        {\n                            <span class=\"badge bg-secondary\">草稿</span>\n                        }\n                    </div>\n                    <div class=\"card-body\">\n                        <p class=\"card-text text-muted\">@(form.Description ?? \"暂无描述\")</p>\n                        <p class=\"card-text\"><small>字段数: @form.FieldCount</small></p>\n                        <p class=\"card-text\"><small>创建时间: @form.CreatedAt.ToString(\"yyyy-MM-dd HH:mm\")</small></p>\n                    </div>\n                    <div class=\"card-footer\">\n                        <div class=\"btn-group w-100\" role=\"group\">\n                            <button class=\"btn btn-outline-primary btn-sm\" @onclick=\"() => DesignForm(form.FormId)\">\n                                🎨 设计\n                            </button>\n                            <button class=\"btn btn-outline-success btn-sm\" @onclick=\"() => PreviewForm(form.FormId)\">\n                                👁️ 预览\n                            </button>\n                            @if (!form.IsPublished)\n                            {\n                                <button class=\"btn btn-outline-warning btn-sm\" @onclick=\"() => PublishForm(form.FormId)\">\n                                    📢 发布\n                                </button>\n                            }\n                            <button class=\"btn btn-outline-danger btn-sm\" @onclick=\"() => DeleteForm(form.FormId)\">\n                                🗑️\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3 alert-dismissible fade show\">\n        @successMessage\n        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n    </div>\n}\n\n@code {\n    private List<FormListDto>? forms;\n    private string searchKeyword = \"\";\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadForms();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadForms()\n    {\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<List<FormListDto>>>(\"api/forms\");\n            if (response?.Success == true)\n            {\n                forms = response.Data;\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private void CreateForm()\n    {\n        NavigationManager.NavigateTo(\"/forms/create\");\n    }\n\n    private void DesignForm(Guid formId)\n    {\n        NavigationManager.NavigateTo($\"/forms/{formId}/design\");\n    }\n\n    private void PreviewForm(Guid formId)\n    {\n        NavigationManager.NavigateTo($\"/forms/{formId}/preview\");\n    }\n\n    private async Task PublishForm(Guid formId)\n    {\n        try\n        {\n            var response = await Http.PostAsync($\"api/forms/{formId}/publish\", null);\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"表单发布成功！\";\n                await LoadForms();\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"发布失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"发布异常: {ex.Message}\";\n        }\n    }\n\n    private async Task DeleteForm(Guid formId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要删除这个表单吗？\"))\n            return;\n\n        // TODO: Implement delete form API\n        errorMessage = \"删除表单功能待实现\";\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class FormListDto\n    {\n        public Guid FormId { get; set; }\n        public string FormName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsPublished { get; set; }\n        public int FieldCount { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/FormList.razor"}},{"type":"toolCall","id":"call_0d6b22ded83544b4b0f67bf1","name":"write","arguments":{"content":"@page \"/forms/{FormId:guid}/design\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>表单设计器</h3>\n\n@if (form == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse\n{\n    <div class=\"row\">\n        <!-- 左侧：字段工具箱 -->\n        <div class=\"col-md-3\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h6 class=\"mb-0\">📦 字段工具箱</h6>\n                </div>\n                <div class=\"card-body\">\n                    <div class=\"mb-3\">\n                        <h6 class=\"text-muted\">基础字段</h6>\n                        <div class=\"d-grid gap-2\">\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Text\")\">\n                                📝 文本框\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"TextArea\")\">\n                                📄 多行文本\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Number\")\">\n                                🔢 数字\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Email\")\">\n                                ✉️ 邮箱\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Phone\")\">\n                                📞 电话\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Date\")\">\n                                📅 日期\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"DateTime\")\">\n                                📅 日期时间\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"mb-3\">\n                        <h6 class=\"text-muted\">选择字段</h6>\n                        <div class=\"d-grid gap-2\">\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Select\")\">\n                                📋 下拉选择\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Radio\")\">\n                                ⭕ 单选框\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Checkbox\")\">\n                                ☑️ 复选框\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Switch\")\">\n                                🔄 开关\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"mb-3\">\n                        <h6 class=\"text-muted\">高级字段</h6>\n                        <div class=\"d-grid gap-2\">\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"File\")\">\n                                📎 文件上传\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Image\")\">\n                                🖼️ 图片上传\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"RichText\")\">\n                                📝 富文本\n                            </button>\n                            <button class=\"btn btn-outline-secondary btn-sm text-start\" @onclick=\"() => AddField(\"Cascader\")\">\n                                🌳 级联选择\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 中间：表单设计区 -->\n        <div class=\"col-md-6\">\n            <div class=\"card\">\n                <div class=\"card-header d-flex justify-content-between align-items-center\">\n                    <h6 class=\"mb-0\">@form.FormName</h6>\n                    <span class=\"badge @(form.IsPublished ? \"bg-success\" : \"bg-secondary\")\">\n                        @(form.IsPublished ? \"已发布\" : \"草稿\")\n                    </span>\n                </div>\n                <div class=\"card-body\" style=\"min-height: 400px;\">\n                    @if (form.Fields == null || !form.Fields.Any())\n                    {\n                        <div class=\"text-center text-muted py-5 border border-dashed rounded\">\n                            <h5>从左侧拖拽字段到这里</h5>\n                            <p>或点击左侧字段类型添加</p>\n                        </div>\n                    }\n                    else\n                    {\n                        <div class=\"list-group\">\n                            @foreach (var field in form.Fields.OrderBy(f => f.SortOrder))\n                            {\n                                <div class=\"list-group-item d-flex justify-content-between align-items-center \n                                            @(selectedFieldId == field.FieldId ? \"active\" : \"\")\"\n                                     @onclick=\"() => SelectField(field.FieldId)\"\n                                     style=\"cursor: move;\">\n                                    <div>\n                                        <span class=\"me-2\">@GetFieldIcon(field.FieldType)</span>\n                                        <strong>@field.Label</strong>\n                                        <small class=\"text-muted ms-2\">(@field.FieldName)</small>\n                                        @if (field.IsRequired)\n                                        {\n                                            <span class=\"text-danger ms-1\">*</span>\n                                        }\n                                    </div>\n                                    <div>\n                                        <button class=\"btn btn-sm btn-outline-light\" \n                                                @onclick=\"() => MoveField(field.FieldId, -1)\">↑</button>\n                                        <button class=\"btn btn-sm btn-outline-light\"\n                                                @onclick=\"() => MoveField(field.FieldId, 1)\">↓</button>\n                                        <button class=\"btn btn-sm btn-outline-danger\"\n                                                @onclick=\"() => DeleteField(field.FieldId)\">🗑️</button>\n                                    </div>\n                                </div>\n                            }\n                        </div>\n                    }\n                </div>\n                <div class=\"card-footer\">\n                    <button class=\"btn btn-secondary btn-sm\" @onclick=\"GoBack\">返回列表</button>\n                    <button class=\"btn btn-success btn-sm ms-2\" @onclick=\"SaveForm\" disabled=\"@isSaving\">\n                        @if (isSaving)\n                        {\n                            <span class=\"spinner-border spinner-border-sm me-1\"></span>\n                        }\n                        💾 保存\n                    </button>\n                    <button class=\"btn btn-primary btn-sm ms-2\" @onclick=\"PreviewForm\">👁️ 预览</button>\n                    @if (!form.IsPublished)\n                    {\n                        <button class=\"btn btn-warning btn-sm ms-2\" @onclick=\"PublishForm\">📢 发布</button>\n                    }\n                </div>\n            </div>\n        </div>\n\n        <!-- 右侧：字段属性配置 -->\n        <div class=\"col-md-3\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h6 class=\"mb-0\">⚙️ 字段属性</h6>\n                </div>\n                <div class=\"card-body\">\n                    @if (selectedField == null)\n                    {\n                        <p class=\"text-muted\">请选择一个字段进行编辑</p>\n                    }\n                    else\n                    {\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">字段名</label>\n                            <input type=\"text\" class=\"form-control form-control-sm\" \n                                   @bind=\"selectedField.FieldName\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">标签</label>\n                            <input type=\"text\" class=\"form-control form-control-sm\" \n                                   @bind=\"selectedField.Label\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">占位符</label>\n                            <input type=\"text\" class=\"form-control form-control-sm\" \n                                   @bind=\"selectedField.Placeholder\" />\n                        </div>\n                        <div class=\"mb-3\">\n                            <label class=\"form-label\">默认值</label>\n                            <input type=\"text\" class=\"form-control form-control-sm\" \n                                   @bind=\"selectedField.DefaultValue\" />\n                        </div>\n                        <div class=\"mb-3 form-check\">\n                            <input type=\"checkbox\" class=\"form-check-input\" \n                                   @bind=\"selectedField.IsRequired\" />\n                            <label class=\"form-check-label\">必填</label>\n                        </div>\n                        <div class=\"mb-3 form-check\">\n                            <input type=\"checkbox\" class=\"form-check-input\" \n                                   @bind=\"selectedField.IsVisible\" />\n                            <label class=\"form-check-label\">可见</label>\n                        </div>\n                        <div class=\"mb-3 form-check\">\n                            <input type=\"checkbox\" class=\"form-check-input\" \n                                   @bind=\"selectedField.IsEditable\" />\n                            <label class=\"form-check-label\">可编辑</label>\n                        </div>\n                        <button class=\"btn btn-primary btn-sm w-100\" @onclick=\"UpdateField\">\n                            ✅ 更新字段\n                        </button>\n                    }\n                </div>\n            </div>\n        </div>\n    </div>\n}\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3\">@successMessage</div>\n}\n\n@code {\n    [Parameter]\n    public Guid FormId { get; set; }\n\n    private FormDetailDto? form;\n    private Guid? selectedFieldId;\n    private FieldDto? selectedField;\n    private bool isSaving = false;\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadForm();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadForm()\n    {\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<FormDetailDto>>($\"api/forms/{FormId}\");\n            if (response?.Success == true)\n            {\n                form = response.Data;\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private void SelectField(Guid fieldId)\n    {\n        selectedFieldId = fieldId;\n        selectedField = form?.Fields?.FirstOrDefault(f => f.FieldId == fieldId);\n    }\n\n    private async Task AddField(string fieldType)\n    {\n        if (form == null) return;\n\n        var newField = new AddFieldModel\n        {\n            FieldName = $\"field_{DateTime.Now:yyyyMMddHHmmss}\",\n            FieldType = fieldType,\n            Label = GetFieldLabel(fieldType),\n            Placeholder = $\"请输入{GetFieldLabel(fieldType)}\",\n            IsRequired = false,\n            IsVisible = true,\n            IsEditable = true\n        };\n\n        try\n        {\n            var response = await Http.PostAsJsonAsync($\"api/forms/{FormId}/fields\", newField);\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"字段添加成功！\";\n                await LoadForm();\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"添加失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"添加异常: {ex.Message}\";\n        }\n    }\n\n    private async Task UpdateField()\n    {\n        if (selectedField == null || form == null) return;\n\n        try\n        {\n            var response = await Http.PutAsJsonAsync($\"api/forms/{FormId}/fields/{selectedField.FieldId}\", selectedField);\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"字段更新成功！\";\n                await LoadForm();\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"更新失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"更新异常: {ex.Message}\";\n        }\n    }\n\n    private async Task DeleteField(Guid fieldId)\n    {\n        if (!await JSRuntime.InvokeAsync<bool>(\"confirm\", \"确定要删除这个字段吗？\"))\n            return;\n\n        try\n        {\n            var response = await Http.DeleteAsync($\"api/forms/{FormId}/fields/{fieldId}\");\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"字段删除成功！\";\n                selectedFieldId = null;\n                selectedField = null;\n                await LoadForm();\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"删除失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"删除异常: {ex.Message}\";\n        }\n    }\n\n    private void MoveField(Guid fieldId, int direction)\n    {\n        // TODO: Implement field reordering\n        errorMessage = \"字段排序功能待实现\";\n    }\n\n    private async Task SaveForm()\n    {\n        isSaving = true;\n        errorMessage = null;\n\n        try\n        {\n            // Auto-save on field changes\n            successMessage = \"表单已保存！\";\n        }\n        finally\n        {\n            isSaving = false;\n        }\n    }\n\n    private void PreviewForm()\n    {\n        NavigationManager.NavigateTo($\"/forms/{FormId}/preview\");\n    }\n\n    private async Task PublishForm()\n    {\n        try\n        {\n            var response = await Http.PostAsync($\"api/forms/{FormId}/publish\", null);\n            if (response.IsSuccessStatusCode)\n            {\n                successMessage = \"表单发布成功！\";\n                await LoadForm();\n            }\n            else\n            {\n                var error = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();\n                errorMessage = error?.Message ?? \"发布失败\";\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"发布异常: {ex.Message}\";\n        }\n    }\n\n    private void GoBack()\n    {\n        NavigationManager.NavigateTo(\"/forms\");\n    }\n\n    private string GetFieldIcon(string fieldType) => fieldType switch\n    {\n        \"Text\" => \"📝\",\n        \"TextArea\" => \"📄\",\n        \"Number\" => \"🔢\",\n        \"Email\" => \"✉️\",\n        \"Phone\" => \"📞\",\n        \"Date\" => \"📅\",\n        \"DateTime\" => \"🕐\",\n        \"Select\" => \"📋\",\n        \"Radio\" => \"⭕\",\n        \"Checkbox\" => \"☑️\",\n        \"Switch\" => \"🔄\",\n        \"File\" => \"📎\",\n        \"Image\" => \"🖼️\",\n        \"RichText\" => \"📝\",\n        \"Cascader\" => \"🌳\",\n        _ => \"❓\"\n    };\n\n    private string GetFieldLabel(string fieldType) => fieldType switch\n    {\n        \"Text\" => \"文本\",\n        \"TextArea\" => \"多行文本\",\n        \"Number\" => \"数字\",\n        \"Email\" => \"邮箱\",\n        \"Phone\" => \"电话\",\n        \"Date\" => \"日期\",\n        \"DateTime\" => \"日期时间\",\n        \"Select\" => \"下拉选择\",\n        \"Radio\" => \"单选\",\n        \"Checkbox\" => \"复选\",\n        \"Switch\" => \"开关\",\n        \"File\" => \"文件\",\n        \"Image\" => \"图片\",\n        \"RichText\" => \"富文本\",\n        \"Cascader\" => \"级联\",\n        _ => \"字段\"\n    };\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class FormDetailDto\n    {\n        public Guid FormId { get; set; }\n        public string FormName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsPublished { get; set; }\n        public List<FieldDto>? Fields { get; set; }\n    }\n\n    public class FieldDto\n    {\n        public Guid FieldId { get; set; }\n        public string FieldName { get; set; } = \"\";\n        public string FieldType { get; set; } = \"\";\n        public string? Label { get; set; }\n        public string? Placeholder { get; set; }\n        public string? DefaultValue { get; set; }\n        public bool IsRequired { get; set; }\n        public bool IsVisible { get; set; }\n        public bool IsEditable { get; set; }\n        public int SortOrder { get; set; }\n    }\n\n    public class AddFieldModel\n    {\n        public string FieldName { get; set; } = \"\";\n        public string FieldType { get; set; } = \"\";\n        public string? Label { get; set; }\n        public string? Placeholder { get; set; }\n        public string? DefaultValue { get; set; }\n        public bool IsRequired { get; set; }\n        public bool IsVisible { get; set; }\n        public bool IsEditable { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/FormDesigner.razor"}},{"type":"toolCall","id":"call_c27b53a3b82c4891ac90aefe","name":"write","arguments":{"content":"@page \"/forms/{FormId:guid}/preview\"\n@inject HttpClient Http\n@inject NavigationManager NavigationManager\n@inject IJSRuntime JSRuntime\n\n<h3>表单预览</h3>\n\n@if (form == null)\n{\n    <p><em>加载中...</em></p>\n}\nelse\n{\n    <div class=\"row\">\n        <div class=\"col-md-8 offset-md-2\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h5 class=\"mb-0\">@form.FormName</h5>\n                    @if (!string.IsNullOrEmpty(form.Description))\n                    {\n                        <small class=\"text-muted\">@form.Description</small>\n                    }\n                </div>\n                <div class=\"card-body\">\n                    <EditForm Model=\"formData\" OnValidSubmit=\"SubmitForm\">\n                        <DataAnnotationsValidator />\n\n                        @if (form.Fields != null && form.Fields.Any())\n                        {\n                            @foreach (var field in form.Fields.OrderBy(f => f.SortOrder).Where(f => f.IsVisible))\n                            {\n                                <div class=\"mb-3\">\n                                    <label class=\"form-label\">\n                                        @field.Label\n                                        @if (field.IsRequired)\n                                        {\n                                            <span class=\"text-danger\">*</span>\n                                        }\n                                    </label>\n\n                                    @switch (field.FieldType)\n                                    {\n                                        case \"Text\":\n                                            <input type=\"text\" class=\"form-control\"\n                                                   placeholder=\"@field.Placeholder\"\n                                                   @bind=\"GetFieldValue(field.FieldName)\"\n                                                   @bind:after=\"() => SetFieldValue(field.FieldName, GetFieldValue(field.FieldName))\"\n                                                   readonly=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"TextArea\":\n                                            <textarea class=\"form-control\" rows=\"4\"\n                                                      placeholder=\"@field.Placeholder\"\n                                                      @bind=\"GetFieldValue(field.FieldName)\"\n                                                      readonly=\"@(!field.IsEditable)\"></textarea>\n                                            break;\n\n                                        case \"Number\":\n                                            <input type=\"number\" class=\"form-control\"\n                                                   placeholder=\"@field.Placeholder\"\n                                                   @bind=\"GetFieldValue(field.FieldName)\"\n                                                   readonly=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"Email\":\n                                            <input type=\"email\" class=\"form-control\"\n                                                   placeholder=\"@field.Placeholder\"\n                                                   @bind=\"GetFieldValue(field.FieldName)\"\n                                                   readonly=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"Phone\":\n                                            <input type=\"tel\" class=\"form-control\"\n                                                   placeholder=\"@field.Placeholder\"\n                                                   @bind=\"GetFieldValue(field.FieldName)\"\n                                                   readonly=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"Date\":\n                                            <input type=\"date\" class=\"form-control\"\n                                                   @bind=\"GetFieldValue(field.FieldName)\"\n                                                   readonly=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"DateTime\":\n                                            <input type=\"datetime-local\" class=\"form-control\"\n                                                   @bind=\"GetFieldValue(field.FieldName)\"\n                                                   readonly=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"Select\":\n                                            <select class=\"form-select\"\n                                                    @bind=\"GetFieldValue(field.FieldName)\"\n                                                    disabled=\"@(!field.IsEditable)\">\n                                                <option value=\"\">请选择</option>\n                                                @if (!string.IsNullOrEmpty(field.FieldConfig))\n                                                {\n                                                    @foreach (var option in field.FieldConfig.Split(','))\n                                                    {\n                                                        <option value=\"@option\">@option</option>\n                                                    }\n                                                }\n                                            </select>\n                                            break;\n\n                                        case \"Radio\":\n                                            @if (!string.IsNullOrEmpty(field.FieldConfig))\n                                            {\n                                                @foreach (var option in field.FieldConfig.Split(','))\n                                                {\n                                                    <div class=\"form-check\">\n                                                        <input type=\"radio\" class=\"form-check-input\"\n                                                               name=\"@field.FieldName\"\n                                                               value=\"@option\"\n                                                               @bind=\"GetFieldValue(field.FieldName)\"\n                                                               disabled=\"@(!field.IsEditable)\" />\n                                                        <label class=\"form-check-label\">@option</label>\n                                                    </div>\n                                                }\n                                            }\n                                            break;\n\n                                        case \"Checkbox\":\n                                            <div class=\"form-check\">\n                                                <input type=\"checkbox\" class=\"form-check-input\"\n                                                       @bind=\"GetFieldValue(field.FieldName)\"\n                                                       disabled=\"@(!field.IsEditable)\" />\n                                                <label class=\"form-check-label\">@(field.Label)</label>\n                                            </div>\n                                            break;\n\n                                        case \"Switch\":\n                                            <div class=\"form-check form-switch\">\n                                                <input type=\"checkbox\" class=\"form-check-input\"\n                                                       @bind=\"GetFieldValue(field.FieldName)\"\n                                                       disabled=\"@(!field.IsEditable)\" />\n                                                <label class=\"form-check-label\">@(field.Label)</label>\n                                            </div>\n                                            break;\n\n                                        case \"File\":\n                                            <input type=\"file\" class=\"form-control\"\n                                                   disabled=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"Image\":\n                                            <input type=\"file\" class=\"form-control\" accept=\"image/*\"\n                                                   disabled=\"@(!field.IsEditable)\" />\n                                            break;\n\n                                        case \"RichText\":\n                                            <textarea class=\"form-control\" rows=\"6\"\n                                                      placeholder=\"@field.Placeholder\"\n                                                      @bind=\"GetFieldValue(field.FieldName)\"\n                                                      readonly=\"@(!field.IsEditable)\"></textarea>\n                                            <small class=\"text-muted\">富文本编辑器</small>\n                                            break;\n\n                                        default:\n                                            <input type=\"text\" class=\"form-control\"\n                                                   placeholder=\"@field.Placeholder\"\n                                                   @bind=\"GetFieldValue(field.FieldName)\"\n                                                   readonly=\"@(!field.IsEditable)\" />\n                                            break;\n                                    }\n\n                                    @if (!string.IsNullOrEmpty(field.Placeholder))\n                                    {\n                                        <small class=\"text-muted\">@field.Placeholder</small>\n                                    }\n                                </div>\n                            }\n                        }\n                        else\n                        {\n                            <div class=\"alert alert-info\">\n                                此表单暂无字段\n                            </div>\n                        }\n\n                        <div class=\"d-flex gap-2 mt-4\">\n                            <button type=\"submit\" class=\"btn btn-primary\" disabled=\"@isSubmitting\">\n                                @if (isSubmitting)\n                                {\n                                    <span class=\"spinner-border spinner-border-sm me-2\"></span>\n                                }\n                                ✅ 提交表单\n                            </button>\n                            <button type=\"button\" class=\"btn btn-secondary\" @onclick=\"ResetForm\">🔄 重置</button>\n                            <button type=\"button\" class=\"btn btn-outline-secondary\" @onclick=\"GoBack\">返回</button>\n                        </div>\n                    </EditForm>\n                </div>\n            </div>\n\n            <!-- 表单数据预览 -->\n            <div class=\"card mt-3\">\n                <div class=\"card-header\">\n                    <h6 class=\"mb-0\">📋 表单数据预览</h6>\n                </div>\n                <div class=\"card-body\">\n                    <pre class=\"bg-light p-3 rounded\"><code>@System.Text.Json.JsonSerializer.Serialize(formData, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</code></pre>\n                </div>\n            </div>\n        </div>\n    </div>\n}\n\n@if (!string.IsNullOrEmpty(errorMessage))\n{\n    <div class=\"alert alert-danger mt-3\">@errorMessage</div>\n}\n\n@if (!string.IsNullOrEmpty successMessage)\n{\n    <div class=\"alert alert-success mt-3\">@successMessage</div>\n}\n\n@code {\n    [Parameter]\n    public Guid FormId { get; set; }\n\n    private FormDetailDto? form;\n    private Dictionary<string, object?> formData = new();\n    private bool isSubmitting = false;\n    private string? errorMessage;\n    private string? successMessage;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await SetupAuthHeader();\n        await LoadForm();\n    }\n\n    private async Task SetupAuthHeader()\n    {\n        var token = await GetTokenAsync();\n        if (!string.IsNullOrEmpty(token))\n        {\n            Http.DefaultRequestHeaders.Authorization = \n                new System.Net.Http.Headers.AuthenticationHeaderValue(\"Bearer\", token);\n        }\n    }\n\n    private async Task LoadForm()\n    {\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<FormDetailDto>>($\"api/forms/{FormId}\");\n            if (response?.Success == true)\n            {\n                form = response.Data;\n                InitializeFormData();\n            }\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"加载失败: {ex.Message}\";\n        }\n    }\n\n    private void InitializeFormData()\n    {\n        if (form?.Fields == null) return;\n\n        formData = new Dictionary<string, object?>();\n        foreach (var field in form.Fields)\n        {\n            if (!string.IsNullOrEmpty(field.DefaultValue))\n            {\n                formData[field.FieldName] = field.DefaultValue;\n            }\n            else\n            {\n                formData[field.FieldName] = null;\n            }\n        }\n    }\n\n    private object? GetFieldValue(string fieldName)\n    {\n        if (formData.TryGetValue(fieldName, out var value))\n            return value;\n        return null;\n    }\n\n    private void SetFieldValue(string fieldName, object? value)\n    {\n        formData[fieldName] = value;\n    }\n\n    private async Task SubmitForm()\n    {\n        isSubmitting = true;\n        errorMessage = null;\n        successMessage = null;\n\n        try\n        {\n            // In preview mode, just show success message\n            await Task.Delay(500); // Simulate submission\n            successMessage = \"表单提交成功！（预览模式）\";\n        }\n        catch (Exception ex)\n        {\n            errorMessage = $\"提交异常: {ex.Message}\";\n        }\n        finally\n        {\n            isSubmitting = false;\n        }\n    }\n\n    private void ResetForm()\n    {\n        InitializeFormData();\n    }\n\n    private void GoBack()\n    {\n        NavigationManager.NavigateTo($\"/forms/{FormId}/design\");\n    }\n\n    private async Task<string?> GetTokenAsync()\n    {\n        try\n        {\n            return await JSRuntime.InvokeAsync<string?>(\"localStorage.getItem\", \"jwt_token\");\n        }\n        catch\n        {\n            return null;\n        }\n    }\n\n    public class FormDetailDto\n    {\n        public Guid FormId { get; set; }\n        public string FormName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsPublished { get; set; }\n        public List<FieldDto>? Fields { get; set; }\n    }\n\n    public class FieldDto\n    {\n        public Guid FieldId { get; set; }\n        public string FieldName { get; set; } = \"\";\n        public string FieldType { get; set; } = \"\";\n        public string? Label { get; set; }\n        public string? Placeholder { get; set; }\n        public string? DefaultValue { get; set; }\n        public string? FieldConfig { get; set; }\n        public bool IsRequired { get; set; }\n        public bool IsVisible { get; set; }\n        public bool IsEditable { get; set; }\n        public int SortOrder { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n","path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/FormPreview.razor"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":6425,"output":7472,"cacheRead":26048,"cacheWrite":0,"totalTokens":39945,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774395703506}}
