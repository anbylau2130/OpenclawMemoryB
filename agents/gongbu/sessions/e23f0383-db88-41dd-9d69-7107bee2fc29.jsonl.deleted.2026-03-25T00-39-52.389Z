       </NavLink>\n            </div>\n            \n            <div class=\"nav-item px-3\">\n                <div class=\"nav-link disabled text-uppercase fw-bold small\">工作流</div>\n            </div>\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"workflows\">\n                    <span class=\"bi bi-diagram-3-nav-menu\" aria-hidden=\"true\"></span> 🔄 工作流管理\n                </NavLink>\n            </div>\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"workflows/my-tasks\">\n                    <span class=\"bi bi-check2-square-nav-menu\" aria-hidden=\"true\"></span> ✅ 我的待办\n                </NavLink>\n            </div>\n            \n            <div class=\"nav-item px-3\">\n                <div class=\"nav-link disabled text-uppercase fw-bold small\">系统管理</div>\n            </div>\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"admin/users\">\n                    <span class=\"bi bi-people-nav-menu\" aria-hidden=\"true\"></span> 👥 用户管理\n                </NavLink>\n            </div>\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"admin/roles\">\n                    <span class=\"bi bi-shield-lock-nav-menu\" aria-hidden=\"true\"></span> 🔐 角色管理\n                </NavLink>\n            </div>\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"admin/plugins\">\n                    <span class=\"bi bi-puzzle-nav-menu\" aria-hidden=\"true\"></span> 🧩 插件管理\n                </NavLink>\n            </div>\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"admin/tenants\">\n                    <span class=\"bi bi-building-nav-menu\" aria-hidden=\"true\"></span> 🏢 租户管理\n                </NavLink>\n            </div>\n            \n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"notifications\">\n                    <span class=\"bi bi-bell-nav-menu\" aria-hidden=\"true\"></span> 🔔 通知中心\n                    @if (UnreadCount > 0)\n                    {\n                        <span class=\"badge bg-danger ms-1\">@UnreadCount</span>\n                    }\n                </NavLink>\n            </div>\n            \n            <hr class=\"my-2\" />\n            \n            <div class=\"nav-item px-3\">\n                <a class=\"nav-link\" href=\"#\" @onclick=\"HandleLogout\">\n                    <span class=\"bi bi-box-arrow-right-nav-menu\" aria-hidden=\"true\"></span> 🚪 登出\n                </a>\n            </div>\n        }\n        else\n        {\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"login\">\n                    <span class=\"bi bi-box-arrow-in-right-nav-menu\" aria-hidden=\"true\"></span> 🔐 登录\n                </NavLink>\n            </div>\n            <div class=\"nav-item px-3\">\n                <NavLink class=\"nav-link\" href=\"register\">\n                    <span class=\"bi bi-person-plus-nav-menu\" aria-hidden=\"true\"></span> ✨ 注册\n                </NavLink>\n            </div>\n        }\n    </nav>\n</div>\n\n@code {\n    private bool collapseNavMenu = true;\n    private bool IsAuthenticated = false;\n    private int UnreadCount = 0;\n    \n    private string? NavMenuCssClass => collapseNavMenu ? \"collapse\" : null;\n    \n    protected override async Task OnInitializedAsync()\n    {\n        await CheckAuthentication();\n    }\n    \n    private async Task CheckAuthentication()\n    {\n        IsAuthenticated = await AuthService.IsAuthenticatedAsync();\n        // TODO: Load unread notification count\n        if (IsAuthenticated)\n        {\n            UnreadCount = 3; // Mock value\n        }\n        StateHasChanged();\n    }\n    \n    private void ToggleNavMenu()\n    {\n        collapseNavMenu = !collapseNavMenu;\n    }\n    \