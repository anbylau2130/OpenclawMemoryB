\": \"开发指南 > 控件使用指南 > 业务字段 > 基础资料字段\",\n        \"url\": \"https://vip.kingdee.com/knowledge/atlas/221670300038589696/detail\"\n      },\n      {\n        \"name\": \"单据体\",\n        \"entityId\": \"224093028694948608\",\n        \"id\": \"248822542436417280\",\n        \"path\": \"开发指南 > 控件使用指南 > 单据体 > 单据体\",\n        \"url\": \"https://vip.kingdee.com/knowledge/atlas/224093028694948608/detail\"\n      },\n      {\n        \"name\": \"单据体\",\n        \"entityId\": \"304189867372874752\",\n        \"id\": \"304974229315580672\",\n        \"path\": \"开发案例库 > 控件 > 单据体\",\n        \"url\": \"https://vip.kingdee.com/knowledge/atlas/304189867372874752/detail\"\n      }\n    ]\n  }\n}"}],"details":{"ok":true,"targetId":"ADBAF45F03907D36424ABD4D7C453243","url":"https://vip.kingdee.com/knowledge/specialDetail/218022218066869248?productLineId=29&lang=zh-CN","result":{"totalFound":8,"documents":[{"name":"文本字段","entityId":"215128684791905280","id":"248483045102409216","path":"开发指南 > 控件使用指南 > 通用字段 > 文本字段","url":"https://vip.kingdee.com/knowledge/atlas/215128684791905280/detail"},{"name":"整数字段","entityId":"220142099956385536","id":"248820933703068672","path":"开发指南 > 控件使用指南 > 通用字段 > 整数字段","url":"https://vip.kingdee.com/knowledge/atlas/220142099956385536/detail"},{"name":"小数字段","entityId":"220153919438712064","id":"248820981282914048","path":"开发指南 > 控件使用指南 > 通用字段 > 小数字段","url":"https://vip.kingdee.com/knowledge/atlas/220153919438712064/detail"},{"name":"日期字段","entityId":"220180664904104960","id":"248821285453840128","path":"开发指南 > 控件使用指南 > 通用字段 > 日期字段","url":"https://vip.kingdee.com/knowledge/atlas/220180664904104960/detail"},{"name":"复选框字段","entityId":"221552451739577600","id":"248821542027804416","path":"开发指南 > 控件使用指南 > 通用字段 > 复选框字段","url":"https://vip.kingdee.com/knowledge/atlas/221552451739577600/detail"},{"name":"基础资料字段","entityId":"221670300038589696","id":"474510133054365696","path":"开发指南 > 控件使用指南 > 业务字段 > 基础资料字段","url":"https://vip.kingdee.com/knowledge/atlas/2216703000385