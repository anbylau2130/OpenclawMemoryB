ed\":false,\"useCategory\":1,\"name\":\"开发平台\",\"description\":\"苍穹开发者的用户手册，从入门到高级，从前端到后端，从开发指南到最佳实践，一应俱全，应有尽有！\",\"hasHomePage\":1,\"itemNum\":601,\"logo\":\"/download/0100c38c6d64f372474c9975bdf6fa77160c.png\",\"title\":\"开发平台\",\"id\":\"218022218066869248\",\"views\":10065029,\"status\":2,\"totalAppraisalScore\":1122,\"totalAppraisalUsers\":225},\"categoryList\":[{\"childCategory\":[{\"childCategory\":[{\"childCategory\":null,\"code\":null,\"description\":\"\",\"entityId\":\"765939177593756160\",\"entityType\":\"Knowledge\",\"id\":\"768793136637675008\",\"isCategory\":false,\"name\":\"苍穹V8.0第三方包升级说明\",\"parentId\":\"218024718795190528\",\"sort\":null,\"specialId\":\"218022218066869248\",\"status\":1,\"order\":1},{\"childCategory\":null,\"code\":null,\"description\":\"\",\"entityId\":\"767850225473553920\",\"entityType\":\"Knowledge\",\"id\":\"768468787737134592\",\"isCategory\":false,\"name\":\"苍穹V8.0及以上版本支持的JDK版本调整\",\"parentId\":\"218024718795190528\",\"sort\":\"1\",\"specialId\":\"218022218066869248\",\"status\":1,\"order\":2},{\"childCategory\":null,\"code\":null,\"description\":\"\",\"entityId\":\"697394879487465472\",\"entityType\":\"Knowledge\",\"id\":\"768792082709939712\",\"isCategory\":false,\"name\":\"苍穹V7.0.9第三方依赖包升级说明\",\"parentId\":\"218024718795190528\",\"sort\":\"2\",\"specialId\":\"218022218066869248\",\"status\":1,\"order\":3}],\"code\":null,\"description\":null,\"entityId\":null,\"entityType\":null,\"id\":\"218024718795190528\",\"isCategory\":true,\"name\":\"重要通知\",\"parentId\":\"218024674369122560\",\"sort\":\"1\",\"specialId\":\"218022218066869248\",\"status\":1}],\"code\":null,\"description\":null,\"entityId\":null,\"entityType\":null,\"id\":\"218024674369122560\",\"isCategory\":true,\"name\":\"动态与公告\",\"parentId\":\"-1\",\"sort\":\"1\",\"specialId\":\"218022218066869248\",\"status\":1},{\"childCategory\":[{\"childCategory\":null,\"code\":null,\"description\":\"\",\"entityId\":\"355302802538757376\",\"entityType\":\"Knowledge\",\"id\":\"3553