{"type":"message","id":"0bf96955","parentId":"5227bf06","timestamp":"2026-03-22T15:03:24.292Z","message":{"role":"toolResult","toolCallId":"call_a0f42f1690404e578728cfda","toolName":"read","content":[{"type":"text","text":"# 云天佑 (Tianyou) 环境配置文件\n\n# 数据库配置\nPOSTGRES_HOST=localhost\nPOSTGRES_PORT=5432\nPOSTGRES_DB=tianyou\nPOSTGRES_USER=tianyou\nPOSTGRES_PASSWORD=tianyou123\n\n# Redis配置\nREDIS_HOST=localhost\nREDIS_PORT=6379\nREDIS_PASSWORD=\n\n# RabbitMQ配置\nRABBITMQ_HOST=localhost\nRABBITMQ_PORT=5672\nRABBITMQ_USER=tianyou\nRABBITMQ_PASSWORD=tianyou123\n\n# MinIO配置\nMINIO_ENDPOINT=localhost:9000\nMINIO_ACCESS_KEY=tianyou\nMINIO_SECRET_KEY=tianyou123\n\n# JWT配置\nJWT_SECRET_KEY=Tianyou_Secret_Key_2026_Must_Be_At_Least_32_Characters_Long\nJWT_ISSUER=Tianyou\nJWT_AUDIENCE=Tianyou.Users\n\n# 应用配置\nASPNETCORE_ENVIRONMENT=Production\nAPI_PORT=5000\nWEB_PORT=5001\n"}],"isError":false,"timestamp":1774191804292}}
