{"type":"message","id":"dc7b8854","parentId":"d488776f","timestamp":"2026-03-22T15:03:18.585Z","message":{"role":"toolResult","toolCallId":"call_7a635d36446545f9ba019a91","toolName":"read","content":[{"type":"text","text":"# API 服务 Dockerfile\nFROM mcr.microsoft.com/dotnet/aspnet:8.0 AS base\nWORKDIR /app\nEXPOSE 80\nEXPOSE 443\n\nFROM mcr.microsoft.com/dotnet/sdk:8.0 AS build\nWORKDIR /src\n\n# 复制项目文件\nCOPY [\"services/Tianyou.FormService/Tianyou.FormService.csproj\", \"Tianyou.FormService/\"]\nCOPY [\"src/Tianyou.Core.Abstractions/Tianyou.Core.Abstractions.csproj\", \"Tianyou.Core.Abstractions/\"]\nCOPY [\"src/Tianyou.Plugin.Abstractions/Tianyou.Plugin.Abstractions.csproj\", \"Tianyou.Plugin.Abstractions/\"]\nCOPY [\"src/Tianyou.LowCode.Engine/Tianyou.LowCode.Engine.csproj\", \"Tianyou.LowCode.Engine/\"]\nCOPY [\"src/Tianyou.Data/Tianyou.Data.csproj\", \"Tianyou.Data/\"]\nCOPY [\"src/Tianyou.Plugin/Tianyou.Plugin.csproj\", \"Tianyou.Plugin/\"]\nCOPY [\"src/Tianyou.Auth/Tianyou.Auth.csproj\", \"Tianyou.Auth/\"]\n\n# 还原依赖\nRUN dotnet restore \"Tianyou.FormService/Tianyou.FormService.csproj\"\n\n# 复制源代码\nCOPY . .\n\n# 构建项目\nWORKDIR \"/src/Tianyou.FormService\"\nRUN dotnet build \"Tianyou.FormService.csproj\" -c Release -o /app/build\n\n# 发布项目\nFROM build AS publish\nRUN dotnet publish \"Tianyou.FormService.csproj\" -c Release -o /app/publish /p:UseAppHost=false\n\n# 最终镜像\nFROM base AS final\nWORKDIR /app\nCOPY --from=publish /app/publish .\nENTRYPOINT [\"dotnet\", \"Tianyou.FormService.dll\"]\n"}],"isError":false,"timestamp":1774191798585}}
{"type":"message","id":"7fac5c60","parentId":"dc7b8854","timestamp":"2026-03-22T15:03:18.618Z","message":{"role":"toolResult","toolCallId":"call_6ed9f79e63a7406695f033f5","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n\n# 云天佑(Tianyou) - 一键安装脚本\n# 作者: Tianyou Team\n# 日期: 2026-03-22\n\nset -e\n\necho \"==========================================\"\necho \"   云天佑(Tianyou) 项目安装脚本\"\necho \"==========================================\"\necho \"\"\n\n# 颜色定义\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nNC='\\033[0m' # No Color\n\n# 检查Docker\nif ! command -v docker &> /dev/null; then\n    echo -e \"${RED}错误: 未安装Docker${NC}\"\n    echo \"请先安装Docker: https://docs.docker.com/get-docker/\"\n    exit 1\nfi\n\n# 检查Docker Compose\nif ! command -v docker-compose &> /dev/null; then\n    echo -e \"${RED}错误: 未安装Docker Compose${NC}\"\n    echo \"请先安装Docker Compose: https://docs.docker.com/compose/install/\"\n    exit 1\nfi\n\n# 检查.NET SDK\nif ! command -v dotnet &> /dev/null; then\n    echo -e \"${YELLOW}警告: 未安装.NET SDK${NC}\"\n    echo \"建议安装.NET 8 SDK: https://dotnet.microsoft.com/download\"\nfi\n\necho -e \"${GREEN}✓ 环境检查通过${NC}\"\necho \"\"\n\n# 创建数据目录\necho \"创建数据目录...\"\nmkdir -p data/postgres\nmkdir -p data/redis\nmkdir -p data/rabbitmq\nmkdir -p data/minio\nmkdir -p logs\n\n# 设置权限\nchmod -R 755 data\nchmod -R 755 logs\n\necho -e \"${GREEN}✓ 数据目录创建完成${NC}\"\necho \"\"\n\n# 复制环境配置文件\nif [ ! -f .env ]; then\n    echo \"创建环境配置文件...\"\n    cp .env.example .env\n    echo -e \"${YELLOW}请编辑 .env 文件配置您的环境变量${NC}\"\nfi\n\n# 构建Docker镜像\necho \"\"\necho \"构建Docker镜像...\"\necho \"这可能需要几分钟时间...\"\ndocker-compose -f deploy/docker/docker-compose.yml build\n\necho -e \"${GREEN}✓ Docker镜像构建完成${NC}\"\necho \"\"\n\n# 启动服务\necho \"启动服务...\"\ndocker-compose -f deploy/docker/docker-compose.yml up -d\n\necho \"\"\necho \"==========================================\"\necho \"   安装完成!\"\necho \"==========================================\"\necho \"\"\necho -e \"${GREEN}访问地址:${NC}\"\necho \"  - Web前端: http://localhost:5001\"\necho \"  - API服务: http://localhost:5000\"\necho \"  - RabbitMQ管理: http://localhost:15672 (用户名: tianyou, 密码: tianyou123)\"\necho \"  - MinIO控制台: http://localhost:9001 (用户名: tianyou, 密码: tianyou123)\"\necho \"\"\necho -e \"${GREEN}默认账号:${NC}\"\necho \"  - 管理员: admin / admin123\"\necho \"\"\necho -e \"${YELLOW}提示:${NC}\"\necho \"  - 首次启动可能需要等待30秒让数据库初始化\"\necho \"  - 查看日志: docker-compose -f deploy/docker/docker-compose.yml logs -f\"\necho \"  - 停止服务: docker-compose -f deploy/docker/docker-compose.yml down\"\necho \"\"\n"}],"isError":false,"timestamp":1774191798618}}
