ontrollers}\n./src/Tianyou.Auth/Models\n./src/Tianyou.Auth/Services\n./src/Tianyou.Auth/Authorization\n./src/Tianyou.Auth/DataSecurity\n./src/Tianyou.Auth/Security\n./src/Tianyou.Auth/Controllers\n./src/Tianyou.Plugin\n./src/Tianyou.Domain\n./src/Tianyou.Domain/Common\n./src/Tianyou.Domain/Repositories\n./src/Tianyou.Domain/Services\n./src/Tianyou.Domain/Models\n./src/Tianyou.Domain/Events\n./src/Tianyou.Infrastructure\n./src/Tianyou.Infrastructure/Caching\n./src/Tianyou.Infrastructure/Resilience\n./src/Tianyou.Infrastructure/HealthChecks\n./plugins\n./plugins/Tianyou.Plugin.Samples\n./deploy\n./deploy/{docker,k8s,scripts,monitoring}\n./deploy/docker\n./deploy/k8s\n./deploy/scripts\n./.github\n./.github/workflows\n./services\n./services/Tianyou.FormService\n./services/Tianyou.FormService/Controllers\n./database\n./database/postgresql\n./docs\n./docs/architecture\n./docs/api\n./docs/guides\n./tests\n./tests/Tianyou.Domain.UnitTests","cwd":"/root/clawd-gongbu"},"isError":false,"timestamp":1774191786447}}
{"type":"message","id":"f05149ec","parentId":"c40e2eae","timestamp":"2026-03-22T15:03:06.579Z","message":{"role":"toolResult","toolCallId":"call_652ec89a37624669b1e6b363","toolName":"read","content":[{"type":"text","text":"# 云天佑 - 企业级低代码开发平台\n\n> 使用 C# / .NET 8 构建的企业级低代码开发平台\n> 创建时间: 2026-03-22\n> 项目代号: Tianyou\n\n---\n\n## 🎯 项目目标\n\n### 核心目标\n1. **功能一致性**: 对标企业级低代码平台功能\n2. **二次开发复用**: 支持插件化扩展\n3. **低代码优先**: 低代码平台作为核心功能\n4. **现代化架构**: 采用最新的.NET技术栈\n\n### 技术目标\n- 使用 .NET 8 + C# 12\n- 微服务架构（可独立部署）\n- 云原生支持（Docker/K8s）\n- 跨平台（Windows/Linux/macOS）\n\n---\n\n## 📐 系统架构\n\n### 整体架构图\n\n```\n┌─────────────────────────────────────────────────────────────┐\n│                      前端层 (Frontend)                        │\n│  ┌─────────────┐  ┌─────────────┐  ┌─────────────┐          │\n│  │  React SPA  │  │  Vue SPA    │  │  Blazor     │          │\n│  │  (可选)     │  │  (可选)     │  │  (主推)     │          │\n│  └─────────────┘  └─────────────┘  └─────────────┘          │\n└─────────────────────────────────────────────────────────────┘\n                              │\n                              ▼\n┌─────────────────────────────────────────────────────────────┐\n│                    API网关层 (API Gateway)                    │\n│  ┌─────────────────────────────────────────────────────┐    │\n│  │  YARP (Yet Another Reverse Proxy)                   │    │\n│  │  - 路由转发  - 负载均衡  - 限流熔断  - 认证授权     │    │\n│  └─────────────────────────────────────────────────────┘    │\n└─────────────────────────────────────────────────────────────┘\n                              │\n                              ▼\n┌─────────────────────────────────────────────────────────────┐\n│                    微服务层 (Microservices)                   │\n│  ┌──────────┐ ┌──────────┐ ┌──────────┐ ┌──────────┐       │\n│  │低代码引擎│ │ 表单服务 │ │ 工作流   │ │ 报表服务 │       │\n│  │LowCode   │ │Form      │ │Workflow  │ │Report    │       │\n│  └──────────┘ └──────────┘ └──────────┘ └──────────┘       │\n│  ┌──────────┐ ┌──────────┐ ┌──────────┐ ┌──────────┐       │\n│  │ 插件服务 │ │ 数据服务 │ │ 权限服务 │ │ 消息服务 │       │\n│  │Plugin    │ │Data      │ │Auth      │ │Message   │       │\n│  └──────────┘ └──────────┘ └──────────┘ └──────────┘       │\n└─────────────────────────────────────────────────────────────┘\n                              │\n                              ▼\n┌─────────────────────────────────────────────────────────────┐\n│                    数据层 (Data Layer)                        │\n│  ┌──────────┐ ┌──────────┐ ┌──────────┐ ┌──────────┐       │\n│  │PostgreSQL│ │  Redis   │ │ RabbitMQ │ │ MinIO    │       │\n│  │ (主库)   │ │ (缓存)   │ │ (消息)   │ │ (文件)   │       │\n│  └──────────┘ └──────────┘ └──────────┘ └──────────┘       │\n└─────────────────────────────────────────────────────────────┘\n```\n\n---\n\n## 🏗️ 核心模块\n\n### 1. 低代码引擎 (Tianyou.LowCode)\n\n**功能**:\n- 可视化表单设计器\n- 模型驱动开发\n- 自动代码生成\n- 多端适配\n\n**核心组件**:\n```\nTianyou.LowCode/\n├── Engine/                    # 核心引擎\n│   ├── FormEngine.cs         # 表单引擎\n│   ├── PageEngine.cs         # 页面引擎\n│   ├── WorkflowEngine.cs     # 工作流引擎\n│   └── ReportEngine.cs       # 报表引擎\n├── Designer/                  # 设计器\n│   ├── FormDesigner.cs       # 表单设计器\n│   ├── WorkflowDesigner.cs   # 流程设计器\n│   └── ReportDesigner.cs     # 报表设计器\n├── Metadata/                  # 元数据\n│   ├── FormMetadata.cs       # 表单元数据\n│   ├── FieldMetadata.cs      # 字段元数据\n│   └── ControlMetadata.cs    # 控件元数据\n└── Generator/                 # 代码生成\n    ├── CsGenerator.cs        # C#代码生成\n    ├── TsGenerator.cs        # TypeScript生成\n    └── SqlGenerator.cs       # SQL生成\n```\n\n### 2. 插件系统 (Tianyou.Plugin)\n\n**功能**:\n- 插件生命周期管理\n- 依赖注入支持\n- 热加载/卸载\n- 插件隔离\n\n**核心接口**:\n```csharp\nnamespace Tianyou.Plugin;\n\n/// <summary>\n/// 插件基类接口\n/// </summary>\npublic interface IPlugin\n{\n    string Id { get; }\n    string Name { get; }\n    Version Version { get; }\n    string Description { get; }\n    \n    void Initialize(IServiceProvider services);\n    void Start();\n    void Stop();\n    void Dispose();\n}\n\n/// <summary>\n/// 表单插件基类\n/// </summary>\npublic abstract class FormPluginBase : IPlugin\n{\n    protected IFormView View { get; }\n    protected IDataModel Model { get; }\n    \n    public virtual void OnInitialize() { }\n    public virtual void OnAfterBindData(AfterBindDataEvent e) { }\n    public virtual void OnClick(ClickEvent e) { }\n    public virtual void OnPropertyChanged(PropertyChangedEvent e) { }\n    public virtual void OnBeforeOperation(BeforeOperationEvent e) { }\n    public virtual void OnAfterOperation(AfterOperationEvent e) { }\n}\n\n/// <summary>\n/// 操作插件基类\n/// </summary>\npublic abstract class OperationPluginBase : IPlugin\n{\n    public virtual void OnExecute(OperationContext context) { }\n    public virtual ValidationResult OnValidate(OperationContext context) { }\n}\n```\n\n---\n\n## 📁 项目结构\n\n```\nTianyou/\n├── src/                           # 源代码\n│   ├── Tianyou.Core/             # 核心库\n│   ├── Tianyou.LowCode/          # 低代码引擎\n│   ├── Tianyou.Plugin/           # 插件系统\n│   ├── Tianyou.Form/             # 表单服务\n│   ├── Tianyou.Workflow/         # 工作流服务\n│   ├── Tianyou.Report/           # 报表服务\n│   ├── Tianyou.Data/             # 数据服务\n│   ├── Tianyou.Auth/             # 认证授权\n│   ├── Tianyou.Message/          # 消息服务\n│   └── Tianyou.Gateway/          # API网关\n│\n├── services/                      # 微服务\n│   ├── Tianyou.FormService/      # 表单微服务\n│   ├── Tianyou.WorkflowService/  # 工作流微服务\n│   ├── Tianyou.ReportService/    # 报表微服务\n│   └── Tianyou.PluginService/    # 插件微服务\n│\n├── web/                           # 前端项目\n│   ├── Tianyou.Web.Blazor/       # Blazor前端\n│   ├── Tianyou.Web.React/        # React前端(可选)\n│   └── Tianyou.Designer/         # 可视化设计器\n│\n├── plugins/                       # 标准插件\n│   ├── Tianyou.Plugin.Standard/  # 标准插件库\n│   └── Tianyou.Plugin.Samples/   # 示例插件\n│\n├── tests/                         # 测试\n│   ├── Tianyou.Core.Tests/\n│   ├── Tianyou.LowCode.Tests/\n│   └── Tianyou.Integration.Tests/\n│\n├── docs/                          # 文档\n│   ├── architecture/             # 架构文档\n│   ├── api/                      # API文档\n│   └── guides/                   # 开发指南\n│\n├── deploy/                        # 部署配置\n│   ├── docker/                   # Docker配置\n│   ├── k8s/                      # Kubernetes配置\n│   └── scripts/                  # 部署脚本\n│\n└── tools/                         # 工具\n    ├── Tianyou.CLI/              # 命令行工具\n    └── Tianyou.Generator/        # 代码生成器\n```\n\n---\n\n## 🚀 开发路线图\n\n### Phase 1: 基础框架 (2周)\n- [ ] 项目结构搭建\n- [ ] 核心接口定义\n- [ ] 依赖注入配置\n- [ ] 日志系统\n- [ ] 配置管理\n\n### Phase 2: 低代码引擎 (4周)\n- [ ] 元数据模型设计\n- [ ] 表单引擎实现\n- [ ] 页面引擎实现\n- [ ] 可视化设计器(基础)\n- [ ] 代码生成器\n\n### Phase 3: 插件系统 (3周)\n- [ ] 插件生命周期管理\n- [ ] 插件加载器\n- [ ] 事件系统\n- [ ] 插件API\n- [ ] 插件市场\n\n### Phase 4: 核心服务 (4周)\n- [ ] 表单服务\n- [ ] 数据服务\n- [ ] 权限服务\n- [ ] 工作流服务(基础)\n- [ ] 报表服务(基础)\n\n### Phase 5: 前端开发 (4周)\n- [ ] Blazor组件库\n- [ ] 表单渲染器\n- [ ] 列表渲染器\n- [ ] 可视化设计器\n\n### Phase 6: 微服务化 (3周)\n- [ ] 服务拆分\n- [ ] API网关\n- [ ] 服务发现\n- [ ] 分布式事务\n\n### Phase 7: 测试与优化 (2周)\n- [ ] 单元测试\n- [ ] 集成测试\n- [ ] 性能优化\n- [ ] 文档完善\n\n**预计总工期: 22周 (约5.5个月)**\n\n---\n\n## 📦 技术栈\n\n### 后端\n| 组件 | 技术 | 版本 |\n|-----|------|------|\n| 运行时 | .NET | 8.0 |\n| 语言 | C# | 12 |\n| Web框架 | ASP.NET Core | 8.0 |\n| ORM | EF Core / Dapper | 8.0 |\n| 数据库 | PostgreSQL | 16 |\n| 缓存 | Redis | 7 |\n| 消息队列 | RabbitMQ | 3.12 |\n| API网关 | YARP | 2.0 |\n| 容器 | Docker | 24 |\n| 编排 | Kubernetes | 1.28 |\n\n### 前端\n| 组件 | 技术 | 版本 |\n|-----|------|------|\n| 框架 | Blazor | 8.0 |\n| UI库 | MudBlazor | 7.x |\n| 图表 | ApexCharts | 3.x |\n| 设计器 | Ant Design Blazor | 1.x |\n\n### 工具\n| 组件 | 技术 |\n|-----|------|\n| IDE | VS 2022 / Rider |\n| 构建工具 | dotnet CLI |\n| 包管理 | NuGet |\n| 代码分析 | Roslyn Analyzers |\n| 测试 | xUnit |\n\n---\n\n## 🔗 相关文档\n\n- [架构设计详解](./docs/architecture/README.md)\n- [插件开发指南](./docs/guides/plugin-development.md)\n- [API参考文档](./docs/api/README.md)\n- [部署指南](./docs/deployment/README.md)\n\n---\n\n**项目维护**: 云天佑团队\n**最后更新**: 2026-03-22\n"}],"isError":false,"timestamp":1774191786579}}
{"type":"message","id":"c0a5b234","parentId":"f05149ec","timestamp":"2026-03-22T15:03:06.582Z","message":{"role":"toolResult","toolCallId":"call_158d3f6a6f40411f9845de65","toolName":"read","content":[{"type":"text","text":"# 云天佑 (Tianyou) - 项目开发总览\n\n> **项目名称**: 云天佑 (Cloud Tianyou)\n> **启动时间**: 2026-03-22 21:55\n> **当前阶段**: 全力开发中\n> **预计完成**: 2026-03-23 08:00\n\n---\n\n## 🎯 项目目标\n\n### 核心目标\n1. ✅ 功能对标企业级低代码平台\n2. ✅ 插件化架构设计\n3. ✅ 微服务架构\n4. ✅ 云原生支持\n\n### 技术栈\n- **后端**: .NET 8 + C# 12\n- **前端**: Blazor Server\n- **数据库**: PostgreSQL 16\n- **缓存**: Redis 7\n- **消息队列**: RabbitMQ 3.12\n- **容器**: Docker + Kubernetes\n\n---\n\n## 🚀 开发进度\n\n### 已完成 ✅\n- [x] 项目结构搭建\n- [x] 核心接口定义\n- [x] 元数据模型设计\n- [x] 事件系统实现\n- [x] 插件基类实现\n- [x] 表单引擎核心\n- [x] 示例插件开发\n\n### 进行中 🔄\n- [ ] 核心服务实现 (兵部负责)\n  - 数据服务层\n  - 插件管理器\n  - 表单服务API\n- [ ] 文档和前端 (礼部负责)\n  - 完整文档\n  - 数据库脚本\n  - Blazor前端\n- [ ] 部署配置 (工部负责)\n  - Docker配置\n  - Kubernetes配置\n  - CI/CD流程\n- [ ] 安全权限 (刑部负责)\n  - JWT认证\n  - RBAC权限\n  - 数据安全\n\n### 待开始 ⏳\n- [ ] 工作流引擎\n- [ ] 报表引擎\n- [ ] 移动端适配\n- [ ] 性能优化\n\n---\n\n## 📁 项目结构\n\n```\ntianyou-dotnet/\n├── Tianyou.sln                    # 解决方案文件\n├── Directory.Build.props          # 全局构建配置\n├── .gitignore                     # Git忽略文件\n│\n├── src/                           # 源代码\n│   ├── Tianyou.Core.Abstractions/ # 核心抽象层\n│   ├── Tianyou.Plugin.Abstractions/ # 插件抽象层\n│   ├── Tianyou.LowCode.Engine/    # 低代码引擎\n│   ├── Tianyou.Data/              # 数据服务\n│   ├── Tianyou.Plugin/            # 插件系统\n│   └── Tianyou.Auth/              # 认证授权\n│\n├── services/                      # 微服务\n│   └── Tianyou.FormService/       # 表单服务\n│\n├── web/                           # 前端\n│   └── Tianyou.Web.Blazor/        # Blazor前端\n│\n├── plugins/                       # 插件\n│   └── Tianyou.Plugin.Samples/    # 示例插件\n│\n├── docs/                          # 文档\n├── database/                      # 数据库脚本\n└── deploy/                        # 部署配置\n```\n\n---\n\n## 🏗️ 核心架构\n\n### 1. 低代码引擎\n```\n表单元数据 → 表单引擎 → 动态渲染 → 数据绑定 → 事件触发\n```\n\n### 2. 插件系统\n```\n插件加载 → 生命周期管理 → 事件订阅 → 业务扩展\n```\n\n### 3. 微服务架构\n```\nAPI网关 → 服务发现 → 微服务 → 数据层\n```\n\n---\n\n## 🔌 核心功能模块\n\n### 已实现模块\n| 模块 | 功能 | 完成度 |\n|-----|------|--------|\n| **元数据模型** | 表单/字段/规则定义 | 100% |\n| **插件基类** | 5种插件类型 | 100% |\n| **事件系统** | 12种事件类型 | 100% |\n| **表单引擎** | 核心渲染逻辑 | 80% |\n\n### 待实现模块\n| 模块 | 负责部门 | 预计完成 |\n|-----|---------|---------|\n| **数据服务** | 兵部 | 今晚 |\n| **Web API** | 兵部 | 今晚 |\n| **前端框架** | 礼部 | 今晚 |\n| **数据库脚本** | 礼部 | 今晚 |\n| **Docker配置** | 工部 | 今晚 |\n| **认证授权** | 刑部 | 今晚 |\n\n---\n\n## 🎨 功能对比\n\n| 功能 | 云苍穹 | 云天佑 | 状态 |\n|-----|--------|--------|------|\n| **表单设计器** | ✅ | 🔄 | 开发中 |\n| **插件系统** | ✅ | ✅ | 已完成 |\n| **工作流** | ✅ | ⏳ | 待开发 |\n| **报表** | ✅ | ⏳ | 待开发 |\n| **移动端** | ✅ | ⏳ | 待开发 |\n| **API接口** | ✅ | 🔄 | 开发中 |\n| **权限系统** | ✅ | 🔄 | 开发中 |\n| **低代码** | ✅ | ✅ | 已完成核心 |\n\n---\n\n## 📝 开发规范\n\n### 命名空间\n- 所有代码使用 `Tianyou.*` 命名空间\n- 不使用任何第三方品牌名称\n\n### 代码风格\n- C# 12 最新语法\n- Nullable引用类型\n- 异步编程优先\n- 依赖注入\n\n### 提交规范\n- feat: 新功能\n- fix: 修复\n- docs: 文档\n- refactor: 重构\n- test: 测试\n\n---\n\n## 🔗 快速链接\n\n- [项目文档](./docs/README.md)\n- [API文档](./docs/api/README.md)\n- [开发指南](./docs/guides/quick-start.md)\n- [插件开发](./docs/guides/plugin-development.md)\n- [部署指南](./docs/deployment/README.md)\n\n---\n\n## 👥 团队分工\n\n| 部门 | 职责 | 状态 |\n|-----|------|------|\n| **司礼监** | 项目统筹 | 🟢 运行中 |\n| **兵部** | 核心代码 | 🔄 开发中 |\n| **礼部** | 文档前端 | 🔄 开发中 |\n| **工部** | 部署运维 | 🔄 开发中 |\n| **刑部** | 安全权限 | 🔄 开发中 |\n\n---\n\n## 📊 项目统计\n\n| 指标 | 当前 | 目标 |\n|-----|------|------|\n| **代码文件** | 8个 | 50+ |\n| **代码行数** | 2000+ | 10000+ |\n| **核心模块** | 3个 | 10+ |\n| **示例插件** | 4个 | 10+ |\n| **API接口** | 0个 | 50+ |\n\n---\n\n**最后更新**: 2026-03-22 21:55\n**下次更新**: 子代理完成后\n"}],"isError":false,"timestamp":1774191786579}}
{"type":"message","id":"5b08f641","parentId":"c0a5b234","timestamp":"2026-03-22T15:03:13.486Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，我已经了解了项目的基本结构。现在我需要：\n\n1. 完善所有技术文档\n2. 创建API使用文档\n3. 创建部署指南\n4. 配置Docker部署文件\n5. 创建一键部署脚本\n\n让我先查看现有的文档和部署配置，然后补充缺失的内容。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_92b4cdf8f8b046969c478abc","name":"read","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/deploy/docker/docker-compose.yml"}},{"type":"toolCall","id":"call_d026b49054b74d54bbcfab25","name":"read","arguments":{"file_path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/docs/api/README.md"}},{"type":"toolCall","id":"call_1998603a4bb34a77aac5ac3f","name":"exec","arguments":{"command":"find /root/.openclaw/workspace-silijian/projects/tianyou-dotnet/deploy -type f"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":4950,"output":157,"cacheRead":12480,"cacheWrite":0,"totalTokens":17587,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774191786583}}
{"type":"message","id":"89032d15","parentId":"5b08f641","timestamp":"2026-03-22T15:03:13.597Z","message":{"role":"toolResult","toolCallId":"call_92b4cdf8f8b046969c478abc","toolName":"read","content":[{"type":"text","text":"version: '3.8'\n\nservices:\n  # PostgreSQL 数据库\n  postgres:\n    image: postgres:16-alpine\n    container_name: tianyou-postgres\n    environment:\n      POSTGRES_DB: tianyou\n      POSTGRES_USER: tianyou\n      POSTGRES_PASSWORD: tianyou123\n    ports:\n      - \"5432:5432\"\n    volumes:\n      - postgres_data:/var/lib/postgresql/data\n      - ../database/postgresql/01_init.sql:/docker-entrypoint-initdb.d/01_init.sql\n    networks:\n      - tianyou-network\n    restart: unless-stopped\n\n  # Redis 缓存\n  redis:\n    image: redis:7-alpine\n    container_name: tianyou-redis\n    ports:\n      - \"6379:6379\"\n    volumes:\n      - redis_data:/data\n    networks:\n      - tianyou-network\n    restart: unless-stopped\n\n  # RabbitMQ 消息队列\n  rabbitmq:\n    image: rabbitmq:3.12-management-alpine\n    container_name: tianyou-rabbitmq\n    environment:\n      RABBITMQ_DEFAULT_USER: tianyou\n      RABBITMQ_DEFAULT_PASS: tianyou123\n    ports:\n      - \"5672:5672\"\n      - \"15672:15672\"\n    volumes:\n      - rabbitmq_data:/var/lib/rabbitmq\n    networks:\n      - tianyou-network\n    restart: unless-stopped\n\n  # MinIO 文件存储\n  minio:\n    image: minio/minio:latest\n    container_name: tianyou-minio\n    environment:\n      MINIO_ROOT_USER: tianyou\n      MINIO_ROOT_PASSWORD: tianyou123\n    ports:\n      - \"9000:9000\"\n      - \"9001:9001\"\n    volumes:\n      - minio_data:/data\n    command: server /data --console-address \":9001\"\n    networks:\n      - tianyou-network\n    restart: unless-stopped\n\n  # API 服务\n  api:\n    build:\n      context: ../\n      dockerfile: deploy/docker/Dockerfile.api\n    container_name: tianyou-api\n    environment:\n      - ASPNETCORE_ENVIRONMENT=Production\n      - ConnectionStrings__Default=Host=postgres;Database=tianyou;Username=tianyou;Password=tianyou123\n      - Redis__Connection=redis:6379\n      - RabbitMQ__Host=rabbitmq\n      - MinIO__Endpoint=minio:9000\n    ports:\n      - \"5000:80\"\n    depends_on:\n      - postgres\n      - redis\n      - rabbitmq\n    networks:\n      - tianyou-network\n    restart: unless-stopped\n\n  # Web 前端\n  web:\n    build:\n      context: ../\n      dockerfile: deploy/docker/Dockerfile.web\n    container_name: tianyou-web\n    environment:\n      - ASPNETCORE_ENVIRONMENT=Production\n      - Api__BaseUrl=http://api\n    ports:\n      - \"5001:80\"\n    depends_on:\n      - api\n    networks:\n      - tianyou-network\n    restart: unless-stopped\n\nvolumes:\n  postgres_data:\n  redis_data:\n  rabbitmq_data:\n  minio_data:\n\nnetworks:\n  tianyou-network:\n    driver: bridge\n"}],"isError":false,"timestamp":1774191793596}}
{"type":"message","id":"ffa148f6","parentId":"89032d15","timestamp":"2026-03-22T15:03:13.622Z","message":{"role":"toolResult","toolCallId":"call_d026b49054b74d54bbcfab25","toolName":"read","content":[{"type":"text","text":"# 云天佑 (Tianyou) - API 接口文档\n\n> 版本: 1.0.0\n> 基础URL: http://localhost:5000/api\n> 认证方式: JWT Bearer Token\n\n---\n\n## 1. 认证接口\n\n### 1.1 登录\n\n**请求**:\n```http\nPOST /auth/login\nContent-Type: application/json\n\n{\n  \"userName\": \"admin\",\n  \"password\": \"admin123\"\n}\n```\n\n**响应**:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"refreshToken\": \"d4f5g6h7j8k9...\",\n    \"expiresIn\": 7200,\n    \"user\": {\n      \"id\": \"uuid\",\n      \"userName\": \"admin\",\n      \"displayName\": \"系统管理员\",\n      \"email\": \"admin@tianyou.local\",\n      \"roles\": [\"admin\"]\n    }\n  }\n}\n```\n\n### 1.2 刷新Token\n\n**请求**:\n```http\nPOST /auth/refresh\nContent-Type: application/json\n\n{\n  \"refreshToken\": \"d4f5g6h7j8k9...\"\n}\n```\n\n### 1.3 获取当前用户\n\n**请求**:\n```http\nGET /auth/me\nAuthorization: Bearer {token}\n```\n\n---\n\n## 2. 表单接口\n\n### 2.1 获取表单列表\n\n**请求**:\n```http\nGET /forms?page=1&pageSize=20&keyword=订单\nAuthorization: Bearer {token}\n```\n\n**响应**:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"items\": [\n      {\n        \"id\": \"uuid\",\n        \"code\": \"order_form\",\n        \"name\": \"订单表单\",\n        \"formType\": \"Bill\",\n        \"description\": \"订单管理\",\n        \"isActive\": true,\n        \"createdAt\": \"2026-03-22T10:00:00Z\"\n      }\n    ],\n    \"total\": 100,\n    \"page\": 1,\n    \"pageSize\": 20\n  }\n}\n```\n\n### 2.2 获取表单定义\n\n**请求**:\n```http\nGET /forms/{formId}\nAuthorization: Bearer {token}\n```\n\n**响应**:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"uuid\",\n    \"code\": \"order_form\",\n    \"name\": \"订单表单\",\n    \"formType\": \"Bill\",\n    \"fields\": [\n      {\n        \"code\": \"order_no\",\n        \"name\": \"订单号\",\n        \"fieldType\": \"Text\",\n        \"dataType\": \"String\",\n        \"required\": true,\n        \"readOnly\": false,\n        \"controlConfig\": {\n          \"placeholder\": \"自动生成\",\n          \"width\": 200\n        }\n      },\n      {\n        \"code\": \"customer\",\n        \"name\": \"客户\",\n        \"fieldType\": \"Reference\",\n        \"dataType\": \"Reference\",\n        \"required\": true,\n        \"controlConfig\": {\n          \"refForm\": \"customer_form\",\n          \"displayField\": \"name\"\n        }\n      }\n    ],\n    \"entries\": [\n      {\n        \"code\": \"order_entry\",\n        \"name\": \"订单明细\",\n        \"fields\": [\n          {\n            \"code\": \"material\",\n            \"name\": \"物料\",\n            \"fieldType\": \"Reference\"\n          },\n          {\n            \"code\": \"qty\",\n            \"name\": \"数量\",\n            \"fieldType\": \"Number\"\n          },\n          {\n            \"code\": \"price\",\n            \"name\": \"单价\",\n            \"fieldType\": \"Number\"\n          },\n          {\n            \"code\": \"amount\",\n            \"name\": \"金额\",\n            \"fieldType\": \"Number\"\n          }\n        ]\n      }\n    ],\n    \"plugins\": [\n      {\n        \"pluginId\": \"tianyou.sample.amount_calculator\",\n        \"config\": {}\n      }\n    ]\n  }\n}\n```\n\n### 2.3 创建表单\n\n**请求**:\n```http\nPOST /forms\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"code\": \"order_form\",\n  \"name\": \"订单表单\",\n  \"formType\": \"Bill\",\n  \"description\": \"订单管理\",\n  \"fields\": [...]\n}\n```\n\n### 2.4 更新表单\n\n**请求**:\n```http\nPUT /forms/{formId}\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"name\": \"订单表单（更新）\",\n  \"fields\": [...]\n}\n```\n\n### 2.5 删除表单\n\n**请求**:\n```http\nDELETE /forms/{formId}\nAuthorization: Bearer {token}\n```\n\n---\n\n## 3. 数据接口\n\n### 3.1 获取数据列表\n\n**请求**:\n```http\nGET /forms/{formId}/data?page=1&pageSize=20&filter=status='approved'\nAuthorization: Bearer {token}\n```\n\n**响应**:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"items\": [\n      {\n        \"id\": \"uuid\",\n        \"dataId\": \"ORD20260322001\",\n        \"data\": {\n          \"order_no\": \"ORD20260322001\",\n          \"customer\": {\n            \"id\": \"cust001\",\n            \"name\": \"客户A\"\n          },\n          \"order_entry\": [\n            {\n              \"material\": {\"id\": \"mat001\", \"name\": \"产品A\"},\n              \"qty\": 10,\n              \"price\": 100,\n              \"amount\": 1000\n            }\n          ],\n          \"total_amount\": 1000\n        },\n        \"createdAt\": \"2026-03-22T10:00:00Z\",\n        \"createdBy\": \"admin\"\n      }\n    ],\n    \"total\": 50,\n    \"page\": 1,\n    \"pageSize\": 20\n  }\n}\n```\n\n### 3.2 获取单条数据\n\n**请求**:\n```http\nGET /forms/{formId}/data/{dataId}\nAuthorization: Bearer {token}\n```\n\n### 3.3 创建数据\n\n**请求**:\n```http\nPOST /forms/{formId}/data\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"customer\": {\"id\": \"cust001\"},\n  \"order_entry\": [\n    {\n      \"material\": {\"id\": \"mat001\"},\n      \"qty\": 10,\n      \"price\": 100\n    }\n  ]\n}\n```\n\n**响应**:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"dataId\": \"ORD20260322001\",\n    \"message\": \"保存成功\"\n  }\n}\n```\n\n### 3.4 更新数据\n\n**请求**:\n```http\nPUT /forms/{formId}/data/{dataId}\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"customer\": {\"id\": \"cust002\"},\n  \"order_entry\": [...]\n}\n```\n\n### 3.5 删除数据\n\n**请求**:\n```http\nDELETE /forms/{formId}/data/{dataId}\nAuthorization: Bearer {token}\n```\n\n### 3.6 批量删除\n\n**请求**:\n```http\nPOST /forms/{formId}/data/batch-delete\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"dataIds\": [\"id1\", \"id2\", \"id3\"]\n}\n```\n\n---\n\n## 4. 插件接口\n\n### 4.1 获取插件列表\n\n**请求**:\n```http\nGET /plugins\nAuthorization: Bearer {token}\n```\n\n**响应**:\n```json\n{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": \"uuid\",\n      \"pluginId\": \"tianyou.sample.amount_calculator\",\n      \"name\": \"金额自动计算插件\",\n      \"version\": \"1.0.0\",\n      \"description\": \"当数量或单价变更时，自动计算金额\",\n      \"author\": \"Tianyou Team\",\n      \"category\": \"表单插件\",\n      \"isActive\": true\n    }\n  ]\n}\n```\n\n### 4.2 注册插件\n\n**请求**:\n```http\nPOST /plugins\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"assemblyPath\": \"/plugins/sample.dll\",\n  \"className\": \"Tianyou.Plugin.Samples.AmountCalculatorPlugin\"\n}\n```\n\n### 4.3 为表单启用插件\n\n**请求**:\n```http\nPOST /forms/{formId}/plugins\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"pluginId\": \"tianyou.sample.amount_calculator\",\n  \"config\": {}\n}\n```\n\n---\n\n## 5. 操作接口\n\n### 5.1 执行操作\n\n**请求**:\n```http\nPOST /forms/{formId}/operations/{operationKey}\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"dataIds\": [\"id1\", \"id2\"],\n  \"parameters\": {}\n}\n```\n\n**响应**:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"message\": \"操作执行成功\",\n    \"affectedCount\": 2\n  }\n}\n```\n\n### 5.2 常用操作\n\n- `submit` - 提交\n- `approve` - 审批\n- `reject` - 驳回\n- `delete` - 删除\n- `copy` - 复制\n- `export` - 导出\n\n---\n\n## 6. 用户管理接口\n\n### 6.1 获取用户列表\n\n**请求**:\n```http\nGET /users?page=1&pageSize=20\nAuthorization: Bearer {token}\n```\n\n### 6.2 创建用户\n\n**请求**:\n```http\nPOST /users\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"userName\": \"user1\",\n  \"email\": \"user1@tianyou.local\",\n  \"password\": \"password123\",\n  \"displayName\": \"用户1\",\n  \"roles\": [\"user\"]\n}\n```\n\n### 6.3 更新用户\n\n**请求**:\n```http\nPUT /users/{userId}\nAuthorization: Bearer {token}\nContent-Type: application/json\n\n{\n  \"displayName\": \"用户1（更新）\",\n  \"roles\": [\"user\", \"developer\"]\n}\n```\n\n---\n\n## 7. 错误码\n\n| 错误码 | 说明 |\n|-------|------|\n| 200 | 成功 |\n| 400 | 请求参数错误 |\n| 401 | 未授权 |\n| 403 | 无权限 |\n| 404 | 资源不存在 |\n| 409 | 资源冲突 |\n| 500 | 服务器内部错误 |\n\n**错误响应格式**:\n```json\n{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"VALIDATION_ERROR\",\n    \"message\": \"数据验证失败\",\n    \"details\": [\n      {\n        \"field\": \"qty\",\n        \"message\": \"数量必须大于0\"\n      }\n    ]\n  }\n}\n```\n\n---\n\n**文档版本**: 1.0.0\n**最后更新**: 2026-03-22 21:57\n"}],"isError":false,"timestamp":1774191793622}}
