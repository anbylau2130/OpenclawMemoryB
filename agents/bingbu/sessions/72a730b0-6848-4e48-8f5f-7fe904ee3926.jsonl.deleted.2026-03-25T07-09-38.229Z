ication/obj/Release/net8.0/Tianyou.Application.GlobalUsings.g.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/obj/Release/net8.0/.NETCoreApp,Version=v8.0.AssemblyAttributes.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/obj/Release/net8.0/Tianyou.Application.AssemblyInfo.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Validators/InputValidator.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Security/XssProtector.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Security/CodeGeneratorValidator.cs"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/UserService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/AuthService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/EntityService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/FormService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/WorkflowService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/PluginService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/CodeGeneratorService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/ReportService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/NotificationService.cs\n/root/.openclaw/tang-sansheng/projects/tianyou-platform/backend/src/Tianyou.Application/Services/TenantService.cs\n/root/.openclaw/tang-sansheng/projects/tian