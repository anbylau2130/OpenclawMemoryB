{"type":"message","id":"e751e7cd","parentId":"226d8f43","timestamp":"2026-03-25T06:09:44.376Z","message":{"role":"toolResult","toolCallId":"call_60f0b9219e3844459547fe1a","toolName":"read","content":[{"type":"text","text":"version: '3.8'\n\nservices:\n  # PostgreSQL 数据库\n  postgres:\n    image: postgres:15-alpine\n    container_name: tianyou-postgres\n    restart: always\n    environment:\n      POSTGRES_USER: tianyou_admin\n      POSTGRES_PASSWORD: Tianyou@2026!\n      POSTGRES_DB: tianyou_platform\n    ports:\n      - \"5432:5432\"\n    volumes:\n      - postgres_data:/var/lib/postgresql/data\n      - ./database/init:/docker-entrypoint-initdb.d\n    networks:\n      - tianyou-network\n\n  # Redis 缓存\n  redis:\n    image: redis:7-alpine\n    container_name: tianyou-redis\n    restart: always\n    ports:\n      - \"6379:6379\"\n    volumes:\n      - redis_data:/data\n    networks:\n      - tianyou-network\n\n  # RabbitMQ 消息队列\n  rabbitmq:\n    image: rabbitmq:3.12-management-alpine\n    container_name: tianyou-rabbitmq\n    restart: always\n    environment:\n      RABBITMQ_DEFAULT_USER: admin\n      RABBITMQ_DEFAULT_PASS: admin@123\n    ports:\n      - \"5672:5672\"\n      - \"15672:15672\"\n    volumes:\n      - rabbitmq_data:/var/lib/rabbitmq\n    networks:\n      - tianyou-network\n\n  # Tianyou API\n  tianyou-api:\n    build:\n      context: ./backend\n      dockerfile: src/Tianyou.Api/Dockerfile\n    container_name: tianyou-api\n    restart: always\n    environment:\n      ASPNETCORE_ENVIRONMENT: Production\n      ConnectionStrings__DefaultConnection: \"Host=postgres;Port=5432;Database=tianyou_platform;Username=tianyou_admin;Password=Tianyou@2026!\"\n      Redis__ConnectionString: \"redis:6379\"\n      RabbitMQ__Host: rabbitmq\n    ports:\n      - \"5000:80\"\n      - \"5001:443\"\n    depends_on:\n      - postgres\n      - redis\n      - rabbitmq\n    networks:\n      - tianyou-network\n\n  # Tianyou Web (Blazor WebAssembly)\n  tianyou-web:\n    build:\n      context: ./frontend/Tianyou.Web\n      dockerfile: Dockerfile\n    container_name: tianyou-web\n    restart: always\n    ports:\n      - \"8080:80\"\n    depends_on:\n      - tianyou-api\n    networks:\n      - tianyou-network\n\nvolumes:\n  postgres_data:\n  redis_data:\n  rabbitmq_data:\n\nnetworks:\n  tianyou-network:\n    driver: bridge"}],"isError":false,"timestamp":1774418984369}}
