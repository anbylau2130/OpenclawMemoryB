{"type":"message","id":"d42cbdf9","parentId":"d9876cb7","timestamp":"2026-03-23T00:58:07.738Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建QueryBuilder。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_467f7d960a2e435081f0abea","name":"write","arguments":{"content":"namespace Tianyou.Core.Abstractions.Services;\n\n/// <summary>\n/// 查询构建器 - 用于构建查询条件\n/// </summary>\npublic class QueryBuilder\n{\n    private readonly QueryObject _query;\n\n    private QueryBuilder(string entityId)\n    {\n        _query = new QueryObject { EntityId = entityId };\n    }\n\n    /// <summary>\n    /// 创建查询构建器\n    /// </summary>\n    public static QueryBuilder Create(string entityId)\n    {\n        return new QueryBuilder(entityId);\n    }\n\n    /// <summary>\n    /// 添加等于条件\n    /// </summary>\n    public QueryBuilder Equal(string fieldName, object? value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.Equal,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加不等于条件\n    /// </summary>\n    public QueryBuilder NotEqual(string fieldName, object? value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.NotEqual,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加大于条件\n    /// </summary>\n    public QueryBuilder GreaterThan(string fieldName, object value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.GreaterThan,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加大于等于条件\n    /// </summary>\n    public QueryBuilder GreaterThanOrEqual(string fieldName, object value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.GreaterThanOrEqual,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加小于条件\n    /// </summary>\n    public QueryBuilder LessThan(string fieldName, object value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.LessThan,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加小于等于条件\n    /// </summary>\n    public QueryBuilder LessThanOrEqual(string fieldName, object value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.LessThanOrEqual,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加包含条件\n    /// </summary>\n    public QueryBuilder Contains(string fieldName, string value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.Contains,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加不包含条件\n    /// </summary>\n    public QueryBuilder NotContains(string fieldName, string value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.NotContains,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加开始于条件\n    /// </summary>\n    public QueryBuilder StartsWith(string fieldName, string value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.StartsWith,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加结束于条件\n    /// </summary>\n    public QueryBuilder EndsWith(string fieldName, string value)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.EndsWith,\n            Value = value\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加为空条件\n    /// </summary>\n    public QueryBuilder IsNull(string fieldName)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.IsNull\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加不为空条件\n    /// </summary>\n    public QueryBuilder IsNotNull(string fieldName)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.IsNotNull\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加在列表中条件\n    /// </summary>\n    public QueryBuilder In(string fieldName, List<object> values)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.In,\n            Value = values\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加不在列表中条件\n    /// </summary>\n    public QueryBuilder NotIn(string fieldName, List<object> values)\n    {\n        _query.Filters.Add(new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.NotIn,\n            Value = values\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加自定义过滤条件\n    /// </summary>\n    public QueryBuilder Where(FilterCondition filter)\n    {\n        _query.Filters.Add(filter);\n        return this;\n    }\n\n    /// <summary>\n    /// 添加多个过滤条件\n    /// </summary>\n    public QueryBuilder Where(IEnumerable<FilterCondition> filters)\n    {\n        _query.Filters.AddRange(filters);\n        return this;\n    }\n\n    /// <summary>\n    /// 添加升序排序\n    /// </summary>\n    public QueryBuilder OrderBy(string fieldName)\n    {\n        _query.Sorts.Add(new SortCondition\n        {\n            FieldName = fieldName,\n            Direction = SortDirection.Ascending\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加降序排序\n    /// </summary>\n    public QueryBuilder OrderByDescending(string fieldName)\n    {\n        _query.Sorts.Add(new SortCondition\n        {\n            FieldName = fieldName,\n            Direction = SortDirection.Descending\n        });\n        return this;\n    }\n\n    /// <summary>\n    /// 添加自定义排序\n    /// </summary>\n    public QueryBuilder OrderBy(SortCondition sort)\n    {\n        _query.Sorts.Add(sort);\n        return this;\n    }\n\n    /// <summary>\n    /// 添加多个排序条件\n    /// </summary>\n    public QueryBuilder OrderBy(IEnumerable<SortCondition> sorts)\n    {\n        _query.Sorts.AddRange(sorts);\n        return this;\n    }\n\n    /// <summary>\n    /// 跳过指定数量\n    /// </summary>\n    public QueryBuilder Skip(int count)\n    {\n        _query.Skip = count;\n        return this;\n    }\n\n    /// <summary>\n    /// 获取指定数量\n    /// </summary>\n    public QueryBuilder Take(int count)\n    {\n        _query.Take = count;\n        return this;\n    }\n\n    /// <summary>\n    /// 分页查询\n    /// </summary>\n    public QueryBuilder Paged(int pageIndex, int pageSize)\n    {\n        _query.Skip = (pageIndex - 1) * pageSize;\n        _query.Take = pageSize;\n        return this;\n    }\n\n    /// <summary>\n    /// 构建查询对象\n    /// </summary>\n    public QueryObject Build()\n    {\n        return _query;\n    }\n\n    /// <summary>\n    /// 隐式转换为查询对象\n    /// </summary>\n    public static implicit operator QueryObject(QueryBuilder builder)\n    {\n        return builder.Build();\n    }\n}\n","path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Services/QueryBuilder.cs"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7