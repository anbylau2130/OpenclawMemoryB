{"type":"message","id":"3b2749b3","parentId":"a6449a4a","timestamp":"2026-03-23T00:57:52.985Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"创建GenericDataService。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_ba486424d1594a82bfe8699c","name":"write","arguments":{"content":"namespace Tianyou.Core.Abstractions.Services;\n\n/// <summary>\n/// 通用数据服务 - 提供通用的数据操作功能\n/// </summary>\npublic interface IGenericDataService\n{\n    /// <summary>\n    /// 查询单条记录\n    /// </summary>\n    Task<DynamicObject?> QueryByIdAsync(string entityId, string id);\n\n    /// <summary>\n    /// 查询多条记录\n    /// </summary>\n    Task<List<DynamicObject>> QueryAsync(string entityId, QueryCondition condition);\n\n    /// <summary>\n    /// 分页查询\n    /// </summary>\n    Task<PagedResult<DynamicObject>> QueryPagedAsync(string entityId, QueryCondition condition);\n\n    /// <summary>\n    /// 新增记录\n    /// </summary>\n    Task<string> CreateAsync(string entityId, DynamicObject data);\n\n    /// <summary>\n    /// 批量新增\n    /// </summary>\n    Task<List<string>> CreateBatchAsync(string entityId, List<DynamicObject> dataList);\n\n    /// <summary>\n    /// 更新记录\n    /// </summary>\n    Task<bool> UpdateAsync(string entityId, DynamicObject data);\n\n    /// <summary>\n    /// 批量更新\n    /// </summary>\n    Task<bool> UpdateBatchAsync(string entityId, List<DynamicObject> dataList);\n\n    /// <summary>\n    /// 删除记录\n    /// </summary>\n    Task<bool> DeleteAsync(string entityId, string id);\n\n    /// <summary>\n    /// 批量删除\n    /// </summary>\n    Task<bool> DeleteBatchAsync(string entityId, List<string> ids);\n\n    /// <summary>\n    /// 统计记录数\n    /// </summary>\n    Task<int> CountAsync(string entityId, QueryCondition? condition = null);\n\n    /// <summary>\n    /// 判断记录是否存在\n    /// </summary>\n    Task<bool> ExistsAsync(string entityId, string id);\n\n    /// <summary>\n    /// 执行自定义查询\n    /// </summary>\n    Task<List<DynamicObject>> ExecuteQueryAsync(string sql, Dictionary<string, object>? parameters = null);\n}\n\n/// <summary>\n/// 通用数据服务实现\n/// </summary>\npublic class GenericDataService : IGenericDataService\n{\n    private readonly IRepository _repository;\n\n    public GenericDataService(IRepository repository)\n    {\n        _repository = repository;\n    }\n\n    public async Task<DynamicObject?> QueryByIdAsync(string entityId, string id)\n    {\n        return await _repository.GetByIdAsync(entityId, id);\n    }\n\n    public async Task<List<DynamicObject>> QueryAsync(string entityId, QueryCondition condition)\n    {\n        var query = QueryBuilder.Create(entityId).Where(condition);\n        return await _repository.QueryAsync(query);\n    }\n\n    public async Task<PagedResult<DynamicObject>> QueryPagedAsync(string entityId, QueryCondition condition)\n    {\n        var query = QueryBuilder.Create(entityId)\n            .Where(condition)\n            .Paged(condition.PageIndex, condition.PageSize);\n\n        var data = await _repository.QueryAsync(query);\n        var total = await CountAsync(entityId, condition);\n\n        return new PagedResult<DynamicObject>\n        {\n            Data = data,\n            TotalCount = total,\n            PageIndex = condition.PageIndex,\n            PageSize = condition.PageSize\n        };\n    }\n\n    public async Task<string> CreateAsync(string entityId, DynamicObject data)\n    {\n        return await _repository.CreateAsync(entityId, data);\n    }\n\n    public async Task<List<string>> CreateBatchAsync(string entityId, List<DynamicObject> dataList)\n    {\n        var ids = new List<string>();\n        foreach (var data in dataList)\n        {\n            var id = await CreateAsync(entityId, data);\n            ids.Add(id);\n        }\n        return ids;\n    }\n\n    public async Task<bool> UpdateAsync(string entityId, DynamicObject data)\n    {\n        return await _repository.UpdateAsync(entityId, data);\n    }\n\n    public async Task<bool> UpdateBatchAsync(string entityId, List<DynamicObject> dataList)\n    {\n        foreach (var data in dataList)\n        {\n            if (!await UpdateAsync(entityId, data))\n            {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    public async Task<bool> DeleteAsync(string entityId, string id)\n    {\n        return await _repository.DeleteAsync(entityId, id);\n    }\n\n    public async Task<bool> DeleteBatchAsync(string entityId, List<string> ids)\n    {\n        foreach (var id in ids)\n        {\n            if (!await DeleteAsync(entityId, id))\n            {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    public async Task<int> CountAsync(string entityId, QueryCondition? condition = null)\n    {\n        var query = QueryBuilder.Create(entityId);\n        if (condition != null)\n        {\n            query.Where(condition);\n        }\n        return await _repository.CountAsync(query);\n    }\n\n    public async Task<bool> ExistsAsync(string entityId, string id)\n    {\n        return await _repository.ExistsAsync(entityId, id);\n    }\n\n    public async Task<List<DynamicObject>> ExecuteQueryAsync(string sql, Dictionary<string, object>? parameters = null)\n    {\n        return await _repository.ExecuteQueryAsync(sql, parameters);\n    }\n}\n\n/// <summary>\n/// 查询条件\n/// </summary>\npublic class QueryCondition\n{\n    /// <summary>\n    /// 过滤条件\n    /// </summary>\n    public List<FilterCondition> Filters { get; set; } = new();\n\n    /// <summary>\n    /// 排序条件\n    /// </summary>\n    public List<SortCondition> Sorts { get; set; } = new();\n\n    /// <summary>\n    /// 页码\n    /// </summary>\n    public int PageIndex { get; set; } = 1;\n\n    /// <summary>\n    /// 每页大小\n    /// </summary>\n    public int PageSize { get; set; } = 20;\n\n    /// <summary>\n    /// 添加过滤条件\n    /// </summary>\n    public QueryCondition AddFilter(FilterCondition filter)\n    {\n        Filters.Add(filter);\n        return this;\n    }\n\n    /// <summary>\n    /// 添加排序条件\n    /// </summary>\n    public QueryCondition AddSort(SortCondition sort)\n    {\n        Sorts.Add(sort);\n        return this;\n    }\n}\n\n/// <summary>\n/// 排序条件\n/// </summary>\npublic class SortCondition\n{\n    /// <summary>\n    /// 字段名\n    /// </summary>\n    public string FieldName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 排序方向\n    /// </summary>\n    public SortDirection Direction { get; set; } = SortDirection.Ascending;\n}\n\n/// <summary>\n/// 分页结果\n/// </summary>\npublic class PagedResult<T>\n{\n    /// <summary>\n    /// 数据列表\n    /// </summary>\n    public List<T> Data { get; set; } = new();\n\n    /// <summary>\n    /// 总记录数\n    /// </summary>\n    public int TotalCount { get; set; }\n\n    /// <summary>\n    /// 页码\n    /// </summary>\n    public int PageIndex { get; set; }\n\n    /// <summary>\n    /// 每页大小\n    /// </summary>\n    public int PageSize { get; set; }\n\n    /// <summary>\n    /// 总页数\n    /// </summary>\n    public int TotalPages => (int)Math.Ceiling((double)TotalCount / PageSize);\n\n    /// <summary>\n    /// 是否有上一页\n    /// </summary>\n    public bool HasPreviousPage => PageIndex > 1;\n\n    /// <summary>\n    /// 是否有下一页\n    /// </summary>\n    public bool HasNextPage => PageIndex < TotalPages;\n}\n\n/// <summary>\n/// 数据仓库接口\n/// </summary>\npublic interface IRepository\n{\n    Task<DynamicObject?> GetByIdAsync(string entityId, string id);\n    Task<List<DynamicObject>> QueryAsync(QueryObject query);\n    Task<int> CountAsync(QueryObject query);\n    Task<string> CreateAsync(string entityId, DynamicObject data);\n    Task<bool> UpdateAsync(string entityId, DynamicObject data);\n    Task<bool> DeleteAsync(string entityId, string id);\n    Task<bool> ExistsAsync(string entityId, string id);\n    Task<List<DynamicObject>> ExecuteQueryAsync(string sql, Dictionary<string, object>? parameters = null);\n}\n\n/// <summary>\n/// 查询对象\n/// </summary>\npublic class QueryObject\n{\n    /// <summary>\n    /// 实体ID\n    /// </summary>\n    public string EntityId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 过滤条件\n    /// </summary>\n    public List<FilterCondition> Filters { get; set; } = new();\n\n    /// <summary>\n    /// 排序条件\n    /// </summary>\n    public List<SortCondition> Sorts { get; set; } = new();\n\n    /// <summary>\n    /// 跳过数量\n    /// </summary>\n    public int Skip { get; set; }\n\n    /// <summary>\n    /// 获取数量\n    /// </summary>\n    public int Take { get; set; }\n}\n","path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Services/GenericDataService.cs"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":9,"output":1974,"cacheRead":41520,"cacheWrite":0,"totalTokens":43503,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227455467}}
