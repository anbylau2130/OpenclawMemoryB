object> Parameters { get; set; } = new();\n\n    /// <summary>\n    /// 过滤条件\n    /// </summary>\n    public List<FilterCondition> Filters { get; set; } = new();\n\n    /// <summary>\n    /// 当前用户\n    /// </summary>\n    public UserInfo CurrentUser { get; set; } = default!;\n\n    /// <summary>\n    /// 取消标志\n    /// </summary>\n    public bool Cancel { get; set; }\n\n    /// <summary>\n    /// 错误消息\n    /// </summary>\n    public string? ErrorMessage { get; set; }\n}\n\n/// <summary>\n/// 报表查询后事件参数\n/// </summary>\npublic class ReportAfterQueryEventArgs\n{\n    /// <summary>\n    /// 报表ID\n    /// </summary>\n    public string ReportId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 查询参数\n    /// </summary>\n    public Dictionary<string, object> Parameters { get; set; } = new();\n\n    /// <summary>\n    /// 查询结果\n    /// </summary>\n    public List<DynamicObject> Data { get; set; } = new();\n\n    /// <summary>\n    /// 总记录数\n    /// </summary>\n    public int TotalCount { get; set; }\n\n    /// <summary>\n    /// 执行耗时（毫秒）\n    /// </summary>\n    public int ExecutionTimeMs { get; set; }\n}\n\n/// <summary>\n/// 报表数据计算前事件参数\n/// </summary>\npublic class ReportBeforeCalculateEventArgs\n{\n    /// <summary>\n    /// 报表ID\n    /// </summary>\n    public string ReportId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 原始数据\n    /// </summary>\n    public List<DynamicObject> RawData { get; set; } = new();\n\n    /// <summary>\n    /// 计算参数\n    /// </summary>\n    public Dictionary<string, object> Parameters { get; set; } = new();\n\n    /// <summary>\n    /// 当前用户\n    /// </summary>\n    public UserInfo CurrentUser { get; set; } = default!;\n\n    /// <summary>\n    /// 取消标志\n    /// </summary>\n    public bool Cancel { get; set; }\n\n    /// <summary>\n    /// 错误消息\n    /// </summary>\n    public string? ErrorMessage { get; set; }\n}\n\n/// <summary>\n/// 报表数据计算后事件参数\n/// </summary>\npublic class ReportAfterCalculateEventArgs\n{\n    /// <summary>\n    /// 报表ID\n    /// </summary>\n    public string ReportId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 计算结果\n    /// </summary>\n    public List<DynamicObject> CalculatedData { get; set; } = new();\n\n    /// <summary>\n    /// 汇总数据\n    /// </summary>\n    public Dictionary<string, object> SummaryData { get; set; } = new();\n\n    /// <summary>\n    /// 执行耗时（毫秒）\n    /// </summary>\n    public int ExecutionTimeMs { get; set; }\n}\n\n/// <summary>\n/// 报表渲染前事件参数\n/// </summary>\npublic class ReportBeforeRenderEventArgs\n{\n    /// <summary>\n    /// 报表ID\n    /// </summary>\n    public string ReportId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 报表数据\n    /// </summary>\n    public List<DynamicObject> Data { get; set; } = new();\n\n    /// <summary>\n    /// 渲染格式\n    /// </summary>\n    public RenderFormat Format { get; set; } = RenderFormat.Html;\n\n    /// <summary>\n    /// 渲染参数\n    /// </summary>\n    public Dictionary<string, object> Parameters { get; set; } = new();\n\n    /// <summary>\n    /// 当前用户\n    /// </summary>\n    public UserInfo CurrentUser { get; set; } = default!;\n\n    /// <summary>\n    /// 取消标志\n    /// </summary>\n    public bool Cancel { get; set; }\n\n    /// <summary>\n    /// 错误消息\n    /// </summary>\n    public string? ErrorMessage { get; set; }\n}\n\n/// <summary>\n/// 报表导出前事件参数\n/// </summary>\npublic class ReportBeforeExportEventArgs\n{\n    /// <summary>\n    /// 报表ID\n    /// </summary>\n    public string ReportId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 报表数据\n    /// </summary>\n    public List<DynamicObject> Data { get; set; } = new();\n\n    /// <summary>\n    /// 导出格式\n    /// </summary>\n    public ExportFormat Format { get; set; } = ExportFormat.Excel;\n\n    /// <summary>\n    /// 导出参数\n    /// </summary>\n    public Dictionary<string, object> Parameters { get; set; } = new();\n\n    /// <summary>\n    /// 当前用户\n    /// </summary>\n    public UserInfo CurrentUser { get; set; } = default!;\n\n    /// <summary>\n    /// 取消标志\n    /// </summary>\n    public bool Cancel { get; set; }\n\n    /// <summary>\n    /// 错误消息\n    /// </summary>\n    public string? ErrorMessage { get; set; }\n}\n\n/// <summary>\n/// 报表导出后事件参数\n/// </summary>\npublic class ReportAfterExportEventArgs\n{\n    /// <summary>\n    /// 报表ID\n    /// </summary>\n    public string ReportId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 导出格式\n    /// </summary>\n    public ExportFormat Format { get; set; } = ExportFormat.Excel;\n\n    /// <summary>\n    /// 导出文件路径\n    /// </summary>\n    public string FilePath { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 文件大小（字节）\n    /// </summary>\n    public long FileSize { get; set; }\n\n    /// <summary>\n    /// 执行耗时（毫秒）\n    /// </summary>\n    public int ExecutionTimeMs { get; set; }\n}\n\n/// <summary>\n/// 渲染格式\n/// </summary>\npublic enum RenderFormat\n{\n    /// <summary>\n    /// HTML\n    /// </summary>\n    Html,\n\n    /// <summary>\n    /// PDF\n    /// </summary>\n    Pdf,\n\n    /// <summary>\n    /// 图片\n    /// </summary>\n    Image,\n\n    /// <summary>\n    /// JSON\n    /// </summary>\n    Json\n}\n\n/// <summary>\n/// 导出格式\n/// </summary>\npublic enum ExportFormat\n{\n    /// <summary>\n    /// Excel\n    /// </summary>\n    Excel,\n\n    /// <summary>\n    /// PDF\n    /// </summary>\n    Pdf,\n\n    /// <summary>\n    /// Word\n    /// </summary>\n    Word,\n\n    /// <summary>\n    /// CSV\n    /// </summary>\n    Csv\n}\n\n/// <summary>\n/// 报表列定义\n/// </summary>\npublic class ReportColumn\n{\n    /// <summary>\n    /// 列名\n    /// </summary>\n    public string ColumnName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 显示名称\n    /// </summary>\n    public string DisplayName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 数据类型\n    /// </summary>\n    public ColumnDataType DataType { get; set; } = ColumnDataType.String;\n\n    /// <summary>\n    /// 宽度\n    /// </summary>\n    public int Width { get; set; } = 100;\n\n    /// <summary>\n    /// 是否可见\n    /// </summary>\n    public bool IsVisible { get; set; } = true;\n\n    /// <summary>\n    /// 是否可排序\n    /// </summary>\n    public bool IsSortable { get; set; } = true;\n\n    /// <summary>\n    /// 是否可筛选\n    /// </summary>\n    public bool IsFilterable { get; set; } = true;\n\n    /// <summary>\n    /// 格式字符串\n    /// </summary>\n    public string? FormatString { get; set; }\n\n    /// <summary>\n    /// 对齐方式\n    /// </summary>\n    public ColumnAlignment Alignment { get; set; } = ColumnAlignment.Left;\n}\n\n/// <summary>\n/// 列数据类型\n/// </summary>\npublic enum ColumnDataType\n{\n    /// <summary>\n    /// 字符串\n    /// </summary>\n    String,\n\n    /// <summary>\n    /// 整数\n    /// </summary>\n    Integer,\n\n    /// <summary>\n    /// 小数\n    /// </summary>\n    Decimal,\n\n    /// <summary>\n    /// 日期\n    /// </summary>\n    Date,\n\n    /// <summary>\n    /// 布尔值\n    /// </summary>\n    Boolean\n}\n\n/// <summary>\n/// 列对齐方式\n/// </summary>\npublic enum ColumnAlignment\n{\n    /// <summary>\n    /// 左对齐\n    /// </summary>\n    Left,\n\n    /// <summary>\n    /// 居中对齐\n    /// </summary>\n    Center,\n\n    /// <summary>\n    /// 右对齐\n    /// </summary>\n    Right\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":43,"output":2528,"cacheRead":32954,"cacheWrite":0,"totalTokens":35525,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227386039}}
