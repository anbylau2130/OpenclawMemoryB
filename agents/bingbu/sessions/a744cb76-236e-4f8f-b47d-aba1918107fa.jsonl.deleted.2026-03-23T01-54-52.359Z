{"type":"message","id":"6edf1b2c","parentId":"fa926207","timestamp":"2026-03-23T00:57:34.096Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建OperationMetadata。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_b4789cd546fd448ab795e2bf","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Metadata/OperationMetadata.cs","content":"namespace Tianyou.Core.Abstractions.Metadata;\n\n/// <summary>\n/// 操作元数据服务\n/// </summary>\npublic class OperationMetadata\n{\n    /// <summary>\n    /// 操作Key\n    /// </summary>\n    public string OperationKey { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 操作名称\n    /// </summary>\n    public string OperationName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 操作类型\n    /// </summary>\n    public OperationType OperationType { get; set; } = OperationType.Custom;\n\n    /// <summary>\n    /// 关联实体\n    /// </summary>\n    public string? EntityId { get; set; }\n\n    /// <summary>\n    /// 关联表单\n    /// </summary>\n    public string? FormId { get; set; }\n\n    /// <summary>\n    /// 关联列表\n    /// </summary>\n    public string? ListId { get; set; }\n\n    /// <summary>\n    /// 图标\n    /// </summary>\n    public string? Icon { get; set; }\n\n    /// <summary>\n    /// 是否启用\n    /// </summary>\n    public bool IsEnabled { get; set; } = true;\n\n    /// <summary>\n    /// 是否需要确认\n    /// </summary>\n    public bool RequireConfirm { get; set; }\n\n    /// <summary>\n    /// 确认消息\n    /// </summary>\n    public string? ConfirmMessage { get; set; }\n\n    /// <summary>\n    /// 操作位置\n    /// </summary>\n    public OperationPosition Position { get; set; } = OperationPosition.Toolbar;\n\n    /// <summary>\n    /// 显示顺序\n    /// </summary>\n    public int DisplayOrder { get; set; }\n\n    /// <summary>\n    /// 权限要求\n    /// </summary>\n    public List<string> RequiredPermissions { get; set; } = new();\n\n    /// <summary>\n    /// 参数定义\n    /// </summary>\n    public List<OperationParameter> Parameters { get; set; } = new();\n\n    /// <summary>\n    /// 创建时间\n    /// </summary>\n    public DateTime CreatedTime { get; set; } = DateTime.Now;\n\n    /// <summary>\n    /// 更新时间\n    /// </summary>\n    public DateTime UpdatedTime { get; set; } = DateTime.Now;\n\n    /// <summary>\n    /// 检查权限\n    /// </summary>\n    public bool CheckPermission(UserInfo user)\n    {\n        if (RequiredPermissions.Count == 0)\n            return true;\n\n        return RequiredPermissions.Any(p => user.Roles.Contains(p));\n    }\n\n    /// <summary>\n    /// 获取参数定义\n    /// </summary>\n    public OperationParameter? GetParameter(string paramName)\n    {\n        return Parameters.FirstOrDefault(p => p.Name == paramName);\n    }\n\n    /// <summary>\n    /// 添加参数\n    /// </summary>\n    public void AddParameter(OperationParameter parameter)\n    {\n        Parameters.Add(parameter);\n    }\n\n    /// <summary>\n    /// 验证参数\n    /// </summary>\n    public ValidationResult ValidateParameters(Dictionary<string, object> parameters)\n    {\n        var result = new ValidationResult();\n\n        foreach (var param in Parameters)\n        {\n            if (param.IsRequired && !parameters.ContainsKey(param.Name))\n            {\n                result.AddError(param.Name, $\"{param.Label}为必填项\");\n            }\n        }\n\n        return result;\n    }\n}\n\n/// <summary>\n/// 操作类型\n/// </summary>\npublic enum OperationType\n{\n    /// <summary>\n    /// 新增\n    /// </summary>\n    Create,\n\n    /// <summary>\n    /// 编辑\n    /// </summary>\n    Edit,\n\n    /// <summary>\n    /// 删除\n    /// </summary>\n    Delete,\n\n    /// <summary>\n    /// 查看\n    /// </summary>\n    View,\n\n    /// <summary>\n    /// 提交\n    /// </summary>\n    Submit,\n\n    /// <summary>\n    /// 审批\n    /// </summary>\n    Approve,\n\n    /// <summary>\n    /// 驳回\n    /// </summary>\n    Reject,\n\n    /// <summary>\n    /// 复制\n    /// </summary>\n    Copy,\n\n    /// <summary>\n    /// 打印\n    /// </summary>\n    Print,\n\n    /// <summary>\n    /// 导出\n    /// </summary>\n    Export,\n\n    /// <summary>\n    /// 导入\n    /// </summary>\n    Import,\n\n    /// <summary>\n    /// 自定义\n    /// </summary>\n    Custom\n}\n\n/// <summary>\n/// 操作位置\n/// </summary>\npublic enum OperationPosition\n{\n    /// <summary>\n    /// 工具栏\n    /// </summary>\n    Toolbar,\n\n    /// <summary>\n    /// 上下文菜单\n    /// </summary>\n    ContextMenu,\n\n    /// <summary>\n    /// 操作列\n    /// </summary>\n    ActionColumn,\n\n    /// <summary>\n    /// 批量操作\n    /// </summary>\n    BatchAction\n}\n\n/// <summary>\n/// 操作参数\n/// </summary>\npublic class OperationParameter\n{\n    /// <summary>\n    /// 参数名\n    /// </summary>\n    public string Name { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 参数标签\n    /// </summary>\n    public string Label { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 数据类型\n    /// </summary>\n    public ParameterDataType DataType { get; set; } = ParameterDataType.String;\n\n    /// <summary>\n    /// 是否必填\n    /// </summary>\n    public bool IsRequired { get; set; }\n\n    /// <summary>\n    /// 默认值\n    /// </summary>\n    public object? DefaultValue { get; set; }\n\n    /// <summary>\n    /// 提示信息\n    /// </summary>\n    public string? Placeholder { get; set; }\n\n    /// <summary>\n    /// 数据源\n    /// </summary>\n    public string? DataSource { get; set; }\n\n    /// <summary>\n    /// 控件类型\n    /// </summary>\n    public ControlType ControlType { get; set; } = ControlType.TextBox;\n\n    /// <summary>\n    /// 验证规则\n    /// </summary>\n    public List<ValidationRule> ValidationRules { get; set; } = new();\n\n    /// <summary>\n    /// 验证参数值\n    /// </summary>\n    public ValidationResult Validate(object? value)\n    {\n        var result = new ValidationResult();\n\n        // 必填验证\n        if (IsRequired && (value == null || string.IsNullOrEmpty(value.ToString())))\n        {\n            result.AddError(Name, $\"{Label}为必填项\");\n        }\n\n        // 自定义验证规则\n        foreach (var rule in ValidationRules)\n        {\n            if (!rule.Validate(value))\n            {\n                result.AddError(Name, rule.ErrorMessage);\n            }\n        }\n\n        return result;\n    }\n}\n\n/// <summary>\n/// 参数数据类型\n/// </summary>\npublic enum ParameterDataType\n{\n    /// <summary>\n    /// 字符串\n    /// </summary>\n    String,\n\n    /// <summary>\n    /// 整数\n    /// </summary>\n    Integer,\n\n    /// <summary>\n    /// 小数\n    /// </summary>\n    Decimal,\n\n    /// <summary>\n    /// 布尔值\n    /// </summary>\n    Boolean,\n\n    /// <summary>\n    /// 日期\n    /// </summary>\n    Date,\n\n    /// <summary>\n    /// 日期时间\n    /// </summary>\n    DateTime,\n\n    /// <summary>\n    /// 数组\n    /// </summary>\n    Array,\n\n    /// <summary>\n    /// 对象\n    /// </summary>\n    Object\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":43,"output":1690,"cacheRead":39700,"cacheWrite":0,"totalTokens":41433,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227440266}}
