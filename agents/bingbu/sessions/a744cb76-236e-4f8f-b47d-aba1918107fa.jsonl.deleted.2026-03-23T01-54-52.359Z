{"type":"message","id":"f5853eac","parentId":"a0fee18f","timestamp":"2026-03-23T00:56:53.360Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建元数据服务类。首先创建FormMetadata。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_367414b8ffc149799e82f25e","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Metadata/FormMetadata.cs","content":"namespace Tianyou.Core.Abstractions.Metadata;\n\n/// <summary>\n/// 表单元数据服务\n/// </summary>\npublic class FormMetadata\n{\n    /// <summary>\n    /// 表单ID\n    /// </summary>\n    public string FormId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 表单名称\n    /// </summary>\n    public string FormName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 实体ID\n    /// </summary>\n    public string EntityId { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 字段列表\n    /// </summary>\n    public List<FieldMetadata> Fields { get; set; } = new();\n\n    /// <summary>\n    /// 表单类型\n    /// </summary>\n    public FormType FormType { get; set; } = FormType.Normal;\n\n    /// <summary>\n    /// 是否启用\n    /// </summary>\n    public bool IsEnabled { get; set; } = true;\n\n    /// <summary>\n    /// 创建时间\n    /// </summary>\n    public DateTime CreatedTime { get; set; } = DateTime.Now;\n\n    /// <summary>\n    /// 更新时间\n    /// </summary>\n    public DateTime UpdatedTime { get; set; } = DateTime.Now;\n\n    /// <summary>\n    /// 获取字段元数据\n    /// </summary>\n    public FieldMetadata? GetField(string fieldKey)\n    {\n        return Fields.FirstOrDefault(f => f.FieldKey == fieldKey);\n    }\n\n    /// <summary>\n    /// 添加字段\n    /// </summary>\n    public void AddField(FieldMetadata field)\n    {\n        Fields.Add(field);\n    }\n\n    /// <summary>\n    /// 移除字段\n    /// </summary>\n    public void RemoveField(string fieldKey)\n    {\n        var field = GetField(fieldKey);\n        if (field != null)\n        {\n            Fields.Remove(field);\n        }\n    }\n\n    /// <summary>\n    /// 获取必填字段列表\n    /// </summary>\n    public List<FieldMetadata> GetRequiredFields()\n    {\n        return Fields.Where(f => f.IsRequired).ToList();\n    }\n\n    /// <summary>\n    /// 获取可见字段列表\n    /// </summary>\n    public List<FieldMetadata> GetVisibleFields()\n    {\n        return Fields.Where(f => f.IsVisible).ToList();\n    }\n\n    /// <summary>\n    /// 获取可编辑字段列表\n    /// </summary>\n    public List<FieldMetadata> GetEditableFields()\n    {\n        return Fields.Where(f => !f.IsReadOnly).ToList();\n    }\n}\n\n/// <summary>\n/// 表单类型\n/// </summary>\npublic enum FormType\n{\n    /// <summary>\n    /// 普通表单\n    /// </summary>\n    Normal,\n\n    /// <summary>\n    /// 树形表单\n    /// </summary>\n    Tree,\n\n    /// <summary>\n    /// 列表表单\n    /// </summary>\n    List,\n\n    /// <summary>\n    /// 卡片表单\n    /// </summary>\n    Card,\n\n    /// <summary>\n    /// 自定义表单\n    /// </summary>\n    Custom\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":9,"output":737,"cacheRead":35618,"cacheWrite":0,"totalTokens":36364,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227406741}}
