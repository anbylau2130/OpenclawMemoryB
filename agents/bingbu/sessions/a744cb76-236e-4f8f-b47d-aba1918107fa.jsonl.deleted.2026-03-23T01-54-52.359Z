{"type":"message","id":"16bc11ea","parentId":"13e138ea","timestamp":"2026-03-23T00:54:42.472Z","message":{"role":"toolResult","toolCallId":"call_1b6a9a8241fb4e44b091e00e","toolName":"read","content":[{"type":"text","text":"namespace Tianyou.Plugin.Abstractions;\n\n/// <summary>\n/// 表单视图接口\n/// </summary>\npublic interface IFormView\n{\n    /// <summary>\n    /// 表单ID\n    /// </summary>\n    string FormId { get; }\n    \n    /// <summary>\n    /// 设置字段可见性\n    /// </summary>\n    void SetVisible(string fieldKey, bool visible);\n    \n    /// <summary>\n    /// 设置字段只读\n    /// </summary>\n    void SetReadOnly(string fieldKey, bool readOnly);\n    \n    /// <summary>\n    /// 设置字段启用状态\n    /// </summary>\n    void SetEnabled(string fieldKey, bool enabled);\n    \n    /// <summary>\n    /// 设置字段必填\n    /// </summary>\n    void SetRequired(string fieldKey, bool required);\n    \n    /// <summary>\n    /// 设置字段标签\n    /// </summary>\n    void SetLabel(string fieldKey, string label);\n    \n    /// <summary>\n    /// 设置字段值\n    /// </summary>\n    void SetValue(string fieldKey, object? value);\n    \n    /// <summary>\n    /// 获取字段值\n    /// </summary>\n    T? GetValue<T>(string fieldKey);\n    \n    /// <summary>\n    /// 刷新字段\n    /// </summary>\n    void RefreshField(string fieldKey);\n    \n    /// <summary>\n    /// 刷新整个表单\n    /// </summary>\n    void Refresh();\n    \n    /// <summary>\n    /// 显示消息\n    /// </summary>\n    void ShowMessage(string message, MessageType type = MessageType.Info);\n    \n    /// <summary>\n    /// 显示确认对话框\n    /// </summary>\n    Task<bool> ShowConfirm(string message, string title = \"确认\");\n    \n    /// <summary>\n    /// 关闭页面\n    /// </summary>\n    void Close(bool refreshParent = false);\n    \n    /// <summary>\n    /// 打开新页面\n    /// </summary>\n    void OpenPage(string pageId, Dictionary<string, object>? parameters = null);\n    \n    /// <summary>\n    /// 执行操作\n    /// </summary>\n    Task<OperationResult> DoOperation(string operationKey, Dictionary<string, object>? parameters = null);\n    \n    /// <summary>\n    /// 触发事件\n    /// </summary>\n    void FireEvent(string eventName, Dictionary<string, object>? data = null);\n    \n    /// <summary>\n    /// 设置分录行数\n    /// </summary>\n    void SetEntryRowCount(string entryKey, int count);\n    \n    /// <summary>\n    /// 获取分录行数\n    /// </summary>\n    int GetEntryRowCount(string entryKey);\n}\n\n/// <summary>\n/// 数据模型接口\n/// </summary>\npublic interface IDataModel\n{\n    /// <summary>\n    /// 获取字段值\n    /// </summary>\n    T? GetValue<T>(string fieldKey);\n    \n    /// <summary>\n    /// 设置字段值\n    /// </summary>\n    void SetValue(string fieldKey, object? value);\n    \n    /// <summary>\n    /// 获取整个数据实体\n    /// </summary>\n    DynamicObject GetDataEntity();\n    \n    /// <summary>\n    /// 设置数据实体\n    /// </summary>\n    void SetDataEntity(DynamicObject data);\n    \n    /// <summary>\n    /// 获取分录行数\n    /// </summary>\n    int GetEntryRowCount(string entryKey);\n    \n    /// <summary>\n    /// 新增分录行\n    /// </summary>\n    int AddEntryRow(string entryKey);\n    \n    /// <summary>\n    /// 删除分录行\n    /// </summary>\n    void DeleteEntryRow(string entryKey, int rowIndex);\n    \n    /// <summary>\n    /// 获取分录行数据\n    /// </summary>\n    DynamicObject GetEntryRow(string entryKey, int rowIndex);\n    \n    /// <summary>\n    /// 设置分录行数据\n    /// </summary>\n    void SetEntryRow(string entryKey, int rowIndex, DynamicObject data);\n    \n    /// <summary>\n    /// 获取分录字段值\n    /// </summary>\n    T? GetEntryValue<T>(string entryKey, int rowIndex, string fieldKey);\n    \n    /// <summary>\n    /// 设置分录字段值\n    /// </summary>\n    void SetEntryValue(string entryKey, int rowIndex, string fieldKey, object? value);\n    \n    /// <summary>\n    /// 数据变更事件\n    /// </summary>\n    event EventHandler<DataChangedEventArgs>? DataChanged;\n}\n\n/// <summary>\n/// 列表视图接口\n/// </summary>\npublic interface IListView\n{\n    /// <summary>\n    /// 列表ID\n    /// </summary>\n    string ListId { get; }\n    \n    /// <summary>\n    /// 获取选中行ID列表\n    /// </summary>\n    List<string> GetSelectedRowIds();\n    \n    /// <summary>\n    /// 设置选中行\n    /// </summary>\n    void SetSelectedRows(List<string> rowIds);\n    \n    /// <summary>\n    /// 刷新列表\n    /// </summary>\n    void Refresh();\n    \n    /// <summary>\n    /// 设置过滤条件\n    /// </summary>\n    void SetFilter(List<FilterCondition> conditions);\n    \n    /// <summary>\n    /// 显示消息\n    /// </summary>\n    void ShowMessage(string message, MessageType type = MessageType.Info);\n    \n    /// <summary>\n    /// 执行操作\n    /// </summary>\n    Task<OperationResult> DoOperation(string operationKey, List<string> rowIds);\n    \n    /// <summary>\n    /// 打开详情页\n    /// </summary>\n    void OpenDetail(string rowId);\n    \n    /// <summary>\n    /// 新增记录\n    /// </summary>\n    void CreateNew();\n}\n\n/// <summary>\n/// 列表模型接口\n/// </summary>\npublic interface IListModel\n{\n    /// <summary>\n    /// 获取选中行数据\n    /// </summary>\n    List<DynamicObject> GetSelectedRows();\n    \n    /// <summary>\n    /// 获取所有行数据\n    /// </summary>\n    List<DynamicObject> GetAllRows();\n    \n    /// <summary>\n    /// 获取过滤条件\n    /// </summary>\n    List<FilterCondition> GetFilter();\n    \n    /// <summary>\n    /// 设置过滤条件\n    /// </summary>\n    void SetFilter(List<FilterCondition> conditions);\n}\n\n/// <summary>\n/// 操作上下文接口\n/// </summary>\npublic interface IOperationContext\n{\n    /// <summary>\n    /// 操作Key\n    /// </summary>\n    string OperationKey { get; }\n    \n    /// <summary>\n    /// 表单ID\n    /// </summary>\n    string FormId { get; }\n    \n    /// <summary>\n    /// 数据行列表\n    /// </summary>\n    List<DynamicObject> DataRows { get; }\n    \n    /// <summary>\n    /// 操作参数\n    /// </summary>\n    Dictionary<string, object> Parameters { get; }\n    \n    /// <summary>\n    /// 当前用户\n    /// </summary>\n    UserInfo CurrentUser { get; }\n    \n    /// <summary>\n    /// 获取服务\n    /// </summary>\n    T? GetService<T>();\n}\n\n/// <summary>\n/// 动态对象\n/// </summary>\npublic class DynamicObject : Dictionary<string, object?>\n{\n    public string Id { get; set; } = string.Empty;\n    public string? Name { get; set; }\n    \n    public T? GetValue<T>(string key)\n    {\n        if (TryGetValue(key, out var value))\n        {\n            if (value is T typedValue)\n            {\n                return typedValue;\n            }\n            try\n            {\n                return (T?)Convert.ChangeType(value, typeof(T));\n            }\n            catch\n            {\n                return default;\n            }\n        }\n        return default;\n    }\n    \n    public void SetValue(string key, object? value)\n    {\n        this[key] = value;\n    }\n}\n\n/// <summary>\n/// 用户信息\n/// </summary>\npublic class UserInfo\n{\n    public string UserId { get; set; } = string.Empty;\n    public string UserName { get; set; } = string.Empty;\n    public string? DisplayName { get; set; }\n    public string? Email { get; set; }\n    public string? Phone { get; set; }\n    public List<string> Roles { get; set; } = new();\n    public Dictionary<string, object> ExtendedProperties { get; set; } = new();\n}\n\n/// <summary>\n/// 消息类型\n/// </summary>\npublic enum MessageType\n{\n    Info,\n    Success,\n    Warning,\n    Error\n}\n\n/// <summary>\n/// 操作结果\n/// </summary>\npublic class OperationResult\n{\n    public bool Success { get; set; }\n    public string? Message { get; set; }\n    public Dictionary<string, object> Data { get; set; } = new();\n    \n    public static OperationResult Ok(string? message = null)\n    {\n        return new OperationResult { Success = true, Message = message };\n    }\n    \n    public static OperationResult Fail(string message)\n    {\n        return new OperationResult { Success = false, Message = message };\n    }\n}\n\n/// <summary>\n/// 数据变更事件参数\n/// </summary>\npublic class DataChangedEventArgs : EventArgs\n{\n    public string FieldKey { get; set; } = string.Empty;\n    public object? OldValue { get; set; }\n    public object? NewValue { get; set; }\n}\n"}],"isError":false,"timestamp":1774227282463}}
