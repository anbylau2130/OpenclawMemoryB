{"type":"message","id":"3228e389","parentId":"c53828bf","timestamp":"2026-03-23T00:57:07.521Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建FieldMetadata。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_4f7aae92fa9648a0a1c14267","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Metadata/FieldMetadata.cs","content":"namespace Tianyou.Core.Abstractions.Metadata;\n\n/// <summary>\n/// 字段元数据服务\n/// </summary>\npublic class FieldMetadata\n{\n    /// <summary>\n    /// 字段Key\n    /// </summary>\n    public string FieldKey { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 字段名称\n    /// </summary>\n    public string FieldName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 数据类型\n    /// </summary>\n    public FieldDataType DataType { get; set; } = FieldDataType.String;\n\n    /// <summary>\n    /// 长度\n    /// </summary>\n    public int? Length { get; set; }\n\n    /// <summary>\n    /// 精度\n    /// </summary>\n    public int? Precision { get; set; }\n\n    /// <summary>\n    /// 是否必填\n    /// </summary>\n    public bool IsRequired { get; set; }\n\n    /// <summary>\n    /// 是否唯一\n    /// </summary>\n    public bool IsUnique { get; set; }\n\n    /// <summary>\n    /// 是否可见\n    /// </summary>\n    public bool IsVisible { get; set; } = true;\n\n    /// <summary>\n    /// 是否只读\n    /// </summary>\n    public bool IsReadOnly { get; set; }\n\n    /// <summary>\n    /// 是否启用\n    /// </summary>\n    public bool IsEnabled { get; set; } = true;\n\n    /// <summary>\n    /// 默认值\n    /// </summary>\n    public object? DefaultValue { get; set; }\n\n    /// <summary>\n    /// 验证规则\n    /// </summary>\n    public List<ValidationRule> ValidationRules { get; set; } = new();\n\n    /// <summary>\n    /// 字段分组\n    /// </summary>\n    public string? Group { get; set; }\n\n    /// <summary>\n    /// 显示顺序\n    /// </summary>\n    public int DisplayOrder { get; set; }\n\n    /// <summary>\n    /// 控件类型\n    /// </summary>\n    public ControlType ControlType { get; set; } = ControlType.TextBox;\n\n    /// <summary>\n    /// 数据源\n    /// </summary>\n    public string? DataSource { get; set; }\n\n    /// <summary>\n    /// 关联实体\n    /// </summary>\n    public string? RelatedEntity { get; set; }\n\n    /// <summary>\n    /// 关联字段\n    /// </summary>\n    public string? RelatedField { get; set; }\n\n    /// <summary>\n    /// 是否关联字段\n    /// </summary>\n    public bool IsLookup => !string.IsNullOrEmpty(RelatedEntity);\n\n    /// <summary>\n    /// 验证字段值\n    /// </summary>\n    public ValidationResult Validate(object? value)\n    {\n        var result = new ValidationResult();\n\n        // 必填验证\n        if (IsRequired && (value == null || string.IsNullOrEmpty(value.ToString())))\n        {\n            result.AddError(FieldKey, $\"{FieldName}为必填项\");\n        }\n\n        // 长度验证\n        if (Length != null && value != null && value.ToString()?.Length > Length)\n        {\n            result.AddError(FieldKey, $\"{FieldName}长度不能超过{Length}\");\n        }\n\n        // 自定义验证规则\n        foreach (var rule in ValidationRules)\n        {\n            if (!rule.Validate(value))\n            {\n                result.AddError(FieldKey, rule.ErrorMessage);\n            }\n        }\n\n        return result;\n    }\n\n    /// <summary>\n    /// 格式化显示值\n    /// </summary>\n    public string? FormatValue(object? value)\n    {\n        if (value == null) return null;\n\n        return DataType switch\n        {\n            FieldDataType.DateTime when value is DateTime dt => dt.ToString(\"yyyy-MM-dd HH:mm:ss\"),\n            FieldDataType.Date when value is DateTime dt => dt.ToString(\"yyyy-MM-dd\"),\n            FieldDataType.Decimal when value is decimal d => d.ToString(\"F2\"),\n            FieldDataType.Integer when value is int i => i.ToString(),\n            _ => value.ToString()\n        };\n    }\n\n    /// <summary>\n    /// 转换值类型\n    /// </summary>\n    public object? ConvertValue(object? value)\n    {\n        if (value == null) return null;\n\n        return DataType switch\n        {\n            FieldDataType.String => value.ToString(),\n            FieldDataType.Integer => Convert.ToInt32(value),\n            FieldDataType.Decimal => Convert.ToDecimal(value),\n            FieldDataType.Boolean => Convert.ToBoolean(value),\n            FieldDataType.Date or FieldDataType.DateTime => Convert.ToDateTime(value),\n            _ => value\n        };\n    }\n}\n\n/// <summary>\n/// 字段数据类型\n/// </summary>\npublic enum FieldDataType\n{\n    /// <summary>\n    /// 字符串\n    /// </summary>\n    String,\n\n    /// <summary>\n    /// 整数\n    /// </summary>\n    Integer,\n\n    /// <summary>\n    /// 小数\n    /// </summary>\n    Decimal,\n\n    /// <summary>\n    /// 布尔值\n    /// </summary>\n    Boolean,\n\n    /// <summary>\n    /// 日期\n    /// </summary>\n    Date,\n\n    /// <summary>\n    /// 日期时间\n    /// </summary>\n    DateTime,\n\n    /// <summary>\n    /// 文本\n    /// </summary>\n    Text,\n\n    /// <summary>\n    /// 二进制\n    /// </summary>\n    Binary\n}\n\n/// <summary>\n/// 控件类型\n/// </summary>\npublic enum ControlType\n{\n    /// <summary>\n    /// 文本框\n    /// </summary>\n    TextBox,\n\n    /// <summary>\n    /// 数字框\n    /// </summary>\n    NumberBox,\n\n    /// <summary>\n    /// 日期选择器\n    /// </summary>\n    DatePicker,\n\n    /// <summary>\n    /// 下拉选择\n    /// </summary>\n    ComboBox,\n\n    /// <summary>\n    /// 复选框\n    /// </summary>\n    CheckBox,\n\n    /// <summary>\n    /// 单选框\n    /// </summary>\n    RadioButton,\n\n    /// <summary>\n    /// 文本域\n    /// </summary>\n    TextArea,\n\n    /// <summary>\n    /// 富文本编辑器\n    /// </summary>\n    RichTextEditor,\n\n    /// <summary>\n    /// 文件上传\n    /// </summary>\n    FileUpload,\n\n    /// <summary>\n    /// 图片上传\n    /// </summary>\n    ImageUpload,\n\n    /// <summary>\n    /// 查找框\n    /// </summary>\n    Lookup\n}\n\n/// <summary>\n/// 验证规则\n/// </summary>\npublic class ValidationRule\n{\n    /// <summary>\n    /// 规则名称\n    /// </summary>\n    public string RuleName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 验证表达式\n    /// </summary>\n    public string? Expression { get; set; }\n\n    /// <summary>\n    /// 错误消息\n    /// </summary>\n    public string ErrorMessage { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 验证值\n    /// </summary>\n    public bool Validate(object? value)\n    {\n        if (string.IsNullOrEmpty(Expression))\n            return true;\n\n        // 简单的正则表达式验证\n        try\n        {\n            return System.Text.RegularExpressions.Regex.IsMatch(\n                value?.ToString() ?? \"\",\n                Expression\n            );\n        }\n        catch\n        {\n            return false;\n        }\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":42,"output":1638,"cacheRead":36350,"cacheWrite":0,"totalTokens":38030,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227413382}}
