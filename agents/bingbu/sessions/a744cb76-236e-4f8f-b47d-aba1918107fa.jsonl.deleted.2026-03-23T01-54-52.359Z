{"type":"message","id":"e5818539","parentId":"147e1ebc","timestamp":"2026-03-23T00:58:30.799Z","message":{"role":"toolResult","toolCallId":"call_878b9c3cd9844bdeb550094f","toolName":"read","content":[{"type":"text","text":"using System;\n\nnamespace Tianyou.Plugin.Abstractions\n{\n    /// <summary>\n    /// 插件基类 - 参考金蝶云苍穹IPlugin\n    /// </summary>\n    public abstract class PluginBase : IPlugin\n    {\n        /// <summary>\n        /// 插件ID\n        /// </summary>\n        public virtual string PluginId { get; set; }\n        \n        /// <summary>\n        /// 插件名称\n        /// </summary>\n        public virtual string PluginName { get; set; }\n        \n        /// <summary>\n        /// 插件版本\n        /// </summary>\n        public virtual Version Version { get; set; }\n        \n        /// <summary>\n        /// 插件描述\n        /// </summary>\n        public virtual string Description { get; set; }\n        \n        /// <summary>\n        /// 作者\n        /// </summary>\n        public virtual string Author { get; set; }\n        \n        /// <summary>\n        /// 部署模式\n        /// </summary>\n        public virtual DeployMode DeployMode { get; set; }\n        \n        /// <summary>\n        /// 依赖项\n        /// </summary>\n        public virtual List<PluginDependency> Dependencies { get; set; }\n\n        /// <summary>\n        /// 初始化插件\n        /// </summary>\n        public virtual void Initialize()\n        {\n            // 验证依赖项\n            ValidateDependencies();\n            \n            // 初始化资源\n            InitializeResources();\n        }\n\n        /// <summary>\n        /// 验证依赖项\n        /// </summary>\n        private void ValidateDependencies()\n        {\n            if (Dependencies == null || Dependencies.Count == 0)\n                return;\n            \n            foreach (var dependency in Dependencies)\n            {\n                // 验证依赖插件是否已安装\n                if (!PluginManager.IsInstalled(dependency.PluginId))\n                {\n                    throw new PluginDependencyException(\n                        $\"依赖插件 {dependency.PluginId} 未安装\");\n                }\n                \n                // 验证版本\n                var installed = PluginManager.GetPlugin(dependency.PluginId);\n                if (installed.Version < dependency.Version)\n                {\n                    throw new PluginDependencyException(\n                        $\"依赖插件 {dependency.PluginId} 版本不满足要求\");\n                }\n            }\n        }\n\n        /// <summary>\n        /// 初始化资源\n        /// </summary>\n        protected virtual void InitializeResources()\n        {\n            // 子类实现\n        }\n\n        /// <summary>\n        /// 卸载插件\n        /// </summary>\n        public virtual void Unload()\n        {\n            // 清理资源\n            CleanupResources();\n        }\n\n        /// <summary>\n        /// 清理资源\n        /// </summary>\n        protected virtual void CleanupResources()\n        {\n            // 子类实现\n        }\n    }\n\n    /// <summary>\n    /// 插件接口\n    /// </summary>\n    public interface IPlugin\n    {\n        string PluginId { get; }\n        string PluginName { get; }\n        Version Version { get; }\n        string Description { get; }\n        string Author { get; }\n        DeployMode DeployMode { get; }\n        List<PluginDependency> Dependencies { get; }\n        \n        void Initialize();\n        void Unload();\n    }\n\n    /// <summary>\n    /// 插件元数据特性 - 参考云苍穹PluginMetadata\n    /// </summary>\n    [AttributeUsage(AttributeTargets.Class, Inherited = false)]\n    public class PluginMetadataAttribute : Attribute\n    {\n        public string Id { get; }\n        public string Name { get; }\n        public string Version { get; }\n        public string Description { get; set; }\n        public string Author { get; set; }\n        public DeployMode DeployMode { get; set; } = DeployMode.Standalone;\n\n        public PluginMetadataAttribute(string id, string name, string version)\n        {\n            Id = id;\n            Name = name;\n            Version = version;\n        }\n    }\n\n    /// <summary>\n    /// 部署模式\n    /// </summary>\n    public enum DeployMode\n    {\n        /// <summary>\n        /// 独立部署\n        /// </summary>\n        Standalone,\n        \n        /// <summary>\n        /// 共享部署\n        /// </summary>\n        Shared,\n        \n        /// <summary>\n        /// 微服务部署\n        /// </summary>\n        Microservice\n    }\n\n    /// <summary>\n    /// 插件依赖\n    /// </summary>\n    public class PluginDependency\n    {\n        public string PluginId { get; set; }\n        public Version Version { get; set; }\n    }\n\n    /// <summary>\n    /// 插件依赖异常\n    /// </summary>\n    public class PluginDependencyException : Exception\n    {\n        public PluginDependencyException(string message) : base(message)\n        {\n        }\n    }\n\n    /// <summary>\n    /// 插件管理器（静态工具类）\n    /// </summary>\n    public static class PluginManager\n    {\n        private static readonly Dictionary<string, IPlugin> _plugins = new();\n\n        public static bool IsInstalled(string pluginId)\n        {\n            return _plugins.ContainsKey(pluginId);\n        }\n\n        public static IPlugin GetPlugin(string pluginId)\n        {\n            return _plugins.TryGetValue(pluginId, out var plugin) ? plugin : null;\n        }\n\n        public static void RegisterPlugin(IPlugin plugin)\n        {\n            _plugins[plugin.PluginId] = plugin;\n        }\n    }\n}\n"}],"isError":false,"timestamp":1774227510794}}
