 </summary>\n    public FieldMetadata? GetField(string fieldKey)\n    {\n        return Fields.FirstOrDefault(f => f.FieldKey == fieldKey);\n    }\n\n    /// <summary>\n    /// 添加字段\n    /// </summary>\n    public void AddField(FieldMetadata field)\n    {\n        Fields.Add(field);\n    }\n\n    /// <summary>\n    /// 获取分录元数据\n    /// </summary>\n    public EntryMetadata? GetEntry(string entryKey)\n    {\n        return Entries.FirstOrDefault(e => e.EntryKey == entryKey);\n    }\n\n    /// <summary>\n    /// 添加分录\n    /// </summary>\n    public void AddEntry(EntryMetadata entry)\n    {\n        Entries.Add(entry);\n    }\n\n    /// <summary>\n    /// 获取关系\n    /// </summary>\n    public List<RelationMetadata> GetRelations(string fieldKey)\n    {\n        return Relations.Where(r => r.FieldKey == fieldKey).ToList();\n    }\n\n    /// <summary>\n    /// 添加关系\n    /// </summary>\n    public void AddRelation(RelationMetadata relation)\n    {\n        Relations.Add(relation);\n    }\n\n    /// <summary>\n    /// 获取索引\n    /// </summary>\n    public IndexMetadata? GetIndex(string indexName)\n    {\n        return Indexes.FirstOrDefault(i => i.IndexName == indexName);\n    }\n\n    /// <summary>\n    /// 添加索引\n    /// </summary>\n    public void AddIndex(IndexMetadata index)\n    {\n        Indexes.Add(index);\n    }\n\n    /// <summary>\n    /// 获取所有可查询字段\n    /// </summary>\n    public List<string> GetQueryableFields()\n    {\n        return Fields.Where(f => f.IsVisible)\n                    .Select(f => f.FieldKey)\n                    .ToList();\n    }\n\n    /// <summary>\n    /// 获取所有可排序字段\n    /// </summary>\n    public List<string> GetSortableFields()\n    {\n        return Fields.Where(f => f.IsVisible && !f.IsReadOnly)\n                    .Select(f => f.FieldKey)\n                    .ToList();\n    }\n}\n\n/// <summary>\n/// 分录元数据\n/// </summary>\npublic class EntryMetadata\n{\n    /// <summary>\n    /// 分录Key\n    /// </summary>\n    public string EntryKey { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 分录名称\n    /// </summary>\n    public string EntryName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 表名\n    /// </summary>\n    public string TableName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 主键字段\n    /// </summary>\n    public string PrimaryKey { get; set; } = \"Id\";\n\n    /// <summary>\n    /// 关联主表字段\n    /// </summary>\n    public string ForeignKey { get; set; } = \"MainId\";\n\n    /// <summary>\n    /// 字段列表\n    /// </summary>\n    public List<FieldMetadata> Fields { get; set; } = new();\n\n    /// <summary>\n    /// 获取字段\n    /// </summary>\n    public FieldMetadata? GetField(string fieldKey)\n    {\n        return Fields.FirstOrDefault(f => f.FieldKey == fieldKey);\n    }\n\n    /// <summary>\n    /// 添加字段\n    /// </summary>\n    public void AddField(FieldMetadata field)\n    {\n        Fields.Add(field);\n    }\n}\n\n/// <summary>\n/// 索引元数据\n/// </summary>\npublic class IndexMetadata\n{\n    /// <summary>\n    /// 索引名称\n    /// </summary>\n    public string IndexName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 字段列表\n    /// </summary>\n    public List<string> FieldNames { get; set; } = new();\n\n    /// <summary>\n    /// 是否唯一索引\n    /// </summary>\n    public bool IsUnique { get; set; }\n\n    /// <summary>\n    /// 是否聚集索引\n    /// </summary>\n    public bool IsClustered { get; set; }\n}\n\n/// <summary>\n/// 关系元数据\n/// </summary>\npublic class RelationMetadata\n{\n    /// <summary>\n    /// 关系名称\n    /// </summary>\n    public string RelationName { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 字段Key\n    /// </summary>\n    public string FieldKey { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 关系类型\n    /// </summary>\n    public RelationType RelationType { get; set; } = RelationType.OneToOne;\n\n    /// <summary>\n    /// 关联实体\n    /// </summary>\n    public string RelatedEntity { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 关联字段\n    /// </summary>\n    public string RelatedField { get; set; } = string.Empty;\n\n    /// <summary>\n    /// 是否级联删除\n    /// </summary>\n    public bool CascadeDelete { get; set; }\n}\n\n/// <summary>\n/// 关系类型\n/// </summary>\npublic enum RelationType\n{\n    /// <summary>\n    /// 一对一\n    /// </summary>\n    OneToOne,\n\n    /// <summary>\n    /// 一对多\n    /// </summary>\n    OneToMany,\n\n    /// <summary>\n    /// 多对一\n    /// </summary>\n    ManyToOne,\n\n    /// <summary>\n    /// 多对多\n    /// </summary>\n    ManyToMany\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":43,"output":1641,"cacheRead":38023,"cacheWrite":0,"totalTokens":39707,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227427557}}
