{"type":"message","id":"2039f6e7","parentId":"54e9a141","timestamp":"2026-03-23T00:58:26.619Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建FilterParser。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_c689ac64ab964455ab2e7d89","name":"write","arguments":{"content":"namespace Tianyou.Core.Abstractions.Services;\n\n/// <summary>\n/// 过滤条件解析器 - 用于解析和转换过滤条件\n/// </summary>\npublic class FilterParser\n{\n    /// <summary>\n    /// 解析JSON格式的过滤条件\n    /// </summary>\n    public static List<FilterCondition> ParseFromJson(string json)\n    {\n        try\n        {\n            return System.Text.Json.JsonSerializer.Deserialize<List<FilterCondition>>(json) ?? new List<FilterCondition>();\n        }\n        catch\n        {\n            return new List<FilterCondition>();\n        }\n    }\n\n    /// <summary>\n    /// 解析字典格式的过滤条件\n    /// </summary>\n    public static List<FilterCondition> ParseFromDictionary(Dictionary<string, object> dictionary)\n    {\n        var filters = new List<FilterCondition>();\n\n        foreach (var kvp in dictionary)\n        {\n            var parts = kvp.Key.Split('_');\n            if (parts.Length >= 1)\n            {\n                var fieldName = parts[0];\n                var op = parts.Length > 1 ? parts[1] : \"eq\";\n\n                var condition = new FilterCondition\n                {\n                    FieldName = fieldName,\n                    Operator = ParseOperator(op),\n                    Value = kvp.Value\n                };\n\n                filters.Add(condition);\n            }\n        }\n\n        return filters;\n    }\n\n    /// <summary>\n    /// 解析查询字符串格式的过滤条件\n    /// </summary>\n    public static List<FilterCondition> ParseFromQueryString(string queryString)\n    {\n        var filters = new List<FilterCondition>();\n\n        if (string.IsNullOrEmpty(queryString))\n        {\n            return filters;\n        }\n\n        var pairs = queryString.Split('&');\n        foreach (var pair in pairs)\n        {\n            var keyValue = pair.Split('=');\n            if (keyValue.Length == 2)\n            {\n                var key = System.Web.HttpUtility.UrlDecode(keyValue[0]);\n                var value = System.Web.HttpUtility.UrlDecode(keyValue[1]);\n\n                if (!string.IsNullOrEmpty(key))\n                {\n                    var parts = key.Split('_');\n                    var fieldName = parts[0];\n                    var op = parts.Length > 1 ? parts[1] : \"eq\";\n\n                    var condition = new FilterCondition\n                    {\n                        FieldName = fieldName,\n                        Operator = ParseOperator(op),\n                        Value = value\n                    };\n\n                    filters.Add(condition);\n                }\n            }\n        }\n\n        return filters;\n    }\n\n    /// <summary>\n    /// 解析操作符字符串\n    /// </summary>\n    public static FilterOperator ParseOperator(string op)\n    {\n        return op.ToLower() switch\n        {\n            \"eq\" => FilterOperator.Equal,\n            \"ne\" => FilterOperator.NotEqual,\n            \"gt\" => FilterOperator.GreaterThan,\n            \"gte\" => FilterOperator.GreaterThanOrEqual,\n            \"lt\" => FilterOperator.LessThan,\n            \"lte\" => FilterOperator.LessThanOrEqual,\n            \"contains\" => FilterOperator.Contains,\n            \"notcontains\" => FilterOperator.NotContains,\n            \"startswith\" => FilterOperator.StartsWith,\n            \"endswith\" => FilterOperator.EndsWith,\n            \"isnull\" => FilterOperator.IsNull,\n            \"isnotnull\" => FilterOperator.IsNotNull,\n            \"in\" => FilterOperator.In,\n            \"notin\" => FilterOperator.NotIn,\n            _ => FilterOperator.Equal\n        };\n    }\n\n    /// <summary>\n    /// 将操作符转换为字符串\n    /// </summary>\n    public static string OperatorToString(FilterOperator op)\n    {\n        return op switch\n        {\n            FilterOperator.Equal => \"eq\",\n            FilterOperator.NotEqual => \"ne\",\n            FilterOperator.GreaterThan => \"gt\",\n            FilterOperator.GreaterThanOrEqual => \"gte\",\n            FilterOperator.LessThan => \"lt\",\n            FilterOperator.LessThanOrEqual => \"lte\",\n            FilterOperator.Contains => \"contains\",\n            FilterOperator.NotContains => \"notcontains\",\n            FilterOperator.StartsWith => \"startswith\",\n            FilterOperator.EndsWith => \"endswith\",\n            FilterOperator.IsNull => \"isnull\",\n            FilterOperator.IsNotNull => \"isnotnull\",\n            FilterOperator.In => \"in\",\n            FilterOperator.NotIn => \"notin\",\n            _ => \"eq\"\n        };\n    }\n\n    /// <summary>\n    /// 将过滤条件转换为JSON字符串\n    /// </summary>\n    public static string ToJson(List<FilterCondition> filters)\n    {\n        return System.Text.Json.JsonSerializer.Serialize(filters);\n    }\n\n    /// <summary>\n    /// 将过滤条件转换为SQL WHERE子句\n    /// </summary>\n    public static string ToSqlWhere(List<FilterCondition> filters, Dictionary<string, object>? parameters = null)\n    {\n        if (filters.Count == 0)\n        {\n            return \"1=1\";\n        }\n\n        parameters ??= new Dictionary<string, object>();\n        var conditions = new List<string>();\n\n        for (int i = 0; i < filters.Count; i++)\n        {\n            var filter = filters[i];\n            var paramName = $\"param_{i}_{Guid.NewGuid():N}\";\n            var sql = FilterToSql(filter, paramName, parameters);\n            conditions.Add(sql);\n        }\n\n        return string.Join($\" {filters[0].Logic} \", conditions);\n    }\n\n    /// <summary>\n    /// 将单个过滤条件转换为SQL\n    /// </summary>\n    private static string FilterToSql(FilterCondition filter, string paramName, Dictionary<string, object> parameters)\n    {\n        var sql = filter.Operator switch\n        {\n            FilterOperator.Equal => $\"{filter.FieldName} = @{paramName}\",\n            FilterOperator.NotEqual => $\"{filter.FieldName} <> @{paramName}\",\n            FilterOperator.GreaterThan => $\"{filter.FieldName} > @{paramName}\",\n            FilterOperator.GreaterThanOrEqual => $\"{filter.FieldName} >= @{paramName}\",\n            FilterOperator.LessThan => $\"{filter.FieldName} < @{paramName}\",\n            FilterOperator.LessThanOrEqual => $\"{filter.FieldName} <= @{paramName}\",\n            FilterOperator.Contains => $\"{filter.FieldName} LIKE @{paramName}\",\n            FilterOperator.NotContains => $\"{filter.FieldName} NOT LIKE @{paramName}\",\n            FilterOperator.StartsWith => $\"{filter.FieldName} LIKE @{paramName}\",\n            FilterOperator.EndsWith => $\"{filter.FieldName} LIKE @{paramName}\",\n            FilterOperator.IsNull => $\"{filter.FieldName} IS NULL\",\n            FilterOperator.IsNotNull => $\"{filter.FieldName} IS NOT NULL\",\n            FilterOperator.In => $\"{filter.FieldName} IN @{paramName}\",\n            FilterOperator.NotIn => $\"{filter.FieldName} NOT IN @{paramName}\",\n            _ => $\"{filter.FieldName} = @{paramName}\"\n        };\n\n        if (filter.Operator != FilterOperator.IsNull && filter.Operator != FilterOperator.IsNotNull)\n        {\n            var paramValue = filter.Value;\n            if (filter.Operator == FilterOperator.Contains)\n            {\n                paramValue = $\"%{filter.Value}%\";\n            }\n            else if (filter.Operator == FilterOperator.StartsWith)\n            {\n                paramValue = $\"{filter.Value}%\";\n            }\n            else if (filter.Operator == FilterOperator.EndsWith)\n            {\n                paramValue = $\"%{filter.Value}\";\n            }\n\n            parameters[paramName] = paramValue!;\n        }\n\n        return sql;\n    }\n\n    /// <summary>\n    /// 合并过滤条件\n    /// </summary>\n    public static List<FilterCondition> MergeFilters(List<FilterCondition> filters1, List<FilterCondition> filters2, FilterLogic logic = FilterLogic.And)\n    {\n        var merged = new List<FilterCondition>(filters1);\n\n        foreach (var filter in filters2)\n        {\n            filter.Logic = logic;\n            merged.Add(filter);\n        }\n\n        return merged;\n    }\n\n    /// <summary>\n    /// 验证过滤条件\n    /// </summary>\n    public static bool ValidateFilter(FilterCondition filter)\n    {\n        if (string.IsNullOrEmpty(filter.FieldName))\n        {\n            return false;\n        }\n\n        // 检查值是否有效\n        if (filter.Operator != FilterOperator.IsNull &&\n            filter.Operator != FilterOperator.IsNotNull &&\n            filter.Value == null)\n        {\n            return false;\n        }\n\n        return true;\n    }\n\n    /// <summary>\n    /// 转换过滤条件的字段名\n    /// </summary>\n    public static List<FilterCondition> TransformFieldNames(List<FilterCondition> filters, Func<string, string> transformer)\n    {\n        foreach (var filter in filters)\n        {\n            filter.FieldName = transformer(filter.FieldName);\n        }\n\n        return filters;\n    }\n\n    /// <summary>\n    /// 创建等于条件\n    /// </summary>\n    public static FilterCondition CreateEqual(string fieldName, object? value)\n    {\n        return new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.Equal,\n            Value = value\n        };\n    }\n\n    /// <summary>\n    /// 创建包含条件\n    /// </summary>\n    public static FilterCondition CreateContains(string fieldName, string value)\n    {\n        return new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.Contains,\n            Value = value\n        };\n    }\n\n    /// <summary>\n    /// 创建在列表中条件\n    /// </summary>\n    public static FilterCondition CreateIn(string fieldName, List<object> values)\n    {\n        return new FilterCondition\n        {\n            FieldName = fieldName,\n            Operator = FilterOperator.In,\n            Value = values\n        };\n    }\n}\n","path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Core.Abstractions/Services/FilterParser.cs"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":42,"output":1965,"cacheRead":45173,"cacheWrite":0,"totalTokens":47180,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774227487762}}
