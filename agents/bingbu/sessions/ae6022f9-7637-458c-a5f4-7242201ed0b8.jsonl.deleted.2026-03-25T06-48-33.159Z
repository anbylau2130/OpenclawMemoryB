{"type":"message","id":"891db69b","parentId":"6dae12fd","timestamp":"2026-03-25T05:51:06.350Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在修改错误提示的友好性，根据不同的错误类型提供不同的提示。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_f1f3369b69cd49dc89d40e70","name":"edit","arguments":{"file_path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/Login.razor","newText":"    private async Task HandleLogin()\n    {\n        IsLoading = true;\n        ErrorMessage = null;\n        \n        try\n        {\n            var result = await AuthService.LoginAsync(loginModel.Username, loginModel.Password);\n            \n            if (result.Success)\n            {\n                Logger.LogInformation(\"登录成功，跳转到首页\");\n                NavigationManager.NavigateTo(\"/\");\n            }\n            else\n            {\n                // 根据错误消息提供友好的提示\n                ErrorMessage = GetFriendlyErrorMessage(result.Message);\n            }\n        }\n        catch (HttpRequestException ex)\n        {\n            Logger.LogError(ex, \"网络连接失败\");\n            ErrorMessage = \"网络连接失败，请检查您的网络连接后重试\";\n        }\n        catch (TaskCanceledException ex)\n        {\n            Logger.LogError(ex, \"登录超时\");\n            ErrorMessage = \"登录请求超时，请稍后重试\";\n        }\n        catch (Exception ex)\n        {\n            Logger.LogError(ex, \"登录异常\");\n            ErrorMessage = \"系统暂时无法处理您的请求，请稍后重试\";\n        }\n        finally\n        {\n            IsLoading = false;\n        }\n    }\n    \n    private string GetFriendlyErrorMessage(string? serverMessage)\n    {\n        if (string.IsNullOrEmpty(serverMessage))\n            return \"登录失败，请重试\";\n        \n        // 根据服务器返回的错误消息提供更友好的提示\n        return serverMessage.ToLower() switch\n        {\n            var msg when msg.Contains(\"invalid credentials\") || msg.Contains(\"用户名或密码错误\") \n                => \"用户名或密码错误，请检查后重试\",\n            var msg when msg.Contains(\"user not found\") || msg.Contains(\"用户不存在\") \n                => \"该用户不存在，请检查用户名\",\n            var msg when msg.Contains(\"account locked\") || msg.Contains(\"账户锁定\") \n                => \"您的账户已被锁定，请联系管理员\",\n            var msg when msg.Contains(\"account disabled\") || msg.Contains(\"账户禁用\") \n                => \"您的账户已被禁用，请联系管理员\",\n            var msg when msg.Contains(\"too many attempts\") || msg.Contains(\"尝试次数过多\") \n                => \"登录尝试次数过多，请稍后再试\",\n            _ => serverMessage\n        };\n    }","oldText":"    private async Task HandleLogin()\n    {\n        IsLoading = true;\n        ErrorMessage = null;\n        \n        try\n        {\n            var result = await AuthService.LoginAsync(loginModel.Username, loginModel.Password);\n            \n            if (result.Success)\n            {\n                Logger.LogInformation(\"登录成功，跳转到首页\");\n                NavigationManager.NavigateTo(\"/\");\n            }\n            else\n            {\n                ErrorMessage = result.Message ?? \"登录失败，请重试\";\n            }\n        }\n        catch (Exception ex)\n        {\n            Logger.LogError(ex, \"登录异常\");\n            ErrorMessage = $\"登录失败: {ex.Message}\";\n        }\n        finally\n        {\n            IsLoading = false;\n        }\n    }"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":552,"output":657,"cacheRead":24704,"cacheWrite":0,"totalTokens":25913,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774417845522}}
