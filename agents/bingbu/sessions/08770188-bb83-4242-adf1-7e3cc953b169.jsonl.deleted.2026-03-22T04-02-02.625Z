open('/tmp/nuxt_data.json', 'w', encoding='utf-8') as f:\n            json.dump(nuxt_data, f, ensure_ascii=False, indent=2)\n        print(\"数据已保存到 /tmp/nuxt_data.json\")\n    else:\n        print(\"未获取到window.__NUXT__数据\")\n\nexcept Exception as e:\n    print(f\"错误: {e}\")\nfinally:\n    driver.quit()\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":88,"output":700,"cacheRead":65334,"cacheWrite":0,"totalTokens":66122,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774149045220}}
