{"type":"message","id":"e9562438","parentId":"ecd60d38","timestamp":"2026-03-22T23:56:06.210Z","message":{"role":"toolResult","toolCallId":"call_58c68e00db724deab11c5638","toolName":"read","content":[{"type":"text","text":"using Microsoft.OpenApi.Models;\nusing Serilog;\nusing Tianyou.Data.SqlSugar;\n\nvar builder = WebApplication.CreateBuilder(args);\n\nLog.Logger = new LoggerConfiguration()\n    .WriteTo.Console()\n    .WriteTo.File(\"logs/data-.log\", rollingInterval: RollingInterval.Day)\n    .CreateLogger();\n\nbuilder.Host.UseSerilog();\n\nbuilder.Services.AddSqlSugar(builder.Configuration);\nbuilder.Services.AddSqlSugarRepositories();\n\nbuilder.Services.AddControllers();\nbuilder.Services.AddCors(options =>\n{\n    options.AddPolicy(\"AllowAll\", policy =>\n    {\n        policy.AllowAnyOrigin()\n              .AllowAnyMethod()\n              .AllowAnyHeader();\n    });\n});\n\nbuilder.Services.AddEndpointsApiExplorer();\nbuilder.Services.AddSwaggerGen(c =>\n{\n    c.SwaggerDoc(\"v1\", new OpenApiInfo\n    {\n        Title = \"数据服务 API\",\n        Version = \"v1\"\n    });\n});\n\nvar app = builder.Build();\n\nusing (var scope = app.Services.CreateScope())\n{\n    var dbInitializer = new DatabaseInitializer(\n        scope.ServiceProvider.GetRequiredService<ISqlSugarClient>()\n    );\n    await dbInitializer.InitializeAsync();\n}\n\napp.UseCors(\"AllowAll\");\napp.MapControllers();\n\napp.UseSwagger();\napp.UseSwaggerUI(c =>\n{\n    c.SwaggerEndpoint(\"/swagger/v1/swagger.json\", \"Data API V1\");\n});\n\napp.MapGet(\"/health\", () => Results.Ok(new\n{\n    service = \"Tianyou Data Service\",\n    status = \"healthy\"\n}));\n\nLog.Information(\"数据服务启动中...\");\napp.Run();\n"}],"isError":false,"timestamp":1774223766201}}
