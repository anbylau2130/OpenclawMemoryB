{"type":"message","id":"d67e9755","parentId":"c5ead76c","timestamp":"2026-03-22T23:59:19.846Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"\n\n\n\n现在让我创建Program.cs，配置SqlSugar和服务。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_127da7bacc5b451e88d9c670","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.BasicDataService/Program.cs","content":"using Microsoft.OpenApi.Models;\nusing Serilog;\nusing SqlSugar;\nusing Tianyou.BasicDataService.Entities;\nusing Tianyou.BasicDataService.Repositories;\n\nvar builder = WebApplication.CreateBuilder(args);\n\nLog.Logger = new LoggerConfiguration()\n    .WriteTo.Console()\n    .WriteTo.File(\"logs/basicdata-.log\", rollingInterval: RollingInterval.Day)\n    .CreateLogger();\n\nbuilder.Host.UseSerilog();\n\nvar dbConfig = builder.Configuration.GetSection(\"Database\");\nvar connectionString = dbConfig[\"ConnectionString\"] ?? \"Data Source=/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/database/tianyou.db\";\n\nbuilder.Services.AddSingleton<ISqlSugarClient>(s =>\n{\n    var db = new SqlSugarClient(new ConnectionConfig\n    {\n        ConnectionString = connectionString,\n        DbType = DbType.Sqlite,\n        IsAutoCloseConnection = true,\n        InitKeyType = InitKeyType.Attribute\n    });\n\n    db.Aop.OnLogExecuting = (sql, pars) =>\n    {\n        Console.WriteLine($\"[SQL] {sql}\");\n    };\n\n    return db;\n});\n\nbuilder.Services.AddScoped<BasicDataRepository>();\nbuilder.Services.AddScoped<Services.BasicDataService>();\n\nbuilder.Services.AddControllers();\nbuilder.Services.AddCors(options =>\n{\n    options.AddPolicy(\"AllowAll\", policy =>\n    {\n        policy.AllowAnyOrigin()\n              .AllowAnyMethod()\n              .AllowAnyHeader();\n    });\n});\n\nbuilder.Services.AddEndpointsApiExplorer();\nbuilder.Services.AddSwaggerGen(c =>\n{\n    c.SwaggerDoc(\"v1\", new OpenApiInfo\n    {\n        Title = \"基础资料服务 API\",\n        Version = \"v1\",\n        Description = \"提供组织架构、员工档案、客户、供应商、物料、仓库管理功能\"\n    });\n});\n\nvar app = builder.Build();\n\nusing (var scope = app.Services.CreateScope())\n{\n    var db = scope.ServiceProvider.GetRequiredService<ISqlSugarClient>();\n    await InitializeDatabaseAsync(db);\n}\n\napp.UseCors(\"AllowAll\");\napp.MapControllers();\n\napp.UseSwagger();\napp.UseSwaggerUI(c =>\n{\n    c.SwaggerEndpoint(\"/swagger/v1/swagger.json\", \"BasicData API V1\");\n});\n\napp.MapGet(\"/health\", () => Results.Ok(new\n{\n    service = \"Tianyou Basic Data Service\",\n    status = \"healthy\",\n    timestamp = DateTime.UtcNow\n}));\n\napp.MapGet(\"/api\", () => Results.Ok(new\n{\n    name = \"基础资料服务\",\n    version = \"1.0.0\",\n    description = \"提供组织架构、员工档案、客户、供应商、物料、仓库管理功能\",\n    endpoints = new[]\n    {\n        \"/api/department\",\n        \"/api/position\",\n        \"/api/employee\",\n        \"/api/customer\",\n        \"/api/supplier\",\n        \"/api/material\",\n        \"/api/warehouse\"\n    }\n}));\n\nLog.Information(\"基础资料服务启动中...\");\napp.Run();\n\nstatic async Task InitializeDatabaseAsync(ISqlSugarClient db)\n{\n    Log.Information(\"正在初始化数据库表...\");\n\n    var tables = new Type[]\n    {\n        typeof(DepartmentEntity),\n        typeof(PositionEntity),\n        typeof(EmployeeEntity),\n        typeof(CustomerEntity),\n        typeof(SupplierEntity),\n        typeof(MaterialEntity),\n        typeof(WarehouseEntity),\n        typeof(WarehouseStockEntity)\n    };\n\n    db.CodeFirst.InitTables(tables);\n    Log.Information($\"已创建/更新 {tables.Length} 个数据表\");\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":42,"output":754,"cacheRead":32118,"cacheWrite":0,"totalTokens":32914,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774223952609}}
