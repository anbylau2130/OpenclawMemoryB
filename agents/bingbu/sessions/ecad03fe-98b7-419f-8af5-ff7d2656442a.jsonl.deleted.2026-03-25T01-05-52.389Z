{"type":"message","id":"ab892c58","parentId":"15c52c91","timestamp":"2026-03-25T00:06:06.527Z","message":{"role":"toolResult","toolCallId":"call_ae5627f6fd5940bba32768f2","toolName":"exec","content":[{"type":"text","text":"[HttpPost(\"register\")]\n    [HttpPost(\"login\")]\n    [HttpGet(\"me\")]\n    [HttpPut(\"password\")]\n    [HttpPost]\n    [HttpPost(\"{entityId}/fields\")]\n    [HttpGet]\n    [HttpGet(\"{entityId}\")]\n    [HttpPost(\"{entityId}/data\")]\n    [HttpGet(\"{entityId}/data\")]\n    [HttpPut(\"data/{dataId}\")]\n    [HttpDelete(\"data/{dataId}\")]\n    [HttpPost]\n    [HttpPost(\"{formId}/fields\")]\n    [HttpPost(\"{formId}/publish\")]\n    [HttpGet]\n    [HttpGet(\"{formId}\")]\n    [HttpPost]\n    [HttpPost(\"{workflowId}/start\")]\n    [HttpPost(\"instances/{instanceId}/tasks\")]\n    [HttpPost(\"tasks/{taskId}/complete\")]\n    [HttpGet]\n    [HttpGet(\"my-tasks\")]\n    [HttpGet(\"instances/{instanceId}\")]"}],"details":{"status":"completed","exitCode":0,"durationMs":120,"aggregated":"[HttpPost(\"register\")]\n    [HttpPost(\"login\")]\n    [HttpGet(\"me\")]\n    [HttpPut(\"password\")]\n    [HttpPost]\n    [HttpPost(\"{entityId}/fields\")]\n    [HttpGet]\n    [HttpGet(\"{entityId}\")]\n    [HttpPost(\"{entityId}/data\")]\n    [HttpGet(\"{entityId}/data\")]\n    [HttpPut(\"data/{dataId}\")]\n    [HttpDelete(\"data/{dataId}\")]\n    [HttpPost]\n    [HttpPost(\"{formId}/fields\")]\n    [HttpPost(\"{formId}/publish\")]\n    [HttpGet]\n    [HttpGet(\"{formId}\")]\n    [HttpPost]\n    [HttpPost(\"{workflowId}/start\")]\n    [HttpPost(\"instances/{instanceId}/tasks\")]\n    [HttpPost(\"tasks/{taskId}/complete\")]\n    [HttpGet]\n    [HttpGet(\"my-tasks\")]\n    [HttpGet(\"instances/{instanceId}\")]","cwd":"/root/.openclaw/tang-sansheng/workspace-bingbu"},"isError":false,"timestamp":1774397166496}}
{"type":"message","id":"77ca10ca","parentId":"ab892c58","timestamp":"2026-03-25T00:06:06.809Z","message":{"role":"toolResult","toolCallId":"call_b293d95a7f0b4ab2a67d305e","toolName":"read","content":[{"type":"text","text":"using Microsoft.AspNetCore.Authorization;\nusing Microsoft.AspNetCore.Mvc;\nusing Tianyou.Application.Services;\n\nnamespace Tianyou.Api.Controllers;\n\n/// <summary>\n/// 表单管理控制器\n/// </summary>\n[ApiController]\n[Route(\"api/forms\")]\n[Authorize]\npublic class FormController : ControllerBase\n{\n    private readonly FormService _formService;\n    private readonly ILogger<FormController> _logger;\n    \n    public FormController(FormService formService, ILogger<FormController> logger)\n    {\n        _formService = formService;\n        _logger = logger;\n    }\n    \n    /// <summary>\n    /// 创建表单\n    /// </summary>\n    [HttpPost]\n    public async Task<IActionResult> CreateForm([FromBody] CreateFormRequest request)\n    {\n        try\n        {\n            var form = await _formService.CreateFormAsync(\n                request.FormName,\n                request.Description,\n                request.EntityDefinitionId);\n            \n            return Ok(new\n            {\n                success = true,\n                data = new\n                {\n                    formId = form.Id,\n                    formName = form.FormName,\n                    description = form.Description,\n                    isPublished = form.IsPublished,\n                    createdAt = form.CreatedAt\n                }\n            });\n        }\n        catch (Exception ex)\n        {\n            return BadRequest(new { success = false, message = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 添加表单字段\n    /// </summary>\n    [HttpPost(\"{formId}/fields\")]\n    public async Task<IActionResult> AddField(Guid formId, [FromBody] AddFormFieldRequest request)\n    {\n        try\n        {\n            var field = await _formService.AddFormFieldAsync(\n                formId,\n                request.FieldName,\n                request.FieldType,\n                request.Label,\n                request.Placeholder,\n                request.DefaultValue,\n                request.IsRequired,\n                request.IsVisible,\n                request.IsEditable,\n                request.ValidationRules,\n                request.FieldConfig);\n            \n            return Ok(new\n            {\n                success = true,\n                data = new\n                {\n                    fieldId = field.Id,\n                    fieldName = field.FieldName,\n                    fieldType = field.FieldType,\n                    label = field.Label\n                }\n            });\n        }\n        catch (Exception ex)\n        {\n            return BadRequest(new { success = false, message = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 发布表单\n    /// </summary>\n    [HttpPost(\"{formId}/publish\")]\n    public async Task<IActionResult> PublishForm(Guid formId)\n    {\n        try\n        {\n            var form = await _formService.PublishFormAsync(formId);\n            \n            return Ok(new\n            {\n                success = true,\n                data = new\n                {\n                    formId = form.Id,\n                    isPublished = form.IsPublished,\n                    updatedAt = form.UpdatedAt\n                }\n            });\n        }\n        catch (Exception ex)\n        {\n            return BadRequest(new { success = false, message = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 获取表单列表\n    /// </summary>\n    [HttpGet]\n    public async Task<IActionResult> GetForms()\n    {\n        var forms = await _formService.GetFormsAsync();\n        \n        return Ok(new\n        {\n            success = true,\n            data = forms.Select(f => new\n            {\n                formId = f.Id,\n                formName = f.FormName,\n                description = f.Description,\n                isPublished = f.IsPublished,\n                fieldCount = f.Fields.Count,\n                createdAt = f.CreatedAt\n            })\n        });\n    }\n    \n    /// <summary>\n    /// 获取表单详情\n    /// </summary>\n    [HttpGet(\"{formId}\")]\n    public async Task<IActionResult> GetForm(Guid formId)\n    {\n        var form = await _formService.GetFormAsync(formId);\n        \n        if (form == null)\n        {\n            return NotFound(new { success = false, message = \"表单不存在\" });\n        }\n        \n        return Ok(new\n        {\n            success = true,\n            data = new\n            {\n                formId = form.Id,\n                formName = form.FormName,\n                description = form.Description,\n                isPublished = form.IsPublished,\n                fields = form.Fields.Select(f => new\n                {\n                    fieldId = f.Id,\n                    fieldName = f.FieldName,\n                    fieldType = f.FieldType,\n                    label = f.Label,\n                    isRequired = f.IsRequired,\n                    isVisible = f.IsVisible\n                })\n            }\n        });\n    }\n}\n\n// DTO类\npublic record CreateFormRequest(string FormName, string? Description, Guid? EntityDefinitionId);\npublic record AddFormFieldRequest(\n    string FieldName,\n    string FieldType,\n    string? Label,\n    string? Placeholder,\n    string? DefaultValue,\n    bool IsRequired = false,\n    bool IsVisible = true,\n    bool IsEditable = true,\n    string? ValidationRules = null,\n    string? FieldConfig = null);"}],"isError":false,"timestamp":1774397166527}}
{"type":"message","id":"a463ad2c","parentId":"77ca10ca","timestamp":"2026-03-25T00:10:05.780Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，现在我了解了API结构。让我开始创建13个页面。我会快速创建它们，确保：\n\n1. 使用Bootstrap 5样式\n2. 调用已有的API接口\n3. 包含基本的CRUD功能\n4. 简化实现，确保无语法错误\n\n让我开始批量创建页面。","thinkingSignature":"reasoning_content"},{"type":"text","text":"现在开始快速创建13个页面！"},{"type":"toolCall","id":"call_17bb4250908844489b0baae6","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/EntityDetail.razor","content":"@page \"/entities/{EntityId:guid}\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>📋 实体详情</h3>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (entity == null)\n{\n    <div class=\"alert alert-warning\">实体不存在</div>\n}\nelse\n{\n    <div class=\"row\">\n        <div class=\"col-md-8\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h5>@entity.EntityName</h5>\n                </div>\n                <div class=\"card-body\">\n                    <table class=\"table table-borderless\">\n                        <tr>\n                            <th width=\"150\">表名：</th>\n                            <td><code>@entity.TableName</code></td>\n                        </tr>\n                        <tr>\n                            <th>描述：</th>\n                            <td>@entity.Description</td>\n                        </tr>\n                        <tr>\n                            <th>创建时间：</th>\n                            <td>@entity.CreatedAt.ToString(\"yyyy-MM-dd HH:mm:ss\")</td>\n                        </tr>\n                    </table>\n                </div>\n            </div>\n\n            @if (fields != null && fields.Count > 0)\n            {\n                <div class=\"card mt-3\">\n                    <div class=\"card-header\">\n                        <h5>字段列表 (@fields.Count)</h5>\n                    </div>\n                    <div class=\"card-body\">\n                        <table class=\"table table-striped\">\n                            <thead>\n                                <tr>\n                                    <th>字段名</th>\n                                    <th>类型</th>\n                                    <th>必填</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                @foreach (var field in fields)\n                                {\n                                    <tr>\n                                        <td>@field.FieldName</td>\n                                        <td><span class=\"badge bg-info\">@field.FieldType</span></td>\n                                        <td>@(field.IsRequired ? \"✓\" : \"-\")</td>\n                                    </tr>\n                                }\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            }\n        </div>\n    </div>\n\n    <div class=\"mt-3\">\n        <button class=\"btn btn-secondary\" @onclick=\"GoBack\">← 返回列表</button>\n        <button class=\"btn btn-success\" @onclick=\"ManageData\">管理数据</button>\n    </div>\n}\n\n@code {\n    [Parameter]\n    public Guid EntityId { get; set; }\n\n    private EntityDto? entity;\n    private List<FieldDto> fields = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadEntity();\n    }\n\n    private async Task LoadEntity()\n    {\n        loading = true;\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<EntityDto>>($\"api/entities/{EntityId}\");\n            if (response?.Success == true)\n            {\n                entity = response.Data;\n            }\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void GoBack()\n    {\n        NavManager.NavigateTo(\"/entities\");\n    }\n\n    private void ManageData()\n    {\n        NavManager.NavigateTo($\"/entities/{EntityId}/data\");\n    }\n\n    public class EntityDto\n    {\n        public Guid EntityId { get; set; }\n        public string EntityName { get; set; } = \"\";\n        public string TableName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class FieldDto\n    {\n        public string FieldName { get; set; } = \"\";\n        public string FieldType { get; set; } = \"\";\n        public bool IsRequired { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_6f7c4a05054a4a3cbaf73601","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/EntityData.razor","content":"@page \"/entities/{EntityId:guid}/data\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>📊 实体数据管理</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-primary\" @onclick=\"CreateData\">➕ 新增数据</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadData\">🔄 刷新</button>\n    <button class=\"btn btn-outline-secondary\" @onclick=\"GoBack\">← 返回</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (dataList == null || dataList.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无数据</div>\n}\nelse\n{\n    <div class=\"table-responsive\">\n        <table class=\"table table-striped table-hover\">\n            <thead class=\"table-dark\">\n                <tr>\n                    <th>ID</th>\n                    <th>数据内容</th>\n                    <th>创建时间</th>\n                    <th>操作</th>\n                </tr>\n            </thead>\n            <tbody>\n                @foreach (var item in dataList)\n                {\n                    <tr>\n                        <td><code>@item.DataId.ToString()[..8]...</code></td>\n                        <td>@item.DataContent</td>\n                        <td>@item.CreatedAt.ToString(\"yyyy-MM-dd HH:mm\")</td>\n                        <td>\n                            <button class=\"btn btn-sm btn-warning\" @onclick=\"() => EditData(item.DataId)\">编辑</button>\n                            <button class=\"btn btn-sm btn-danger\" @onclick=\"() => DeleteData(item.DataId)\">删除</button>\n                        </td>\n                    </tr>\n                }\n            </tbody>\n        </table>\n    </div>\n}\n\n@if (showForm)\n{\n    <div class=\"modal\" style=\"display: block; background: rgba(0,0,0,0.5);\">\n        <div class=\"modal-dialog\">\n            <div class=\"modal-content\">\n                <div class=\"modal-header\">\n                    <h5 class=\"modal-title\">@(isEditing ? \"编辑数据\" : \"新增数据\")</h5>\n                </div>\n                <div class=\"modal-body\">\n                    <div class=\"mb-3\">\n                        <label class=\"form-label\">数据内容 (JSON)</label>\n                        <textarea class=\"form-control\" @bind=\"formData\" rows=\"6\" placeholder='{\"key\": \"value\"}'></textarea>\n                    </div>\n                </div>\n                <div class=\"modal-footer\">\n                    <button class=\"btn btn-primary\" @onclick=\"SaveData\">保存</button>\n                    <button class=\"btn btn-secondary\" @onclick=\"CloseForm\">取消</button>\n                </div>\n            </div>\n        </div>\n    </div>\n}\n\n@code {\n    [Parameter]\n    public Guid EntityId { get; set; }\n\n    private List<DataDto> dataList = new();\n    private bool loading = true;\n    private bool showForm = false;\n    private bool isEditing = false;\n    private Guid editingId = Guid.Empty;\n    private string formData = \"\";\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadData();\n    }\n\n    private async Task LoadData()\n    {\n        loading = true;\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<List<DataDto>>>($\"api/entities/{EntityId}/data\");\n            if (response?.Success == true)\n            {\n                dataList = response.Data ?? new List<DataDto>();\n            }\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void CreateData()\n    {\n        isEditing = false;\n        editingId = Guid.Empty;\n        formData = \"\";\n        showForm = true;\n    }\n\n    private void EditData(Guid dataId)\n    {\n        var item = dataList.FirstOrDefault(d => d.DataId == dataId);\n        if (item != null)\n        {\n            isEditing = true;\n            editingId = dataId;\n            formData = item.DataContent;\n            showForm = true;\n        }\n    }\n\n    private async Task SaveData()\n    {\n        try\n        {\n            if (isEditing)\n            {\n                await Http.PutAsJsonAsync($\"api/entities/data/{editingId}\", new { DataContent = formData });\n            }\n            else\n            {\n                await Http.PostAsJsonAsync($\"api/entities/{EntityId}/data\", new { DataContent = formData });\n            }\n            showForm = false;\n            await LoadData();\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"保存失败: {ex.Message}\");\n        }\n    }\n\n    private async Task DeleteData(Guid dataId)\n    {\n        if (await JS.InvokeAsync<bool>(\"confirm\", \"确定删除此数据吗？\"))\n        {\n            try\n            {\n                await Http.DeleteAsync($\"api/entities/data/{dataId}\");\n                await LoadData();\n            }\n            catch (Exception ex)\n            {\n                Console.WriteLine($\"删除失败: {ex.Message}\");\n            }\n        }\n    }\n\n    private void CloseForm()\n    {\n        showForm = false;\n    }\n\n    private void GoBack()\n    {\n        NavManager.NavigateTo($\"/entities/{EntityId}\");\n    }\n\n    [Inject]\n    private IJSRuntime JS { get; set; } = null!;\n\n    public class DataDto\n    {\n        public Guid DataId { get; set; }\n        public string DataContent { get; set; } = \"\";\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_e379fde8a55140c09b569fa1","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/FormList.razor","content":"@page \"/forms\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>📝 表单管理</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-primary\" @onclick=\"CreateForm\">➕ 创建表单</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadForms\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (forms == null || forms.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无表单，请点击\"创建表单\"按钮添加</div>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var form in forms)\n        {\n            <div class=\"col-md-4 mb-3\">\n                <div class=\"card\">\n                    <div class=\"card-body\">\n                        <h5 class=\"card-title\">@form.FormName</h5>\n                        <p class=\"card-text text-muted\">@(form.Description ?? \"无描述\")</p>\n                        <p>\n                            <span class=\"badge @(form.IsPublished ? \"bg-success\" : \"bg-secondary\")\">\n                                @(form.IsPublished ? \"已发布\" : \"草稿\")\n                            </span>\n                            <span class=\"badge bg-info\">@form.FieldCount 字段</span>\n                        </p>\n                        <button class=\"btn btn-sm btn-primary\" @onclick=\"() => DesignForm(form.FormId)\">设计</button>\n                        <button class=\"btn btn-sm btn-info\" @onclick=\"() => PreviewForm(form.FormId)\">预览</button>\n                    </div>\n                    <div class=\"card-footer text-muted\">\n                        创建于 @form.CreatedAt.ToString(\"yyyy-MM-dd\")\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n@code {\n    private List<FormDto> forms = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadForms();\n    }\n\n    private async Task LoadForms()\n    {\n        loading = true;\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<List<FormDto>>>(\"api/forms\");\n            if (response?.Success == true)\n            {\n                forms = response.Data ?? new List<FormDto>();\n            }\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void CreateForm()\n    {\n        NavManager.NavigateTo(\"/forms/create\");\n    }\n\n    private void DesignForm(Guid formId)\n    {\n        NavManager.NavigateTo($\"/forms/{formId}/design\");\n    }\n\n    private void PreviewForm(Guid formId)\n    {\n        NavManager.NavigateTo($\"/forms/{formId}/preview\");\n    }\n\n    public class FormDto\n    {\n        public Guid FormId { get; set; }\n        public string FormName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsPublished { get; set; }\n        public int FieldCount { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_85047e526e7c4d9f8d97ecfd","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/FormDesigner.razor","content":"@page \"/forms/{FormId:guid}/design\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>🎨 表单设计器</h3>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse\n{\n    <div class=\"row\">\n        <div class=\"col-md-4\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h5>字段工具箱</h5>\n                </div>\n                <div class=\"card-body\">\n                    <div class=\"d-grid gap-2\">\n                        <button class=\"btn btn-outline-primary\" @onclick='() => AddField(\"text\")'>文本框</button>\n                        <button class=\"btn btn-outline-primary\" @onclick='() => AddField(\"number\")'>数字框</button>\n                        <button class=\"btn btn-outline-primary\" @onclick='() => AddField(\"select\")'>下拉框</button>\n                        <button class=\"btn btn-outline-primary\" @onclick='() => AddField(\"date\")'>日期选择</button>\n                        <button class=\"btn btn-outline-primary\" @onclick='() => AddField(\"textarea\")'>多行文本</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"col-md-8\">\n            <div class=\"card\">\n                <div class=\"card-header d-flex justify-content-between\">\n                    <h5>表单预览</h5>\n                    <div>\n                        <button class=\"btn btn-success btn-sm\" @onclick=\"PublishForm\">发布表单</button>\n                        <button class=\"btn btn-secondary btn-sm\" @onclick=\"GoBack\">返回</button>\n                    </div>\n                </div>\n                <div class=\"card-body\">\n                    @if (fields.Count == 0)\n                    {\n                        <div class=\"text-center text-muted py-5\">\n                            从左侧工具箱选择字段类型添加\n                        </div>\n                    }\n                    else\n                    {\n                        @foreach (var field in fields)\n                        {\n                            <div class=\"mb-3 border p-3 rounded\">\n                                <div class=\"d-flex justify-content-between\">\n                                    <label class=\"form-label\">\n                                        @field.Label (@field.FieldName)\n                                        @if (field.IsRequired)\n                                        {\n                                            <span class=\"text-danger\">*</span>\n                                        }\n                                    </label>\n                                    <button class=\"btn btn-sm btn-outline-danger\" @onclick=\"() => RemoveField(field.FieldId)\">删除</button>\n                                </div>\n                                <input type=\"@field.FieldType\" class=\"form-control\" disabled placeholder=\"@field.Placeholder\" />\n                            </div>\n                        }\n                    }\n                </div>\n            </div>\n        </div>\n    </div>\n}\n\n@code {\n    [Parameter]\n    public Guid FormId { get; set; }\n\n    private List<FormFieldDto> fields = new();\n    private bool loading = true;\n    private int fieldCounter = 0;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadForm();\n    }\n\n    private async Task LoadForm()\n    {\n        loading = true;\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<FormDetailDto>>($\"api/forms/{FormId}\");\n            if (response?.Success == true && response.Data != null)\n            {\n                fields = response.Data.Fields ?? new List<FormFieldDto>();\n            }\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private async Task AddField(string fieldType)\n    {\n        fieldCounter++;\n        var fieldName = $\"field_{fieldCounter}\";\n        var label = GetFieldLabel(fieldType);\n\n        try\n        {\n            await Http.PostAsJsonAsync($\"api/forms/{FormId}/fields\", new\n            {\n                FieldName = fieldName,\n                FieldType = fieldType,\n                Label = label,\n                IsRequired = false\n            });\n            await LoadForm();\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"添加字段失败: {ex.Message}\");\n        }\n    }\n\n    private string GetFieldLabel(string fieldType) => fieldType switch\n    {\n        \"text\" => \"文本输入\",\n        \"number\" => \"数字输入\",\n        \"select\" => \"下拉选择\",\n        \"date\" => \"日期选择\",\n        \"textarea\" => \"多行文本\",\n        _ => \"字段\"\n    };\n\n    private async Task RemoveField(Guid fieldId)\n    {\n        fields.RemoveAll(f => f.FieldId == fieldId);\n        StateHasChanged();\n    }\n\n    private async Task PublishForm()\n    {\n        try\n        {\n            await Http.PostAsync($\"api/forms/{FormId}/publish\", null);\n            NavManager.NavigateTo(\"/forms\");\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"发布失败: {ex.Message}\");\n        }\n    }\n\n    private void GoBack()\n    {\n        NavManager.NavigateTo(\"/forms\");\n    }\n\n    public class FormDetailDto\n    {\n        public List<FormFieldDto>? Fields { get; set; }\n    }\n\n    public class FormFieldDto\n    {\n        public Guid FieldId { get; set; }\n        public string FieldName { get; set; } = \"\";\n        public string FieldType { get; set; } = \"\";\n        public string Label { get; set; } = \"\";\n        public string? Placeholder { get; set; }\n        public bool IsRequired { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_20492df3261543c4afc8e670","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/FormPreview.razor","content":"@page \"/forms/{FormId:guid}/preview\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>👁️ 表单预览</h3>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (form == null)\n{\n    <div class=\"alert alert-warning\">表单不存在</div>\n}\nelse\n{\n    <div class=\"row\">\n        <div class=\"col-md-8\">\n            <div class=\"card\">\n                <div class=\"card-header\">\n                    <h5>@form.FormName</h5>\n                    <small class=\"text-muted\">@form.Description</small>\n                </div>\n                <div class=\"card-body\">\n                    @if (form.Fields == null || form.Fields.Count == 0)\n                    {\n                        <div class=\"text-center text-muted py-5\">\n                            此表单暂无字段\n                        </div>\n                    }\n                    else\n                    {\n                        @foreach (var field in form.Fields)\n                        {\n                            <div class=\"mb-3\">\n                                <label class=\"form-label\">\n                                    @field.Label\n                                    @if (field.IsRequired)\n                                    {\n                                        <span class=\"text-danger\">*</span>\n                                    }\n                                </label>\n                                \n                                @if (field.FieldType == \"textarea\")\n                                {\n                                    <textarea class=\"form-control\" rows=\"3\" placeholder=\"@field.Placeholder\" disabled=\"@(!field.IsEditable)\"></textarea>\n                                }\n                                else if (field.FieldType == \"select\")\n                                {\n                                    <select class=\"form-control\" disabled=\"@(!field.IsEditable)\">\n                                        <option>请选择...</option>\n                                    </select>\n                                }\n                                else\n                                {\n                                    <input type=\"@field.FieldType\" class=\"form-control\" placeholder=\"@field.Placeholder\" disabled=\"@(!field.IsEditable)\" />\n                                }\n                            </div>\n                        }\n\n                        <div class=\"mt-4\">\n                            <button class=\"btn btn-primary\" disabled>提交</button>\n                            <button class=\"btn btn-secondary\" disabled>重置</button>\n                        </div>\n                    }\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"mt-3\">\n        <button class=\"btn btn-secondary\" @onclick=\"GoBack\">← 返回</button>\n    </div>\n}\n\n@code {\n    [Parameter]\n    public Guid FormId { get; set; }\n\n    private FormDetailDto? form;\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadForm();\n    }\n\n    private async Task LoadForm()\n    {\n        loading = true;\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<FormDetailDto>>($\"api/forms/{FormId}\");\n            if (response?.Success == true)\n            {\n                form = response.Data;\n            }\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void GoBack()\n    {\n        NavManager.NavigateTo(\"/forms\");\n    }\n\n    public class FormDetailDto\n    {\n        public string FormName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public List<FormFieldDto>? Fields { get; set; }\n    }\n\n    public class FormFieldDto\n    {\n        public string FieldName { get; set; } = \"\";\n        public string FieldType { get; set; } = \"\";\n        public string Label { get; set; } = \"\";\n        public string? Placeholder { get; set; }\n        public bool IsRequired { get; set; }\n        public bool IsEditable { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_82390743de9245b0a6452ec5","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/WorkflowList.razor","content":"@page \"/workflows\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>⚙️ 工作流管理</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-primary\" @onclick=\"CreateWorkflow\">➕ 创建工作流</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadWorkflows\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (workflows == null || workflows.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无工作流，请点击\"创建工作流\"按钮添加</div>\n}\nelse\n{\n    <div class=\"table-responsive\">\n        <table class=\"table table-striped table-hover\">\n            <thead class=\"table-dark\">\n                <tr>\n                    <th>工作流名称</th>\n                    <th>描述</th>\n                    <th>状态</th>\n                    <th>创建时间</th>\n                    <th>操作</th>\n                </tr>\n            </thead>\n            <tbody>\n                @foreach (var workflow in workflows)\n                {\n                    <tr>\n                        <td><strong>@workflow.WorkflowName</strong></td>\n                        <td>@workflow.Description</td>\n                        <td>\n                            <span class=\"badge @(workflow.IsActive ? \"bg-success\" : \"bg-secondary\")\">\n                                @(workflow.IsActive ? \"启用\" : \"禁用\")\n                            </span>\n                        </td>\n                        <td>@workflow.CreatedAt.ToString(\"yyyy-MM-dd HH:mm\")</td>\n                        <td>\n                            <button class=\"btn btn-sm btn-primary\" @onclick=\"() => DesignWorkflow(workflow.WorkflowId)\">设计</button>\n                            <button class=\"btn btn-sm btn-success\" @onclick=\"() => StartWorkflow(workflow.WorkflowId)\">启动</button>\n                        </td>\n                    </tr>\n                }\n            </tbody>\n        </table>\n    </div>\n}\n\n@code {\n    private List<WorkflowDto> workflows = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadWorkflows();\n    }\n\n    private async Task LoadWorkflows()\n    {\n        loading = true;\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<List<WorkflowDto>>>(\"api/workflows\");\n            if (response?.Success == true)\n            {\n                workflows = response.Data ?? new List<WorkflowDto>();\n            }\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void CreateWorkflow()\n    {\n        NavManager.NavigateTo(\"/workflows/create\");\n    }\n\n    private void DesignWorkflow(Guid workflowId)\n    {\n        NavManager.NavigateTo($\"/workflows/{workflowId}/design\");\n    }\n\n    private async Task StartWorkflow(Guid workflowId)\n    {\n        try\n        {\n            await Http.PostAsync($\"api/workflows/{workflowId}/start\", null);\n            NavManager.NavigateTo(\"/workflows/tasks\");\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"启动失败: {ex.Message}\");\n        }\n    }\n\n    public class WorkflowDto\n    {\n        public Guid WorkflowId { get; set; }\n        public string WorkflowName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public bool IsActive { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_108bd1f61c904177927cd75b","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/WorkflowDesigner.razor","content":"@page \"/workflows/{WorkflowId:guid}/design\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>🔧 工作流设计器</h3>\n\n<div class=\"row\">\n    <div class=\"col-md-3\">\n        <div class=\"card\">\n            <div class=\"card-header\">\n                <h5>节点工具箱</h5>\n            </div>\n            <div class=\"card-body\">\n                <div class=\"d-grid gap-2\">\n                    <button class=\"btn btn-outline-success\" @onclick='() => AddNode(\"start\")'>开始节点</button>\n                    <button class=\"btn btn-outline-primary\" @onclick='() => AddNode(\"task\")'>任务节点</button>\n                    <button class=\"btn btn-outline-info\" @onclick='() => AddNode(\"approve\")'>审批节点</button>\n                    <button class=\"btn btn-outline-warning\" @onclick='() => AddNode(\"condition\")'>条件节点</button>\n                    <button class=\"btn btn-outline-danger\" @onclick='() => AddNode(\"end\")'>结束节点</button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"col-md-9\">\n        <div class=\"card\">\n            <div class=\"card-header d-flex justify-content-between\">\n                <h5>流程设计</h5>\n                <div>\n                    <button class=\"btn btn-success btn-sm\" @onclick=\"SaveWorkflow\">保存</button>\n                    <button class=\"btn btn-secondary btn-sm\" @onclick=\"GoBack\">返回</button>\n                </div>\n            </div>\n            <div class=\"card-body\">\n                <div class=\"workflow-canvas\" style=\"min-height: 400px; background: #f8f9fa; border: 2px dashed #dee2e6; border-radius: 4px; padding: 20px;\">\n                    @if (nodes.Count == 0)\n                    {\n                        <div class=\"text-center text-muted py-5\">\n                            从左侧工具箱选择节点类型添加\n                        </div>\n                    }\n                    else\n                    {\n                        <div class=\"row\">\n                            @foreach (var node in nodes)\n                            {\n                                <div class=\"col-md-4 mb-3\">\n                                    <div class=\"card @GetNodeCardClass(node.NodeType)\">\n                                        <div class=\"card-body text-center\">\n                                            <h6>@GetNodeLabel(node.NodeType)</h6>\n                                            <small>@node.NodeName</small>\n                                            <button class=\"btn btn-sm btn-outline-danger mt-2\" @onclick=\"() => RemoveNode(node.NodeId)\">删除</button>\n                                        </div>\n                                    </div>\n                                </div>\n                            }\n                        </div>\n                    }\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n@code {\n    [Parameter]\n    public Guid WorkflowId { get; set; }\n\n    private List<NodeDto> nodes = new();\n    private int nodeCounter = 0;\n\n    private void AddNode(string nodeType)\n    {\n        nodeCounter++;\n        nodes.Add(new NodeDto\n        {\n            NodeId = Guid.NewGuid(),\n            NodeType = nodeType,\n            NodeName = $\"{GetNodeLabel(nodeType)} {nodeCounter}\"\n        });\n    }\n\n    private string GetNodeLabel(string nodeType) => nodeType switch\n    {\n        \"start\" => \"开始\",\n        \"task\" => \"任务\",\n        \"approve\" => \"审批\",\n        \"condition\" => \"条件\",\n        \"end\" => \"结束\",\n        _ => \"节点\"\n    };\n\n    private string GetNodeCardClass(string nodeType) => nodeType switch\n    {\n        \"start\" => \"border-success\",\n        \"task\" => \"border-primary\",\n        \"approve\" => \"border-info\",\n        \"condition\" => \"border-warning\",\n        \"end\" => \"border-danger\",\n        _ => \"\"\n    };\n\n    private void RemoveNode(Guid nodeId)\n    {\n        nodes.RemoveAll(n => n.NodeId == nodeId);\n    }\n\n    private async Task SaveWorkflow()\n    {\n        try\n        {\n            await Http.PostAsJsonAsync($\"api/workflows/{WorkflowId}/nodes\", nodes);\n            NavManager.NavigateTo(\"/workflows\");\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"保存失败: {ex.Message}\");\n        }\n    }\n\n    private void GoBack()\n    {\n        NavManager.NavigateTo(\"/workflows\");\n    }\n\n    public class NodeDto\n    {\n        public Guid NodeId { get; set; }\n        public string NodeType { get; set; } = \"\";\n        public string NodeName { get; set; } = \"\";\n    }\n}\n"}},{"type":"toolCall","id":"call_d637196fe26b40edb10c45ac","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/WorkflowTasks.razor","content":"@page \"/workflows/tasks\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>📋 我的待办任务</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-secondary\" @onclick=\"LoadTasks\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (tasks == null || tasks.Count == 0)\n{\n    <div class=\"alert alert-success\">\n        ✅ 暂无待办任务\n    </div>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var task in tasks)\n        {\n            <div class=\"col-md-6 mb-3\">\n                <div class=\"card\">\n                    <div class=\"card-body\">\n                        <h5 class=\"card-title\">@task.TaskName</h5>\n                        <p class=\"card-text text-muted\">@task.WorkflowName</p>\n                        <div class=\"mb-2\">\n                            <span class=\"badge @GetPriorityBadge(task.Priority)\">@task.Priority</span>\n                            <span class=\"badge bg-secondary\">@task.Status</span>\n                        </div>\n                        <p class=\"card-text\">\n                            <small class=\"text-muted\">创建于 @task.CreatedAt.ToString(\"yyyy-MM-dd HH:mm\")</small>\n                        </p>\n                        <button class=\"btn btn-primary btn-sm\" @onclick=\"() => CompleteTask(task.TaskId)\">完成</button>\n                        <button class=\"btn btn-info btn-sm\" @onclick=\"() => ViewDetail(task.InstanceId)\">查看详情</button>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n@code {\n    private List<TaskDto> tasks = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadTasks();\n    }\n\n    private async Task LoadTasks()\n    {\n        loading = true;\n        try\n        {\n            var response = await Http.GetFromJsonAsync<ApiResponse<List<TaskDto>>>(\"api/workflows/my-tasks\");\n            if (response?.Success == true)\n            {\n                tasks = response.Data ?? new List<TaskDto>();\n            }\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private async Task CompleteTask(Guid taskId)\n    {\n        try\n        {\n            await Http.PostAsync($\"api/workflows/tasks/{taskId}/complete\", null);\n            await LoadTasks();\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"完成任务失败: {ex.Message}\");\n        }\n    }\n\n    private void ViewDetail(Guid instanceId)\n    {\n        NavManager.NavigateTo($\"/workflows/instances/{instanceId}\");\n    }\n\n    private string GetPriorityBadge(string priority) => priority switch\n    {\n        \"高\" => \"bg-danger\",\n        \"中\" => \"bg-warning\",\n        \"低\" => \"bg-info\",\n        _ => \"bg-secondary\"\n    };\n\n    public class TaskDto\n    {\n        public Guid TaskId { get; set; }\n        public string TaskName { get; set; } = \"\";\n        public string WorkflowName { get; set; } = \"\";\n        public string Priority { get; set; } = \"中\";\n        public string Status { get; set; } = \"\";\n        public DateTime CreatedAt { get; set; }\n        public Guid InstanceId { get; set; }\n    }\n\n    public class ApiResponse<T>\n    {\n        public bool Success { get; set; }\n        public T? Data { get; set; }\n        public string? Message { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_311d3be07e064531a20d3eec","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/UserManagement.razor","content":"@page \"/users\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>👥 用户管理</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-primary\" @onclick=\"CreateUser\">➕ 新增用户</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadUsers\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (users == null || users.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无用户数据</div>\n}\nelse\n{\n    <div class=\"table-responsive\">\n        <table class=\"table table-striped table-hover\">\n            <thead class=\"table-dark\">\n                <tr>\n                    <th>用户名</th>\n                    <th>邮箱</th>\n                    <th>角色</th>\n                    <th>状态</th>\n                    <th>创建时间</th>\n                    <th>操作</th>\n                </tr>\n            </thead>\n            <tbody>\n                @foreach (var user in users)\n                {\n                    <tr>\n                        <td><strong>@user.Username</strong></td>\n                        <td>@user.Email</td>\n                        <td><span class=\"badge bg-primary\">@user.Role</span></td>\n                        <td>\n                            <span class=\"badge @(user.IsActive ? \"bg-success\" : \"bg-secondary\")\">\n                                @(user.IsActive ? \"激活\" : \"禁用\")\n                            </span>\n                        </td>\n                        <td>@user.CreatedAt.ToString(\"yyyy-MM-dd HH:mm\")</td>\n                        <td>\n                            <button class=\"btn btn-sm btn-warning\" @onclick=\"() => EditUser(user.UserId)\">编辑</button>\n                            <button class=\"btn btn-sm btn-danger\" @onclick=\"() => DeleteUser(user.UserId)\">删除</button>\n                        </td>\n                    </tr>\n                }\n            </tbody>\n        </table>\n    </div>\n}\n\n@code {\n    private List<UserDto> users = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadUsers();\n    }\n\n    private async Task LoadUsers()\n    {\n        loading = true;\n        try\n        {\n            // 临时模拟数据（实际应调用API）\n            users = new List<UserDto>\n            {\n                new UserDto { UserId = Guid.NewGuid(), Username = \"admin\", Email = \"admin@example.com\", Role = \"管理员\", IsActive = true, CreatedAt = DateTime.Now.AddDays(-30) },\n                new UserDto { UserId = Guid.NewGuid(), Username = \"user1\", Email = \"user1@example.com\", Role = \"普通用户\", IsActive = true, CreatedAt = DateTime.Now.AddDays(-10) }\n            };\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void CreateUser()\n    {\n        NavManager.NavigateTo(\"/users/create\");\n    }\n\n    private void EditUser(Guid userId)\n    {\n        NavManager.NavigateTo($\"/users/{userId}/edit\");\n    }\n\n    private async Task DeleteUser(Guid userId)\n    {\n        users.RemoveAll(u => u.UserId == userId);\n        StateHasChanged();\n    }\n\n    public class UserDto\n    {\n        public Guid UserId { get; set; }\n        public string Username { get; set; } = \"\";\n        public string Email { get; set; } = \"\";\n        public string Role { get; set; } = \"\";\n        public bool IsActive { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_20e005f467dd4fe38cd186b7","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/RoleManagement.razor","content":"@page \"/roles\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>🔑 角色管理</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-primary\" @onclick=\"CreateRole\">➕ 新增角色</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadRoles\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (roles == null || roles.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无角色数据</div>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var role in roles)\n        {\n            <div class=\"col-md-4 mb-3\">\n                <div class=\"card\">\n                    <div class=\"card-body\">\n                        <h5 class=\"card-title\">@role.RoleName</h5>\n                        <p class=\"card-text text-muted\">@role.Description</p>\n                        <div class=\"mb-2\">\n                            @foreach (var permission in role.Permissions.Take(3))\n                            {\n                                <span class=\"badge bg-info me-1\">@permission</span>\n                            }\n                            @if (role.Permissions.Count > 3)\n                            {\n                                <span class=\"badge bg-secondary\">+@(role.Permissions.Count - 3)</span>\n                            }\n                        </div>\n                        <button class=\"btn btn-sm btn-warning\" @onclick=\"() => EditRole(role.RoleId)\">编辑</button>\n                        <button class=\"btn btn-sm btn-danger\" @onclick=\"() => DeleteRole(role.RoleId)\">删除</button>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n@code {\n    private List<RoleDto> roles = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadRoles();\n    }\n\n    private async Task LoadRoles()\n    {\n        loading = true;\n        try\n        {\n            // 临时模拟数据\n            roles = new List<RoleDto>\n            {\n                new RoleDto \n                { \n                    RoleId = Guid.NewGuid(), \n                    RoleName = \"管理员\", \n                    Description = \"系统管理员，拥有所有权限\",\n                    Permissions = new List<string> { \"用户管理\", \"角色管理\", \"系统配置\", \"数据管理\" },\n                    CreatedAt = DateTime.Now.AddDays(-30)\n                },\n                new RoleDto \n                { \n                    RoleId = Guid.NewGuid(), \n                    RoleName = \"普通用户\", \n                    Description = \"普通用户，基础权限\",\n                    Permissions = new List<string> { \"查看数据\", \"提交表单\" },\n                    CreatedAt = DateTime.Now.AddDays(-30)\n                }\n            };\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void CreateRole()\n    {\n        NavManager.NavigateTo(\"/roles/create\");\n    }\n\n    private void EditRole(Guid roleId)\n    {\n        NavManager.NavigateTo($\"/roles/{roleId}/edit\");\n    }\n\n    private async Task DeleteRole(Guid roleId)\n    {\n        roles.RemoveAll(r => r.RoleId == roleId);\n        StateHasChanged();\n    }\n\n    public class RoleDto\n    {\n        public Guid RoleId { get; set; }\n        public string RoleName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public List<string> Permissions { get; set; } = new();\n        public DateTime CreatedAt { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_97263d91c858481a8f92ddc8","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/PluginManagement.razor","content":"@page \"/plugins\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>🔌 插件管理</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-primary\" @onclick=\"UploadPlugin\">📤 上传插件</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadPlugins\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (plugins == null || plugins.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无插件</div>\n}\nelse\n{\n    <div class=\"row\">\n        @foreach (var plugin in plugins)\n        {\n            <div class=\"col-md-6 mb-3\">\n                <div class=\"card\">\n                    <div class=\"card-body\">\n                        <div class=\"d-flex justify-content-between\">\n                            <h5 class=\"card-title\">@plugin.PluginName</h5>\n                            <span class=\"badge @(plugin.IsEnabled ? \"bg-success\" : \"bg-secondary\")\">\n                                @(plugin.IsEnabled ? \"已启用\" : \"已禁用\")\n                            </span>\n                        </div>\n                        <p class=\"card-text text-muted\">@plugin.Description</p>\n                        <div class=\"mb-2\">\n                            <span class=\"badge bg-info\">@plugin.Version</span>\n                            <span class=\"badge bg-primary\">@plugin.Author</span>\n                        </div>\n                        <p class=\"card-text\">\n                            <small class=\"text-muted\">安装于 @plugin.InstalledAt.ToString(\"yyyy-MM-dd\")</small>\n                        </p>\n                        <div class=\"btn-group btn-group-sm\">\n                            <button class=\"btn btn-outline-primary\" @onclick=\"() => ConfigurePlugin(plugin.PluginId)\">配置</button>\n                            <button class=\"btn btn-outline-warning\" @onclick=\"() => TogglePlugin(plugin.PluginId)\">\n                                @(plugin.IsEnabled ? \"禁用\" : \"启用\")\n                            </button>\n                            <button class=\"btn btn-outline-danger\" @onclick=\"() => UninstallPlugin(plugin.PluginId)\">卸载</button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n@code {\n    private List<PluginDto> plugins = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadPlugins();\n    }\n\n    private async Task LoadPlugins()\n    {\n        loading = true;\n        try\n        {\n            // 临时模拟数据\n            plugins = new List<PluginDto>\n            {\n                new PluginDto \n                { \n                    PluginId = Guid.NewGuid(), \n                    PluginName = \"数据导入插件\", \n                    Description = \"支持Excel、CSV数据批量导入\",\n                    Version = \"1.0.0\",\n                    Author = \"Tianyou\",\n                    IsEnabled = true,\n                    InstalledAt = DateTime.Now.AddDays(-15)\n                },\n                new PluginDto \n                { \n                    PluginId = Guid.NewGuid(), \n                    PluginName = \"报表生成器\", \n                    Description = \"自动生成统计报表\",\n                    Version = \"2.1.0\",\n                    Author = \"Tianyou\",\n                    IsEnabled = false,\n                    InstalledAt = DateTime.Now.AddDays(-10)\n                }\n            };\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void UploadPlugin()\n    {\n        NavManager.NavigateTo(\"/plugins/upload\");\n    }\n\n    private void ConfigurePlugin(Guid pluginId)\n    {\n        NavManager.NavigateTo($\"/plugins/{pluginId}/config\");\n    }\n\n    private async Task TogglePlugin(Guid pluginId)\n    {\n        var plugin = plugins.FirstOrDefault(p => p.PluginId == pluginId);\n        if (plugin != null)\n        {\n            plugin.IsEnabled = !plugin.IsEnabled;\n            StateHasChanged();\n        }\n    }\n\n    private async Task UninstallPlugin(Guid pluginId)\n    {\n        plugins.RemoveAll(p => p.PluginId == pluginId);\n        StateHasChanged();\n    }\n\n    public class PluginDto\n    {\n        public Guid PluginId { get; set; }\n        public string PluginName { get; set; } = \"\";\n        public string? Description { get; set; }\n        public string Version { get; set; } = \"\";\n        public string Author { get; set; } = \"\";\n        public bool IsEnabled { get; set; }\n        public DateTime InstalledAt { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_f2acfe4e03644e2681eb6d6d","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/TenantManagement.razor","content":"@page \"/tenants\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>🏢 租户管理</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-primary\" @onclick=\"CreateTenant\">➕ 新增租户</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadTenants\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (tenants == null || tenants.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无租户数据</div>\n}\nelse\n{\n    <div class=\"table-responsive\">\n        <table class=\"table table-striped table-hover\">\n            <thead class=\"table-dark\">\n                <tr>\n                    <th>租户名称</th>\n                    <th>联系人</th>\n                    <th>用户数</th>\n                    <th>状态</th>\n                    <th>到期时间</th>\n                    <th>操作</th>\n                </tr>\n            </thead>\n            <tbody>\n                @foreach (var tenant in tenants)\n                {\n                    <tr>\n                        <td><strong>@tenant.TenantName</strong></td>\n                        <td>@tenant.ContactName</td>\n                        <td><span class=\"badge bg-info\">@tenant.UserCount</span></td>\n                        <td>\n                            <span class=\"badge @(tenant.IsActive ? \"bg-success\" : \"bg-secondary\")\">\n                                @(tenant.IsActive ? \"正常\" : \"停用\")\n                            </span>\n                        </td>\n                        <td>@tenant.ExpireAt.ToString(\"yyyy-MM-dd\")</td>\n                        <td>\n                            <button class=\"btn btn-sm btn-info\" @onclick=\"() => ViewTenant(tenant.TenantId)\">查看</button>\n                            <button class=\"btn btn-sm btn-warning\" @onclick=\"() => EditTenant(tenant.TenantId)\">编辑</button>\n                            <button class=\"btn btn-sm btn-danger\" @onclick=\"() => DeleteTenant(tenant.TenantId)\">删除</button>\n                        </td>\n                    </tr>\n                }\n            </tbody>\n        </table>\n    </div>\n}\n\n@code {\n    private List<TenantDto> tenants = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadTenants();\n    }\n\n    private async Task LoadTenants()\n    {\n        loading = true;\n        try\n        {\n            // 临时模拟数据\n            tenants = new List<TenantDto>\n            {\n                new TenantDto \n                { \n                    TenantId = Guid.NewGuid(), \n                    TenantName = \"天佑科技\", \n                    ContactName = \"张经理\",\n                    UserCount = 50,\n                    IsActive = true,\n                    ExpireAt = DateTime.Now.AddYears(1),\n                    CreatedAt = DateTime.Now.AddDays(-100)\n                },\n                new TenantDto \n                { \n                    TenantId = Guid.NewGuid(), \n                    TenantName = \"测试公司\", \n                    ContactName = \"李总\",\n                    UserCount = 10,\n                    IsActive = true,\n                    ExpireAt = DateTime.Now.AddMonths(3),\n                    CreatedAt = DateTime.Now.AddDays(-30)\n                }\n            };\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private void CreateTenant()\n    {\n        NavManager.NavigateTo(\"/tenants/create\");\n    }\n\n    private void ViewTenant(Guid tenantId)\n    {\n        NavManager.NavigateTo($\"/tenants/{tenantId}\");\n    }\n\n    private void EditTenant(Guid tenantId)\n    {\n        NavManager.NavigateTo($\"/tenants/{tenantId}/edit\");\n    }\n\n    private async Task DeleteTenant(Guid tenantId)\n    {\n        tenants.RemoveAll(t => t.TenantId == tenantId);\n        StateHasChanged();\n    }\n\n    public class TenantDto\n    {\n        public Guid TenantId { get; set; }\n        public string TenantName { get; set; } = \"\";\n        public string ContactName { get; set; } = \"\";\n        public int UserCount { get; set; }\n        public bool IsActive { get; set; }\n        public DateTime ExpireAt { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n}\n"}},{"type":"toolCall","id":"call_83647b1ac4e84413bc3251af","name":"write","arguments":{"path":"/root/.openclaw/tang-sansheng/projects/tianyou-platform/frontend/Tianyou.Web/Pages/NotificationList.razor","content":"@page \"/notifications\"\n@attribute [Authorize]\n@inject HttpClient Http\n@inject NavigationManager NavManager\n\n<h3>🔔 通知中心</h3>\n\n<div class=\"mb-3\">\n    <button class=\"btn btn-success\" @onclick=\"MarkAllRead\">✓ 全部已读</button>\n    <button class=\"btn btn-secondary\" @onclick=\"LoadNotifications\">🔄 刷新</button>\n</div>\n\n@if (loading)\n{\n    <div class=\"text-center\">\n        <div class=\"spinner-border\" role=\"status\">\n            <span class=\"visually-hidden\">加载中...</span>\n        </div>\n    </div>\n}\nelse if (notifications == null || notifications.Count == 0)\n{\n    <div class=\"alert alert-info\">暂无通知</div>\n}\nelse\n{\n    <div class=\"list-group\">\n        @foreach (var notification in notifications)\n        {\n            <div class=\"list-group-item list-group-item-action @(!notification.IsRead ? \"list-group-item-primary\" : \"\")\">\n                <div class=\"d-flex w-100 justify-content-between\">\n                    <h5 class=\"mb-1\">\n                        @if (!notification.IsRead)\n                        {\n                            <span class=\"badge bg-danger me-2\">新</span>\n                        }\n                        @notification.Title\n                    </h5>\n                    <small>@notification.CreatedAt.ToString(\"MM-dd HH:mm\")</small>\n                </div>\n                <p class=\"mb-1\">@notification.Content</p>\n                <div class=\"d-flex justify-content-between align-items-center\">\n                    <span class=\"badge @GetTypeBadge(notification.Type)\">@notification.Type</span>\n                    <div>\n                        <button class=\"btn btn-sm btn-outline-primary\" @onclick=\"() => MarkAsRead(notification.NotificationId)\">已读</button>\n                        <button class=\"btn btn-sm btn-outline-danger\" @onclick=\"() => DeleteNotification(notification.NotificationId)\">删除</button>\n                    </div>\n                </div>\n            </div>\n        }\n    </div>\n}\n\n@code {\n    private List<NotificationDto> notifications = new();\n    private bool loading = true;\n\n    protected override async Task OnInitializedAsync()\n    {\n        await LoadNotifications();\n    }\n\n    private async Task LoadNotifications()\n    {\n        loading = true;\n        try\n        {\n            // 临时模拟数据\n            notifications = new List<NotificationDto>\n            {\n                new NotificationDto \n                { \n                    NotificationId = Guid.NewGuid(), \n                    Title = \"新任务分配\", \n                    Content = \"您有一个新的审批任务待处理\",\n                    Type = \"任务\",\n                    IsRead = false,\n                    CreatedAt = DateTime.Now.AddHours(-2)\n                },\n                new NotificationDto \n                { \n                    NotificationId = Guid.NewGuid(), \n                    Title = \"系统升级通知\", \n                    Content = \"系统将于今晚22:00进行升级维护\",\n                    Type = \"系统\",\n                    IsRead = false,\n                    CreatedAt = DateTime.Now.AddHours(-5)\n                },\n                new NotificationDto \n                { \n                    NotificationId = Guid.NewGuid(), \n                    Title = \"审批通过\", \n                    Content = \"您的请假申请已通过审批\",\n                    Type = \"审批\",\n                    IsRead = true,\n                    CreatedAt = DateTime.Now.AddDays(-1)\n                }\n            };\n        }\n        catch (Exception ex)\n        {\n            Console.WriteLine($\"加载失败: {ex.Message}\");\n        }\n        loading = false;\n    }\n\n    private async Task MarkAsRead(Guid notificationId)\n    {\n        var notification = notifications.FirstOrDefault(n => n.NotificationId == notificationId);\n        if (notification != null)\n        {\n            notification.IsRead = true;\n            StateHasChanged();\n        }\n    }\n\n    private async Task MarkAllRead()\n    {\n        foreach (var notification in notifications)\n        {\n            notification.IsRead = true;\n        }\n        StateHasChanged();\n    }\n\n    private async Task DeleteNotification(Guid notificationId)\n    {\n        notifications.RemoveAll(n => n.NotificationId == notificationId);\n        StateHasChanged();\n    }\n\n    private string GetTypeBadge(string type) => type switch\n    {\n        \"系统\" => \"bg-warning\",\n        \"任务\" => \"bg-info\",\n        \"审批\" => \"bg-success\",\n        _ => \"bg-secondary\"\n    };\n\n    public class NotificationDto\n    {\n        public Guid NotificationId { get; set; }\n        public string Title { get; set; } = \"\";\n        public string Content { get; set; } = \"\";\n        public string Type { get; set; } = \"\";\n        public bool IsRead { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1321,"output":12689,"cacheRead":16832,"cacheWrite":0,"totalTokens":30842,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774397166809}}
