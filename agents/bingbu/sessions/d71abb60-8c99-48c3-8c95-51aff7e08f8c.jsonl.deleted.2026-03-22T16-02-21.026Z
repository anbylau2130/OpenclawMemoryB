{"type":"message","id":"cf3ccd96","parentId":"1fc637a4","timestamp":"2026-03-22T15:03:11.862Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建MetadataRepository的SqlSugar实现。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_1d41efa094904503ae387c26","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Data/SqlSugar/MetadataRepository.cs","content":"using SqlSugar;\nusing System.Text.Json;\nusing Tianyou.Core.Abstractions;\n\nnamespace Tianyou.Data.SqlSugar;\n\n/// <summary>\n/// SqlSugar 元数据仓库实现\n/// </summary>\npublic class MetadataRepository : IMetadataRepository\n{\n    private readonly ISqlSugarClient _db;\n\n    public MetadataRepository(ISqlSugarClient db)\n    {\n        _db = db;\n    }\n\n    public async Task<FormMetadata?> GetMetadataAsync(string code)\n    {\n        var entity = await _db.Queryable<FormMetadataEntity>()\n            .Where(e => e.Code == code)\n            .FirstAsync();\n\n        return entity?.ToMetadata();\n    }\n\n    public async Task<FormMetadata?> GetMetadataByIdAsync(string id)\n    {\n        var entity = await _db.Queryable<FormMetadataEntity>()\n            .Where(e => e.Id == id)\n            .FirstAsync();\n\n        return entity?.ToMetadata();\n    }\n\n    public async Task<List<FormMetadata>> GetAllMetadataAsync()\n    {\n        var entities = await _db.Queryable<FormMetadataEntity>()\n            .OrderBy(e => e.Code)\n            .ToListAsync();\n\n        return entities.Select(e => e.ToMetadata()).ToList();\n    }\n\n    public async Task<List<FormMetadata>> GetMetadataByAppAsync(string appId)\n    {\n        var entities = await _db.Queryable<FormMetadataEntity>()\n            .Where(e => e.AppId == appId)\n            .OrderBy(e => e.Code)\n            .ToListAsync();\n\n        return entities.Select(e => e.ToMetadata()).ToList();\n    }\n\n    public async Task<string> SaveMetadataAsync(FormMetadata metadata)\n    {\n        var existing = string.IsNullOrEmpty(metadata.Id)\n            ? null\n            : await _db.Queryable<FormMetadataEntity>()\n                .Where(e => e.Id == metadata.Id)\n                .FirstAsync();\n\n        if (existing != null)\n        {\n            existing.Name = metadata.Name;\n            existing.Description = metadata.Description;\n            existing.FieldsJson = JsonSerializer.Serialize(metadata.Fields);\n            existing.EntriesJson = JsonSerializer.Serialize(metadata.Entries);\n            existing.RulesJson = JsonSerializer.Serialize(metadata.Rules);\n            existing.LayoutJson = JsonSerializer.Serialize(metadata.Layout);\n            existing.PluginsJson = JsonSerializer.Serialize(metadata.Plugins);\n            existing.ExtendedPropertiesJson = JsonSerializer.Serialize(metadata.ExtendedProperties);\n            existing.ModifyTime = DateTime.UtcNow;\n            existing.Version++;\n            await _db.Updateable(existing).ExecuteCommandAsync();\n            return existing.Id;\n        }\n\n        var entity = FormMetadataEntity.FromMetadata(metadata);\n        entity.Id = Guid.NewGuid().ToString();\n        entity.CreateTime = DateTime.UtcNow;\n        entity.ModifyTime = DateTime.UtcNow;\n\n        await _db.Insertable(entity).ExecuteCommandAsync();\n        return entity.Id;\n    }\n\n    public async Task<bool> DeleteMetadataAsync(string id)\n    {\n        var count = await _db.Deleteable<FormMetadataEntity>()\n            .Where(e => e.Id == id)\n            .ExecuteCommandAsync();\n\n        return count > 0;\n    }\n\n    public async Task<bool> EnableMetadataAsync(string id, bool enabled)\n    {\n        var count = await _db.Updateable<FormMetadataEntity>()\n            .SetColumns(e => e.IsEnabled == enabled)\n            .Where(e => e.Id == id)\n            .ExecuteCommandAsync();\n\n        return count > 0;\n    }\n\n    public async Task<int> GetMetadataCountAsync(string? appId = null)\n    {\n        var query = _db.Queryable<FormMetadataEntity>();\n\n        if (!string.IsNullOrEmpty(appId))\n        {\n            query = query.Where(e => e.AppId == appId);\n        }\n\n        return await query.CountAsync();\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":42,"output":784,"cacheRead":20081,"cacheWrite":0,"totalTokens":20907,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774191781841}}
