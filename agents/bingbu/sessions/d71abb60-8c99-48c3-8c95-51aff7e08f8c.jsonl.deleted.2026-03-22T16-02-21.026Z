);\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":48,"output":380,"cacheRead":28616,"cacheWrite":0,"totalTokens":29044,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774191949467}}
