{"type":"message","id":"92d3e04d","parentId":"6f9a0394","timestamp":"2026-03-22T15:05:46.589Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建WorkflowService的控制器。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_67217adc4cff45d7806348b4","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.WorkflowService/Controllers/WorkflowController.cs","content":"using Microsoft.AspNetCore.Mvc;\nusing Tianyou.Core.Abstractions;\n\nnamespace Tianyou.WorkflowService.Controllers;\n\n[ApiController]\n[Route(\"api/[controller]\")]\npublic class WorkflowController : ControllerBase\n{\n    private readonly IWorkflowService _workflowService;\n    private readonly ILogger<WorkflowController> _logger;\n\n    public WorkflowController(IWorkflowService workflowService, ILogger<WorkflowController> logger)\n    {\n        _workflowService = workflowService;\n        _logger = logger;\n    }\n\n    [HttpGet(\"{id}\")]\n    public async Task<IActionResult> GetWorkflow(string id)\n    {\n        try\n        {\n            var workflow = await _workflowService.GetWorkflowAsync(id);\n            if (workflow == null)\n            {\n                return NotFound();\n            }\n\n            return Ok(workflow);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取工作流失败: {WorkflowId}\", id);\n            return StatusCode(500, new { message = \"获取工作流失败\" });\n        }\n    }\n\n    [HttpGet]\n    public async Task<IActionResult> GetWorkflows([FromQuery] int page = 1, [FromQuery] int pageSize = 20)\n    {\n        try\n        {\n            var workflows = await _workflowService.GetWorkflowsAsync(page, pageSize);\n            return Ok(workflows);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取工作流列表失败\");\n            return StatusCode(500, new { message = \"获取工作流列表失败\" });\n        }\n    }\n\n    [HttpPost]\n    public async Task<IActionResult> CreateWorkflow([FromBody] WorkflowDefinition workflow)\n    {\n        try\n        {\n            var id = await _workflowService.CreateWorkflowAsync(workflow);\n            return CreatedAtAction(nameof(GetWorkflow), new { id }, new { id });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"创建工作流失败\");\n            return StatusCode(500, new { message = \"创建工作流失败\" });\n        }\n    }\n\n    [HttpPut(\"{id}\")]\n    public async Task<IActionResult> UpdateWorkflow(string id, [FromBody] WorkflowDefinition workflow)\n    {\n        try\n        {\n            workflow.Id = id;\n            await _workflowService.UpdateWorkflowAsync(workflow);\n            return NoContent();\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"更新工作流失败: {WorkflowId}\", id);\n            return StatusCode(500, new { message = \"更新工作流失败\" });\n        }\n    }\n\n    [HttpDelete(\"{id}\")]\n    public async Task<IActionResult> DeleteWorkflow(string id)\n    {\n        try\n        {\n            await _workflowService.DeleteWorkflowAsync(id);\n            return NoContent();\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"删除工作流失败: {WorkflowId}\", id);\n            return StatusCode(500, new { message = \"删除工作流失败\" });\n        }\n    }\n\n    [HttpPost(\"{id}/start\")]\n    public async Task<IActionResult> StartWorkflow(string id, [FromBody] Dictionary<string, object> data)\n    {\n        try\n        {\n            var instanceId = await _workflowService.StartWorkflowAsync(id, data);\n            return Ok(new { instanceId });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"启动工作流失败: {WorkflowId}\", id);\n            return StatusCode(500, new { message = \"启动工作流失败\" });\n        }\n    }\n\n    [HttpGet(\"instances/{instanceId}\")]\n    public async Task<IActionResult> GetWorkflowInstance(string instanceId)\n    {\n        try\n        {\n            var instance = await _workflowService.GetWorkflowInstanceAsync(instanceId);\n            if (instance == null)\n            {\n                return NotFound();\n            }\n\n            return Ok(instance);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取工作流实例失败: {InstanceId}\", instanceId);\n            return StatusCode(500, new { message = \"获取工作流实例失败\" });\n        }\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":40,"output":882,"cacheRead":27357,"cacheWrite":0,"totalTokens":28279,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774191938327}}
