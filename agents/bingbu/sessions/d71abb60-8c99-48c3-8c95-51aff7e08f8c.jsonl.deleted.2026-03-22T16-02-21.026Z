{"type":"message","id":"de6a3a83","parentId":"671bee10","timestamp":"2026-03-22T15:04:41.037Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建SqlSugar的实体类定义。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_660c57cc2934448a8a3b3a4e","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Data/SqlSugar/Entities.cs","content":"using SqlSugar;\nusing System.Text.Json;\nusing Tianyou.Core.Abstractions;\n\nnamespace Tianyou.Data.SqlSugar;\n\n/// <summary>\n/// 表单元数据实体\n/// </summary>\n[SugarTable(\"form_metadata\")]\npublic class FormMetadataEntity\n{\n    [SugarColumn(IsPrimaryKey = true, Length = 50)]\n    public string Id { get; set; } = Guid.NewGuid().ToString();\n\n    [SugarColumn(Length = 100, IsNullable = false)]\n    public string Code { get; set; } = string.Empty;\n\n    [SugarColumn(Length = 200, IsNullable = false)]\n    public string Name { get; set; } = string.Empty;\n\n    [SugarColumn(Length = 500)]\n    public string? Description { get; set; }\n\n    [SugarColumn(ColumnDataType = \"varchar(50)\")]\n    public string FormType { get; set; } = \"Basic\";\n\n    [SugarColumn(Length = 50, IsNullable = false)]\n    public string AppId { get; set; } = string.Empty;\n\n    [SugarColumn(ColumnDataType = \"text\")]\n    public string FieldsJson { get; set; } = \"[]\";\n\n    [SugarColumn(ColumnDataType = \"text\")]\n    public string EntriesJson { get; set; } = \"[]\";\n\n    [SugarColumn(ColumnDataType = \"text\")]\n    public string RulesJson { get; set; } = \"[]\";\n\n    [SugarColumn(ColumnDataType = \"text\")]\n    public string LayoutJson { get; set; } = \"{}\";\n\n    [SugarColumn(ColumnDataType = \"text\")]\n    public string PluginsJson { get; set; } = \"[]\";\n\n    [SugarColumn(ColumnDataType = \"text\")]\n    public string ExtendedPropertiesJson { get; set; } = \"{}\";\n\n    public DateTime CreateTime { get; set; } = DateTime.UtcNow;\n\n    public DateTime ModifyTime { get; set; } = DateTime.UtcNow;\n\n    public int Version { get; set; } = 1;\n\n    public bool IsEnabled { get; set; } = true;\n\n    public FormMetadata ToMetadata()\n    {\n        return new FormMetadata\n        {\n            Id = Id,\n            Code = Code,\n            Name = Name,\n            Description = Description,\n            FormType = Enum.Parse<FormType>(FormType),\n            AppId = AppId,\n            Fields = JsonSerializer.Deserialize<List<FieldMetadata>>(FieldsJson) ?? new(),\n            Entries = JsonSerializer.Deserialize<List<EntryMetadata>>(EntriesJson) ?? new(),\n            Rules = JsonSerializer.Deserialize<List<FormRule>>(RulesJson) ?? new(),\n            Layout = JsonSerializer.Deserialize<FormLayout>(LayoutJson) ?? new(),\n            Plugins = JsonSerializer.Deserialize<List<PluginReference>>(PluginsJson) ?? new(),\n            ExtendedProperties = JsonSerializer.Deserialize<Dictionary<string, object>>(ExtendedPropertiesJson) ?? new(),\n            CreateTime = CreateTime,\n            ModifyTime = ModifyTime,\n            Version = Version\n        };\n    }\n\n    public static FormMetadataEntity FromMetadata(FormMetadata metadata)\n    {\n        return new FormMetadataEntity\n        {\n            Id = metadata.Id,\n            Code = metadata.Code,\n            Name = metadata.Name,\n            Description = metadata.Description,\n            FormType = metadata.FormType.ToString(),\n            AppId = metadata.AppId,\n            FieldsJson = JsonSerializer.Serialize(metadata.Fields),\n            EntriesJson = JsonSerializer.Serialize(metadata.Entries),\n            RulesJson = JsonSerializer.Serialize(metadata.Rules),\n            LayoutJson = JsonSerializer.Serialize(metadata.Layout),\n            PluginsJson = JsonSerializer.Serialize(metadata.Plugins),\n            ExtendedPropertiesJson = JsonSerializer.Serialize(metadata.ExtendedProperties),\n            CreateTime = metadata.CreateTime,\n            ModifyTime = metadata.ModifyTime,\n            Version = metadata.Version\n        };\n    }\n}\n\n/// <summary>\n/// 表单数据实体\n/// </summary>\n[SugarTable(\"form_data\")]\npublic class FormDataEntity\n{\n    [SugarColumn(IsPrimaryKey = true, Length = 50)]\n    public string Id { get; set; } = Guid.NewGuid().ToString();\n\n    [SugarColumn(Length = 50)]\n    public string FormId { get; set; } = string.Empty;\n\n    [SugarColumn(Length = 100, IsNullable = false)]\n    public string FormCode { get; set; } = string.Empty;\n\n    [SugarColumn(ColumnDataType = \"text\")]\n    public string DataJson { get; set; } = \"{}\";\n\n    [SugarColumn(Length = 50)]\n    public string Status { get; set; } = \"Draft\";\n\n    [SugarColumn(Length = 100)]\n    public string? CreatedBy { get; set; }\n\n    [SugarColumn(Length = 200)]\n    public string? CreatedByName { get; set; }\n\n    public DateTime CreateTime { get; set; } = DateTime.UtcNow;\n\n    public DateTime? ModifyTime { get; set; }\n\n    [SugarColumn(Length = 100)]\n    public string? ModifiedBy { get; set; }\n\n    [SugarColumn(Length = 200)]\n    public string? ModifiedByName { get; set; }\n}\n\n/// <summary>\n/// 插件实体\n/// </summary>\n[SugarTable(\"plugins\")]\npublic class PluginEntity\n{\n    [SugarColumn(IsPrimaryKey = true, Length = 50)]\n    public string Id { get; set; } = Guid.NewGuid().ToString();\n\n    [SugarColumn(Length = 100, IsNullable = false)]\n    public string PluginId { get; set; } = string.Empty;\n\n    [SugarColumn(Length = 200, IsNullable = false)]\n    public string Name { get; set; } = string.Empty;\n\n    [SugarColumn(Length = 500)]\n    public string? Description { get; set; }\n\n    [SugarColumn(Length = 20)]\n    public string Version { get; set; } = \"1.0.0\";\n\n    [SugarColumn(Length = 100)]\n    public string? Author { get; set; }\n\n    [SugarColumn(Length = 100)]\n    public string? Category { get; set; }\n\n    [SugarColumn(Length = 500)]\n    public string? AssemblyName { get