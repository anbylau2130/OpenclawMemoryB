           brace_count++\n                if (brace_count == 1) {\n                    function_start = current_line\n                }\n            }\n            # 检测函数结束\n            if (/}/) {\n                brace_count--\n                if (brace_count == 0 && function_start > 0) {\n                    function_lines = current_line - function_start - 1\n                    if (function_lines > 50) {\n                        print \"  ⚠️  函数超过50行: 行 \" function_start \"-\" current_line \" (\" function_lines \" 行)\"\n                        violations++\n                    }\n                    function_start = 0\n                }\n            }\n        }\n        END {\n            if (violations == 0) {\n                print \"  ✅ 所有函数均符合要求\"\n            }\n        }\n        ' \"$file\"\n    else\n        echo \"⚠️  文件不存在: $file\"\n    fi\ndone\n\necho \"\"\necho \"========================================\"\nif [ $violations -eq 0 ]; then\n    echo \"✅ 代码质量验证通过！所有函数均不超过50行\"\nelse\n    echo \"❌ 发现 $violations 个函数超过50行\"\nfi\n\necho \"\"\necho \"文件统计:\"\necho \"  SqlSugar 文件数: $(find src/Tianyou.Data/SqlSugar -name \"*.cs\" | wc -l)\"\necho \"  新服务文件数: $(find services/Tianyou.Gateway services/Tianyou.AuthService services/Tianyou.WorkflowService services/Tianyou.PluginService services/Tianyou.DataService -name \"*.cs\" | wc -l)\"\necho \"  总行数: $(cat ${files[@]} 2>/dev/null | wc -l)\"\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":216,"output":1056,"cacheRead":39529,"cacheWrite":0,"totalTokens":40801,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774192069083}}
