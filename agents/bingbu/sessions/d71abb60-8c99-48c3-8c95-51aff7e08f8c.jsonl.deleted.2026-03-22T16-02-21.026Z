{"type":"message","id":"7e2fd3b2","parentId":"18a69a12","timestamp":"2026-03-22T15:06:04.421Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建PluginService的控制器。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_ced2fb18b1a646a39dce40bd","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.PluginService/Controllers/PluginController.cs","content":"using Microsoft.AspNetCore.Mvc;\nusing Tianyou.Core.Abstractions;\n\nnamespace Tianyou.PluginService.Controllers;\n\n[ApiController]\n[Route(\"api/[controller]\")]\npublic class PluginController : ControllerBase\n{\n    private readonly IPluginManager _pluginManager;\n    private readonly ILogger<PluginController> _logger;\n\n    public PluginController(IPluginManager pluginManager, ILogger<PluginController> logger)\n    {\n        _pluginManager = pluginManager;\n        _logger = logger;\n    }\n\n    [HttpGet]\n    public async Task<IActionResult> GetPlugins([FromQuery] bool? enabled = null)\n    {\n        try\n        {\n            var plugins = await _pluginManager.GetPluginsAsync(enabled);\n            return Ok(plugins);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取插件列表失败\");\n            return StatusCode(500, new { message = \"获取插件列表失败\" });\n        }\n    }\n\n    [HttpGet(\"{pluginId}\")]\n    public async Task<IActionResult> GetPlugin(string pluginId)\n    {\n        try\n        {\n            var plugin = await _pluginManager.GetPluginAsync(pluginId);\n            if (plugin == null)\n            {\n                return NotFound();\n            }\n\n            return Ok(plugin);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"获取插件失败\" });\n        }\n    }\n\n    [HttpPost]\n    public async Task<IActionResult> RegisterPlugin([FromBody] PluginMetadata plugin)\n    {\n        try\n        {\n            await _pluginManager.RegisterPluginAsync(plugin);\n            return Ok(new { message = \"插件注册成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"注册插件失败\");\n            return StatusCode(500, new { message = \"注册插件失败\" });\n        }\n    }\n\n    [HttpDelete(\"{pluginId}\")]\n    public async Task<IActionResult> UnregisterPlugin(string pluginId)\n    {\n        try\n        {\n            await _pluginManager.UnregisterPluginAsync(pluginId);\n            return Ok(new { message = \"插件卸载成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"卸载插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"卸载插件失败\" });\n        }\n    }\n\n    [HttpPost(\"{pluginId}/enable\")]\n    public async Task<IActionResult> EnablePlugin(string pluginId)\n    {\n        try\n        {\n            await _pluginManager.EnablePluginAsync(pluginId);\n            return Ok(new { message = \"插件启用成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"启用插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"启用插件失败\" });\n        }\n    }\n\n    [HttpPost(\"{pluginId}/disable\")]\n    public async Task<IActionResult> DisablePlugin(string pluginId)\n    {\n        try\n        {\n            await _pluginManager.DisablePluginAsync(pluginId);\n            return Ok(new { message = \"插件禁用成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"禁用插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"禁用插件失败\" });\n        }\n    }\n\n    [HttpPost(\"{pluginId}/reload\")]\n    public async Task<IActionResult> ReloadPlugin(string pluginId)\n    {\n        try\n        {\n            await _pluginManager.ReloadPluginAsync(pluginId);\n            return Ok(new { message = \"插件重载成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"重载插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"重载插件失败\" });\n        }\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":39,"output":851,"cacheRead":29032,"cacheWrite":0,"totalTokens":29922,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774191953824}}
