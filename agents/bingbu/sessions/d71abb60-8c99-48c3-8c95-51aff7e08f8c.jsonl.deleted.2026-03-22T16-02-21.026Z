{"type":"message","id":"315cc6fa","parentId":"946b414e","timestamp":"2026-03-22T15:03:01.690Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建SqlSugar的仓储实现，替换EF Core的仓储。我需要确保每个函数不超过50行。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_a6c8685b8a594f669eb8c074","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Data/SqlSugar/DataRepository.cs","content":"using SqlSugar;\nusing System.Text.Json;\nusing Tianyou.Core.Abstractions;\n\nnamespace Tianyou.Data.SqlSugar;\n\n/// <summary>\n/// SqlSugar 数据仓库实现\n/// </summary>\npublic class DataRepository : IDataRepository\n{\n    private readonly ISqlSugarClient _db;\n\n    public DataRepository(ISqlSugarClient db)\n    {\n        _db = db;\n    }\n\n    public async Task<DynamicObject?> GetFormDataAsync(string dataId)\n    {\n        var entity = await _db.Queryable<FormDataEntity>()\n            .Where(e => e.Id == dataId)\n            .FirstAsync();\n\n        if (entity == null) return null;\n\n        var data = JsonSerializer.Deserialize<DynamicObject>(entity.DataJson);\n        if (data != null) data.Id = entity.Id;\n        return data;\n    }\n\n    public async Task<List<DynamicObject>> GetFormDataListAsync(string formCode, int page = 1, int pageSize = 20)\n    {\n        var skip = (page - 1) * pageSize;\n        var entities = await _db.Queryable<FormDataEntity>()\n            .Where(f => f.FormCode == formCode)\n            .OrderByDescending(f => f.CreateTime)\n            .Skip(skip)\n            .Take(pageSize)\n            .ToListAsync();\n\n        return entities.Select(e =>\n        {\n            var data = JsonSerializer.Deserialize<DynamicObject>(e.DataJson) ?? new();\n            data.Id = e.Id;\n            return data;\n        }).ToList();\n    }\n\n    public async Task<string> SaveFormDataAsync(string formCode, DynamicObject data, string? userId = null, string? userName = null)\n    {\n        if (!string.IsNullOrEmpty(data.Id))\n        {\n            var existing = await _db.Queryable<FormDataEntity>()\n                .Where(e => e.Id == data.Id)\n                .FirstAsync();\n\n            if (existing != null)\n            {\n                existing.DataJson = JsonSerializer.Serialize(data);\n                existing.ModifyTime = DateTime.UtcNow;\n                existing.ModifiedBy = userId;\n                existing.ModifiedByName = userName;\n                await _db.Updateable(existing).ExecuteCommandAsync();\n                return existing.Id;\n            }\n        }\n\n        var entity = new FormDataEntity\n        {\n            Id = Guid.NewGuid().ToString(),\n            FormCode = formCode,\n            DataJson = JsonSerializer.Serialize(data),\n            CreatedBy = userId,\n            CreatedByName = userName,\n            ModifyTime = DateTime.UtcNow,\n            ModifiedBy = userId,\n            ModifiedByName = userName\n        };\n\n        await _db.Insertable(entity).ExecuteCommandAsync();\n        return entity.Id;\n    }\n\n    public async Task<bool> DeleteFormDataAsync(string dataId)\n    {\n        var count = await _db.Deleteable<FormDataEntity>()\n            .Where(e => e.Id == dataId)\n            .ExecuteCommandAsync();\n\n        return count > 0;\n    }\n\n    public async Task<int> BatchDeleteFormDataAsync(List<string> dataIds)\n    {\n        return await _db.Deleteable<FormDataEntity>()\n            .Where(e => dataIds.Contains(e.Id))\n            .ExecuteCommandAsync();\n    }\n\n    public async Task<List<T>> QueryAsync<T>(string sql, object? param = null)\n    {\n        return await _db.Ado.SqlQueryAsync<T>(sql, param);\n    }\n\n    public async Task<T?> QueryFirstOrDefaultAsync<T>(string sql, object? param = null)\n    {\n        return await _db.Ado.SqlQueryAsync<T>(sql, param)\n            .ContinueWith(t => t.Result.FirstOrDefault());\n    }\n\n    public async Task<int> ExecuteAsync(string sql, object? param = null)\n    {\n        return await _db.Ado.ExecuteCommandAsync(sql, param);\n    }\n\n    public async Task<TResult> ExecuteInTransactionAsync<TResult>(Func<Task<TResult>> action)\n    {\n        try\n        {\n            _db.BeginTran();\n            var result = await action();\n            _db.CommitTran();\n            return result;\n        }\n        catch\n        {\n            _db.RollbackTran();\n            throw;\n        }\n    }\n\n    public async Task ExecuteInTransactionAsync(Func<Task> action)\n    {\n        try\n        {\n            _db.BeginTran();\n            await action();\n            _db.CommitTran();\n        }\n        catch\n        {\n            _db.RollbackTran();\n            throw;\n        }\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":43,"output":964,"cacheRead":19099,"cacheWrite":0,"totalTokens":20106,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774191769284}}
