{"type":"message","id":"d118f9ff","parentId":"a1ab1f53","timestamp":"2026-03-22T15:08:05.359Z","message":{"role":"toolResult","toolCallId":"call_bee68b0059064712bb218743","toolName":"exec","content":[{"type":"text","text":"1\tusing SqlSugar;\n     2\tusing System.Text.Json;\n     3\tusing Tianyou.Core.Abstractions;\n     4\t\n     5\tnamespace Tianyou.Data.SqlSugar;\n     6\t\n     7\t/// <summary>\n     8\t/// SqlSugar 数据仓库实现\n     9\t/// </summary>\n    10\tpublic class DataRepository : IDataRepository\n    11\t{\n    12\t    private readonly ISqlSugarClient _db;\n    13\t\n    14\t    public DataRepository(ISqlSugarClient db)\n    15\t    {\n    16\t        _db = db;\n    17\t    }\n    18\t\n    19\t    public async Task<DynamicObject?> GetFormDataAsync(string dataId)\n    20\t    {\n    21\t        var entity = await _db.Queryable<FormDataEntity>()\n    22\t            .Where(e => e.Id == dataId)\n    23\t            .FirstAsync();\n    24\t\n    25\t        if (entity == null) return null;\n    26\t\n    27\t        var data = JsonSerializer.Deserialize<DynamicObject>(entity.DataJson);\n    28\t        if (data != null) data.Id = entity.Id;\n    29\t        return data;\n    30\t    }\n    31\t\n    32\t    public async Task<List<DynamicObject>> GetFormDataListAsync(string formCode, int page = 1, int pageSize = 20)\n    33\t    {\n    34\t        var skip = (page - 1) * pageSize;\n    35\t        var entities = await _db.Queryable<FormDataEntity>()\n    36\t            .Where(f => f.FormCode == formCode)\n    37\t            .OrderByDescending(f => f.CreateTime)\n    38\t            .Skip(skip)\n    39\t            .Take(pageSize)\n    40\t            .ToListAsync();\n    41\t\n    42\t        return entities.Select(e =>\n    43\t        {\n    44\t            var data = JsonSerializer.Deserialize<DynamicObject>(e.DataJson) ?? new();\n    45\t            data.Id = e.Id;\n    46\t            return data;\n    47\t        }).ToList();\n    48\t    }\n    49\t\n    50\t    public async Task<string> SaveFormDataAsync(string formCode, DynamicObject data, string? userId = null, string? userName = null)\n    51\t    {\n    52\t        if (!string.IsNullOrEmpty(data.Id))\n    53\t        {\n    54\t            var existing = await _db.Queryable<FormDataEntity>()\n    55\t                .Where(e => e.Id == data.Id)\n    56\t                .FirstAsync();\n    57\t\n    58\t            if (existing != null)\n    59\t            {\n    60\t                existing.DataJson = JsonSerializer.Serialize(data);\n    61\t                existing.ModifyTime = DateTime.UtcNow;\n    62\t                existing.ModifiedBy = userId;\n    63\t                existing.ModifiedByName = userName;\n    64\t                await _db.Updateable(existing).ExecuteCommandAsync();\n    65\t                return existing.Id;\n    66\t            }\n    67\t        }\n    68\t\n    69\t        var entity = new FormDataEntity\n    70\t        {\n    71\t            Id = Guid.NewGuid().ToString(),\n    72\t            FormCode = formCode,\n    73\t            DataJson = JsonSerializer.Serialize(data),\n    74\t            CreatedBy = userId,\n    75\t            CreatedByName = userName,\n    76\t            ModifyTime = DateTime.UtcNow,\n    77\t            ModifiedBy = userId,\n    78\t            ModifiedByName = userName\n    79\t        };\n    80"}],"details":{"status":"completed","exitCode":0,"durationMs":12,"aggregated":"1\tusing SqlSugar;\n     2\tusing System.Text.Json;\n     3\tusing Tianyou.Core.Abstractions;\n     4\t\n     5\tnamespace Tianyou.Data.SqlSugar;\n     6\t\n     7\t/// <summary>\n     8\t/// SqlSugar 数据仓库实现\n     9\t/// </summary>\n    10\tpublic class DataRepository : IDataRepository\n    11\t{\n    12\t    private readonly ISqlSugarClient _db;\n    13\t\n    14\t    public DataRepository(ISqlSugarClient db)\n    15\t    {\n    16\t        _db = db;\n    17\t    }\n    18\t\n    19\t    public async Task<DynamicObject?> GetForm