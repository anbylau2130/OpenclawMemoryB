{"type":"message","id":"6fd2b2e7","parentId":"7783e1b8","timestamp":"2026-03-22T15:06:24.732Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建DataService的控制器。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_e3a8af8d1c29456f902529a9","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.DataService/Controllers/DataController.cs","content":"using Microsoft.AspNetCore.Mvc;\nusing Tianyou.Core.Abstractions;\n\nnamespace Tianyou.DataService.Controllers;\n\n[ApiController]\n[Route(\"api/[controller]\")]\npublic class DataController : ControllerBase\n{\n    private readonly IDataRepository _dataRepository;\n    private readonly IMetadataRepository _metadataRepository;\n    private readonly ILogger<DataController> _logger;\n\n    public DataController(\n        IDataRepository dataRepository,\n        IMetadataRepository metadataRepository,\n        ILogger<DataController> logger)\n    {\n        _dataRepository = dataRepository;\n        _metadataRepository = metadataRepository;\n        _logger = logger;\n    }\n\n    [HttpGet(\"forms/{formCode}/data/{dataId}\")]\n    public async Task<IActionResult> GetFormData(string formCode, string dataId)\n    {\n        try\n        {\n            var data = await _dataRepository.GetFormDataAsync(dataId);\n            if (data == null)\n            {\n                return NotFound();\n            }\n\n            return Ok(data);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单数据失败: {FormCode}/{DataId}\", formCode, dataId);\n            return StatusCode(500, new { message = \"获取表单数据失败\" });\n        }\n    }\n\n    [HttpGet(\"forms/{formCode}/data\")]\n    public async Task<IActionResult> GetFormDataList(\n        string formCode,\n        [FromQuery] int page = 1,\n        [FromQuery] int pageSize = 20)\n    {\n        try\n        {\n            var data = await _dataRepository.GetFormDataListAsync(formCode, page, pageSize);\n            return Ok(data);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单数据列表失败: {FormCode}\", formCode);\n            return StatusCode(500, new { message = \"获取表单数据列表失败\" });\n        }\n    }\n\n    [HttpPost(\"forms/{formCode}/data\")]\n    public async Task<IActionResult> SaveFormData(string formCode, [FromBody] DynamicObject data)\n    {\n        try\n        {\n            var dataId = await _dataRepository.SaveFormDataAsync(formCode, data);\n            return Ok(new { id = dataId });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"保存表单数据失败: {FormCode}\", formCode);\n            return StatusCode(500, new { message = \"保存表单数据失败\" });\n        }\n    }\n\n    [HttpDelete(\"data/{dataId}\")]\n    public async Task<IActionResult> DeleteFormData(string dataId)\n    {\n        try\n        {\n            var success = await _dataRepository.DeleteFormDataAsync(dataId);\n            if (!success)\n            {\n                return NotFound();\n            }\n\n            return Ok(new { message = \"删除成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"删除表单数据失败: {DataId}\", dataId);\n            return StatusCode(500, new { message = \"删除表单数据失败\" });\n        }\n    }\n\n    [HttpDelete(\"data/batch\")]\n    public async Task<IActionResult> BatchDeleteFormData([FromBody] List<string> dataIds)\n    {\n        try\n        {\n            var count = await _dataRepository.BatchDeleteFormDataAsync(dataIds);\n            return Ok(new { count, message = $\"成功删除 {count} 条数据\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"批量删除表单数据失败\");\n            return StatusCode(500, new { message = \"批量删除表单数据失败\" });\n        }\n    }\n\n    [HttpGet(\"query\")]\n    public async Task<IActionResult> QueryData([FromQuery] string sql, [FromQuery] object? param = null)\n    {\n        try\n        {\n            var data = await _dataRepository.QueryAsync<dynamic>(sql, param);\n            return Ok(data);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"执行查询失败: {Sql}\", sql);\n            return StatusCode(500, new { message = \"执行查询失败\" });\n        }\n    }\n\n    [HttpPost(\"query\")]\n    public async Task<IActionResult> QueryDataPost([FromBody] QueryRequest request)\n    {\n        try\n        {\n            var data = await _dataRepository.QueryAsync<dynamic>(request.Sql, request.Param);\n            return Ok(data);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"执行查询失败: {Sql}\", request.Sql);\n            return StatusCode(500, new { message = \"执行查询失败\" });\n        }\n    }\n}\n\npublic record QueryRequest(string Sql, object? Param = null);\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":39,"output":1001,"cacheRead":30639,"cacheWrite":0,"totalTokens":31679,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774191972308}}
