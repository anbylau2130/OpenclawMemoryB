{"type":"message","id":"48e01433","parentId":"80fc46c7","timestamp":"2026-03-22T14:01:29.363Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，Program.cs 创建成功。现在创建表单控制器。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_c5b70190cdca416aa4ed1ef3","name":"write","arguments":{"content":"using Microsoft.AspNetCore.Mvc;\nusing Microsoft.Extensions.Logging;\nusing Tianyou.Core.Abstractions;\nusing Tianyou.Data.Repositories;\nusing Tianyou.LowCode.Engine;\nusing Tianyou.Plugin.Abstractions;\nusing System.Text.Json;\n\nnamespace Tianyou.FormService.Controllers;\n\n/// <summary>\n/// 表单 API 控制器\n/// </summary>\n[ApiController]\n[Route(\"api/[controller]\")]\npublic class FormController : ControllerBase\n{\n    private readonly IMetadataRepository _metadataRepository;\n    private readonly IDataRepository _dataRepository;\n    private readonly FormEngine _formEngine;\n    private readonly ILogger<FormController> _logger;\n    \n    public FormController(\n        IMetadataRepository metadataRepository,\n        IDataRepository dataRepository,\n        FormEngine formEngine,\n        ILogger<FormController> logger)\n    {\n        _metadataRepository = metadataRepository;\n        _dataRepository = dataRepository;\n        _formEngine = formEngine;\n        _logger = logger;\n    }\n    \n    /// <summary>\n    /// 获取表单元数据\n    /// </summary>\n    [HttpGet(\"metadata/{formCode}\")]\n    public async Task<ActionResult<FormMetadata>> GetFormMetadata(string formCode)\n    {\n        try\n        {\n            var metadata = await _metadataRepository.GetFormMetadataAsync(formCode);\n            if (metadata == null)\n            {\n                return NotFound(new { message = $\"表单不存在: {formCode}\" });\n            }\n            \n            return Ok(metadata);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单元数据失败: {FormCode}\", formCode);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 获取表单数据\n    /// </summary>\n    [HttpGet(\"data/{dataId}\")]\n    public async Task<ActionResult<DynamicObject>> GetFormData(string dataId)\n    {\n        try\n        {\n            var data = await _dataRepository.GetFormDataAsync(dataId);\n            if (data == null)\n            {\n                return NotFound(new { message = $\"数据不存在: {dataId}\" });\n            }\n            \n            return Ok(data);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单数据失败: {DataId}\", dataId);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 获取表单数据列表\n    /// </summary>\n    [HttpGet(\"data\")]\n    public async Task<ActionResult<List<DynamicObject>>> GetFormDataList(\n        [FromQuery] string formCode,\n        [FromQuery] int page = 1,\n        [FromQuery] int pageSize = 20)\n    {\n        try\n        {\n            var data = await _dataRepository.GetFormDataListAsync(formCode, page, pageSize);\n            return Ok(data);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单数据列表失败: {FormCode}\", formCode);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 保存表单数据\n    /// </summary>\n    [HttpPost(\"data\")]\n    public async Task<ActionResult<SaveDataResponse>> SaveFormData([FromBody] SaveDataRequest request)\n    {\n        try\n        {\n            var dataId = await _dataRepository.SaveFormDataAsync(\n                request.FormCode,\n                request.Data,\n                request.UserId,\n                request.UserName);\n            \n            return Ok(new SaveDataResponse\n            {\n                Success = true,\n                DataId = dataId,\n                Message = \"保存成功\"\n            });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"保存表单数据失败: {FormCode}\", request.FormCode);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 删除表单数据\n    /// </summary>\n    [HttpDelete(\"data/{dataId}\")]\n    public async Task<ActionResult> DeleteFormData(string dataId)\n    {\n        try\n        {\n            var success = await _dataRepository.DeleteFormDataAsync(dataId);\n            if (!success)\n            {\n                return NotFound(new { message = $\"数据不存在: {dataId}\" });\n            }\n            \n            return Ok(new { success = true, message = \"删除成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"删除表单数据失败: {DataId}\", dataId);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 批量删除表单数据\n    /// </summary>\n    [HttpDelete(\"data\")]\n    public async Task<ActionResult> BatchDeleteFormData([FromBody] BatchDeleteRequest request)\n    {\n        try\n        {\n            var count = await _dataRepository.BatchDeleteFormDataAsync(request.DataIds);\n            return Ok(new { success = true, message = $\"删除了 {count} 条数据\", count });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"批量删除表单数据失败\");\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 验证表单数据\n    /// </summary>\n    [HttpPost(\"validate\")]\n    public async Task<ActionResult<ValidationResult>> ValidateFormData([FromBody] ValidateDataRequest request)\n    {\n        try\n        {\n            var metadata = await _metadataRepository.GetFormMetadataAsync(request.FormCode);\n            if (metadata == null)\n            {\n                return NotFound(new { message = $\"表单不存在: {request.FormCode}\" });\n            }\n            \n            var model = DataModel.FromJson(metadata, JsonSerializer.Serialize(request.Data), _logger);\n            var validationResult = model.Validate();\n            \n            return Ok(validationResult);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"验证表单数据失败: {FormCode}\", request.FormCode);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 计算表达式\n    /// </summary>\n    [HttpPost(\"evaluate\")]\n    public async Task<ActionResult<object>> EvaluateExpression([FromBody] EvaluateExpressionRequest request)\n    {\n        try\n        {\n            var expressionEngine = new ExpressionEngine(_logger);\n            \n            // 设置数据上下文\n            foreach (var kvp in request.Context)\n            {\n                expressionEngine.SetVariable(kvp.Key, kvp.Value);\n            }\n            \n            var result = expressionEngine.Evaluate(request.Expression);\n            \n            return Ok(new { success = true, result });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"计算表达式失败: {Expression}\", request.Expression);\n            return StatusCode(500, new { message = \"计算失败\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 获取表单配置\n    /// </summary>\n    [HttpGet(\"config/{formCode}\")]\n    public async Task<ActionResult<FormConfigResponse>> GetFormConfig(string formCode)\n    {\n        try\n        {\n            var metadata = await _metadataRepository.GetFormMetadataAsync(formCode);\n            if (metadata == null)\n            {\n                return NotFound(new { message = $\"表单不存在: {formCode}\" });\n            }\n            \n            var config = new FormConfigResponse\n            {\n                FormCode = metadata.Code,\n                FormName = metadata.Name,\n                FormType = metadata.FormType,\n                Fields = metadata.Fields.Select(f => new FieldConfig\n                {\n                    Code = f.Code,\n                    Name = f.Name,\n                    FieldType = f.FieldType,\n                    DataType = f.DataType,\n                    Required = f.Required,\n                    ReadOnly = f.ReadOnly,\n                    DefaultValue = f.DefaultValue\n                }).ToList(),\n                Entries = metadata.Entries.Select(e => new EntryConfig\n                {\n                    Code = e.Code,\n                    Name = e.Name,\n                    Fields = e.Fields.Select(f => new FieldConfig\n                    {\n                        Code = f.Code,\n                        Name = f.Name,\n                        FieldType = f.FieldType,\n                        DataType = f.DataType,\n                        Required = f.Required,\n                        ReadOnly = f.ReadOnly\n                    }).ToList()\n                }).ToList()\n            };\n            \n            return Ok(config);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单配置失败: {FormCode}\", formCode);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n}\n\n#region 请求/响应模型\n\n/// <summary>\n/// 保存数据请求\n/// </summary>\npublic class SaveDataRequest\n{\n    public string FormCode { get; set; } = string.Empty;\n    public DynamicObject Data { get; set; } = new();\n    public string? UserId { get; set; }\n    public string? UserName { get; set; }\n}\n\n/// <summary>\n/// 保存数据响应\n/// </summary>\npublic class SaveDataResponse\n{\n    public bool Success { get; set; }\n    public string? DataId { get; set; }\n    public string? Message { get; set; }\n}\n\n/// <summary>\n/// 批量删除请求\n/// </summary>\npublic class BatchDeleteRequest\n{\n    public List<string> DataIds { get; set; } = new();\n}\n\n/// <summary>\n/// 验证数据请求\n/// </summary>\npublic class ValidateDataRequest\n{\n    public string FormCode { get; set; } = string.Empty;\n    public DynamicObject Data { get; set; } = new();\n}\n\n/// <summary>\n/// 计算表达式请求\n/// </summary>\npublic class EvaluateExpressionRequest\n{\n    public string Expression { get; set; } = string.Empty;\n    public Dictionary<string, object?> Context { get; set; } = new();\n}\n\n/// <summary>\n/// 表单配置响应\n/// </summary>\npublic class FormConfigResponse\n{\n    public string FormCode { get; set; } = string.Empty;\n    public string FormName { get; set; } = string.Empty;\n    public FormType FormType { get; set; }\n    public List<FieldConfig> Fields { get; set; } = new();\n    public List<EntryConfig> Entries { get; set; } = new();\n}\n\n/// <summary>\n/// 字段配置\n/// </summary>\npublic class FieldConfig\n{\n    public string Code { get; set; } = string.Empty;\n    public string Name { get; set; } = string.Empty;\n    public FieldType FieldType { get; set; }\n    public DataType DataType { get; set; }\n    public bool Required { get; set; }\n    public bool ReadOnly { get; set; }\n    public object? DefaultValue { get; set; }\n}\n\n/// <summary>\n/// 分录配置\n/// </summary>\npublic class EntryConfig\n{\n    public string Code { get; set; } = string.Empty;\n    public string Name { get; set; } = string.Empty;\n    public List<FieldConfig> Fields { get; set; } = new();\n}\n\n#endregion\n","path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.FormService/Controllers/FormController.cs"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":40,"output":2410,"cacheRead":41929,"cacheWrite":0,"totalTokens":44379,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774188051375}}
