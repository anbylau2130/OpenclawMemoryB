{"type":"message","id":"8f471aea","parentId":"4a941ca5","timestamp":"2026-03-22T13:57:07.271Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，数据仓库创建成功。现在创建元数据仓库。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_9c13b07fee134af8b95c550c","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Data/Repositories/MetadataRepository.cs","content":"using Microsoft.EntityFrameworkCore;\nusing Microsoft.Extensions.Logging;\nusing Tianyou.Core.Abstractions;\nusing Tianyou.Data.DbContexts;\n\nnamespace Tianyou.Data.Repositories;\n\n/// <summary>\n/// 元数据仓库\n/// </summary>\npublic class MetadataRepository : IMetadataRepository\n{\n    private readonly TianyouDbContext _dbContext;\n    private readonly ILogger<MetadataRepository> _logger;\n    private readonly ICacheService _cacheService;\n    \n    public MetadataRepository(\n        TianyouDbContext dbContext,\n        ILogger<MetadataRepository> logger,\n        ICacheService cacheService)\n    {\n        _dbContext = dbContext;\n        _logger = logger;\n        _cacheService = cacheService;\n    }\n    \n    #region 表单元数据\n    \n    /// <summary>\n    /// 获取表单元数据\n    /// </summary>\n    public async Task<FormMetadata?> GetFormMetadataAsync(string formCode)\n    {\n        try\n        {\n            // 先从缓存获取\n            var cacheKey = $\"form_metadata:{formCode}\";\n            var cached = await _cacheService.GetAsync<FormMetadata>(cacheKey);\n            if (cached != null)\n                return cached;\n            \n            // 从数据库获取\n            var entity = await _dbContext.FormMetadata\n                .FirstOrDefaultAsync(f => f.Code == formCode && f.IsEnabled);\n            \n            if (entity == null)\n                return null;\n            \n            var metadata = entity.ToMetadata();\n            \n            // 缓存1小时\n            await _cacheService.SetAsync(cacheKey, metadata, TimeSpan.FromHours(1));\n            \n            return metadata;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单元数据失败: {FormCode}\", formCode);\n            throw;\n        }\n    }\n    \n    /// <summary>\n    /// 根据ID获取表单元数据\n    /// </summary>\n    public async Task<FormMetadata?> GetFormMetadataByIdAsync(string id)\n    {\n        try\n        {\n            var entity = await _dbContext.FormMetadata.FindAsync(id);\n            return entity?.ToMetadata();\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取表单元数据失败: {Id}\", id);\n            throw;\n        }\n    }\n    \n    /// <summary>\n    /// 获取应用的所有表单元数据\n    /// </summary>\n    public async Task<List<FormMetadata>> GetFormMetadataListAsync(string appId)\n    {\n        try\n        {\n            var entities = await _dbContext.FormMetadata\n                .Where(f => f.AppId == appId && f.IsEnabled)\n                .OrderBy(f => f.Name)\n                .ToListAsync();\n            \n            return entities.Select(e => e.ToMetadata()).ToList();\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取应用表单元数据列表失败: {AppId}\", appId);\n            throw;\n        }\n    }\n    \n    /// <summary>\n    /// 保存表单元数据\n    /// </summary>\n    public async Task<string> SaveFormMetadataAsync(FormMetadata metadata)\n    {\n        try\n        {\n            var entity = await _dbContext.FormMetadata.FindAsync(metadata.Id);\n            \n            if (entity != null)\n            {\n                // 更新\n                entity.Code = metadata.Code;\n                entity.Name = metadata.Name;\n                entity.Description = metadata.Description;\n                entity.FormType = metadata.FormType;\n                entity.AppId = metadata.AppId;\n                entity.FieldsJson = System.Text.Json.JsonSerializer.Serialize(metadata.Fields);\n                entity.EntriesJson = System.Text.Json.JsonSerializer.Serialize(metadata.Entries);\n                entity.RulesJson = System.Text.Json.JsonSerializer.Serialize(metadata.Rules);\n                entity.LayoutJson = System.Text.Json.JsonSerializer.Serialize(metadata.Layout);\n                entity.PluginsJson = System.Text.Json.JsonSerializer.Serialize(metadata.Plugins);\n                entity.ExtendedPropertiesJson = System.Text.Json.JsonSerializer.Serialize(metadata.ExtendedProperties);\n                entity.ModifyTime = DateTime.UtcNow;\n                entity.Version++;\n            }\n            else\n            {\n                // 新增\n                entity = FormMetadataEntity.FromMetadata(metadata);\n                _dbContext.FormMetadata.Add(entity);\n            }\n            \n            await _dbContext.SaveChangesAsync();\n            \n            // 清除缓存\n            await _cacheService.RemoveAsync($\"form_metadata:{metadata.Code}\");\n            \n            return entity.Id;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"保存表单元数据失败: {FormCode}\", metadata.Code);\n            throw;\n        }\n    }\n    \n    /// <summary>\n    /// 删除表单元数据\n    /// </summary>\n    public async Task<bool> DeleteFormMetadataAsync(string formCode)\n    {\n        try\n        {\n            var entity = await _dbContext.FormMetadata\n                .FirstOrDefaultAsync(f => f.Code == formCode);\n            \n            if (entity == null)\n                return false;\n            \n            // 软删除\n            entity.IsEnabled = false;\n            await _dbContext.SaveChangesAsync();\n            \n            // 清除缓存\n            await _cacheService.RemoveAsync($\"form_metadata:{formCode}\");\n            \n            return true;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"删除表单元数据失败: {FormCode}\", formCode);\n            throw;\n        }\n    }\n    \n    #endregion\n    \n    #region 字段元数据\n    \n    /// <summary>\n    /// 获取字段元数据\n    /// </summary>\n    public async Task<FieldMetadata?> GetFieldMetadataAsync(string formCode, string fieldCode)\n    {\n        try\n        {\n            var formMetadata = await GetFormMetadataAsync(formCode);\n            if (formMetadata == null)\n                return null;\n            \n            return formMetadata.Fields.FirstOrDefault(f => f.Code == fieldCode);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取字段元数据失败: {FormCode}.{FieldCode}\", formCode, fieldCode);\n            throw;\n        }\n    }\n    \n    #endregion\n    \n    #region 搜索\n    \n    /// <summary>\n    /// 搜索表单元数据\n    /// </summary>\n    public async Task<List<FormMetadata>> SearchFormMetadataAsync(string keyword, string? appId = null)\n    {\n        try\n        {\n            var query = _dbContext.FormMetadata.Where(f => f.IsEnabled);\n            \n            if (!string.IsNullOrEmpty(appId))\n            {\n                query = query.Where(f => f.AppId == appId);\n            }\n            \n            if (!string.IsNullOrEmpty(keyword))\n            {\n                query = query.Where(f => \n                    f.Name.Contains(keyword) || \n                    f.Code.Contains(keyword) ||\n                    (f.Description != null && f.Description.Contains(keyword)));\n            }\n            \n            var entities = await query\n                .OrderBy(f => f.Name)\n                .Take(100)\n                .ToListAsync();\n            \n            return entities.Select(e => e.ToMetadata()).ToList();\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"搜索表单元数据失败: {Keyword}\", keyword);\n            throw;\n        }\n    }\n    \n    #endregion\n}\n\n/// <summary>\n/// 元数据仓库接口\n/// </summary>\npublic interface IMetadataRepository\n{\n    Task<FormMetadata?> GetFormMetadataAsync(string formCode);\n    Task<FormMetadata?> GetFormMetadataByIdAsync(string id);\n    Task<List<FormMetadata>> GetFormMetadataListAsync(string appId);\n    Task<string> SaveFormMetadataAsync(FormMetadata metadata);\n    Task<bool> DeleteFormMetadataAsync(string formCode);\n    Task<FieldMetadata?> GetFieldMetadataAsync(string formCode, string fieldCode);\n    Task<List<FormMetadata>> SearchFormMetadataAsync(string keyword, string? appId = null);\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":40,"output":1605,"cacheRead":23795,"cacheWrite":0,"totalTokens":25440,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187805699}}
