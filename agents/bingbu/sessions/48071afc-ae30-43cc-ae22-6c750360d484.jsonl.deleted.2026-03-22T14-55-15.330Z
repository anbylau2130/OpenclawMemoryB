{"type":"message","id":"0a9ed97d","parentId":"f591b4f6","timestamp":"2026-03-22T13:58:41.334Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，插件加载器创建成功。现在创建插件管理器。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_f3051188c6614fd08b1ab6f2","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Plugin/PluginManager.cs","content":"using Microsoft.Extensions.Logging;\nusing System.Reflection;\nusing Tianyou.Plugin.Abstractions;\n\nnamespace Tianyou.Plugin;\n\n/// <summary>\n/// 插件管理器 - 负责插件的生命周期管理\n/// </summary>\npublic class PluginManager : IDisposable\n{\n    private readonly ILogger<PluginManager> _logger;\n    private readonly PluginLoader _loader;\n    private readonly Dictionary<string, PluginInstance> _plugins;\n    private readonly Dictionary<string, PluginMetadata> _metadata;\n    private readonly IServiceProvider _serviceProvider;\n    private readonly string _pluginDirectory;\n    private readonly FileSystemWatcher? _watcher;\n    private bool _disposed;\n    \n    public PluginManager(\n        IServiceProvider serviceProvider,\n        ILogger<PluginManager> logger,\n        string pluginDirectory)\n    {\n        _serviceProvider = serviceProvider;\n        _logger = logger;\n        _pluginDirectory = pluginDirectory;\n        _loader = new PluginLoader(logger);\n        _plugins = new Dictionary<string, PluginInstance>();\n        _metadata = new Dictionary<string, PluginMetadata>();\n        \n        // 确保插件目录存在\n        if (!Directory.Exists(pluginDirectory))\n        {\n            Directory.CreateDirectory(pluginDirectory);\n        }\n        \n        // 设置文件监视器（支持热加载）\n        try\n        {\n            _watcher = new FileSystemWatcher(pluginDirectory)\n            {\n                NotifyFilter = NotifyFilters.LastWrite | NotifyFilters.FileName,\n                Filter = \"*.dll\",\n                EnableRaisingEvents = true\n            };\n            \n            _watcher.Changed += async (sender, e) => await OnPluginFileChanged(e);\n            _watcher.Created += async (sender, e) => await OnPluginFileChanged(e);\n            _watcher.Deleted += async (sender, e) => await OnPluginFileDeleted(e);\n            \n            _logger.LogInformation(\"插件文件监视器已启动: {PluginDirectory}\", pluginDirectory);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogWarning(ex, \"启动插件文件监视器失败\");\n        }\n    }\n    \n    #region 插件加载\n    \n    /// <summary>\n    /// 从目录加载所有插件\n    /// </summary>\n    public async Task<int> LoadAllPluginsAsync()\n    {\n        _logger.LogInformation(\"开始加载插件目录: {PluginDirectory}\", _pluginDirectory);\n        \n        var dllFiles = Directory.GetFiles(_pluginDirectory, \"*.dll\", SearchOption.TopDirectoryOnly);\n        var loadedCount = 0;\n        \n        foreach (var dllFile in dllFiles)\n        {\n            try\n            {\n                var plugin = await _loader.LoadFromFileAsync(dllFile);\n                if (plugin != null)\n                {\n                    loadedCount++;\n                }\n            }\n            catch (Exception ex)\n            {\n                _logger.LogError(ex, \"加载插件失败: {DllFile}\", dllFile);\n            }\n        }\n        \n        _logger.LogInformation(\"插件加载完成，共加载 {Count} 个插件\", loadedCount);\n        return loadedCount;\n    }\n    \n    /// <summary>\n    /// 加载单个插件\n    /// </summary>\n    public async Task<bool> LoadPluginAsync(string pluginPath, Dictionary<string, object>? config = null)\n    {\n        try\n        {\n            var plugin = await _loader.LoadFromFileAsync(pluginPath, config);\n            if (plugin == null)\n                return false;\n            \n            // 提取元数据\n            var metadata = ExtractMetadata(plugin);\n            _metadata[metadata.Id] = metadata;\n            \n            // 注册插件实例\n            var context = new PluginContext(\n                _serviceProvider,\n                _logger,\n                _serviceProvider.GetService<IConfiguration>()!,\n                _pluginDirectory,\n                config ?? new Dictionary<string, object>(),\n                metadata);\n            \n            plugin.Initialize(context);\n            \n            _plugins[metadata.Id] = new PluginInstance\n            {\n                Plugin = plugin,\n                Metadata = metadata,\n                Context = context,\n                LoadTime = DateTime.UtcNow\n            };\n            \n            metadata.State = PluginState.Loaded;\n            \n            _logger.LogInformation(\"插件加载成功: {PluginName} (ID: {PluginId})\", metadata.Name, metadata.Id);\n            return true;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"加载插件失败: {PluginPath}\", pluginPath);\n            return false;\n        }\n    }\n    \n    #endregion\n    \n    #region 插件启动\n    \n    /// <summary>\n    /// 启动所有已加载的插件\n    /// </summary>\n    public async Task<int> StartAllPluginsAsync()\n    {\n        _logger.LogInformation(\"开始启动所有插件\");\n        \n        var startedCount = 0;\n        var sortedPlugins = _plugins.Values\n            .OrderBy(p => p.Metadata.LoadTime)\n            .ToList();\n        \n        foreach (var pluginInstance in sortedPlugins)\n        {\n            try\n            {\n                if (await StartPluginAsync(pluginInstance.Metadata.Id))\n                {\n                    startedCount++;\n                }\n            }\n            catch (Exception ex)\n            {\n                _logger.LogError(ex, \"启动插件失败: {PluginId}\", pluginInstance.Metadata.Id);\n            }\n        }\n        \n        _logger.LogInformation(\"插件启动完成，共启动 {Count} 个插件\", startedCount);\n        return startedCount;\n    }\n    \n    /// <summary>\n    /// 启动单个插件\n    /// </summary>\n    public async Task<bool> StartPluginAsync(string pluginId)\n    {\n        try\n        {\n            if (!_plugins.TryGetValue(pluginId, out var pluginInstance))\n            {\n                _logger.LogWarning(\"插件不存在: {PluginId}\", pluginId);\n                return false;\n            }\n            \n            pluginInstance.Plugin.Start();\n            pluginInstance.Metadata.State = PluginState.Started;\n            \n            _logger.LogInformation(\"插件启动成功: {PluginName}\", pluginInstance.Metadata.Name);\n            return true;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"启动插件失败: {PluginId}\", pluginId);\n            return false;\n        }\n    }\n    \n    #endregion\n    \n    #region 插件停止\n    \n    /// <summary>\n    /// 停止所有插件\n    /// </summary>\n    public async Task<int> StopAllPluginsAsync()\n    {\n        _logger.LogInformation(\"开始停止所有插件\");\n        \n        var stoppedCount = 0;\n        var plugins = _plugins.Values.ToList();\n        \n        foreach (var pluginInstance in plugins)\n        {\n            try\n            {\n                if (await StopPluginAsync(pluginInstance.Metadata.Id))\n                {\n                    stoppedCount++;\n                }\n            }\n            catch (Exception ex)\n            {\n                _logger.LogError(ex, \"停止插件失败: {PluginId}\", pluginInstance.Metadata.Id);\n            }\n        }\n        \n        _logger.LogInformation(\"插件停止完成，共停止 {Count} 个插件\", stoppedCount);\n        return stoppedCount;\n    }\n    \n    /// <summary>\n    /// 停止单个插件\n    /// </summary>\n    public async Task<bool> StopPluginAsync(string pluginId)\n    {\n        try\n        {\n            if (!_plugins.TryGetValue(pluginId, out var pluginInstance))\n            {\n                _logger.LogWarning(\"插件不存在: {PluginId}\", pluginId);\n                return false;\n            }\n            \n            pluginInstance.Plugin.Stop();\n            pluginInstance.Metadata.State = PluginState.Stopped;\n            \n            _logger.LogInformation(\"插件停止成功: {PluginName}\", pluginInstance.Metadata.Name);\n            return true;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"停止插件失败: {PluginId}\", pluginId);\n            return false;\n        }\n    }\n    \n    #endregion\n    \n    #region 插件卸载\n    \n    /// <summary>\n    /// 卸载单个插件\n    /// </summary>\n    public async Task<bool> UnloadPluginAsync(string pluginId)\n    {\n        try\n        {\n            // 先停止插件\n            if (_plugins.TryGetValue(pluginId, out var pluginInstance))\n            {\n                pluginInstance.Plugin.Stop();\n                pluginInstance.Plugin.Dispose();\n                _plugins.Remove(pluginId);\n            }\n            \n            // 卸载程序集\n            var unloaded = await _loader.UnloadAsync(pluginId);\n            \n            // 清理元数据\n            _metadata.Remove(pluginId);\n            \n            _logger.LogInformation(\"插件卸载成功: {PluginId}\", pluginId);\n            return unloaded;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"卸载插件失败: {PluginId}\", pluginId);\n            return false;\n        }\n    }\n    \n    #endregion\n    \n    #region 插件查询\n    \n    /// <summary>\n    /// 获取所有插件元数据\n    /// </summary>\n    public List<PluginMetadata> GetAllPlugins()\n    {\n        return _metadata.Values.ToList();\n    }\n    \n    /// <summary>\n    /// 获取插件元数据\n    /// </summary>\n    public PluginMetadata? GetPluginMetadata(string pluginId)\n    {\n        return _metadata.TryGetValue(pluginId, out var metadata) ? metadata : null;\n    }\n    \n    /// <summary>\n    /// 获取插件实例\n    /// </summary>\n    public IPlugin? GetPlugin(string pluginId)\n    {\n        return _plugins.TryGetValue(pluginId, out var instance) ? instance.Plugin : null;\n    }\n    \n    /// <summary>\n    /// 获取指定类型的插件\n    /// </summary>\n    public List<T> GetPlugins<T>() where T : IPlugin\n    {\n        return _plugins.Values\n            .Where(p => p.Plugin is T)\n            .Select(p => (T)p.Plugin)\n            .ToList();\n    }\n    \n    /// <summary>\n    /// 检查插件是否已加载\n    /// </summary>\n    public bool IsPluginLoaded(string pluginId)\n    {\n        return _plugins.ContainsKey(pluginId);\n    }\n    \n    #endregion\n    \n    #region 事件处理\n    \n    private async Task OnPluginFileChanged(FileSystemEventArgs e)\n    {\n        try\n        {\n            _logger.LogInformation(\"检测到插件文件变更: {FilePath}\", e.FullPath);\n            \n            // 等待文件写入完成\n            await Task.Delay(500);\n            \n            // 根据插件ID卸载旧版本\n            var pluginId = Path.GetFileNameWithoutExtension(e.Name);\n            await UnloadPluginAsync(pluginId);\n            \n            // 加载新版本\n            await LoadPluginAsync(e.FullPath);\n            await StartPluginAsync(pluginId);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"处理插件文件变更失败: {FilePath}\", e.FullPath);\n        }\n    }\n    \n    private async Task OnPluginFileDeleted(FileSystemEventArgs e)\n    {\n        try\n        {\n            _logger.LogInformation(\"检测到插件文件删除: {FilePath}\", e.FullPath);\n            \n            var pluginId = Path.GetFileNameWithoutExtension(e.Name);\n            await UnloadPluginAsync(pluginId);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"处理插件文件删除失败: {FilePath}\", e.FullPath);\n        }\n    }\n    \n    #endregion\n    \n    #region 辅助方法\n    \n    private PluginMetadata ExtractMetadata(IPlugin plugin)\n    {\n        var type = plugin.GetType();\n        var metadataAttr = type.GetCustomAttribute<PluginMetadataAttribute>();\n        \n        return new PluginMetadata\n        {\n            Id = metadataAttr?.Id ?? plugin.Id,\n            Name = metadataAttr?.Name ?? plugin.Name,\n            Version = plugin.Version.ToString(),\n            Description = metadataAttr?.Description ?? plugin.Description,\n            Author = metadataAttr?.Author ?? plugin.Author,\n            Category = metadataAttr?.Category,\n            AssemblyName = type.Assembly.GetName().Name ?? string.Empty,\n            TypeName = type.FullName ?? string.Empty,\n            IsHotLoad = true\n        };\n    }\n    \n    #endregion\n    \n    public void Dispose()\n    {\n        if (!_disposed)\n        {\n            // 停止所有插件\n            StopAllPluginsAsync().GetAwaiter().GetResult();\n            \n            // 清理资源\n            _loader.Dispose();\n            _watcher?.Dispose();\n            \n            _disposed = true;\n        }\n        GC.SuppressFinalize(this);\n    }\n}\n\n/// <summary>\n/// 插件实例信息\n/// </summary>\ninternal class PluginInstance\n{\n    public IPlugin Plugin { get; set; } = null!;\n    public PluginMetadata Metadata { get; set; } = null!;\n    public PluginContext Context { get; set; } = null!;\n    public DateTime LoadTime { get; set; }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":40,"output":2622,"cacheRead":30248,"cacheWrite":0,"totalTokens":32910,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187881658}}
