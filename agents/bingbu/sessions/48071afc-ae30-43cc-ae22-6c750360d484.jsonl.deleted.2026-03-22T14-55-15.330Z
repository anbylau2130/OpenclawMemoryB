{"type":"message","id":"cf73adbb","parentId":"b22cc889","timestamp":"2026-03-22T13:59:38.385Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，表单视图创建成功。现在创建数据模型。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_60a307b4e9e54115ae3054a7","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.LowCode.Engine/DataModel.cs","content":"using Microsoft.Extensions.Logging;\nusing Tianyou.Plugin.Abstractions;\nusing Tianyou.Core.Abstractions;\nusing System.Text.Json;\n\nnamespace Tianyou.LowCode.Engine;\n\n/// <summary>\n/// 数据模型实现\n/// </summary>\npublic class DataModel : IDataModel\n{\n    private readonly ILogger<DataModel> _logger;\n    private readonly FormMetadata _metadata;\n    private DynamicObject _data;\n    private readonly Dictionary<string, EntryData> _entryData;\n    \n    public event EventHandler<DataChangedEventArgs>? DataChanged;\n    \n    public DataModel(\n        FormMetadata metadata,\n        ILogger<DataModel> logger)\n    {\n        _metadata = metadata;\n        _logger = logger;\n        _data = new DynamicObject();\n        _entryData = new Dictionary<string, EntryData>();\n    }\n    \n    /// <summary>\n    /// 从 JSON 数据初始化\n    /// </summary>\n    public static DataModel FromJson(\n        FormMetadata metadata,\n        string jsonData,\n        ILogger<DataModel> logger)\n    {\n        var model = new DataModel(metadata, logger);\n        \n        try\n        {\n            model._data = JsonSerializer.Deserialize<DynamicObject>(jsonData) ?? new DynamicObject();\n        }\n        catch (Exception ex)\n        {\n            logger.LogError(ex, \"解析 JSON 数据失败\");\n            model._data = new DynamicObject();\n        }\n        \n        return model;\n    }\n    \n    #region 字段操作\n    \n    /// <summary>\n    /// 获取字段值\n    /// </summary>\n    public T? GetValue<T>(string fieldKey)\n    {\n        try\n        {\n            return _data.GetValue<T>(fieldKey);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取字段值失败: {FieldKey}\", fieldKey);\n            return default;\n        }\n    }\n    \n    /// <summary>\n    /// 设置字段值\n    /// </summary>\n    public void SetValue(string fieldKey, object? value)\n    {\n        try\n        {\n            var oldValue = _data.ContainsKey(fieldKey) ? _data[fieldKey] : null;\n            _data[fieldKey] = value;\n            \n            _logger.LogDebug(\"设置字段值: {FieldKey} = {Value} (旧值: {OldValue})\", fieldKey, value, oldValue);\n            \n            // 触发数据变更事件\n            OnDataChanged(new DataChangedEventArgs\n            {\n                FieldKey = fieldKey,\n                OldValue = oldValue,\n                NewValue = value\n            });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"设置字段值失败: {FieldKey}\", fieldKey);\n        }\n    }\n    \n    /// <summary>\n    /// 批量设置字段值\n    /// </summary>\n    public void SetValues(Dictionary<string, object?> values)\n    {\n        foreach (var kvp in values)\n        {\n            SetValue(kvp.Key, kvp.Value);\n        }\n    }\n    \n    #endregion\n    \n    #region 数据实体\n    \n    /// <summary>\n    /// 获取整个数据实体\n    /// </summary>\n    public DynamicObject GetDataEntity()\n    {\n        return new DynamicObject(_data);\n    }\n    \n    /// <summary>\n    /// 设置数据实体\n    /// </summary>\n    public void SetDataEntity(DynamicObject data)\n    {\n        _data = data ?? new DynamicObject();\n        _logger.LogDebug(\"设置数据实体\");\n    }\n    \n    /// <summary>\n    /// 转换为 JSON\n    /// </summary>\n    public string ToJson()\n    {\n        return JsonSerializer.Serialize(_data, new JsonSerializerOptions\n        {\n            WriteIndented = true,\n            DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull\n        });\n    }\n    \n    #endregion\n    \n    #region 分录操作\n    \n    /// <summary>\n    /// 获取分录行数\n    /// </summary>\n    public int GetEntryRowCount(string entryKey)\n    {\n        if (_entryData.TryGetValue(entryKey, out var entry))\n        {\n            return entry.Rows.Count;\n        }\n        return 0;\n    }\n    \n    /// <summary>\n    /// 新增分录行\n    /// </summary>\n    public int AddEntryRow(string entryKey)\n    {\n        if (!_entryData.TryGetValue(entryKey, out var entry))\n        {\n            entry = new EntryData { EntryKey = entryKey };\n            _entryData[entryKey] = entry;\n        }\n        \n        var rowIndex = entry.Rows.Count;\n        var row = new DynamicObject();\n        entry.Rows.Add(row);\n        \n        _logger.LogDebug(\"新增分录行: {EntryKey}, 行号: {RowIndex}\", entryKey, rowIndex);\n        return rowIndex;\n    }\n    \n    /// <summary>\n    /// 删除分录行\n    /// </summary>\n    public void DeleteEntryRow(string entryKey, int rowIndex)\n    {\n        if (_entryData.TryGetValue(entryKey, out var entry))\n        {\n            if (rowIndex >= 0 && rowIndex < entry.Rows.Count)\n            {\n                entry.Rows.RemoveAt(rowIndex);\n                _logger.LogDebug(\"删除分录行: {EntryKey}, 行号: {RowIndex}\", entryKey, rowIndex);\n            }\n            else\n            {\n                _logger.LogWarning(\"分录行号超出范围: {EntryKey}, 行号: {RowIndex}\", entryKey, rowIndex);\n            }\n        }\n        else\n        {\n            _logger.LogWarning(\"分录不存在: {EntryKey}\", entryKey);\n        }\n    }\n    \n    /// <summary>\n    /// 获取分录行数据\n    /// </summary>\n    public DynamicObject GetEntryRow(string entryKey, int rowIndex)\n    {\n        if (_entryData.TryGetValue(entryKey, out var entry))\n        {\n            if (rowIndex >= 0 && rowIndex < entry.Rows.Count)\n            {\n                return entry.Rows[rowIndex];\n            }\n        }\n        \n        _logger.LogWarning(\"获取分录行失败: {EntryKey}, 行号: {RowIndex}\", entryKey, rowIndex);\n        return new DynamicObject();\n    }\n    \n    /// <summary>\n    /// 设置分录行数据\n    /// </summary>\n    public void SetEntryRow(string entryKey, int rowIndex, DynamicObject data)\n    {\n        if (_entryData.TryGetValue(entryKey, out var entry))\n        {\n            if (rowIndex >= 0 && rowIndex < entry.Rows.Count)\n            {\n                entry.Rows[rowIndex] = data;\n                _logger.LogDebug(\"设置分录行数据: {EntryKey}, 行号: {RowIndex}\", entryKey, rowIndex);\n            }\n            else\n            {\n                _logger.LogWarning(\"分录行号超出范围: {EntryKey}, 行号: {RowIndex}\", entryKey, rowIndex);\n            }\n        }\n        else\n        {\n            _logger.LogWarning(\"分录不存在: {EntryKey}\", entryKey);\n        }\n    }\n    \n    /// <summary>\n    /// 获取分录字段值\n    /// </summary>\n    public T? GetEntryValue<T>(string entryKey, int rowIndex, string fieldKey)\n    {\n        var row = GetEntryRow(entryKey, rowIndex);\n        return row.GetValue<T>(fieldKey);\n    }\n    \n    /// <summary>\n    /// 设置分录字段值\n    /// </summary>\n    public void SetEntryValue(string entryKey, int rowIndex, string fieldKey, object? value)\n    {\n        var row = GetEntryRow(entryKey, rowIndex);\n        row[fieldKey] = value;\n        \n        _logger.LogDebug(\"设置分录字段值: {EntryKey}.{RowIndex}.{FieldKey} = {Value}\", \n            entryKey, rowIndex, fieldKey, value);\n    }\n    \n    /// <summary>\n    /// 获取分录所有数据\n    /// </summary>\n    public List<DynamicObject> GetEntryRows(string entryKey)\n    {\n        if (_entryData.TryGetValue(entryKey, out var entry))\n        {\n            return new List<DynamicObject>(entry.Rows);\n        }\n        return new List<DynamicObject>();\n    }\n    \n    /// <summary>\n    /// 设置分录所有数据\n    /// </summary>\n    public void SetEntryRows(string entryKey, List<DynamicObject> rows)\n    {\n        _entryData[entryKey] = new EntryData\n        {\n            EntryKey = entryKey,\n            Rows = new List<DynamicObject>(rows)\n        };\n        \n        _logger.LogDebug(\"设置分录数据: {EntryKey}, 行数: {Count}\", entryKey, rows.Count);\n    }\n    \n    #endregion\n    \n    #region 数据验证\n    \n    /// <summary>\n    /// 验证数据\n    /// </summary>\n    public ValidationResult Validate()\n    {\n        var errors = new List<ValidationError>();\n        \n        // 验证必填字段\n        foreach (var field in _metadata.Fields.Where(f => f.Required))\n        {\n            if (!_data.ContainsKey(field.Code) || _data[field.Code] == null || \n                (_data[field.Code] is string str && string.IsNullOrWhiteSpace(str)))\n            {\n                errors.Add(new ValidationError\n                {\n                    Field = field.Code,\n                    Message = $\"{field.Name} 是必填项\",\n                    Code = \"Required\"\n                });\n            }\n        }\n        \n        // 验证字段规则\n        foreach (var field in _metadata.Fields)\n        {\n            foreach (var rule in field.ValidationRules)\n            {\n                var validationResult = ValidateField(field.Code, rule);\n                if (!validationResult.IsValid)\n                {\n                    errors.AddRange(validationResult.Errors);\n                }\n            }\n        }\n        \n        return errors.Count == 0 \n            ? ValidationResult.Success() \n            : ValidationResult.Failure(errors.ToArray());\n    }\n    \n    /// <summary>\n    /// 验证单个字段\n    /// </summary>\n    public ValidationResult ValidateField(string fieldKey, ValidationRule rule)\n    {\n        var value = _data.ContainsKey(fieldKey) ? _data[fieldKey] : null;\n        var errors = new List<ValidationError>();\n        \n        switch (rule.Type)\n        {\n            case ValidationType.MinLength:\n                if (value is string str && str.Length < int.Parse(rule.Value))\n                {\n                    errors.Add(new ValidationError\n                    {\n                        Field = fieldKey,\n                        Message = rule.Message,\n                        Code = \"MinLength\"\n                    });\n                }\n                break;\n                \n            case ValidationType.MaxLength:\n                if (value is string str2 && str2.Length > int.Parse(rule.Value))\n                {\n                    errors.Add(new ValidationError\n                    {\n                        Field = fieldKey,\n                        Message = rule.Message,\n                        Code = \"MaxLength\"\n                    });\n                }\n                break;\n                \n            case ValidationType.Pattern:\n                if (value is string str3 && !System.Text.RegularExpressions.Regex.IsMatch(str3, rule.Value))\n                {\n                    errors.Add(new ValidationError\n                    {\n                        Field = fieldKey,\n                        Message = rule.Message,\n                        Code = \"Pattern\"\n                    });\n                }\n                break;\n        }\n        \n        return errors.Count == 0 \n            ? ValidationResult.Success() \n            : ValidationResult.Failure(errors.ToArray());\n    }\n    \n    #endregion\n    \n    #region 事件\n    \n    protected virtual void OnDataChanged(DataChangedEventArgs e)\n    {\n        DataChanged?.Invoke(this, e);\n    }\n    \n    #endregion\n}\n\n/// <summary>\n/// 分录数据\n/// </summary>\ninternal class EntryData\n{\n    public string EntryKey { get; set; } = string.Empty;\n    public List<DynamicObject> Rows { get; set; } = new();\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":41,"output":2420,"cacheRead":34867,"cacheWrite":0,"totalTokens":37328,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187951611}}
