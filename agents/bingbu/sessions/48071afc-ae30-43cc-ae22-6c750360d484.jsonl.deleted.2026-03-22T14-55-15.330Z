{"type":"message","id":"b6743717","parentId":"f0ed99d2","timestamp":"2026-03-22T13:58:01.627Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，插件上下文创建成功。现在创建插件加载器。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_6dc77fcadcd9449d8b86353e","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Plugin/PluginLoader.cs","content":"using System.Reflection;\nusing System.Runtime.Loader;\nusing Microsoft.Extensions.Logging;\nusing Tianyou.Plugin.Abstractions;\n\nnamespace Tianyou.Plugin;\n\n/// <summary>\n/// 插件加载器 - 负责加载插件程序集和创建插件实例\n/// </summary>\npublic class PluginLoader\n{\n    private readonly ILogger<PluginLoader> _logger;\n    private readonly Dictionary<string, AssemblyLoadContext> _loadContexts;\n    private readonly Dictionary<string, Assembly> _loadedAssemblies;\n    \n    public PluginLoader(ILogger<PluginLoader> logger)\n    {\n        _logger = logger;\n        _loadContexts = new Dictionary<string, AssemblyLoadContext>();\n        _loadedAssemblies = new Dictionary<string, Assembly>();\n    }\n    \n    /// <summary>\n    /// 从程序集文件加载插件\n    /// </summary>\n    public async Task<IPlugin?> LoadFromFileAsync(string assemblyPath, Dictionary<string, object>? config = null)\n    {\n        try\n        {\n            _logger.LogInformation(\"从文件加载插件: {AssemblyPath}\", assemblyPath);\n            \n            if (!File.Exists(assemblyPath))\n            {\n                _logger.LogError(\"插件文件不存在: {AssemblyPath}\", assemblyPath);\n                return null;\n            }\n            \n            // 创建独立的加载上下文\n            var contextName = $\"Plugin_{Path.GetFileNameWithoutExtension(assemblyPath)}_{Guid.NewGuid():N}\";\n            var loadContext = new PluginLoadContext(contextName, assemblyPath);\n            _loadContexts[contextName] = loadContext;\n            \n            // 加载程序集\n            var assembly = loadContext.LoadFromAssemblyPath(assemblyPath);\n            _loadedAssemblies[assemblyPath] = assembly;\n            \n            // 查找插件类型\n            var pluginType = FindPluginType(assembly);\n            if (pluginType == null)\n            {\n                _logger.LogError(\"插件程序集中未找到插件类型: {AssemblyPath}\", assemblyPath);\n                loadContext.Unload();\n                return null;\n            }\n            \n            // 创建插件实例\n            var plugin = (IPlugin?)Activator.CreateInstance(pluginType);\n            if (plugin == null)\n            {\n                _logger.LogError(\"创建插件实例失败: {PluginType}\", pluginType.FullName);\n                return null;\n            }\n            \n            // 提取元数据\n            var metadataAttr = pluginType.GetCustomAttribute<PluginMetadataAttribute>();\n            var metadata = new PluginMetadata\n            {\n                Id = metadataAttr?.Id ?? pluginType.FullName ?? Guid.NewGuid().ToString(),\n                Name = metadataAttr?.Name ?? pluginType.Name,\n                Version = metadataAttr?.Version ?? \"1.0.0\",\n                Description = metadataAttr?.Description,\n                Author = metadataAttr?.Author,\n                Category = metadataAttr?.Category,\n                AssemblyName = assembly.GetName().Name ?? string.Empty,\n                TypeName = pluginType.FullName ?? string.Empty,\n                Config = config ?? new Dictionary<string, object>(),\n                State = PluginState.Loaded,\n                LoadTime = DateTime.UtcNow\n            };\n            \n            _logger.LogInformation(\"插件加载成功: {PluginName} (v{Version})\", metadata.Name, metadata.Version);\n            \n            return plugin;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"加载插件失败: {AssemblyPath}\", assemblyPath);\n            return null;\n        }\n    }\n    \n    /// <summary>\n    /// 从程序集加载插件\n    /// </summary>\n    public IPlugin? LoadFromAssembly(Assembly assembly)\n    {\n        try\n        {\n            _logger.LogInformation(\"从程序集加载插件: {AssemblyName}\", assembly.GetName().Name);\n            \n            // 查找插件类型\n            var pluginType = FindPluginType(assembly);\n            if (pluginType == null)\n            {\n                _logger.LogError(\"程序集中未找到插件类型: {AssemblyName}\", assembly.GetName().Name);\n                return null;\n            }\n            \n            // 创建插件实例\n            var plugin = (IPlugin?)Activator.CreateInstance(pluginType);\n            if (plugin == null)\n            {\n                _logger.LogError(\"创建插件实例失败: {PluginType}\", pluginType.FullName);\n                return null;\n            }\n            \n            _logger.LogInformation(\"插件加载成功: {PluginName}\", plugin.Name);\n            \n            return plugin;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"加载插件失败: {AssemblyName}\", assembly.GetName().Name);\n            return null;\n        }\n    }\n    \n    /// <summary>\n    /// 查找程序集中的插件类型\n    /// </summary>\n    private Type? FindPluginType(Assembly assembly)\n    {\n        // 查找实现了 IPlugin 接口且不是抽象类的类型\n        return assembly.GetTypes()\n            .FirstOrDefault(t => typeof(IPlugin).IsAssignableFrom(t) && \n                                !t.IsInterface && \n                                !t.IsAbstract);\n    }\n    \n    /// <summary>\n    /// 卸载插件\n    /// </summary>\n    public async Task<bool> UnloadAsync(string pluginId)\n    {\n        try\n        {\n            // 查找加载上下文\n            var contextKey = _loadContexts.Keys.FirstOrDefault(k => k.StartsWith($\"Plugin_{pluginId}_\"));\n            if (contextKey == null)\n            {\n                _logger.LogWarning(\"未找到插件的加载上下文: {PluginId}\", pluginId);\n                return false;\n            }\n            \n            var context = _loadContexts[contextKey];\n            context.Unload();\n            _loadContexts.Remove(contextKey);\n            \n            // 清理程序集缓存\n            var assemblyPath = _loadedAssemblies.Keys.FirstOrDefault(k => k.Contains(pluginId));\n            if (assemblyPath != null)\n            {\n                _loadedAssemblies.Remove(assemblyPath);\n            }\n            \n            _logger.LogInformation(\"插件卸载成功: {PluginId}\", pluginId);\n            return true;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"卸载插件失败: {PluginId}\", pluginId);\n            return false;\n        }\n    }\n    \n    /// <summary>\n    /// 清理所有插件\n    /// </summary>\n    public void Dispose()\n    {\n        foreach (var context in _loadContexts.Values)\n        {\n            try\n            {\n                context.Unload();\n            }\n            catch (Exception ex)\n            {\n                _logger.LogError(ex, \"卸载插件上下文失败\");\n            }\n        }\n        \n        _loadContexts.Clear();\n        _loadedAssemblies.Clear();\n    }\n    \n    /// <summary>\n    /// 获取已加载的插件数量\n    /// </summary>\n    public int LoadedPluginCount => _loadedAssemblies.Count;\n}\n\n/// <summary>\n/// 插件加载上下文 - 支持插件隔离和热加载\n/// </summary>\npublic class PluginLoadContext : AssemblyLoadContext\n{\n    private readonly AssemblyDependencyResolver _resolver;\n    private readonly string _pluginPath;\n    \n    public PluginLoadContext(string name, string pluginPath) : base(name, isCollectible: true)\n    {\n        _pluginPath = pluginPath;\n        _resolver = new AssemblyDependencyResolver(pluginPath);\n    }\n    \n    protected override Assembly? Load(AssemblyName assemblyName)\n    {\n        // 尝试从插件目录解析依赖\n        var assemblyPath = _resolver.ResolveAssemblyToPath(assemblyName);\n        if (assemblyPath != null)\n        {\n            try\n            {\n                return LoadFromAssemblyPath(assemblyPath);\n            }\n            catch\n            {\n                // 忽略加载错误，继续尝试其他方式\n            }\n        }\n        \n        // 尝试从默认上下文加载（如 .NET 运行时程序集）\n        return null;\n    }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":40,"output":1645,"cacheRead":28579,"cacheWrite":0,"totalTokens":30264,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187863166}}
