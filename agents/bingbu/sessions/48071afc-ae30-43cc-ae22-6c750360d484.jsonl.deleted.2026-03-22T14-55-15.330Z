{"type":"message","id":"ee729bb7","parentId":"0d85d194","timestamp":"2026-03-22T13:59:11.581Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，Tianyou.Plugin 项目已经完成。现在完善 Tianyou.LowCode.Engine 项目，添加表单视图、数据模型和表达式引擎。","thinkingSignature":"reasoning_content"},{"type":"text","text":"## 3. 完善 Tianyou.LowCode.Engine 项目"},{"type":"toolCall","id":"call_740ab6b80d664fccadc0dfd4","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.LowCode.Engine/FormView.cs","content":"using Microsoft.Extensions.Logging;\nusing Tianyou.Plugin.Abstractions;\nusing Tianyou.Core.Abstractions;\n\nnamespace Tianyou.LowCode.Engine;\n\n/// <summary>\n/// 表单视图实现\n/// </summary>\npublic class FormView : IFormView\n{\n    private readonly ILogger<FormView> _logger;\n    private readonly FormMetadata _metadata;\n    private readonly Dictionary<string, FieldState> _fieldStates;\n    private readonly List<FormattedMessage> _messages;\n    \n    public string FormId { get; }\n    public string FormCode => _metadata.Code;\n    public string FormName => _metadata.Name;\n    \n    public FormView(\n        string formId,\n        FormMetadata metadata,\n        ILogger<FormView> logger)\n    {\n        FormId = formId;\n        _metadata = metadata;\n        _logger = logger;\n        _fieldStates = new Dictionary<string, FieldState>();\n        _messages = new List<FormattedMessage>();\n        \n        // 初始化字段状态\n        InitializeFieldStates();\n    }\n    \n    /// <summary>\n    /// 初始化字段状态\n    /// </summary>\n    private void InitializeFieldStates()\n    {\n        foreach (var field in _metadata.Fields)\n        {\n            _fieldStates[field.Code] = new FieldState\n            {\n                FieldKey = field.Code,\n                Visible = field.ControlConfig.Visible,\n                Enabled = field.ControlConfig.Enabled,\n                ReadOnly = field.ReadOnly,\n                Required = field.Required,\n                Label = field.Name\n            };\n        }\n        \n        foreach (var entry in _metadata.Entries)\n        {\n            foreach (var field in entry.Fields)\n            {\n                var key = $\"{entry.Code}.{field.Code}\";\n                _fieldStates[key] = new FieldState\n                {\n                    FieldKey = key,\n                    Visible = field.ControlConfig.Visible,\n                    Enabled = field.ControlConfig.Enabled,\n                    ReadOnly = field.ReadOnly,\n                    Required = field.Required,\n                    Label = field.Name\n                };\n            }\n        }\n    }\n    \n    #region 状态控制\n    \n    public void SetVisible(string fieldKey, bool visible)\n    {\n        if (_fieldStates.TryGetValue(fieldKey, out var state))\n        {\n            state.Visible = visible;\n            _logger.LogDebug(\"设置字段可见性: {FieldKey} = {Visible}\", fieldKey, visible);\n        }\n        else\n        {\n            _logger.LogWarning(\"字段不存在: {FieldKey}\", fieldKey);\n        }\n    }\n    \n    public void SetReadOnly(string fieldKey, bool readOnly)\n    {\n        if (_fieldStates.TryGetValue(fieldKey, out var state))\n        {\n            state.ReadOnly = readOnly;\n            _logger.LogDebug(\"设置字段只读: {FieldKey} = {ReadOnly}\", fieldKey, readOnly);\n        }\n        else\n        {\n            _logger.LogWarning(\"字段不存在: {FieldKey}\", fieldKey);\n        }\n    }\n    \n    public void SetEnabled(string fieldKey, bool enabled)\n    {\n        if (_fieldStates.TryGetValue(fieldKey, out var state))\n        {\n            state.Enabled = enabled;\n            _logger.LogDebug(\"设置字段启用状态: {FieldKey} = {Enabled}\", fieldKey, enabled);\n        }\n        else\n        {\n            _logger.LogWarning(\"字段不存在: {FieldKey}\", fieldKey);\n        }\n    }\n    \n    public void SetRequired(string fieldKey, bool required)\n    {\n        if (_fieldStates.TryGetValue(fieldKey, out var state))\n        {\n            state.Required = required;\n            _logger.LogDebug(\"设置字段必填: {FieldKey} = {Required}\", fieldKey, required);\n        }\n        else\n        {\n            _logger.LogWarning(\"字段不存在: {FieldKey}\", fieldKey);\n        }\n    }\n    \n    public void SetLabel(string fieldKey, string label)\n    {\n        if (_fieldStates.TryGetValue(fieldKey, out var state))\n        {\n            state.Label = label;\n            _logger.LogDebug(\"设置字段标签: {FieldKey} = {Label}\", fieldKey, label);\n        }\n        else\n        {\n            _logger.LogWarning(\"字段不存在: {FieldKey}\", fieldKey);\n        }\n    }\n    \n    #endregion\n    \n    #region 数据操作\n    \n    public void SetValue(string fieldKey, object? value)\n    {\n        // 实际值由 DataModel 管理，这里只记录日志\n        _logger.LogDebug(\"设置字段值: {FieldKey} = {Value}\", fieldKey, value);\n    }\n    \n    public T? GetValue<T>(string fieldKey)\n    {\n        // 实际值由 DataModel 管理\n        _logger.LogDebug(\"获取字段值: {FieldKey}\", fieldKey);\n        return default;\n    }\n    \n    #endregion\n    \n    #region 刷新\n    \n    public void RefreshField(string fieldKey)\n    {\n        _logger.LogDebug(\"刷新字段: {FieldKey}\", fieldKey);\n    }\n    \n    public void Refresh()\n    {\n        _logger.LogDebug(\"刷新表单\");\n    }\n    \n    #endregion\n    \n    #region 消息\n    \n    public void ShowMessage(string message, MessageType type = MessageType.Info)\n    {\n        _messages.Add(new FormattedMessage\n        {\n            Message = message,\n            Type = type,\n            Timestamp = DateTime.UtcNow\n        });\n        \n        _logger.LogInformation(\"显示消息 [{Type}]: {Message}\", type, message);\n    }\n    \n    public Task<bool> ShowConfirm(string message, string title = \"确认\")\n    {\n        _logger.LogInformation(\"显示确认对话框: {Title} - {Message}\", title, message);\n        return Task.FromResult(true); // 默认返回 true\n    }\n    \n    #endregion\n    \n    #region 页面操作\n    \n    public void Close(bool refreshParent = false)\n    {\n        _logger.LogInformation(\"关闭页面 (刷新父级: {RefreshParent})\", refreshParent);\n    }\n    \n    public void OpenPage(string pageId, Dictionary<string, object>? parameters = null)\n    {\n        _logger.LogInformation(\"打开页面: {PageId}, 参数: {Parameters}\", pageId, \n            parameters != null ? string.Join(\", \", parameters.Select(p => $\"{p.Key}={p.Value}\")) : \"无\");\n    }\n    \n    #endregion\n    \n    #region 操作\n    \n    public Task<OperationResult> DoOperation(string operationKey, Dictionary<string, object>? parameters = null)\n    {\n        _logger.LogInformation(\"执行操作: {OperationKey}, 参数: {Parameters}\", operationKey,\n            parameters != null ? string.Join(\", \", parameters.Select(p => $\"{p.Key}={p.Value}\")) : \"无\");\n        \n        return Task.FromResult(OperationResult.Ok($\"操作 {operationKey} 已执行\"));\n    }\n    \n    public void FireEvent(string eventName, Dictionary<string, object>? data = null)\n    {\n        _logger.LogInformation(\"触发事件: {EventName}, 数据: {Data}\", eventName,\n            data != null ? string.Join(\", \", data.Select(p => $\"{p.Key}={p.Value}\")) : \"无\");\n    }\n    \n    #endregion\n    \n    #region 分录操作\n    \n    public void SetEntryRowCount(string entryKey, int count)\n    {\n        _logger.LogDebug(\"设置分录行数: {EntryKey} = {Count}\", entryKey, count);\n    }\n    \n    public int GetEntryRowCount(string entryKey)\n    {\n        _logger.LogDebug(\"获取分录行数: {EntryKey}\", entryKey);\n        return 0;\n    }\n    \n    #endregion\n    \n    #region 状态查询\n    \n    /// <summary>\n    /// 获取字段状态\n    /// </summary>\n    public FieldState? GetFieldState(string fieldKey)\n    {\n        return _fieldStates.TryGetValue(fieldKey, out var state) ? state : null;\n    }\n    \n    /// <summary>\n    /// 获取所有字段状态\n    /// </summary>\n    public Dictionary<string, FieldState> GetAllFieldStates()\n    {\n        return new Dictionary<string, FieldState>(_fieldStates);\n    }\n    \n    /// <summary>\n    /// 获取消息列表\n    /// </summary>\n    public List<FormattedMessage> GetMessages()\n    {\n        return new List<FormattedMessage>(_messages);\n    }\n    \n    /// <summary>\n    /// 清空消息\n    /// </summary>\n    public void ClearMessages()\n    {\n        _messages.Clear();\n    }\n    \n    #endregion\n}\n\n/// <summary>\n/// 字段状态\n/// </summary>\npublic class FieldState\n{\n    public string FieldKey { get; set; } = string.Empty;\n    public bool Visible { get; set; } = true;\n    public bool Enabled { get; set; } = true;\n    public bool ReadOnly { get; set; } = false;\n    public bool Required { get; set; } = false;\n    public string Label { get; set; } = string.Empty;\n}\n\n/// <summary>\n/// 格式化消息\n/// </summary>\npublic class FormattedMessage\n{\n    public string Message { get; set; } = string.Empty;\n    public MessageType Type { get; set; }\n    public DateTime Timestamp { get; set; }\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":39,"output":1966,"cacheRead":32894,"cacheWrite":0,"totalTokens":34899,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187921388}}
