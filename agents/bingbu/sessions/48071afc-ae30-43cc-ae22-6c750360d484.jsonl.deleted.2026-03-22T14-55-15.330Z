{"type":"message","id":"280a5288","parentId":"f8615ff9","timestamp":"2026-03-22T13:55:28.645Z","message":{"role":"toolResult","toolCallId":"call_b339ef4232c14aa3ab33b5ed","toolName":"read","content":[{"type":"text","text":"namespace Tianyou.Core.Abstractions;\n\n/// <summary>\n/// 元数据基类\n/// </summary>\npublic abstract class MetadataBase\n{\n    /// <summary>\n    /// 唯一标识\n    /// </summary>\n    public string Id { get; set; } = Guid.NewGuid().ToString();\n    \n    /// <summary>\n    /// 编码\n    /// </summary>\n    public string Code { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 名称\n    /// </summary>\n    public string Name { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 描述\n    /// </summary>\n    public string? Description { get; set; }\n    \n    /// <summary>\n    /// 创建时间\n    /// </summary>\n    public DateTime CreateTime { get; set; } = DateTime.UtcNow;\n    \n    /// <summary>\n    /// 修改时间\n    /// </summary>\n    public DateTime ModifyTime { get; set; } = DateTime.UtcNow;\n    \n    /// <summary>\n    /// 版本号\n    /// </summary>\n    public int Version { get; set; } = 1;\n    \n    /// <summary>\n    /// 扩展属性\n    /// </summary>\n    public Dictionary<string, object> ExtendedProperties { get; set; } = new();\n}\n\n/// <summary>\n/// 表单元数据\n/// </summary>\npublic class FormMetadata : MetadataBase\n{\n    /// <summary>\n    /// 表单类型\n    /// </summary>\n    public FormType FormType { get; set; }\n    \n    /// <summary>\n    /// 所属应用\n    /// </summary>\n    public string AppId { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 字段列表\n    /// </summary>\n    public List<FieldMetadata> Fields { get; set; } = new();\n    \n    /// <summary>\n    /// 分录列表\n    /// </summary>\n    public List<EntryMetadata> Entries { get; set; } = new();\n    \n    /// <summary>\n    /// 表单规则\n    /// </summary>\n    public List<FormRule> Rules { get; set; } = new();\n    \n    /// <summary>\n    /// 表单布局\n    /// </summary>\n    public FormLayout Layout { get; set; } = new();\n    \n    /// <summary>\n    /// 关联插件\n    /// </summary>\n    public List<PluginReference> Plugins { get; set; } = new();\n}\n\n/// <summary>\n/// 字段元数据\n/// </summary>\npublic class FieldMetadata : MetadataBase\n{\n    /// <summary>\n    /// 字段类型\n    /// </summary>\n    public FieldType FieldType { get; set; }\n    \n    /// <summary>\n    /// 数据类型\n    /// </summary>\n    public DataType DataType { get; set; }\n    \n    /// <summary>\n    /// 是否必填\n    /// </summary>\n    public bool Required { get; set; }\n    \n    /// <summary>\n    /// 是否只读\n    /// </summary>\n    public bool ReadOnly { get; set; }\n    \n    /// <summary>\n    /// 默认值\n    /// </summary>\n    public object? DefaultValue { get; set; }\n    \n    /// <summary>\n    /// 验证规则\n    /// </summary>\n    public List<ValidationRule> ValidationRules { get; set; } = new();\n    \n    /// <summary>\n    /// 值更新规则\n    /// </summary>\n    public List<ValueUpdateRule> ValueUpdateRules { get; set; } = new();\n    \n    /// <summary>\n    /// 控件配置\n    /// </summary>\n    public ControlConfig ControlConfig { get; set; } = new();\n}\n\n/// <summary>\n/// 分录元数据\n/// </summary>\npublic class EntryMetadata : MetadataBase\n{\n    /// <summary>\n    /// 字段列表\n    /// </summary>\n    public List<FieldMetadata> Fields { get; set; } = new();\n}\n\n/// <summary>\n/// 表单类型\n/// </summary>\npublic enum FormType\n{\n    /// <summary>\n    /// 单据\n    /// </summary>\n    Bill,\n    \n    /// <summary>\n    /// 基础资料\n    /// </summary>\n    BaseData,\n    \n    /// <summary>\n    /// 动态表单\n    /// </summary>\n    DynamicForm,\n    \n    /// <summary>\n    /// 报表\n    /// </summary>\n    Report\n}\n\n/// <summary>\n/// 字段类型\n/// </summary>\npublic enum FieldType\n{\n    Text,\n    Number,\n    Date,\n    DateTime,\n    Select,\n    MultiSelect,\n    Radio,\n    Checkbox,\n    File,\n    Image,\n    RichText,\n    Reference,\n    EntryTable\n}\n\n/// <summary>\n/// 数据类型\n/// </summary>\npublic enum DataType\n{\n    String,\n    Integer,\n    Decimal,\n    Boolean,\n    DateTime,\n    Binary,\n    Json,\n    Reference\n}\n\n/// <summary>\n/// 表单规则\n/// </summary>\npublic class FormRule\n{\n    public string Name { get; set; } = string.Empty;\n    public RuleType Type { get; set; }\n    public string Condition { get; set; } = string.Empty;\n    public string Action { get; set; } = string.Empty;\n    public int Priority { get; set; }\n}\n\n/// <summary>\n/// 规则类型\n/// </summary>\npublic enum RuleType\n{\n    Visibility,\n    ReadOnly,\n    Required,\n    ValueUpdate,\n    Validation\n}\n\n/// <summary>\n/// 验证规则\n/// </summary>\npublic class ValidationRule\n{\n    public string Name { get; set; } = string.Empty;\n    public ValidationType Type { get; set; }\n    public string Value { get; set; } = string.Empty;\n    public string Message { get; set; } = string.Empty;\n}\n\n/// <summary>\n/// 验证类型\n/// </summary>\npublic enum ValidationType\n{\n    Required,\n    MinLength,\n    MaxLength,\n    Range,\n    Pattern,\n    Custom\n}\n\n/// <summary>\n/// 值更新规则\n/// </summary>\npublic class ValueUpdateRule\n{\n    public string TargetField { get; set; } = string.Empty;\n    public string Expression { get; set; } = string.Empty;\n    public string TriggerField { get; set; } = string.Empty;\n}\n\n/// <summary>\n/// 表单布局\n/// </summary>\npublic class FormLayout\n{\n    public LayoutType Type { get; set; } = LayoutType.Tabs;\n    public List<LayoutSection> Sections { get; set; } = new();\n    public int Columns { get; set; } = 2;\n}\n\n/// <summary>\n/// 布局类型\n/// </summary>\npublic enum LayoutType\n{\n    Tabs,\n    Accordion,\n    Steps,\n    Grid\n}\n\n/// <summary>\n/// 布局区块\n/// </summary>\npublic class LayoutSection\n{\n    public string Title { get; set; } = string.Empty;\n    public List<string> Fields { get; set; } = new();\n    public int Columns { get; set; } = 2;\n}\n\n/// <summary>\n/// 控件配置\n/// </summary>\npublic class ControlConfig\n{\n    public string Placeholder { get; set; } = string.Empty;\n    public int? Width { get; set; }\n    public int? Height { get; set; }\n    public bool Visible { get; set; } = true;\n    public bool Enabled { get; set; } = true;\n    public Dictionary<string, object> ExtendedProps { get; set; } = new();\n}\n\n/// <summary>\n/// 插件引用\n/// </summary>\npublic class PluginReference\n{\n    public string PluginId { get; set; } = string.Empty;\n    public string PluginType { get; set; } = string.Empty;\n    public Dictionary<string, object> Config { get; set; } = new();\n    public int Order { get; set; }\n}\n"}],"isError":false,"timestamp":1774187728638}}
