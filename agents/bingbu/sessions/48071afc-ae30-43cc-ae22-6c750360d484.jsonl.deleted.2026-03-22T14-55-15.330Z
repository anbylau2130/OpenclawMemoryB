{"type":"message","id":"f0642cf0","parentId":"d6820e23","timestamp":"2026-03-22T14:00:33.490Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，数据模型创建成功。现在创建表达式引擎。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_0643552556b7466594a4c79d","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.LowCode.Engine/ExpressionEngine.cs","content":"using Microsoft.Extensions.Logging;\nusing Tianyou.Core.Abstractions;\nusing System.Dynamic;\nusing System.Globalization;\n\nnamespace Tianyou.LowCode.Engine;\n\n/// <summary>\n/// 表达式引擎 - 支持字段引用、算术运算、逻辑运算、函数调用\n/// </summary>\npublic class ExpressionEngine\n{\n    private readonly ILogger<ExpressionEngine> _logger;\n    private readonly Dictionary<string, object?> _variables;\n    private readonly Dictionary<string, Func<object?[], object?>> _functions;\n    \n    public ExpressionEngine(ILogger<ExpressionEngine> logger)\n    {\n        _logger = logger;\n        _variables = new Dictionary<string, object?>();\n        _functions = new Dictionary<string, Func<object?[], object?>>();\n        \n        RegisterBuiltInFunctions();\n    }\n    \n    #region 变量管理\n    \n    /// <summary>\n    /// 设置变量\n    /// </summary>\n    public void SetVariable(string name, object? value)\n    {\n        _variables[name] = value;\n        _logger.LogDebug(\"设置变量: {Name} = {Value}\", name, value);\n    }\n    \n    /// <summary>\n    /// 获取变量\n    /// </summary>\n    public T? GetVariable<T>(string name)\n    {\n        if (_variables.TryGetValue(name, out var value))\n        {\n            try\n            {\n                if (value is T typedValue)\n                    return typedValue;\n                \n                return (T?)Convert.ChangeType(value, typeof(T));\n            }\n            catch\n            {\n                return default;\n            }\n        }\n        return default;\n    }\n    \n    /// <summary>\n    /// 设置数据模型变量\n    /// </summary>\n    public void SetDataModel(DataModel model)\n    {\n        // 导入所有字段作为变量\n        var data = model.GetDataEntity();\n        foreach (var kvp in data)\n        {\n            SetVariable(kvp.Key, kvp.Value);\n        }\n        \n        _logger.LogDebug(\"设置数据模型，共 {Count} 个字段\", data.Count);\n    }\n    \n    #endregion\n    \n    #region 函数管理\n    \n    /// <summary>\n    /// 注册函数\n    /// </summary>\n    public void RegisterFunction(string name, Func<object?[], object?> function)\n    {\n        _functions[name] = function;\n        _logger.LogDebug(\"注册函数: {Name}\", name);\n    }\n    \n    /// <summary>\n    /// 注册内置函数\n    /// </summary>\n    private void RegisterBuiltInFunctions()\n    {\n        // 字符串函数\n        RegisterFunction(\"concat\", args => string.Concat(args));\n        RegisterFunction(\"substring\", args => \n        {\n            if (args.Length >= 2 && args[0] is string str && args[1] is int startIndex)\n            {\n                var length = args.Length >= 3 && args[2] is int len ? len : str.Length - startIndex;\n                return str.Substring(startIndex, length);\n            }\n            return null;\n        });\n        RegisterFunction(\"trim\", args => args.Length > 0 ? args[0]?.ToString()?.Trim() : null);\n        RegisterFunction(\"upper\", args => args.Length > 0 ? args[0]?.ToString()?.ToUpper() : null);\n        RegisterFunction(\"lower\", args => args.Length > 0 ? args[0]?.ToString()?.ToLower() : null);\n        RegisterFunction(\"length\", args => args.Length > 0 ? args[0]?.ToString()?.Length : 0);\n        RegisterFunction(\"contains\", args =>\n        {\n            if (args.Length >= 2 && args[0] is string str && args[1] is string substr)\n            {\n                return str.Contains(substr);\n            }\n            return false;\n        });\n        \n        // 数学函数\n        RegisterFunction(\"abs\", args => args.Length > 0 && args[0] is double d ? Math.Abs(d) : null);\n        RegisterFunction(\"round\", args =>\n        {\n            if (args.Length > 0 && args[0] is double d)\n            {\n                var decimals = args.Length >= 2 && args[1] is int dec ? dec : 0;\n                return Math.Round(d, decimals);\n            }\n            return null;\n        });\n        RegisterFunction(\"floor\", args => args.Length > 0 && args[0] is double d ? Math.Floor(d) : null);\n        RegisterFunction(\"ceil\", args => args.Length > 0 && args[0] is double d ? Math.Ceiling(d) : null);\n        RegisterFunction(\"max\", args =>\n        {\n            if (args.Length > 0 && args[0] is IEnumerable<object> list)\n            {\n                return list.OfType<double>().Max();\n            }\n            return null;\n        });\n        RegisterFunction(\"min\", args =>\n        {\n            if (args.Length > 0 && args[0] is IEnumerable<object> list)\n            {\n                return list.OfType<double>().Min();\n            }\n            return null;\n        });\n        RegisterFunction(\"sum\", args =>\n        {\n            if (args.Length > 0 && args[0] is IEnumerable<object> list)\n            {\n                return list.OfType<double>().Sum();\n            }\n            return null;\n        });\n        RegisterFunction(\"avg\", args =>\n        {\n            if (args.Length > 0 && args[0] is IEnumerable<object> list)\n            {\n                var nums = list.OfType<double>().ToList();\n                return nums.Any() ? nums.Average() : 0;\n            }\n            return null;\n        });\n        \n        // 日期函数\n        RegisterFunction(\"now\", args => DateTime.UtcNow);\n        RegisterFunction(\"today\", args => DateTime.Today);\n        RegisterFunction(\"year\", args => args.Length > 0 && args[0] is DateTime dt ? dt.Year : null);\n        RegisterFunction(\"month\", args => args.Length > 0 && args[0] is DateTime dt ? dt.Month : null);\n        RegisterFunction(\"day\", args => args.Length > 0 && args[0] is DateTime dt ? dt.Day : null);\n        RegisterFunction(\"dateDiff\", args =>\n        {\n            if (args.Length >= 2 && args[0] is DateTime start && args[1] is DateTime end)\n            {\n                return (end - start).Days;\n            }\n            return null;\n        });\n        RegisterFunction(\"addDays\", args =>\n        {\n            if (args.Length >= 2 && args[0] is DateTime dt && args[1] is int days)\n            {\n                return dt.AddDays(days);\n            }\n            return null;\n        });\n        \n        // 类型转换\n        RegisterFunction(\"toString\", args => args.Length > 0 ? args[0]?.ToString() : null);\n        RegisterFunction(\"toNumber\", args =>\n        {\n            if (args.Length > 0)\n            {\n                if (double.TryParse(args[0]?.ToString(), out var num))\n                    return num;\n            }\n            return null;\n        });\n        RegisterFunction(\"toDate\", args =>\n        {\n            if (args.Length > 0 && DateTime.TryParse(args[0]?.ToString(), CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt))\n                return dt;\n            return null;\n        });\n        \n        // 逻辑函数\n        RegisterFunction(\"if\", args =>\n        {\n            if (args.Length >= 3 && args[0] is bool condition)\n            {\n                return condition ? args[1] : args[2];\n            }\n            return null;\n        });\n        RegisterFunction(\"isNullOrEmpty\", args => args.Length == 0 || args[0] == null || string.IsNullOrEmpty(args[0]?.ToString()));\n        RegisterFunction(\"isNullOrWhiteSpace\", args => args.Length == 0 || args[0] == null || string.IsNullOrWhiteSpace(args[0]?.ToString()));\n        \n        _logger.LogInformation(\"已注册 {Count} 个内置函数\", _functions.Count);\n    }\n    \n    #endregion\n    \n    #region 表达式求值\n    \n    /// <summary>\n    /// 计算表达式\n    /// </summary>\n    public object? Evaluate(string expression)\n    {\n        if (string.IsNullOrWhiteSpace(expression))\n        {\n            _logger.LogWarning(\"表达式为空\");\n            return null;\n        }\n        \n        try\n        {\n            _logger.LogDebug(\"计算表达式: {Expression}\", expression);\n            \n            // 移除花括号（如果存在）\n            var expr = expression.Trim();\n            if (expr.StartsWith(\"{\") && expr.EndsWith(\"}\"))\n            {\n                expr = expr.Substring(1, expr.Length - 2);\n            }\n            \n            // 简单表达式解析\n            var result = ParseExpression(expr);\n            \n            _logger.LogDebug(\"表达式计算结果: {Expression} = {Result}\", expression, result);\n            return result;\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"计算表达式失败: {Expression}\", expression);\n            throw new InvalidOperationException($\"表达式计算失败: {expression}\", ex);\n        }\n    }\n    \n    /// <summary>\n    /// 解析表达式\n    /// </summary>\n    private object? ParseExpression(string expression)\n    {\n        expression = expression.Trim();\n        \n        // 1. 检查是否是布尔字面量\n        if (expression.Equals(\"true\", StringComparison.OrdinalIgnoreCase))\n            return true;\n        if (expression.Equals(\"false\", StringComparison.OrdinalIgnoreCase))\n            return false;\n        \n        // 2. 检查是否是 null\n        if (expression.Equals(\"null\", StringComparison.OrdinalIgnoreCase))\n            return null;\n        \n        // 3. 检查是否是数字\n        if (double.TryParse(expression, NumberStyles.Any, CultureInfo.InvariantCulture, out var number))\n            return number;\n        \n        // 4. 检查是否是字符串\n        if ((expression.StartsWith(\"\\\"\") && expression.EndsWith(\"\\\"\")) ||\n            (expression.StartsWith(\"'\") && expression.EndsWith(\"'\")))\n        {\n            return expression.Substring(1, expression.Length - 2);\n        }\n        \n        // 5. 检查是否是变量\n        if (_variables.TryGetValue(expression, out var variableValue))\n            return variableValue;\n        \n        // 6. 检查是否是函数调用\n        var functionMatch = System.Text.RegularExpressions.Regex.Match(expression, @\"^(\\w+)\\((.*)\\)$\");\n        if (functionMatch.Success)\n        {\n            var functionName = functionMatch.Groups[1].Value;\n            var argsString = functionMatch.Groups[2].Value;\n            var args = ParseArguments(argsString);\n            \n            if (_functions.TryGetValue(functionName, out var function))\n            {\n                return function(args.ToArray());\n            }\n            \n            throw new InvalidOperationException($\"未知函数: {functionName}\");\n        }\n        \n        // 7. 处理比较运算\n        var comparisonMatch = System.Text.RegularExpressions.Regex.Match(expression, @\"^(.+?)(==|!=|>=|<=|>||<)(.+)$\");\n        if (comparisonMatch.Success)\n        {\n            var left = ParseExpression(comparisonMatch.Groups[1].Value);\n            var op = comparisonMatch.Groups[2].Value;\n            var right = ParseExpression(comparisonMatch.Groups[3].Value);\n            \n            return EvaluateComparison(left, op, right);\n        }\n        \n        // 8. 处理逻辑运算\n        var logicalMatch = System.Text.RegularExpressions.Regex.Match(expression, @\"^(.+?)(&&|\\|\\|)(.+)$\");\n        if (logicalMatch.Success)\n        {\n            var left = ParseExpression(logicalMatch.Groups[1].Value);\n            var op = logicalMatch.Groups[2].Value;\n            var right = ParseExpression(logicalMatch.Groups[3].Value);\n            \n            return EvaluateLogical(left, op, right);\n        }\n        \n        // 9. 处理算术运算\n        var arithmeticMatch = System.Text.RegularExpressions.Regex.Match(expression, @\"^(.+?)([+\\-*/])(.+)$\");\n        if (arithmeticMatch.Success)\n        {\n            var left = ParseExpression(arithmeticMatch.Groups[1].Value);\n            var op = arithmeticMatch.Groups[2].Value;\n            var right = ParseExpression(arithmeticMatch.Groups[3].Value);\n            \n            return EvaluateArithmetic(left, op, right);\n        }\n        \n        // 10. 处理成员访问（如 Field1.Name）\n        var memberMatch = System.Text.RegularExpressions.Regex.Match(expression, @\"^(\\w+)\\.(\\w+)$\");\n        if (memberMatch.Success)\n        {\n            var obj = ParseExpression(memberMatch.Groups[1].Value);\n            var member = memberMatch.Groups[2].Value;\n            \n            if (obj is DynamicObject dynamicObj)\n            {\n                return dynamicObj[member];\n            }\n            \n            // 使用反射\n            var prop = obj?.GetType().GetProperty(member);\n            return prop?.GetValue(obj);\n        }\n        \n        throw new InvalidOperationException($\"无法解析表达式: {expression}\");\n    }\n    \n    /// <summary>\n    /// 解析参数列表\n    /// </summary>\n    private List<object?> ParseArguments(string argsString)\n    {\n        var args = new List<object?>();\n        if (string.IsNullOrWhiteSpace(argsString))\n            return args;\n        \n        var depth = 0;\n        var current = new System.Text.StringBuilder();\n        \n        foreach (var ch in argsString)\n        {\n            if (ch == '(' || ch == '{' || ch == '[')\n                depth++;\n            else if (ch == ')' || ch == '}' || ch == ']')\n                depth--;\n            else if (ch == ',' && depth == 0)\n            {\n                args.Add(ParseExpression(current.ToString()));\n                current.Clear();\n                continue;\n            }\n            \n            current.Append(ch);\n        }\n        \n        if (current.Length > 0)\n        {\n            args.Add(ParseExpression(current.ToString()));\n        }\n        \n        return args;\n    }\n    \n    #endregion\n    \n    #region 运算求值\n    \n    private object? EvaluateComparison(object? left, string op, object? right)\n    {\n        var leftValue = Convert.ToDouble(left);\n        var rightValue = Convert.ToDouble(right);\n        \n        return op switch\n        {\n            \"==\" => leftValue == rightValue,\n            \"!=\" => leftValue != rightValue,\n            \">\" => leftValue > rightValue,\n            \"<\" => leftValue < rightValue,\n            \">=\" => leftValue >= rightValue,\n            \"<=\" => leftValue <= rightValue,\n            _ => throw new InvalidOperationException($\"未知比较运算符: {op}\")\n        };\n    }\n    \n    private object? EvaluateLogical(object? left, string op, object? right)\n    {\n        var leftValue = Convert.ToBoolean(left);\n        var rightValue = Convert.ToBoolean(right);\n        \n        return op switch\n        {\n            \"&&\" => leftValue && rightValue,\n            \"||\" => leftValue || rightValue,\n            _ => throw new InvalidOperationException($\"未知逻辑运算符: {op}\")\n        };\n    }\n    \n    private object? EvaluateArithmetic(object? left, string op, object? right)\n    {\n        var leftValue = Convert.ToDouble(left);\n        var rightValue = Convert.ToDouble(right);\n        \n        return op switch\n        {\n            \"+\" => leftValue + rightValue,\n            \"-\" => leftValue - rightValue,\n            \"*\" => leftValue * rightValue,\n            \"/\" => rightValue != 0 ? leftValue / rightValue : double.PositiveInfinity,\n            _ => throw new InvalidOperationException($\"未知算术运算符: {op}\")\n        };\n    }\n    \n    #endregion\n    \n    #region 批量计算\n    \n    /// <summary>\n    /// 批量计算表达式\n    /// </summary>\n    public Dictionary<string, object?> EvaluateBatch(Dictionary<string, string> expressions)\n    {\n        var results = new Dictionary<string, object?>();\n        \n        foreach (var kvp in expressions)\n        {\n            try\n            {\n                results[kvp.Key] = Evaluate(kvp.Value);\n            }\n            catch (Exception ex)\n            {\n                _logger.LogError(ex, \"计算表达式失败: {Key} = {Expression}\", kvp.Key, kvp.Value);\n                results[kvp.Key] = null;\n            }\n        }\n        \n        return results;\n    }\n    \n    #endregion\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":40,"output":3380,"cacheRead":37313,"cacheWrite":0,"totalTokens":40733,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187978437}}
