{"type":"message","id":"0ea14ed8","parentId":"966f91d4","timestamp":"2026-03-22T13:55:30.313Z","message":{"role":"toolResult","toolCallId":"call_9cf3978de44c4026bd12eac3","toolName":"read","content":[{"type":"text","text":"using Tianyou.Core.Abstractions;\n\nnamespace Tianyou.Plugin.Abstractions;\n\n/// <summary>\n/// 插件接口\n/// </summary>\npublic interface IPlugin : IDisposable\n{\n    /// <summary>\n    /// 插件ID\n    /// </summary>\n    string Id { get; }\n    \n    /// <summary>\n    /// 插件名称\n    /// </summary>\n    string Name { get; }\n    \n    /// <summary>\n    /// 插件版本\n    /// </summary>\n    Version Version { get; }\n    \n    /// <summary>\n    /// 插件描述\n    /// </summary>\n    string Description { get; }\n    \n    /// <summary>\n    /// 插件作者\n    /// </summary>\n    string Author { get; }\n    \n    /// <summary>\n    /// 依赖项\n    /// </summary>\n    IEnumerable<PluginDependency> Dependencies { get; }\n    \n    /// <summary>\n    /// 初始化\n    /// </summary>\n    void Initialize(PluginContext context);\n    \n    /// <summary>\n    /// 启动\n    /// </summary>\n    void Start();\n    \n    /// <summary>\n    /// 停止\n    /// </summary>\n    void Stop();\n}\n\n/// <summary>\n/// 插件依赖项\n/// </summary>\npublic class PluginDependency\n{\n    public string PluginId { get; set; } = string.Empty;\n    public Version MinVersion { get; set; } = new Version(1, 0);\n    public Version? MaxVersion { get; set; }\n}\n\n/// <summary>\n/// 插件上下文\n/// </summary>\npublic class PluginContext\n{\n    public IServiceProvider Services { get; }\n    public ILogger Logger { get; }\n    public IConfiguration Configuration { get; }\n    \n    public PluginContext(\n        IServiceProvider services, \n        ILogger logger, \n        IConfiguration configuration)\n    {\n        Services = services;\n        Logger = logger;\n        Configuration = configuration;\n    }\n}\n\n/// <summary>\n/// 插件元数据特性\n/// </summary>\n[AttributeUsage(AttributeTargets.Class, AllowMultiple = false)]\npublic class PluginMetadataAttribute : Attribute\n{\n    public string Id { get; }\n    public string Name { get; }\n    public string Version { get; }\n    public string? Description { get; set; }\n    public string? Author { get; set; }\n    public string? Category { get; set; }\n    \n    public PluginMetadataAttribute(string id, string name, string version)\n    {\n        Id = id;\n        Name = name;\n        Version = version;\n    }\n}\n\n/// <summary>\n/// 表单插件基类\n/// </summary>\npublic abstract class FormPluginBase : PluginBase\n{\n    protected IFormView View { get; private set; } = null!;\n    protected IDataModel Model { get; private set; } = null!;\n    \n    internal void SetContext(IFormView view, IDataModel model)\n    {\n        View = view;\n        Model = model;\n    }\n    \n    #region 生命周期事件\n    \n    /// <summary>\n    /// 插件初始化\n    /// </summary>\n    public virtual void OnInitialize() { }\n    \n    /// <summary>\n    /// 数据绑定后\n    /// </summary>\n    public virtual void OnAfterBindData(AfterBindDataEvent e) { }\n    \n    /// <summary>\n    /// 页面关闭前\n    /// </summary>\n    public virtual void OnBeforeClosed(BeforeClosedEvent e) { }\n    \n    /// <summary>\n    /// 按钮点击\n    /// </summary>\n    public virtual void OnClick(ClickEvent e) { }\n    \n    /// <summary>\n    /// 属性变更\n    /// </summary>\n    public virtual void OnPropertyChanged(PropertyChangedEvent e) { }\n    \n    /// <summary>\n    /// 操作执行前\n    /// </summary>\n    public virtual void OnBeforeOperation(BeforeOperationEvent e) { }\n    \n    /// <summary>\n    /// 操作执行后\n    /// </summary>\n    public virtual void OnAfterOperation(AfterOperationEvent e) { }\n    \n    /// <summary>\n    /// 值更新前\n    /// </summary>\n    public virtual void OnBeforeUpdateValue(BeforeUpdateValueEvent e) { }\n    \n    /// <summary>\n    /// 值更新后\n    /// </summary>\n    public virtual void OnAfterUpdateValue(AfterUpdateValueEvent e) { }\n    \n    /// <summary>\n    /// 自定义事件\n    /// </summary>\n    public virtual void OnCustomEvent(CustomEvent e) { }\n    \n    #endregion\n    \n    #region 辅助方法\n    \n    /// <summary>\n    /// 获取字段值\n    /// </summary>\n    protected T? GetValue<T>(string fieldKey)\n    {\n        return Model.GetValue<T>(fieldKey);\n    }\n    \n    /// <summary>\n    /// 设置字段值\n    /// </summary>\n    protected void SetValue(string fieldKey, object? value)\n    {\n        Model.SetValue(fieldKey, value);\n    }\n    \n    /// <summary>\n    /// 显示消息\n    /// </summary>\n    protected void ShowMessage(string message, MessageType type = MessageType.Info)\n    {\n        View.ShowMessage(message, type);\n    }\n    \n    /// <summary>\n    /// 设置字段可见性\n    /// </summary>\n    protected void SetVisible(string fieldKey, bool visible)\n    {\n        View.SetVisible(fieldKey, visible);\n    }\n    \n    /// <summary>\n    /// 设置字段只读\n    /// </summary>\n    protected void SetReadOnly(string fieldKey, bool readOnly)\n    {\n        View.SetReadOnly(fieldKey, readOnly);\n    }\n    \n    /// <summary>\n    /// 设置字段启用状态\n    /// </summary>\n    protected void SetEnabled(string fieldKey, bool enabled)\n    {\n        View.SetEnabled(fieldKey, enabled);\n    }\n    \n    #endregion\n}\n\n/// <summary>\n/// 列表插件基类\n/// </summary>\npublic abstract class ListPluginBase : PluginBase\n{\n    protected IListView View { get; private set; } = null!;\n    protected IListModel Model { get; private set; } = null!;\n    \n    internal void SetContext(IListView view, IListModel model)\n    {\n        View = view;\n        Model = model;\n    }\n    \n    public virtual void OnInitialize() { }\n    public virtual void OnAfterBindData(AfterBindDataEvent e) { }\n    public virtual void OnClick(ClickEvent e) { }\n    public virtual void OnFilterChanged(FilterChangedEvent e) { }\n    public virtual void OnRowSelected(RowSelectedEvent e) { }\n    public virtual void OnBeforeOperation(BeforeOperationEvent e) { }\n    public virtual void OnAfterOperation(AfterOperationEvent e) { }\n}\n\n/// <summary>\n/// 操作插件基类\n/// </summary>\npublic abstract class OperationPluginBase : PluginBase\n{\n    protected IOperationContext Context { get; private set; } = null!;\n    \n    internal void SetContext(IOperationContext context)\n    {\n        Context = context;\n    }\n    \n    /// <summary>\n    /// 执行操作\n    /// </summary>\n    public virtual void OnExecute(OperationExecuteEvent e) { }\n    \n    /// <summary>\n    /// 验证操作\n    /// </summary>\n    public virtual ValidationResult OnValidate(OperationValidateEvent e)\n    {\n        return ValidationResult.Success();\n    }\n    \n    /// <summary>\n    /// 操作前处理\n    /// </summary>\n    public virtual void OnBeforeExecute(OperationExecuteEvent e) { }\n    \n    /// <summary>\n    /// 操作后处理\n    /// </summary>\n    public virtual void OnAfterExecute(OperationExecuteEvent e) { }\n}\n\n/// <summary>\n/// 报表插件基类\n/// </summary>\npublic abstract class ReportPluginBase : PluginBase\n{\n    public virtual void OnInitialize() { }\n    public virtual DataSet OnGetData(ReportDataEvent e) => new DataSet();\n    public virtual void OnBeforePrint(ReportPrintEvent e) { }\n    public virtual void OnAfterPrint(ReportPrintEvent e) { }\n}\n\n/// <summary>\n/// 工作流插件基类\n/// </summary>\npublic abstract class WorkflowPluginBase : PluginBase\n{\n    public virtual void OnInitialize() { }\n    public virtual void OnBeforeStart(WorkflowEvent e) { }\n    public virtual void OnAfterStart(WorkflowEvent e) { }\n    public virtual void OnBeforeApprove(WorkflowEvent e) { }\n    public virtual void OnAfterApprove(WorkflowEvent e) { }\n    public virtual void OnBeforeReject(WorkflowEvent e) { }\n    public virtual void OnAfterReject(WorkflowEvent e) { }\n}\n\n/// <summary>\n/// 插件基类\n/// </summary>\npublic abstract class PluginBase : IPlugin\n{\n    private bool _disposed;\n    protected PluginContext? Context { get; private set; }\n    \n    public virtual string Id => GetType().GetCustomAttribute<PluginMetadataAttribute>()?.Id ?? GetType().FullName ?? Guid.NewGuid().ToString();\n    public virtual string Name => GetType().GetCustomAttribute<PluginMetadataAttribute>()?.Name ?? GetType().Name;\n    public virtual Version Version => Version.Parse(GetType().GetCustomAttribute<PluginMetadataAttribute>()?.Version ?? \"1.0.0\");\n    public virtual string Description => GetType().GetCustomAttribute<PluginMetadataAttribute>()?.Description ?? string.Empty;\n    public virtual string Author => GetType().GetCustomAttribute<PluginMetadataAttribute>()?.Author ?? string.Empty;\n    public virtual IEnumerable<PluginDependency> Dependencies => Enumerable.Empty<PluginDependency>();\n    \n    public virtual void Initialize(PluginContext context)\n    {\n        Context = context;\n    }\n    \n    public virtual void Start() { }\n    public virtual void Stop() { }\n    \n    public void Dispose()\n    {\n        if (!_disposed)\n        {\n            Dispose(true);\n            _disposed = true;\n        }\n        GC.SuppressFinalize(this);\n    }\n    \n    protected virtual void Dispose(bool disposing) { }\n}\n"}],"isError":false,"timestamp":1774187730304}}
