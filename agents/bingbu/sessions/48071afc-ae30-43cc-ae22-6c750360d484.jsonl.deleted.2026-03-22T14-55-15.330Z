{"type":"message","id":"1030b7e4","parentId":"2152a2d8","timestamp":"2026-03-22T13:57:25.802Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，元数据仓库创建成功。现在创建缓存服务。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_c5972fbc95704c6480b18151","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Data/Services/CacheService.cs","content":"using Microsoft.Extensions.Logging;\nusing Microsoft.Extensions.Options;\nusing StackExchange.Redis;\nusing System.Text.Json;\n\nnamespace Tianyou.Data.Services;\n\n/// <summary>\n/// Redis 缓存服务\n/// </summary>\npublic class CacheService : ICacheService, IDisposable\n{\n    private readonly ILogger<CacheService> _logger;\n    private readonly IConnectionMultiplexer _redis;\n    private readonly IDatabase _database;\n    private bool _disposed;\n    \n    public CacheService(\n        IOptions<RedisOptions> options,\n        ILogger<CacheService> logger)\n    {\n        _logger = logger;\n        \n        try\n        {\n            var config = ConfigurationOptions.Parse(options.Value.ConnectionString);\n            config.ConnectRetry = 3;\n            config.ConnectTimeout = 5000;\n            config.SyncTimeout = 5000;\n            config.AsyncTimeout = 5000;\n            \n            _redis = ConnectionMultiplexer.Connect(config);\n            _database = _redis.GetDatabase();\n            \n            _logger.LogInformation(\"Redis 缓存服务已连接\");\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"Redis 连接失败，将使用内存缓存\");\n            _redis = null!;\n            _database = null!;\n        }\n    }\n    \n    private bool IsRedisAvailable => _redis != null && _redis.IsConnected;\n    \n    /// <summary>\n    /// 获取缓存\n    /// </summary>\n    public async Task<T?> GetAsync<T>(string key)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n            {\n                _logger.LogDebug(\"Redis 不可用，跳过缓存读取: {Key}\", key);\n                return default;\n            }\n            \n            var value = await _database.StringGetAsync(key);\n            if (value.IsNullOrEmpty)\n                return default;\n            \n            return JsonSerializer.Deserialize<T>(value!);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"读取缓存失败: {Key}\", key);\n            return default;\n        }\n    }\n    \n    /// <summary>\n    /// 设置缓存\n    /// </summary>\n    public async Task SetAsync<T>(string key, T value, TimeSpan? expiry = null)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n            {\n                _logger.LogDebug(\"Redis 不可用，跳过缓存写入: {Key}\", key);\n                return;\n            }\n            \n            var serialized = JsonSerializer.Serialize(value);\n            await _database.StringSetAsync(key, serialized, expiry);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"写入缓存失败: {Key}\", key);\n        }\n    }\n    \n    /// <summary>\n    /// 删除缓存\n    /// </summary>\n    public async Task RemoveAsync(string key)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n            {\n                _logger.LogDebug(\"Redis 不可用，跳过缓存删除: {Key}\", key);\n                return;\n            }\n            \n            await _database.KeyDeleteAsync(key);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"删除缓存失败: {Key}\", key);\n        }\n    }\n    \n    /// <summary>\n    /// 批量删除缓存\n    /// </summary>\n    public async Task RemoveAsync(IEnumerable<string> keys)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n            {\n                _logger.LogDebug(\"Redis 不可用，跳过缓存批量删除\");\n                return;\n            }\n            \n            var redisKeys = keys.Select(k => (RedisKey)k).ToArray();\n            await _database.KeyDeleteAsync(redisKeys);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"批量删除缓存失败\");\n        }\n    }\n    \n    /// <summary>\n    /// 检查缓存是否存在\n    /// </summary>\n    public async Task<bool> ExistsAsync(string key)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n                return false;\n            \n            return await _database.KeyExistsAsync(key);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"检查缓存存在性失败: {Key}\", key);\n            return false;\n        }\n    }\n    \n    /// <summary>\n    /// 设置缓存过期时间\n    /// </summary>\n    public async Task ExpireAsync(string key, TimeSpan expiry)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n            {\n                _logger.LogDebug(\"Redis 不可用，跳过设置过期时间: {Key}\", key);\n                return;\n            }\n            \n            await _database.KeyExpireAsync(key, expiry);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"设置缓存过期时间失败: {Key}\", key);\n        }\n    }\n    \n    /// <summary>\n    /// 获取缓存剩余过期时间\n    /// </summary>\n    public async Task<TimeSpan?> GetExpiryAsync(string key)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n                return null;\n            \n            return await _database.KeyTimeToLiveAsync(key);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取缓存过期时间失败: {Key}\", key);\n            return null;\n        }\n    }\n    \n    /// <summary>\n    /// 模糊删除缓存\n    /// </summary>\n    public async Task RemoveByPatternAsync(string pattern)\n    {\n        try\n        {\n            if (!IsRedisAvailable)\n            {\n                _logger.LogDebug(\"Redis 不可用，跳过模式删除缓存: {Pattern}\", pattern);\n                return;\n            }\n            \n            var server = _redis.GetServer(_redis.GetEndPoints().First());\n            var keys = server.Keys(pattern: pattern).ToArray();\n            \n            if (keys.Length > 0)\n            {\n                await _database.KeyDeleteAsync(keys);\n                _logger.LogInformation(\"按模式删除缓存: {Pattern}, 删除数量: {Count}\", pattern, keys.Length);\n            }\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"按模式删除缓存失败: {Pattern}\", pattern);\n        }\n    }\n    \n    public void Dispose()\n    {\n        if (!_disposed)\n        {\n            _redis?.Dispose();\n            _disposed = true;\n        }\n        GC.SuppressFinalize(this);\n    }\n}\n\n/// <summary>\n/// 缓存服务接口\n/// </summary>\npublic interface ICacheService\n{\n    Task<T?> GetAsync<T>(string key);\n    Task SetAsync<T>(string key, T value, TimeSpan? expiry = null);\n    Task RemoveAsync(string key);\n    Task RemoveAsync(IEnumerable<string> keys);\n    Task<bool> ExistsAsync(string key);\n    Task ExpireAsync(string key, TimeSpan expiry);\n    Task<TimeSpan?> GetExpiryAsync(string key);\n    Task RemoveByPatternAsync(string pattern);\n}\n\n/// <summary>\n/// Redis 配置选项\n/// </summary>\npublic class RedisOptions\n{\n    public const string SectionName = \"Redis\";\n    public string ConnectionString { get; set; } = \"localhost:6379\";\n    public int Database { get; set; } = 0;\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":42,"output":1546,"cacheRead":25425,"cacheWrite":0,"totalTokens":27013,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187827315}}
