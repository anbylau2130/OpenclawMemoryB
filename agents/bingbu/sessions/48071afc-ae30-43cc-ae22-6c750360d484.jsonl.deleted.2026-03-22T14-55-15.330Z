{"type":"message","id":"6efb70e2","parentId":"8df32949","timestamp":"2026-03-22T14:02:12.529Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，表单控制器创建成功。现在创建插件控制器。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_b8538cb1857149e69daec47e","name":"write","arguments":{"content":"using Microsoft.AspNetCore.Mvc;\nusing Microsoft.Extensions.Logging;\nusing Tianyou.Plugin;\nusing Tianyou.Plugin.Abstractions;\nusing System.Reflection;\n\nnamespace Tianyou.FormService.Controllers;\n\n/// <summary>\n/// 插件 API 控制器\n/// </summary>\n[ApiController]\n[Route(\"api/[controller]\")]\npublic class PluginController : ControllerBase\n{\n    private readonly PluginManager _pluginManager;\n    private readonly ILogger<PluginController> _logger;\n    \n    public PluginController(\n        PluginManager pluginManager,\n        ILogger<PluginController> logger)\n    {\n        _pluginManager = pluginManager;\n        _logger = logger;\n    }\n    \n    /// <summary>\n    /// 获取所有插件\n    /// </summary>\n    [HttpGet]\n    public ActionResult<List<PluginInfoResponse>> GetAllPlugins()\n    {\n        try\n        {\n            var plugins = _pluginManager.GetAllPlugins();\n            var response = plugins.Select(p => new PluginInfoResponse\n            {\n                Id = p.Id,\n                Name = p.Name,\n                Version = p.Version,\n                Description = p.Description,\n                Author = p.Author,\n                Category = p.Category,\n                State = p.State.ToString(),\n                IsHotLoad = p.IsHotLoad,\n                LoadTime = p.LoadTime\n            }).ToList();\n            \n            return Ok(response);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取插件列表失败\");\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 获取插件详情\n    /// </summary>\n    [HttpGet(\"{pluginId}\")]\n    public ActionResult<PluginDetailResponse> GetPlugin(string pluginId)\n    {\n        try\n        {\n            var metadata = _pluginManager.GetPluginMetadata(pluginId);\n            if (metadata == null)\n            {\n                return NotFound(new { message = $\"插件不存在: {pluginId}\" });\n            }\n            \n            var plugin = _pluginManager.GetPlugin(pluginId);\n            \n            return Ok(new PluginDetailResponse\n            {\n                Id = metadata.Id,\n                Name = metadata.Name,\n                Version = metadata.Version,\n                Description = metadata.Description,\n                Author = metadata.Author,\n                Category = metadata.Category,\n                State = metadata.State.ToString(),\n                IsHotLoad = metadata.IsHotLoad,\n                LoadTime = metadata.LoadTime,\n                AssemblyName = metadata.AssemblyName,\n                TypeName = metadata.TypeName,\n                Config = metadata.Config,\n                Dependencies = metadata.Dependencies.Select(d => new DependencyInfo\n                {\n                    PluginId = d.PluginId,\n                    MinVersion = d.MinVersion,\n                    MaxVersion = d.MaxVersion\n                }).ToList()\n            });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取插件详情失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 加载插件\n    /// </summary>\n    [HttpPost(\"load\")]\n    public async Task<ActionResult<LoadPluginResponse>> LoadPlugin([FromBody] LoadPluginRequest request)\n    {\n        try\n        {\n            var success = await _pluginManager.LoadPluginAsync(\n                request.PluginPath,\n                request.Config);\n            \n            if (!success)\n            {\n                return BadRequest(new { message = \"插件加载失败\" });\n            }\n            \n            return Ok(new LoadPluginResponse\n            {\n                Success = true,\n                Message = \"插件加载成功\"\n            });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"加载插件失败: {PluginPath}\", request.PluginPath);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 启动插件\n    /// </summary>\n    [HttpPost(\"{pluginId}/start\")]\n    public async Task<ActionResult> StartPlugin(string pluginId)\n    {\n        try\n        {\n            var success = await _pluginManager.StartPluginAsync(pluginId);\n            if (!success)\n            {\n                return BadRequest(new { message = $\"插件启动失败: {pluginId}\" });\n            }\n            \n            return Ok(new { success = true, message = \"插件启动成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"启动插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 停止插件\n    /// </summary>\n    [HttpPost(\"{pluginId}/stop\")]\n    public async Task<ActionResult> StopPlugin(string pluginId)\n    {\n        try\n        {\n            var success = await _pluginManager.StopPluginAsync(pluginId);\n            if (!success)\n            {\n                return BadRequest(new { message = $\"插件停止失败: {pluginId}\" });\n            }\n            \n            return Ok(new { success = true, message = \"插件停止成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"停止插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 卸载插件\n    /// </summary>\n    [HttpDelete(\"{pluginId}\")]\n    public async Task<ActionResult> UnloadPlugin(string pluginId)\n    {\n        try\n        {\n            var success = await _pluginManager.UnloadPluginAsync(pluginId);\n            if (!success)\n            {\n                return BadRequest(new { message = $\"插件卸载失败: {pluginId}\" });\n            }\n            \n            return Ok(new { success = true, message = \"插件卸载成功\" });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"卸载插件失败: {PluginId}\", pluginId);\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 启动所有插件\n    /// </summary>\n    [HttpPost(\"start-all\")]\n    public async Task<ActionResult> StartAllPlugins()\n    {\n        try\n        {\n            var count = await _pluginManager.StartAllPluginsAsync();\n            return Ok(new { success = true, message = $\"已启动 {count} 个插件\", count });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"启动所有插件失败\");\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 停止所有插件\n    /// </summary>\n    [HttpPost(\"stop-all\")]\n    public async Task<ActionResult> StopAllPlugins()\n    {\n        try\n        {\n            var count = await _pluginManager.StopAllPluginsAsync();\n            return Ok(new { success = true, message = $\"已停止 {count} 个插件\", count });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"停止所有插件失败\");\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 重新加载所有插件\n    /// </summary>\n    [HttpPost(\"reload\")]\n    public async Task<ActionResult> ReloadAllPlugins()\n    {\n        try\n        {\n            // 先停止所有插件\n            await _pluginManager.StopAllPluginsAsync();\n            \n            // 重新加载所有插件\n            var loadedCount = await _pluginManager.LoadAllPluginsAsync();\n            \n            // 启动所有插件\n            var startedCount = await _pluginManager.StartAllPluginsAsync();\n            \n            return Ok(new { \n                success = true, \n                message = $\"重新加载完成，加载 {loadedCount} 个，启动 {startedCount} 个\" \n            });\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"重新加载插件失败\");\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n    \n    /// <summary>\n    /// 获取插件统计信息\n    /// </summary>\n    [HttpGet(\"stats\")]\n    public ActionResult<PluginStatsResponse> GetPluginStats()\n    {\n        try\n        {\n            var plugins = _pluginManager.GetAllPlugins();\n            var stats = new PluginStatsResponse\n            {\n                TotalPlugins = plugins.Count,\n                LoadedPlugins = plugins.Count(p => p.State == PluginState.Loaded),\n                StartedPlugins = plugins.Count(p => p.State == PluginState.Started),\n                StoppedPlugins = plugins.Count(p => p.State == PluginState.Stopped),\n                ErrorPlugins = plugins.Count(p => p.State == PluginState.LoadError || p.State == PluginState.StartError),\n                HotLoadPlugins = plugins.Count(p => p.IsHotLoad)\n            };\n            \n            return Ok(stats);\n        }\n        catch (Exception ex)\n        {\n            _logger.LogError(ex, \"获取插件统计失败\");\n            return StatusCode(500, new { message = \"服务器内部错误\", error = ex.Message });\n        }\n    }\n}\n\n#region 请求/响应模型\n\n/// <summary>\n/// 插件信息响应\n/// </summary>\npublic class PluginInfoResponse\n{\n    public string Id { get; set; } = string.Empty;\n    public string Name { get; set; } = string.Empty;\n    public string Version { get; set; } = string.Empty;\n    public string? Description { get; set; }\n    public string? Author { get; set; }\n    public string? Category { get; set; }\n    public string State { get; set; } = string.Empty;\n    public bool IsHotLoad { get; set; }\n    public DateTime LoadTime { get; set; }\n}\n\n/// <summary>\n/// 插件详情响应\n/// </summary>\npublic class PluginDetailResponse\n{\n    public string Id { get; set; } = string.Empty;\n    public string Name { get; set; } = string.Empty;\n    public string Version { get; set; } = string.Empty;\n    public string? Description { get; set; }\n    public string? Author { get; set; }\n    public string? Category { get; set; }\n    public string State { get; set; } = string.Empty;\n    public bool IsHotLoad { get; set; }\n    public DateTime LoadTime { get; set; }\n    public string AssemblyName { get; set; } = string.Empty;\n    public string TypeName { get; set; } = string.Empty;\n    public Dictionary<string, object> Config { get; set; } = new();\n    public List<DependencyInfo> Dependencies { get; set; } = new();\n}\n\n/// <summary>\n/// 依赖信息\n/// </summary>\npublic class DependencyInfo\n{\n    public string PluginId { get; set; } = string.Empty;\n    public string MinVersion { get; set; } = string.Empty;\n    public string? MaxVersion { get; set; }\n}\n\n/// <summary>\n/// 加载插件请求\n/// </summary>\npublic class LoadPluginRequest\n{\n    public string PluginPath { get; set; } = string.Empty;\n    public Dictionary<string, object>? Config { get; set; }\n}\n\n/// <summary>\n/// 加载插件响应\n/// </summary>\npublic class LoadPluginResponse\n{\n    public bool Success { get; set; }\n    public string? Message { get; set; }\n}\n\n/// <summary>\n/// 插件统计响应\n/// </summary>\npublic class PluginStatsResponse\n{\n    public int TotalPlugins { get; set; }\n    public int LoadedPlugins { get; set; }\n    public int StartedPlugins { get; set; }\n    public int StoppedPlugins { get; set; }\n    public int ErrorPlugins { get; set; }\n    public int HotLoadPlugins { get; set; }\n}\n\n#endregion\n","path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.FormService/Controllers/PluginController.cs"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":41,"output":2556,"cacheRead":44364,"cacheWrite":0,"totalTokens":46961,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774188089419}}
