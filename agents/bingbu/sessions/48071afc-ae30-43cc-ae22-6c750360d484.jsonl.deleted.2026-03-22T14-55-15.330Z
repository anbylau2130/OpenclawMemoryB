{"type":"message","id":"96ca4a47","parentId":"153bb796","timestamp":"2026-03-22T13:55:31.730Z","message":{"role":"toolResult","toolCallId":"call_14d0151eda964645a33393a2","toolName":"read","content":[{"type":"text","text":"namespace Tianyou.Plugin.Abstractions;\n\n/// <summary>\n/// 事件基类\n/// </summary>\npublic abstract class PluginEventBase\n{\n    public DateTime Timestamp { get; } = DateTime.UtcNow;\n    public string Source { get; set; } = string.Empty;\n    public bool Handled { get; set; }\n}\n\n/// <summary>\n/// 数据绑定后事件\n/// </summary>\npublic class AfterBindDataEvent : PluginEventBase\n{\n    public object? Data { get; set; }\n}\n\n/// <summary>\n/// 页面关闭前事件\n/// </summary>\npublic class BeforeClosedEvent : PluginEventBase\n{\n    public bool Cancel { get; set; }\n    public string? Message { get; set; }\n}\n\n/// <summary>\n/// 点击事件\n/// </summary>\npublic class ClickEvent : PluginEventBase\n{\n    public string Key { get; set; } = string.Empty;\n    public string Text { get; set; } = string.Empty;\n    public Dictionary<string, object> Parameters { get; set; } = new();\n}\n\n/// <summary>\n/// 属性变更事件\n/// </summary>\npublic class PropertyChangedEvent : PluginEventBase\n{\n    public string FieldKey { get; set; } = string.Empty;\n    public object? OldValue { get; set; }\n    public object? NewValue { get; set; }\n}\n\n/// <summary>\n/// 操作执行前事件\n/// </summary>\npublic class BeforeOperationEvent : PluginEventBase\n{\n    public string OperationKey { get; set; } = string.Empty;\n    public List<string> SelectedRows { get; set; } = new();\n    public bool Cancel { get; set; }\n    public string? CancelMessage { get; set; }\n}\n\n/// <summary>\n/// 操作执行后事件\n/// </summary>\npublic class AfterOperationEvent : PluginEventBase\n{\n    public string OperationKey { get; set; } = string.Empty;\n    public bool Success { get; set; }\n    public string? Message { get; set; }\n    public Dictionary<string, object> Result { get; set; } = new();\n}\n\n/// <summary>\n/// 值更新前事件\n/// </summary>\npublic class BeforeUpdateValueEvent : PluginEventBase\n{\n    public string FieldKey { get; set; } = string.Empty;\n    public object? OldValue { get; set; }\n    public object? NewValue { get; set; }\n    public bool Cancel { get; set; }\n}\n\n/// <summary>\n/// 值更新后事件\n/// </summary>\npublic class AfterUpdateValueEvent : PluginEventBase\n{\n    public string FieldKey { get; set; } = string.Empty;\n    public object? OldValue { get; set; }\n    public object? NewValue { get; set; }\n}\n\n/// <summary>\n/// 自定义事件\n/// </summary>\npublic class CustomEvent : PluginEventBase\n{\n    public string EventType { get; set; } = string.Empty;\n    public Dictionary<string, object> Data { get; set; } = new();\n}\n\n/// <summary>\n/// 过滤变更事件\n/// </summary>\npublic class FilterChangedEvent : PluginEventBase\n{\n    public List<FilterCondition> Filters { get; set; } = new();\n}\n\n/// <summary>\n/// 行选择事件\n/// </summary>\npublic class RowSelectedEvent : PluginEventBase\n{\n    public List<string> SelectedRowIds { get; set; } = new();\n    public int SelectedCount { get; set; }\n}\n\n/// <summary>\n/// 操作执行事件\n/// </summary>\npublic class OperationExecuteEvent : PluginEventBase\n{\n    public string OperationKey { get; set; } = string.Empty;\n    public List<DataRow> DataRows { get; set; } = new();\n    public Dictionary<string, object> Parameters { get; set; } = new();\n    public Dictionary<string, object> Result { get; set; } = new();\n}\n\n/// <summary>\n/// 操作验证事件\n/// </summary>\npublic class OperationValidateEvent : PluginEventBase\n{\n    public string OperationKey { get; set; } = string.Empty;\n    public List<DataRow> DataRows { get; set; } = new();\n}\n\n/// <summary>\n/// 报表数据事件\n/// </summary>\npublic class ReportDataEvent : PluginEventBase\n{\n    public Dictionary<string, object> Parameters { get; set; } = new();\n    public DateTime? StartDate { get; set; }\n    public DateTime? EndDate { get; set; }\n}\n\n/// <summary>\n/// 报表打印事件\n/// </summary>\npublic class ReportPrintEvent : PluginEventBase\n{\n    public string Format { get; set; } = \"PDF\";\n    public Dictionary<string, object> Options { get; set; } = new();\n}\n\n/// <summary>\n/// 工作流事件\n/// </summary>\npublic class WorkflowEvent : PluginEventBase\n{\n    public string ProcessInstanceId { get; set; } = string.Empty;\n    public string TaskId { get; set; } = string.Empty;\n    public string Action { get; set; } = string.Empty;\n    public string? Comment { get; set; }\n    public Dictionary<string, object> Variables { get; set; } = new();\n}\n\n/// <summary>\n/// 过滤条件\n/// </summary>\npublic class FilterCondition\n{\n    public string FieldKey { get; set; } = string.Empty;\n    public string Operator { get; set; } = \"=\";\n    public object? Value { get; set; }\n    public string? LogicOperator { get; set; }\n}\n\n/// <summary>\n/// 数据行\n/// </summary>\npublic class DataRow : Dictionary<string, object?>\n{\n    public string Id { get; set; } = string.Empty;\n    \n    public T? GetValue<T>(string key)\n    {\n        if (TryGetValue(key, out var value) && value is T typedValue)\n        {\n            return typedValue;\n        }\n        return default;\n    }\n}\n\n/// <summary>\n/// 验证结果\n/// </summary>\npublic class ValidationResult\n{\n    public bool IsValid { get; set; } = true;\n    public List<ValidationError> Errors { get; set; } = new();\n    \n    public static ValidationResult Success() => new() { IsValid = true };\n    \n    public static ValidationResult Failure(params ValidationError[] errors)\n    {\n        return new ValidationResult { IsValid = false, Errors = errors.ToList() };\n    }\n    \n    public static ValidationResult Failure(string field, string message)\n    {\n        return Failure(new ValidationError { Field = field, Message = message });\n    }\n}\n\n/// <summary>\n/// 验证错误\n/// </summary>\npublic class ValidationError\n{\n    public string Field { get; set; } = string.Empty;\n    public string Message { get; set; } = string.Empty;\n    public string Code { get; set; } = string.Empty;\n}\n"}],"isError":false,"timestamp":1774187731690}}
