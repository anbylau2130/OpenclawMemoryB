{"type":"message","id":"f3869ae8","parentId":"04e8c405","timestamp":"2026-03-22T14:00:51.350Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，项目文件创建成功。现在创建 Program.cs。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_612e021bb7854721ac66553b","name":"write","arguments":{"content":"using Microsoft.EntityFrameworkCore;\nusing Serilog;\nusing Tianyou.Data.DbContexts;\nusing Tianyou.Data.Repositories;\nusing Tianyou.Data.Services;\nusing Tianyou.Plugin;\n\nvar builder = WebApplication.CreateBuilder(args);\n\n// 配置 Serilog\nLog.Logger = new LoggerConfiguration()\n    .ReadFrom.Configuration(builder.Configuration)\n    .Enrich.FromLogContext()\n    .WriteTo.Console()\n    .WriteTo.File(\"logs/tianyou-.txt\", rollingInterval: RollingInterval.Day)\n    .CreateLogger();\n\nbuilder.Host.UseSerilog();\n\n// 添加服务到容器\nbuilder.Services.AddControllers();\nbuilder.Services.AddEndpointsApiExplorer();\nbuilder.Services.AddSwaggerGen(c =>\n{\n    c.SwaggerDoc(\"v1\", new() { Title = \"Tianyou Form Service API\", Version = \"v1\" });\n});\n\n// 配置数据库连接\nbuilder.Services.AddDbContext<TianyouDbContext>(options =>\n{\n    var connectionString = builder.Configuration.GetConnectionString(\"PostgreSQL\") \n        ?? \"Host=localhost;Port=5432;Database=tianyou;Username=postgres;Password=postgres\";\n    options.UseNpgsql(connectionString);\n});\n\n// 注册仓库服务\nbuilder.Services.AddScoped<IMetadataRepository, MetadataRepository>();\nbuilder.Services.AddScoped<IDataRepository, DataRepository>();\n\n// 注册缓存服务\nbuilder.Services.Configure<RedisOptions>(builder.Configuration.GetSection(RedisOptions.SectionName));\nbuilder.Services.AddSingleton<ICacheService, CacheService>();\n\n// 注册插件管理器\nvar pluginDirectory = builder.Configuration.GetValue<string>(\"PluginDirectory\") \n    ?? Path.Combine(Directory.GetCurrentDirectory(), \"plugins\");\nbuilder.Services.AddSingleton<PluginManager>(sp => new PluginManager(\n    sp,\n    sp.GetRequiredService<Microsoft.Extensions.Logging.ILogger<PluginManager>>(),\n    pluginDirectory));\n\n// 注册表单引擎服务\nbuilder.Services.AddSingleton<Tianyou.LowCode.Engine.FormEngine>();\n\n// 添加 CORS\nbuilder.Services.AddCors(options =>\n{\n    options.AddPolicy(\"AllowAll\", policy =>\n    {\n        policy.AllowAnyOrigin()\n              .AllowAnyMethod()\n              .AllowAnyHeader();\n    });\n});\n\nvar app = builder.Build();\n\n// 启动时加载插件\nusing (var scope = app.Services.CreateScope())\n{\n    var pluginManager = scope.ServiceProvider.GetRequiredService<PluginManager>();\n    await pluginManager.LoadAllPluginsAsync();\n    await pluginManager.StartAllPluginsAsync();\n}\n\n// 配置 HTTP 请求管道\nif (app.Environment.IsDevelopment())\n{\n    app.UseSwagger();\n    app.UseSwaggerUI(c => c.SwaggerEndpoint(\"/swagger/v1/swagger.json\", \"Tianyou Form Service API v1\"));\n}\n\napp.UseSerilogRequestLogging();\n\napp.UseCors(\"AllowAll\");\n\napp.UseAuthorization();\n\napp.MapControllers();\n\napp.MapGet(\"/\", () => \"Tianyou Form Service API - Powered by Tianyou LowCode Engine\");\n\n// 健康检查\napp.MapGet(\"/health\", () => new \n{ \n    Status = \"Healthy\", \n    Timestamp = DateTime.UtcNow,\n    Service = \"Tianyou Form Service\"\n});\n\ntry\n{\n    Log.Information(\"启动 Tianyou Form Service\");\n    app.Run();\n}\ncatch (Exception ex)\n{\n    Log.Fatal(ex, \"服务启动失败\");\n}\nfinally\n{\n    Log.CloseAndFlush();\n}\n","path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/services/Tianyou.FormService/Program.cs"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":43,"output":725,"cacheRead":41175,"cacheWrite":0,"totalTokens":41943,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774188042470}}
