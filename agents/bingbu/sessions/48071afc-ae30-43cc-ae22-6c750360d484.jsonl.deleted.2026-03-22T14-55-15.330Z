{"type":"message","id":"bdefea36","parentId":"7ebc3586","timestamp":"2026-03-22T13:57:43.120Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，项目文件创建成功。现在创建插件上下文。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_ade1416e273e4ca6ab6eca66","name":"write","arguments":{"path":"/root/.openclaw/workspace-silijian/projects/tianyou-dotnet/src/Tianyou.Plugin/PluginContext.cs","content":"using Microsoft.Extensions.Logging;\nusing Tianyou.Plugin.Abstractions;\n\nnamespace Tianyou.Plugin;\n\n/// <summary>\n/// 插件上下文 - 提供插件运行时环境\n/// </summary>\npublic class PluginContext\n{\n    /// <summary>\n    /// 服务提供程序\n    /// </summary>\n    public IServiceProvider Services { get; }\n    \n    /// <summary>\n    /// 日志记录器\n    /// </summary>\n    public ILogger Logger { get; }\n    \n    /// <summary>\n    /// 配置\n    /// </summary>\n    public IConfiguration Configuration { get; }\n    \n    /// <summary>\n    /// 插件目录\n    /// </summary>\n    public string PluginDirectory { get; }\n    \n    /// <summary>\n    /// 插件配置\n    /// </summary>\n    public Dictionary<string, object> PluginConfig { get; }\n    \n    /// <summary>\n    /// 插件元数据\n    /// </summary>\n    public PluginMetadata Metadata { get; }\n    \n    public PluginContext(\n        IServiceProvider services,\n        ILogger logger,\n        IConfiguration configuration,\n        string pluginDirectory,\n        Dictionary<string, object> pluginConfig,\n        PluginMetadata metadata)\n    {\n        Services = services;\n        Logger = logger;\n        Configuration = configuration;\n        PluginDirectory = pluginDirectory;\n        PluginConfig = pluginConfig;\n        Metadata = metadata;\n    }\n    \n    /// <summary>\n    /// 获取服务\n    /// </summary>\n    public T? GetService<T>()\n    {\n        return Services.GetService<T>();\n    }\n    \n    /// <summary>\n    /// 获取必需的服务\n    /// </summary>\n    public T GetRequiredService<T>()\n    {\n        return Services.GetRequiredService<T>();\n    }\n    \n    /// <summary>\n    /// 获取配置值\n    /// </summary>\n    public T? GetConfigValue<T>(string key, T? defaultValue = default)\n    {\n        if (PluginConfig.TryGetValue(key, out var value))\n        {\n            try\n            {\n                if (value is T typedValue)\n                    return typedValue;\n                \n                return (T?)Convert.ChangeType(value, typeof(T));\n            }\n            catch\n            {\n                return defaultValue;\n            }\n        }\n        return defaultValue;\n    }\n    \n    /// <summary>\n    /// 获取插件目录下的文件路径\n    /// </summary>\n    public string GetPluginFilePath(string relativePath)\n    {\n        return Path.Combine(PluginDirectory, relativePath);\n    }\n}\n\n/// <summary>\n/// 插件元数据\n/// </summary>\npublic class PluginMetadata\n{\n    /// <summary>\n    /// 插件ID\n    /// </summary>\n    public string Id { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 插件名称\n    /// </summary>\n    public string Name { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 插件版本\n    /// </summary>\n    public string Version { get; set; } = \"1.0.0\";\n    \n    /// <summary>\n    /// 插件描述\n    /// </summary>\n    public string? Description { get; set; }\n    \n    /// <summary>\n    /// 插件作者\n    /// </summary>\n    public string? Author { get; set; }\n    \n    /// <summary>\n    /// 插件类别\n    /// </summary>\n    public string? Category { get; set; }\n    \n    /// <summary>\n    /// 程序集名称\n    /// </summary>\n    public string AssemblyName { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 类型名称\n    /// </summary>\n    public string TypeName { get; set; } = string.Empty;\n    \n    /// <summary>\n    /// 插件配置\n    /// </summary>\n    public Dictionary<string, object> Config { get; set; } = new();\n    \n    /// <summary>\n    /// 依赖项\n    /// </summary>\n    public List<PluginDependencyInfo> Dependencies { get; set; } = new();\n    \n    /// <summary>\n    /// 是否热加载\n    /// </summary>\n    public bool IsHotLoad { get; set; }\n    \n    /// <summary>\n    /// 加载时间\n    /// </summary>\n    public DateTime LoadTime { get; set; } = DateTime.UtcNow;\n    \n    /// <summary>\n    /// 插件状态\n    /// </summary>\n    public PluginState State { get; set; }\n}\n\n/// <summary>\n/// 插件依赖信息\n/// </summary>\npublic class PluginDependencyInfo\n{\n    public string PluginId { get; set; } = string.Empty;\n    public string MinVersion { get; set; } = \"1.0.0\";\n    public string? MaxVersion { get; set; }\n}\n\n/// <summary>\n/// 插件状态\n/// </summary>\npublic enum PluginState\n{\n    /// <summary>\n    /// 未加载\n    /// </summary>\n    Unloaded,\n    \n    /// <summary>\n    /// 已加载\n    /// </summary>\n    Loaded,\n    \n    /// <summary>\n    /// 已启动\n    /// </summary>\n    Started,\n    \n    /// <summary>\n    /// 已停止\n    /// </summary>\n    Stopped,\n    \n    /// <summary>\n    /// 已卸载\n    /// </summary>\n    UnloadedAndDisposed,\n    \n    /// <summary>\n    /// 加载失败\n    /// </summary>\n    LoadError,\n    \n    /// <summary>\n    /// 启动失败\n    /// </summary>\n    StartError\n}\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":41,"output":1240,"cacheRead":27313,"cacheWrite":0,"totalTokens":28594,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774187849973}}
