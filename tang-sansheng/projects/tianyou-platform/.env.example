# ========================================
# Tianyou Platform 环境变量配置
# ========================================
# 复制此文件为 .env 并修改配置

# ========================================
# PostgreSQL 数据库配置
# ========================================
POSTGRES_USER=tianyou_admin
POSTGRES_PASSWORD=Tianyou@2026!
POSTGRES_DB=tianyou_platform
POSTGRES_PORT=5432

# ========================================
# Redis 缓存配置
# ========================================
REDIS_PASSWORD=redis@123
REDIS_PORT=6379

# ========================================
# RabbitMQ 消息队列配置
# ========================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin@123
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ========================================
# API 服务配置
# ========================================
ASPNETCORE_ENVIRONMENT=Production
API_HTTP_PORT=5000
API_HTTPS_PORT=5001
API_VERSION=latest

# ========================================
# Web 前端配置
# ========================================
WEB_PORT=8080
WEB_VERSION=latest
API_BASE_URL=http://localhost:5000

# ========================================
# 时区配置
# ========================================
TZ=Asia/Shanghai
