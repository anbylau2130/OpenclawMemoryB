{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://0.0.0.0:5001",
        "Certificate": {
          "Path": "/etc/ssl/certs/tianyou.pfx",
          "Password": "${SSL_CERT_PASSWORD}"
        }
      }
    }
  },
  "HttpsRedirection": {
    "Enabled": true,
    "HttpsPort": 5001
  },
  "Swagger": {
    "Enabled": false
  }
}
