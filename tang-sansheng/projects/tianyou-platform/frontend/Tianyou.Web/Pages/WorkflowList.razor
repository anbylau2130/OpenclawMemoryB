@page "/workflows"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavManager

<h3>⚙️ 工作流管理</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CreateWorkflow">➕ 创建工作流</button>
    <button class="btn btn-secondary" @onclick="LoadWorkflows">🔄 刷新</button>
</div>

@if (loading)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">加载中...</span>
        </div>
    </div>
}
else if (workflows == null || workflows.Count == 0)
{
    <div class="alert alert-info">暂无工作流，请点击"创建工作流"按钮添加</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>工作流名称</th>
                    <th>描述</th>
                    <th>状态</th>
                    <th>创建时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var workflow in workflows)
                {
                    <tr>
                        <td><strong>@workflow.WorkflowName</strong></td>
                        <td>@workflow.Description</td>
                        <td>
                            <span class="badge @(workflow.IsActive ? "bg-success" : "bg-secondary")">
                                @(workflow.IsActive ? "启用" : "禁用")
                            </span>
                        </td>
                        <td>@workflow.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => DesignWorkflow(workflow.WorkflowId)">设计</button>
                            <button class="btn btn-sm btn-success" @onclick="() => StartWorkflow(workflow.WorkflowId)">启动</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<WorkflowDto> workflows = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadWorkflows();
    }

    private async Task LoadWorkflows()
    {
        loading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<WorkflowDto>>>("api/workflows");
            if (response?.Success == true)
            {
                workflows = response.Data ?? new List<WorkflowDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载失败: {ex.Message}");
        }
        loading = false;
    }

    private void CreateWorkflow()
    {
        NavManager.NavigateTo("/workflows/create");
    }

    private void DesignWorkflow(Guid workflowId)
    {
        NavManager.NavigateTo($"/workflows/{workflowId}/design");
    }

    private async Task StartWorkflow(Guid workflowId)
    {
        try
        {
            await Http.PostAsync($"api/workflows/{workflowId}/start", null);
            NavManager.NavigateTo("/workflows/tasks");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"启动失败: {ex.Message}");
        }
    }

    public class WorkflowDto
    {
        public Guid WorkflowId { get; set; }
        public string WorkflowName { get; set; } = "";
        public string? Description { get; set; }
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public T? Data { get; set; }
        public string? Message { get; set; }
    }
}
